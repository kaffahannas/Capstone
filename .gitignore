Desktop.ini
.DS_Store

## ── Secrets & local config (never commit) ─────────────────────
appsettings.*.local.json
secrets.json
.env
.env.*
*.pfx

# User Secrets are stored outside the repo by default; keep local overrides out
appsettings.Development.local.json

