<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <!-- Font Inter dari Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Memanggil CSS Desktop Dashboard -->
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body>
    
    <!-- SIDEBAR KIRI -->
    <aside class="sidebar">
        <!-- Logo dan Nama Aplikasi -->
        <a href="/Psychologist/Index" class="sidebar-brand">
            <img src="~/image/lightenuplogo.ico" alt="Logo" onerror="this.style.display='none'" />
            LightenUp
        </a>

        <div class="nav-menu">
            <!-- Navigasi Beranda -->
            <a href="/Psychologist/Index" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
                Beranda
            </a>
            
            <!-- Navigasi Statistik -->
            <a href="/Psychologist/Statistics" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Statistics" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                </svg>
                Statistik
            </a>

            <!-- Navigasi Jadwal Global -->
            <a href="/Psychologist/Scheduling" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Scheduling" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                Jadwal
            </a>
            
            <!-- Navigasi Worksheet -->
            <a href="/Psychologist/Worksheet" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Worksheet" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
                Worksheet
            </a>
            
            <!-- Navigasi Profil -->
            <a href="/Psychologist/Profile" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
                Profil
            </a>

            <!-- Permintaan HR (NEW bridge) -->
            <a href="/PsyRequests/Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PsyRequests" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                Permintaan HR
            </a>

            <!-- Pengaturan (NEW bridge) -->
            <a href="/Psychologist/Settings" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Settings" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M12 1v6m0 10v6m11-11h-6m-10 0H1m17.5-6.5L17 7m-10 10l-1.5 1.5M18.5 17l-1.5-1.5M7 7L5.5 5.5"></path>
                </svg>
                Pengaturan
            </a>
        </div>
        
        <!-- Tombol Logout diletakkan di paling bawah Sidebar -->
        <div style="margin-top: auto; padding: 0 16px;">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                <button type="submit" class="nav-item" style="width: 100%; border: none; background: transparent; cursor: pointer; color: #EF4444;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    Keluar
                </button>
            </form>
        </div>
    </aside>

    <!-- AREA KONTEN UTAMA KANAN -->
    <main class="main-content" role="main">
        @RenderBody()
    </main>

</body>
</html>