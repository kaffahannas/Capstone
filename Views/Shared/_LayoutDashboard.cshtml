@* #Bagian Layout Dashboard Psikolog# *@
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-psy-hero.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-psy-page.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-psy-detail.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-psy-stats-legacy.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-psy-task.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-psy-profile-legacy.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-prf-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-history-card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/components-status.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
    <link rel="stylesheet" href="~/css/psychologist/components-psy-mobile-text.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/psy-desktop-guard.css" asp-append-version="true" />
</head>
<body class="psychologist-body">

    <div class="app-shell" id="appShell">
        <div class="sidebar-backdrop" id="sidebarBackdrop" aria-hidden="true"></div>

        @* #Komponen Sidebar Navigasi# *@
        <aside class="sidebar app-sidebar" id="appSidebar" aria-label="Navigasi psikolog">
            <div class="sidebar-header">
                <a asp-area="Psychologist" asp-controller="Dashboard" asp-action="Index" class="sidebar-brand">
                    <img src="~/image/lightenuplogo.ico" alt="Logo LightenUp" onerror="this.classList.add('is-hidden')" />
                    LightenUp
                </a>
                <button type="button" class="sidebar-close" id="sidebarClose" aria-label="Tutup menu">&times;</button>
            </div>

@{
    var _ctrl   = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var _action = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";

            // Beranda = Dashboard/Index
            var _navBeranda     = _ctrl == "Dashboard" && _action == "Index";
            var _navKlien       = _ctrl == "Client";
            var _navStatistik   = _ctrl == "Dashboard" && _action == "Statistics";
            var _navJadwal      = _ctrl == "Schedule";
            var _navWorksheet   = _ctrl == "Worksheet";
            var _navProfil      = _ctrl == "Profile";
            var _navPermintaan  = _ctrl == "PsyRequests";
            var _navPendapatan  = _ctrl == "Dashboard" && _action == "Payslip";
        }
                    @* #Komponen Menu Navigasi# *@
                    <div class="nav-menu">
                        <a asp-area="Psychologist" asp-controller="Dashboard" asp-action="Index" class="nav-item @(_navBeranda ? "active" : "")">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                            Beranda
                        </a>
                        <a asp-area="Psychologist" asp-controller="Client" asp-action="Index" class="nav-item @(_navKlien ? "active" : "")">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            Klien
                        </a>
                        <a asp-area="Psychologist" asp-controller="Dashboard" asp-action="Statistics" class="nav-item @(_navStatistik ? "active" : "")">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                    Statistik
                </a>
                <a asp-area="Psychologist" asp-controller="Schedule" asp-action="Scheduling" class="nav-item @(_navJadwal ? "active" : "")">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    Jadwal
                </a>
                <a asp-area="Psychologist" asp-controller="Worksheet" asp-action="Worksheet" class="nav-item @(_navWorksheet ? "active" : "")">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                    Worksheet
                </a>
                <a asp-area="Psychologist" asp-controller="Profile" asp-action="Profile" class="nav-item @(_navProfil ? "active" : "")">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    Profil
                </a>
                <a asp-area="" asp-controller="PsyRequests" asp-action="Index" class="nav-item @(_navPermintaan ? "active" : "")">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    Permintaan
                    @await Component.InvokeAsync("PsyNavBadges")
                </a>
                <a asp-area="Psychologist" asp-controller="Dashboard" asp-action="Payslip" class="nav-item @(_navPendapatan ? "active" : "")">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                    Pendapatan
                </a>
            </div>

            @* #Komponen Tombol Keluar# *@
            <div class="psy-nav-logout">
                <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="psy-logout-btn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        <span>Keluar</span>
                    </button>
                </form>
            </div>
        </aside>

        <div class="main-content app-main">
            @* #Komponen Topbar# *@
            <header class="dashboard-header app-topbar">
                <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Buka menu navigasi" aria-expanded="false" aria-controls="appSidebar">
                    <span class="hamburger" aria-hidden="true"></span>
                </button>
                <div class="psy-topbar-title">
                    @if (ViewData["Title"] != null)
                    {
                        <h1 class="text-header lu-h2">@ViewData["Title"]</h1>
                    }
                </div>
            </header>

            @* #Komponen Konten Utama# *@
            <div class="app-content lu-scroll-host">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
