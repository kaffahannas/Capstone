@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Riwayat Jadwal";
    
    // Menangkap parameter nama perusahaan dari URL (mendukung parameter 'company' atau 'companyName')
    string? companyName = Context.Request.Query["company"].FirstOrDefault();
    if (string.IsNullOrEmpty(companyName))
    {
        companyName = Context.Request.Query["companyName"].FirstOrDefault();
    }

    // Jika companyName ada, kembalikan ke Detail Perusahaan. Jika tidak, ke Beranda.
    string backUrl = string.IsNullOrEmpty(companyName)
        ? "/Psychologist/Index"
        : $"/Psychologist/CompanyDetail?companyName={Uri.EscapeDataString(companyName!)}";
}

<!-- Tombol Kembali Dinamis ke CompanyDetail -->
<a href="@backUrl" class="back-link">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
    </svg>
    Kembali ke @(string.IsNullOrEmpty(companyName) ? "Beranda" : "Detail Perusahaan")
</a>

<div class="dashboard-header" style="margin-bottom: 20px;">
    <div>
        <h1 class="text-header">Riwayat Jadwal Konseling</h1>
        <p class="text-subtitle">Pantau seluruh riwayat dan jadwal konseling client dari @(string.IsNullOrEmpty(companyName) ? "Perusahaan" : companyName).</p>
    </div>
</div>

<div class="patient-list-container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div style="display: flex; align-items: center; background: #F9FAFB; border: 1px solid var(--border-color); border-radius: 12px; padding: 10px 16px; width: 400px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary-purple)" stroke-width="2" style="margin-right: 10px;">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" placeholder="Cari Riwayat Jadwal Konseling..." style="border: none; outline: none; background: transparent; width: 100%; font-size: 14px;" />
        </div>
        <button id="btnOpenScheduleModal" style="display: flex; align-items: center; gap: 8px; padding: 12px 20px; background: var(--primary-purple); color: white; border: none; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; transition: 0.2s;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Tambah Jadwal
        </button>
    </div>

    <!-- Filter & Kartu -->
    <div style="margin-bottom: 24px;">
        <span style="display: block; font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 10px;">Pilih Rentang Waktu</span>
        <div style="display: flex; gap: 10px;">
            <button class="filter-btn active">Hari Ini</button>
            <button class="filter-btn">Minggu</button>
            <button class="filter-btn">Bulan</button>
        </div>
    </div>

    <div style="display: flex; flex-direction: column; gap: 16px;">
        <div class="history-card">
            <div><h3>Jadwal Konseling 1 - Selesai</h3><p>15 Oktober 2025</p><p>09.30 - 11.45</p></div>
            <div class="history-dr-info"><div class="history-avatar"></div><span class="history-dr-name">Dr. Andi Syahputra</span></div>
        </div>
        <div class="history-card" style="opacity: 0.9;">
            <div><h3>Jadwal Konseling 2 - On Going</h3><p>16 Oktober 2025</p><p>09.30 - 11.45</p></div>
            <div class="history-dr-info"><div class="history-avatar"></div><span class="history-dr-name">Dr. Andi Syahputra</span></div>
        </div>
    </div>
</div>

<!-- Modal Tambah Jadwal -->
<div class="modal-overlay" id="addScheduleModal">
    <div class="modal-container" style="max-width: 450px;">
        <div class="modal-header">
            <h2 class="modal-title">Tambah Jadwal</h2>
            <button class="close-btn" id="btnCloseScheduleModal">&times;</button>
        </div>
        <form action="#" method="post">
            <div class="form-group"><label class="form-label">Tambahkan Nama Pasien</label><input type="text" class="form-control" placeholder="Nama Pasien" /></div>
            <div class="form-group"><label class="form-label">Tambahkan Jam</label><input type="time" class="form-control" placeholder="Jam Konsultasi" /></div>
            <div class="form-group"><label class="form-label">Tambahkan D/M/Y</label><input type="date" class="form-control" /></div>
            <div class="form-group"><label class="form-label">Deskripsi kegiatan</label><input type="text" class="form-control" placeholder="Tambahkan Kegiatan" /></div>
            <div class="modal-footer" style="margin-top: 30px;">
                <button type="button" class="btn-outline" id="btnCancelScheduleModal">Batalkan</button>
                <button type="submit" class="btn-fill">Simpan</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const scheduleModal = document.getElementById("addScheduleModal");
        const btnOpen = document.getElementById("btnOpenScheduleModal");
        const btnClose = document.getElementById("btnCloseScheduleModal");
        const btnCancel = document.getElementById("btnCancelScheduleModal");

        function openModal() { if(scheduleModal) scheduleModal.classList.add("active"); }
        function closeModal() { if(scheduleModal) scheduleModal.classList.remove("active"); }

        if(btnOpen) btnOpen.addEventListener("click", openModal);
        if(btnClose) btnClose.addEventListener("click", closeModal);
        if(btnCancel) btnCancel.addEventListener("click", closeModal);

        if(scheduleModal) {
            scheduleModal.addEventListener("click", function(e) {
                if (e.target === scheduleModal) closeModal();
            });
        }

        // Logika Visual Tombol Filter
        const filterBtns = document.querySelectorAll('.filter-btn');
        filterBtns.forEach(btn => {
            if(btn) {
                btn.addEventListener('click', function() {
                    const siblings = this.parentElement.querySelectorAll('.filter-btn');
                    siblings.forEach(s => s.classList.remove('active'));
                    this.classList.add('active');
                });
            }
        });
    });
</script>