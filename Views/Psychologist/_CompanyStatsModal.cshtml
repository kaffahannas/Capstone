@{
    var sehatCount = (int)(ViewBag.SehatCount ?? 0);
    var beresikoCount = (int)(ViewBag.BeresikoCount ?? 0);
    var bahayaCount = (int)(ViewBag.BahayaCount ?? 0);
    var total = sehatCount + beresikoCount + bahayaCount;
}

<div class="modal-container" style="max-width: 500px; padding: 0;">
    <div class="modal-header" style="padding: 24px 24px 10px 24px;">
        <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 4px;">Statistik Mitra</div>
        <h2 class="modal-title" style="margin: 0; font-size: 20px; color: var(--text-dark);">@ViewBag.CompanyName</h2>
        <button class="close-btn" onclick="closeCompanyStatsModal()">&times;</button>
    </div>

    <div style="padding: 24px;">
        <div style="margin-bottom: 24px; display: flex; align-items: center; gap: 8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-dark);">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            <span style="font-size: 16px; font-weight: 600; color: var(--text-dark);">@total</span>
            <span style="font-size: 14px; color: var(--text-muted);">klien ditangani</span>
        </div>

        @if (total > 0)
        {
            <div style="width: 100%; max-width: 300px; margin: 0 auto 32px auto; position: relative;">
                <canvas id="companyStatsModalChart" data-sehat="@sehatCount" data-beresiko="@beresikoCount" data-bahaya="@bahayaCount"></canvas>
            </div>
            
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 24px;">
                <div style="text-align: center; border: 1px solid #E5E7EB; border-radius: 12px; padding: 12px; background: #fff;">
                    <div style="font-size: 18px; margin-bottom: 4px;">✅</div>
                    <div style="font-size: 18px; font-weight: 700; color: #10B981;">@sehatCount</div>
                    <div style="font-size: 12px; color: var(--text-muted);">Sehat</div>
                </div>
                <div style="text-align: center; border: 1px solid #E5E7EB; border-radius: 12px; padding: 12px; background: #fff;">
                    <div style="font-size: 18px; margin-bottom: 4px;">⚠️</div>
                    <div style="font-size: 18px; font-weight: 700; color: #F59E0B;">@beresikoCount</div>
                    <div style="font-size: 12px; color: var(--text-muted);">Beresiko</div>
                </div>
                <div style="text-align: center; border: 1px solid #E5E7EB; border-radius: 12px; padding: 12px; background: #fff;">
                    <div style="font-size: 18px; margin-bottom: 4px;">🔴</div>
                    <div style="font-size: 18px; font-weight: 700; color: #EF4444;">@bahayaCount</div>
                    <div style="font-size: 12px; color: var(--text-muted);">Bahaya</div>
                </div>
            </div>
        }
        else
        {
            <div style="text-align: center; padding: 40px 20px; background: #F9FAFB; border-radius: 12px; margin-bottom: 24px;">
                <p style="color: var(--text-muted); font-size: 14px;">Belum ada klien aktif dari perusahaan ini.</p>
            </div>
        }

        <div style="display: flex; justify-content: flex-end; height: 36px;">
            <button type="button" class="btn-outline" onclick="closeCompanyStatsModal()" style="height: 100%; display: flex; align-items: center; justify-content: center; margin: 0; border: 1px solid var(--border-color); color: var(--text-muted); padding: 0 32px; border-radius: 999px; font-size: 13px; font-weight: 500;">Tutup</button>
        </div>
    </div>
</div>


