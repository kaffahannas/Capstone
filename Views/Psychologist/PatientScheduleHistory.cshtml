@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Riwayat Jadwal Pasien";
}

<!-- Tombol Kembali menggunakan history back agar dinamis -->
<a href="javascript:history.back()" class="back-link">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
    </svg>
    Kembali ke Detail Pasien
</a>

<div class="dashboard-header" style="margin-bottom: 20px;">
    <div>
        <h1 class="text-header">Riwayat Jadwal: @ViewBag.PatientName</h1>
        <p class="text-subtitle">Pantau seluruh riwayat konseling khusus untuk pasien ini.</p>
    </div>
</div>

<div class="patient-list-container">
    
    <!-- Top Bar: Pencarian & Tombol Tambah Jadwal -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div style="display: flex; align-items: center; background: #F9FAFB; border: 1px solid var(--border-color); border-radius: 12px; padding: 10px 16px; width: 400px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary-purple)" stroke-width="2" style="margin-right: 10px;">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" placeholder="Cari Riwayat Jadwal..." style="border: none; outline: none; background: transparent; width: 100%; font-size: 14px;" />
        </div>
        
        <button id="btnOpenScheduleModal" style="display: flex; align-items: center; gap: 8px; padding: 12px 20px; background: var(--primary-purple); color: white; border: none; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; transition: 0.2s;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Tambah Jadwal Pasien
        </button>
    </div>

    <!-- Filter Rentang Waktu -->
    <div style="margin-bottom: 24px;">
        <span style="display: block; font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 10px;">Pilih Rentang Waktu</span>
        <div style="display: flex; gap: 10px;">
            <button class="filter-btn active">Semua</button>
            <button class="filter-btn">Bulan Ini</button>
            <button class="filter-btn">Bulan Lalu</button>
        </div>
    </div>

    <!-- DAFTAR KARTU JADWAL (Khusus Pasien Ini) -->
    <div style="display: flex; flex-direction: column; gap: 16px;">
        
        <!-- Kartu 1 -->
        <div class="history-card">
            <div>
                <h3>Konseling Tahap 1 - Selesai</h3>
                <p>15 Oktober 2025</p>
                <p>09.30 - 11.45</p>
            </div>
            <div class="history-dr-info">
                <div class="history-avatar" style="background: url('https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&q=80') center/cover;"></div>
                <span class="history-dr-name">Dr. Dina</span>
            </div>
        </div>

        <!-- Kartu 2 -->
        <div class="history-card" style="opacity: 0.8;">
            <div>
                <h3>Konseling Awal - Selesai</h3>
                <p>10 Oktober 2025</p>
                <p>13.00 - 14.30</p>
            </div>
            <div class="history-dr-info">
                <div class="history-avatar" style="background: url('https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&q=80') center/cover;"></div>
                <span class="history-dr-name">Dr. Dina</span>
            </div>
        </div>

    </div>
</div>

<!-- ======================================================= -->
<!-- MODAL: TAMBAH JADWAL SPESIFIK PASIEN                    -->
<!-- ======================================================= -->
<div class="modal-overlay" id="addScheduleModal">
    <div class="modal-container" style="max-width: 450px;">
        <div class="modal-header">
            <h2 class="modal-title">Tambah Jadwal Baru</h2>
            <button class="close-btn" id="btnCloseScheduleModal">&times;</button>
        </div>
        
        <form action="#" method="post">
            <div class="form-group">
                <label class="form-label">Nama Pasien</label>
                <!-- Input dimatikan (readonly) karena sudah spesifik pasien ini -->
                <input type="text" class="form-control" value="@ViewBag.PatientName" readonly style="background-color: #F3F4F6;" />
            </div>

            <div class="form-group">
                <label class="form-label">Tambahkan Jam</label>
                <input type="time" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Tambahkan D/M/Y</label>
                <input type="date" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Deskripsi kegiatan</label>
                <input type="text" class="form-control" placeholder="Tambahkan Kegiatan" />
            </div>

            <div class="modal-footer" style="margin-top: 30px;">
                <button type="button" class="btn-outline" id="btnCancelScheduleModal">Batalkan</button>
                <button type="button" class="btn-fill" id="btnSaveSchedule">Simpan</button>
            </div>
        </form>
    </div>
</div>

<!-- SCRIPT UNTUK MENGENDALIKAN MODAL -->
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const scheduleModal = document.getElementById("addScheduleModal");
        const btnOpen = document.getElementById("btnOpenScheduleModal");
        const btnClose = document.getElementById("btnCloseScheduleModal");
        const btnCancel = document.getElementById("btnCancelScheduleModal");
        const btnSave = document.getElementById("btnSaveSchedule");

        function openModal() { scheduleModal.classList.add("active"); }
        function closeModal() { scheduleModal.classList.remove("active"); }

        btnOpen.addEventListener("click", openModal);
        btnClose.addEventListener("click", closeModal);
        btnCancel.addEventListener("click", closeModal);
        btnSave.addEventListener("click", closeModal);

        scheduleModal.addEventListener("click", function(e) {
            if (e.target === scheduleModal) closeModal();
        });
    });
</script>