@model LightenUp.Web.Controllers.WorksheetDetailViewModel

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Review Tugas - " + Model.PatientName;
}

<!-- Tombol Kembali -->
<a href="/Psychologist/Worksheet" class="back-link">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
    </svg>
    Kembali ke Daftar Worksheet
</a>

<div class="dashboard-header" style="margin-bottom: 20px;">
    <div>
        <h1 class="text-header">Review Aktivitas</h1>
        <p class="text-subtitle">Periksa hasil pengerjaan aktivitas klien dan berikan catatan Anda.</p>
    </div>
</div>

<div class="detail-grid">
    
    <!-- KOLOM KIRI (Data Pasien & Detail Tugas) -->
    <div class="left-column">
        
        <!-- Card Data Pasien -->
        <div class="detail-card">
            <h3 class="detail-card-title">Data Pasien</h3>
            <div class="profile-header" style="margin-bottom: 0;">
                <div class="profile-avatar">
                    @(Model.PatientName.Length > 0 ? Model.PatientName.Substring(0, 1).ToUpper() : "?")
                </div>
                <div class="profile-info">
                    <h2>@Model.PatientName</h2>
                    <p>Client LightenUp</p>
                </div>
            </div>
        </div>

        <!-- Card Informasi Tugas -->
        <div class="detail-card">
            <h3 class="detail-card-title">Informasi Tugas</h3>
            
            <div style="margin-bottom: 20px;">
                <span class="box-label">Status</span>
                <span class="status-badge status-@(Model.StatusClass)">@Model.Status</span>
            </div>

            <div style="margin-bottom: 20px;">
                <span class="box-label">Tanggal Pengerjaan</span>
                <p style="margin: 0; font-size: 16px; color: var(--text-dark); font-weight: 500;">@Model.TaskDate</p>
            </div>

            <div style="margin-bottom: 20px;">
                <span class="box-label">Nama Aktivitas</span>
                <p style="margin: 0; font-size: 15px; color: var(--text-dark);">@Model.TaskName</p>
            </div>

            <div>
                <span class="box-label">Periksa Tugas</span>
                <!-- TOMBOL PEMICU POP-UP BUKTI KEGIATAN -->
                <button type="button" id="btnOpenProofModal" class="task-document-box" style="width: 100%; font-family: 'Inter', sans-serif; font-size: 14px;">
                    Lihat File Tugas Disini
                </button>
            </div>
        </div>

    </div>

    <!-- KOLOM KANAN (Catatan & Aksi Cepat) -->
    <div class="right-column">
        
        <!-- Card Beri Catatan -->
        <div class="detail-card">
            <h3 class="detail-card-title">Beri Catatan</h3>
            <form>
                <textarea class="note-textarea" placeholder="Tambahkan catatan evaluasi atau instruksi selanjutnya di sini..."></textarea>
                <div style="display: flex; justify-content: flex-end;">
                    <button type="button" style="padding: 10px 24px; background: white; color: var(--primary-purple); border: 1px solid var(--primary-purple); border-radius: 20px; font-weight: 600; cursor: pointer;">
                        Simpan Catatan
                    </button>
                </div>
            </form>
        </div>

        <!-- Card Tindakan Cepat (Menghubungi) -->
        <div class="detail-card">
            <h3 class="detail-card-title">Tindakan Lanjutan</h3>
            <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 20px;">
                Jika dari hasil tugas atau worksheet ini ditemukan indikasi bahaya pada klien, segera hubungi pihak terkait.
            </p>

            <button class="btn-action-purple">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                Hubungi Karyawan
            </button>
            
            <!-- TOMBOL PEMICU POP-UP HR -->
            <button class="btn-action-purple" id="btnOpenReportModal">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                </svg>
                Hubungi HR Terkait
            </button>
        </div>

    </div>
</div>

<!-- ================= MODAL BUKTI KEGIATAN ================= -->
<div class="modal-overlay" id="proofModal">
    <!-- Container dimodifikasi khusus warna ungu seperti desain Figma -->
    <div class="modal-container" style="background-color: var(--primary-purple); color: white; border-radius: 20px; max-width: 400px; border: 4px solid white; box-shadow: 0 10px 25px rgba(139, 92, 246, 0.4);">
        
        <div class="modal-header" style="margin-bottom: 16px;">
            <h2 class="modal-title" style="color: white; text-align: left; font-size: 16px; display: flex; align-items: center; gap: 8px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
                Bukti Kegiatan:
            </h2>
            <button class="close-btn" id="btnCloseProofModal" style="color: white;">&times;</button>
        </div>
        
        <!-- Gambar Bukti -->
        <div style="background: white; border-radius: 12px; overflow: hidden; margin-bottom: 16px; border: 2px solid white;">
            <!-- Menggunakan gambar meditasi dari Unsplash sebagai placeholder -->
            <img src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Bukti Meditasi" style="width: 100%; height: 180px; object-fit: cover; display: block;" />
        </div>

        <h3 style="font-size: 13px; margin: 0 0 8px 0; font-weight: 600; color: white;">Deskripsi Kegiatan:</h3>
        
        <!-- Box Deskripsi -->
        <div style="background: white; color: var(--text-dark); border-radius: 12px; padding: 16px; min-height: 100px; font-size: 13px; font-weight: 500; line-height: 1.5;">
            Saya merasa lebih relaks dibandingkan sebelumnya
        </div>
        
    </div>
</div>

<!-- ================= MODAL LAPORKAN KE HR ================= -->
<div class="modal-overlay" id="reportHRModal">
    <div class="modal-container" style="background: #FAFAFA;">
        <div class="modal-header" style="margin-bottom: 20px;">
            <h2 class="modal-title">Laporkan ke HR</h2>
            <button class="close-btn" id="btnCloseReportModal">&times;</button>
        </div>

        <!-- Kartu Info Pasien -->
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 16px; padding: 16px; margin-bottom: 16px; display: flex; align-items: center; gap: 16px;">
            <div class="avatar" style="width: 48px; height: 48px;">
                @(Model.PatientName.Length > 0 ? Model.PatientName.Substring(0, 1).ToUpper() : "?")
            </div>
            <div>
                <h3 style="margin: 0 0 4px 0; font-size: 16px; color: var(--text-dark);">@Model.PatientName</h3>
                <p style="margin: 0 0 6px 0; font-size: 13px; color: var(--text-muted);">Divisi Marketing</p>
                <span class="status-badge status-beresiko" style="font-size: 11px; padding: 4px 10px;">Beresiko</span>
            </div>
        </div>

        <!-- Kartu Mood Trend & Metrics -->
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 16px; padding: 16px; margin-bottom: 16px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                <span style="font-weight: 700; font-size: 14px; color: var(--text-dark);">Mood Trend</span>
                <span style="font-size: 12px; color: var(--text-muted);">Dalam 3 hari terakhir</span>
            </div>
            
            <!-- Area Grafik -->
            <div style="height: 70px; width: 100%; margin-bottom: 16px;">
                <canvas id="hrMoodChart"></canvas>
            </div>
            
            <!-- Metrics Penugasan & Stress -->
            <div style="display: flex; justify-content: space-around; text-align: center; margin-top: 10px;">
                <div>
                    <span style="display: block; font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Nilai Penugasan</span>
                    <span style="display: block; font-size: 14px; font-weight: 700; color: #F59E0B;">6.2/10</span>
                    <span style="display: block; font-size: 12px; color: #F59E0B;">Menurun</span>
                </div>
                <div>
                    <span style="display: block; font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Tingkat Stress</span>
                    <span style="display: block; font-size: 14px; font-weight: 700; color: #EF4444; margin-top: 8px;">Tinggi</span>
                </div>
            </div>
        </div>

        <!-- Kartu Catatan Laporan -->
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 16px; padding: 16px; margin-bottom: 20px;">
            <label style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 12px; color: var(--text-dark);">Beri Catatan</label>
            <textarea style="width: 100%; border: none; background: #F9FAFB; border-radius: 8px; padding: 12px; font-family: 'Inter', sans-serif; font-size: 13px; min-height: 80px; resize: vertical; box-sizing: border-box; margin-bottom: 12px;" placeholder="Tambahkan catatan disini..."></textarea>
            <button type="button" style="padding: 6px 16px; background: white; color: var(--primary-purple); border: 1px solid var(--border-color); border-radius: 20px; font-size: 13px; font-weight: 600; cursor: pointer; transition: 0.2s;">
                Simpan
            </button>
        </div>

        <!-- Tombol Aksi Bawah -->
        <div class="modal-footer" style="margin-top: 0;">
            <button type="button" class="btn-outline" id="btnCancelReportModal">Batalkan</button>
            <button type="button" class="btn-fill">Kirim Laporan</button>
        </div>
    </div>
</div>

<!-- Chart.js Pustaka -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<!-- SCRIPT UNTUK MENGENDALIKAN POP-UP -->
<script>
    document.addEventListener("DOMContentLoaded", function() {
    // --- LOGIKA MODAL BUKTI KEGIATAN ---
    const proofModal = document.getElementById("proofModal");
    const btnOpenProof = document.getElementById("btnOpenProofModal");
    const btnCloseProof = document.getElementById("btnCloseProofModal");

    btnOpenProof.addEventListener("click", function(e) {
    e.preventDefault();
    proofModal.classList.add("active");
    });

    function closeProofModal() { proofModal.classList.remove("active"); }
    btnCloseProof.addEventListener("click", closeProofModal);
    proofModal.addEventListener("click", function(e) { if (e.target === proofModal) closeProofModal(); });

    // --- LOGIKA MODAL LAPORKAN HR ---
    const reportModal = document.getElementById("reportHRModal");
    const btnOpenReport = document.getElementById("btnOpenReportModal");
    const btnCloseReport = document.getElementById("btnCloseReportModal");
    const btnCancelReport = document.getElementById("btnCancelReportModal");

    let hrChartInstance = null; // Menyimpan instance chart

    btnOpenReport.addEventListener("click", function(e) {
    e.preventDefault();
    reportModal.classList.add("active");
            
    // Gambar chart dengan jeda sedikit agar modal sempat terbuka dan merender canvas
    setTimeout(renderHRChart, 100);
    });

    function closeReportModal() { reportModal.classList.remove("active"); }
    btnCloseReport.addEventListener("click", closeReportModal);
    btnCancelReport.addEventListener("click", closeReportModal);
    reportModal.addEventListener("click", function(e) { if (e.target === reportModal) closeReportModal(); });

    // --- FUNGSI MENGGAMBAR GRAFIK MOOD DI MODAL HR ---
    function renderHRChart() {
    const ctx = document.getElementById('hrMoodChart').getContext('2d');
            
    if (hrChartInstance) { hrChartInstance.destroy(); } // Hapus grafik lama jika ada

    hrChartInstance = new Chart(ctx, {
    type: 'line',
    data: {
    labels: ['1', '2', '3', '4', '5', '6', '7'],
    datasets: [{
    data: [7, 6.8, 6.5, 6, 6.2, 5.8, 6], // Nilai menurun (garis kuning)
    borderColor: '#F59E0B', // Kuning/Oranye
    borderWidth: 2,
    pointBackgroundColor: '#F59E0B',
    pointBorderColor: '#fff',
    pointBorderWidth: 1,
    pointRadius: 3,
    fill: false,
    tension: 0.1 // Sedikit melengkung
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false }, tooltip: { enabled: false } },
    scales: {
    y: { display: false, min: 0, max: 10 },
    x: { display: false }
    },
    layout: { padding: { top: 5, bottom: 5, left: 10, right: 10 } }
    }
    });
    }
    });
</script>