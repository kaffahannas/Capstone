@using LightenUp.Web.Models
@model LightenUp.Web.Controllers.PatientDetailViewModel
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Detail Pasien - " + Model.FullName;

    var symptoms = (ViewBag.Symptoms as string) ?? "";
    var symptomList = string.IsNullOrEmpty(symptoms) ? new List<string>() : symptoms.Split('\n', ',').Select(s => s.Trim()).Where(s => s.Length > 0).ToList();
    var hasMoodData = (bool)(ViewBag.HasMoodData ?? false);
    var todaySession = ViewBag.TodaySession as Schedule;
    var openWs = (int)(ViewBag.OpenWorksheetCount ?? 0);
}

<a href="/Psychologist/Index" class="back-link">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
    Kembali ke Daftar Pasien
</a>

<div class="detail-grid">
    <div class="left-column">
        <div class="detail-card">
            <div class="profile-header">
                <div class="profile-avatar">
                    @(Model.FullName.Length > 0 ? Model.FullName.Substring(0, 1).ToUpper() : "?")
                </div>
                <div class="profile-info">
                    <h2>@Model.FullName</h2>
                    <p>@Model.Gender</p>
                    <p>@Model.Age</p>
                </div>
            </div>

            <div class="profile-info" style="margin-top: 16px; border-top: 1px solid var(--border-color); padding-top: 16px;">
                <p>@Model.Location</p>
                <p>@Model.Phone</p>
            </div>
        </div>

        <div class="detail-card">
            <h3 class="detail-card-title">Status Saat Ini</h3>
            <span class="status-badge status-@(Model.Status.ToLower())" style="font-size: 14px; padding: 8px 16px;">@Model.Status</span>
        </div>

        <div class="detail-card">
            <h3 class="detail-card-title">Catatan</h3>
            @if (symptomList.Any())
            {
                <ul class="notes-list">
                    @foreach (var item in symptomList)
                    {
                        <li>@item</li>
                    }
                </ul>
            }
            else
            {
                <p style="color:#9CA3AF; font-size:13px;">Belum ada catatan untuk pasien ini.</p>
            }
        </div>
    </div>

    <div class="right-column">
        <div class="detail-card">
            <h3 class="detail-card-title">Jurnal Hari Ini</h3>
            <span class="box-label">Dari pasien</span>
            <div class="journal-box">"@Model.JournalContent"</div>
            <span class="box-label">Keluhan / Catatan</span>
            <div class="complaint-box">@Model.Complaint</div>
        </div>

        <div class="detail-card">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <h3 class="detail-card-title" style="margin-bottom: 0;">Mood Tracker (7 hari terakhir)</h3>
            </div>

            @if (hasMoodData)
            {
                <div class="chart-container">
                    <canvas id="moodChart"></canvas>
                </div>
                <div style="display: flex; justify-content: space-around; margin-top: 20px; text-align: center;">
                    <div><span style="display: block; font-weight: 700; color: #10b981; font-size: 16px;">@ViewBag.SehatPct%</span><span class="box-label">Sehat</span></div>
                    <div><span style="display: block; font-weight: 700; color: #f59e0b; font-size: 16px;">@ViewBag.BeresikoPct%</span><span class="box-label">Beresiko</span></div>
                    <div><span style="display: block; font-weight: 700; color: #ef4444; font-size: 16px;">@ViewBag.BahayaPct%</span><span class="box-label">Bahaya</span></div>
                </div>
            }
            else
            {
                <p style="text-align:center; color:#9CA3AF; padding:30px 0;">Belum ada data mood dalam 7 hari terakhir.</p>
            }
        </div>

        <div class="action-grid">
            <div class="detail-card action-card">
                <h3 class="detail-card-title" style="text-align: left;">Jadwal</h3>
                @if (todaySession != null)
                {
                    <p style="font-size: 14px; color: var(--text-dark); text-align: left; margin-bottom: 12px;">
                        Hari ini @todaySession.SessionStart.ToString("HH:mm")<br/>
                        <small style="color:#6B7280;">@(string.IsNullOrEmpty(todaySession.Notes) ? "" : todaySession.Notes)</small>
                    </p>
                }
                else
                {
                    <p style="font-size: 14px; color: var(--text-muted); text-align: left; margin-bottom: 24px; min-height: 40px;">Tidak ada sesi hari ini.</p>
                }
                <a href="/Psychologist/PatientScheduleHistory?id=@Model.PatientId" class="action-btn">Lihat Riwayat Konseling</a>
            </div>
            <div class="detail-card action-card">
                <h3 class="detail-card-title" style="text-align: left;">Worksheet</h3>
                @if (openWs > 0)
                {
                    <p style="font-size: 14px; color: var(--text-dark); text-align: left; margin-bottom: 24px;"><strong>@openWs</strong> worksheet aktif.</p>
                }
                else
                {
                    <p style="font-size: 14px; color: var(--text-muted); text-align: left; margin-bottom: 24px; min-height: 40px;">Belum ada worksheet aktif.</p>
                }
                <a href="/Psychologist/PatientWorksheetHistory?id=@Model.PatientId" class="action-btn">Lihat Riwayat Worksheet</a>
            </div>
        </div>
    </div>
</div>

@if (hasMoodData)
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('moodChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: @Html.Raw(ViewBag.MoodLabels),
                datasets: [{
                    data: @Html.Raw(ViewBag.MoodScores),
                    borderColor: '#8B5CF6',
                    backgroundColor: 'rgba(139, 92, 246, 0.1)',
                    borderWidth: 3,
                    pointBackgroundColor: '#8B5CF6',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, max: 5, ticks: { stepSize: 1 } }, x: { grid: { display: false } } }
            }
        });
    </script>
}
