@model LightenUp.Web.Controllers.PatientDetailViewModel

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Detail Pasien - " + Model.FullName;
}

<a href="/Psychologist/Index" class="back-link">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
    </svg>
    Kembali ke Daftar Pasien
</a>

<div class="detail-grid">
    <div class="left-column">
        <div class="detail-card">
            <div class="profile-header">
                <div class="profile-avatar">
                    @(Model.FullName.Length > 0 ? Model.FullName.Substring(0, 1).ToUpper() : "?")
                </div>
                <div class="profile-info">
                    <h2>@Model.FullName</h2>
                    <p>@Model.Gender</p>
                    <p>@Model.Age</p>
                </div>
            </div>
            
            <div class="profile-info" style="margin-top: 16px; border-top: 1px solid var(--border-color); padding-top: 16px;">
                <p>@Model.Location</p>
                <p>@Model.Phone</p>
            </div>
        </div>

        <div class="detail-card">
            <h3 class="detail-card-title">Status Saat Ini</h3>
            <span class="status-badge status-@(Model.Status.ToLower())" style="font-size: 14px; padding: 8px 16px;">
                @Model.Status
            </span>
        </div>

        <div class="detail-card">
            <h3 class="detail-card-title">Catatan</h3>
            <ul class="notes-list">
                <li>Gangguan pemusatan perhatian</li>
                <li>Hiperaktivitas</li>
                <li>Impulsivitas</li>
            </ul>
            <a href="#" style="font-size: 13px; color: #3b82f6; text-decoration: none; font-weight: 500;">Detail catatan</a>
        </div>
    </div>

    <div class="right-column">
        <div class="detail-card">
            <h3 class="detail-card-title">Jurnal Hari Ini</h3>
            <span class="box-label">Dari pasien</span>
            <div class="journal-box">
                "@Model.JournalContent"
            </div>
            <span class="box-label">Keluhan</span>
            <div class="complaint-box">
                @Model.Complaint
            </div>
        </div>

        <div class="detail-card">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <h3 class="detail-card-title" style="margin-bottom: 0;">Mood Tracker</h3>
                <div style="display: flex; background: #F3F4F6; border-radius: 20px; padding: 4px;">
                    <button style="border: none; background: white; border-radius: 16px; padding: 4px 12px; font-size: 12px; font-weight: 600; color: var(--text-dark); box-shadow: 0 1px 2px rgba(0,0,0,0.05); cursor: pointer;">Week</button>
                    <button style="border: none; background: transparent; padding: 4px 12px; font-size: 12px; font-weight: 500; color: var(--text-muted); cursor: pointer;">Month</button>
                </div>
            </div>
            
            <div class="chart-container">
                <canvas id="moodChart"></canvas>
            </div>

            <div style="display: flex; justify-content: space-around; margin-top: 20px; text-align: center;">
                <div><span style="display: block; font-weight: 700; color: #10b981; font-size: 16px;">4%</span><span class="box-label">Sehat</span></div>
                <div><span style="display: block; font-weight: 700; color: #f59e0b; font-size: 16px;">10%</span><span class="box-label">Beresiko</span></div>
                <div><span style="display: block; font-weight: 700; color: #ef4444; font-size: 16px;">86%</span><span class="box-label">Bahaya</span></div>
            </div>
        </div>

        <div class="action-grid">
            <div class="detail-card action-card">
                <h3 class="detail-card-title" style="text-align: left;">Jadwal</h3>
                <p style="font-size: 14px; color: var(--text-muted); text-align: left; margin-bottom: 24px; min-height: 40px;">Tidak ada sesi hari ini.</p>
                <a href="/Psychologist/PatientScheduleHistory?id=@Model.PatientId" class="action-btn">Lihat Riwayat Konseling</a>
            </div>
            <div class="detail-card action-card">
                <h3 class="detail-card-title" style="text-align: left;">Worksheet</h3>
                <p style="font-size: 14px; color: var(--text-muted); text-align: left; margin-bottom: 24px; min-height: 40px;">Belum ada worksheet baru.</p>
                <a href="/Psychologist/PatientWorksheetHistory?id=@Model.PatientId" class="action-btn">Lihat Riwayat Worksheet</a>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
    const ctx = document.getElementById('moodChart').getContext('2d');
    const data = {
    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
    datasets: [{
    label: 'Tingkat Bahaya',
    data: [60, 40, 80, 80, 60, 40, 60],
    borderColor: '#8B5CF6',
    backgroundColor: 'rgba(139, 92, 246, 0.1)',
    borderWidth: 3,
    pointBackgroundColor: '#8B5CF6',
    pointBorderColor: '#fff',
    pointBorderWidth: 2,
    pointRadius: 5,
    fill: true,
    tension: 0.4
    }]
    };
    const config = {
    type: 'line', data: data,
    options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
    y: { beginAtZero: true, max: 100, ticks: { display: false }, grid: { color: '#F3F4F6' } },
    x: { grid: { display: false }, ticks: { color: '#6B7280', font: { size: 12 } } }
    }
    }
    };
    new Chart(ctx, config);
    });
</script>