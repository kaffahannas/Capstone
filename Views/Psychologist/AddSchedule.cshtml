@model LightenUp.Web.Models.ViewModels.PsyAddScheduleViewModel
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Tambah Jadwal";
}

<a href="/Psychologist/Scheduling" class="back-link">← Kembali ke Jadwal</a>

<div class="dashboard-header" style="margin-bottom: 20px;">
    <div>
        <h1 class="text-header">Tambah Jadwal Konseling</h1>
        <p class="text-subtitle">Buat jadwal sesi baru untuk salah satu pasien aktif Anda.</p>
    </div>
</div>

<div style="max-width: 560px; background: white; border: 1px solid var(--border-color); border-radius: 16px; padding: 24px;">
    <form asp-action="AddSchedule" method="post">
        <div asp-validation-summary="ModelOnly" style="color:#B91C1C; margin-bottom: 12px;"></div>

        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label">Pasien</label>
            <select asp-for="PatientId" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%;">
                <option value="0">-- Pilih Pasien --</option>
                @foreach (var p in Model.AvailablePatients)
                {
                    <option value="@p.PatientId">@p.FullName @(p.CompanyName != null ? "(" + p.CompanyName + ")" : "")</option>
                }
            </select>
            <span asp-validation-for="PatientId" style="color:#B91C1C; font-size:12px;"></span>
        </div>

        <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
            <div class="form-group">
                <label class="form-label">Tanggal</label>
                <input asp-for="SessionDate" type="date" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%;" />
                <span asp-validation-for="SessionDate" style="color:#B91C1C; font-size:12px;"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Jam</label>
                <input asp-for="SessionTime" type="time" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%;" />
                <span asp-validation-for="SessionTime" style="color:#B91C1C; font-size:12px;"></span>
            </div>
        </div>

        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label">Durasi (menit)</label>
            <input asp-for="DurationMinutes" type="number" min="15" max="240" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%;" />
        </div>

        <div class="form-group" style="margin-bottom: 24px;">
            <label class="form-label">Deskripsi kegiatan</label>
            <textarea asp-for="Notes" rows="3" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%; font-family:inherit;" placeholder="Mis. General Counseling, Review Worksheet, dll."></textarea>
        </div>

        <div style="display:flex; gap: 12px;">
            <a href="/Psychologist/Scheduling" style="flex:1; padding:12px; text-align:center; border-radius:8px; border:1px solid var(--primary-purple); color:var(--primary-purple); text-decoration:none; font-weight:600;">Batalkan</a>
            <button type="submit" style="flex:1; padding:12px; background:var(--primary-purple); color:white; border:none; border-radius:8px; font-weight:600; cursor:pointer;">Simpan</button>
        </div>
    </form>
</div>
