@using LightenUp.Web.Models
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Riwayat Worksheet";

    var worksheets = ViewBag.Worksheets as List<Worksheet> ?? new List<Worksheet>();
    string? companyName = Context.Request.Query["company"].FirstOrDefault();
    string backUrl = string.IsNullOrEmpty(companyName) ? "/Psychologist/Index" : $"/Psychologist/CompanyDetail?companyName={Uri.EscapeDataString(companyName!)}";
    var idCulture = new System.Globalization.CultureInfo("id-ID");

    (string label, string color) MapStatus(string status) => status switch
    {
        "Assigned" => ("Belum Selesai", "#FCA5A5"),
        "InProgress" => ("On Progress", "#FEF08A"),
        "Completed" => ("Selesai", "#A7F3D0"),
        _ => (status, "#A7F3D0")
    };
}

<a href="@backUrl" class="back-link">← Kembali ke @(string.IsNullOrEmpty(companyName) ? "Beranda" : "Detail Perusahaan")</a>

<div class="dashboard-header" style="margin-bottom: 20px;">
    <div>
        <h1 class="text-header">Riwayat Worksheet</h1>
        <p class="text-subtitle">Pantau seluruh riwayat dan progres tugas worksheet client Anda.</p>
    </div>
</div>

@if (TempData["success"] is string ok)
{
    <div style="background:#D1FAE5; color:#047857; padding:10px 14px; border-radius:8px; margin-bottom:12px;">@ok</div>
}

<div class="patient-list-container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div style="display: flex; align-items: center; background: #F9FAFB; border: 1px solid var(--border-color); border-radius: 12px; padding: 10px 16px; width: 400px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary-purple)" stroke-width="2" style="margin-right: 10px;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" id="wsSearch" placeholder="Cari berdasarkan tugas atau nama..." style="border: none; outline: none; background: transparent; width: 100%; font-size: 14px;" />
        </div>
        <a href="/Psychologist/AddTask" style="display: flex; align-items: center; gap: 8px; padding: 12px 20px; background: var(--primary-purple); color: white; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration:none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Tambah Tugas
        </a>
    </div>

    @if (!worksheets.Any())
    {
        <div style="padding: 40px; text-align: center; color: #9CA3AF; border: 1px dashed var(--border-color); border-radius: 12px;">
            Belum ada worksheet.
        </div>
    }
    else
    {
        <div id="wsList" style="display: flex; flex-direction: column; gap: 16px;">
            @foreach (var w in worksheets)
            {
                var (label, color) = MapStatus(w.Status);
                var name = (w.Patient?.User?.FullName ?? "").ToLowerInvariant();
                var task = (w.TaskName ?? "").ToLowerInvariant();
                <a class="history-card" href="@Url.Action("ReviewWorksheet", "Psychologist", new { id = w.WorksheetId })" data-search="@name @task" style="text-decoration:none; color:inherit;">
                    <div>
                        <h3>@w.TaskName</h3>
                        <p>@w.Deadline.ToString("d MMMM yyyy", idCulture) · @(w.Patient?.User?.FullName ?? "—")</p>
                        <p style="margin-top: 8px; font-weight: 500; font-size: 13px; color: @color;">Status : @label</p>
                    </div>
                </a>
            }
        </div>
    }
</div>

<script>
    const input = document.getElementById('wsSearch');
    if (input) input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        document.querySelectorAll('#wsList .history-card').forEach(c => {
            c.style.display = c.dataset.search.includes(q) ? '' : 'none';
        });
    });
</script>
