@model LightenUp.Web.Controllers.WorksheetViewModel

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Monitor Worksheet";
}

<div class="dashboard-header">
    <div>
        <h1 class="text-header">Monitor Worksheet</h1>
        <p class="text-subtitle">Kelola dan pantau aktivitas tugas harian seluruh client Anda.</p>
    </div>
</div>

<div style="display: flex; align-items: center; gap: 8px; margin-bottom: 25px;">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10 9 9 9 8 9"></polyline>
    </svg>
    <span style="font-size: 26px; font-weight: 700; color: var(--text-dark);">@Model.TotalActivities</span>
    <span style="font-size: 18px; color: var(--text-dark);">Aktivitas Aktif</span>
</div>

<div class="patient-list-container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <div style="display: flex; gap: 15px;">
            <button style="display: flex; align-items: center; gap: 8px; padding: 8px 16px; border: 1px solid var(--border-color); background: white; border-radius: 8px; font-size: 14px; cursor: pointer;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                </svg>
                Filter
            </button>
            <div style="display: flex; align-items: center; background: white; border: 1px solid var(--border-color); border-radius: 8px; padding: 8px 12px; width: 250px;">
                <input type="text" placeholder="Cari tugas atau nama..." style="border: none; outline: none; width: 100%; font-size: 14px;" />
            </div>
        </div>

        <button id="btnOpenModal" style="display: flex; align-items: center; gap: 8px; padding: 10px 20px; background: var(--primary-purple); color: white; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: 0.2s;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Tambah Tugas baru
        </button>
    </div>

    @if (Model.Tasks == null || Model.Tasks.Count == 0)
    {
        <div style="text-align: center; padding: 40px 0; color: var(--text-muted);">
            <p>Belum ada aktivitas yang dikerjakan.</p>
        </div>
    }
    else
    {
        @foreach (var task in Model.Tasks)
        {
            <div class="patient-card">
                <div class="patient-info">
                    <div class="avatar">
                        @(task.PatientName.Length > 0 ? task.PatientName.Substring(0, 1).ToUpper() : "?")
                    </div>
                    <div>
                        <h3 style="margin: 0 0 4px 0; font-size: 16px; color: var(--text-dark);">@task.PatientName</h3>
                        <p style="margin: 0 0 8px 0; font-size: 12px; color: var(--text-muted);">@task.Date</p>
                        <p style="margin: 0; font-size: 14px; font-weight: 500; color: var(--text-dark);">@task.TaskName</p>
                    </div>
                </div>

                <div style="display: flex; align-items: center; gap: 24px;">
                    <span class="status-badge status-@(task.StatusClass)">@task.Status</span>
                    <a href="/Psychologist/WorksheetDetail/@task.TaskId" style="padding: 8px 16px; border-radius: 8px; background: var(--light-purple); color: var(--primary-purple); text-decoration: none; font-size: 14px; font-weight: 600;">
                        Lihat Tugas
                    </a>
                </div>
            </div>
        }
    }
</div>

<div class="modal-overlay" id="taskModal">
    <div class="modal-container">
        <div class="modal-header">
            <h2 class="modal-title">Tambahkan Tugas</h2>
            <button class="close-btn" id="btnCloseModal">&times;</button>
        </div>
        
        <form action="#" method="post">
            <div class="form-group">
                <label class="form-label">Tambahkan Nama Pasien</label>
                <input type="text" class="form-control" placeholder="Nama Pasien" />
                <span class="form-help">Masukkan nama pasien yang akan ditambahkan.</span>
            </div>

            <div class="form-group">
                <label class="form-label">Tambahkan Jam Deadline tugas</label>
                <input type="time" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Tambahkan D/M/Y Deadline tugas</label>
                <input type="date" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Deskripsikan Tugas</label>
                <input type="text" class="form-control" placeholder="Tambahkan tugas..." />
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-outline" id="btnCancelModal">Batalkan</button>
                <button type="submit" class="btn-fill">Simpan</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const modal = document.getElementById("taskModal");
        const btnOpen = document.getElementById("btnOpenModal");
        const btnClose = document.getElementById("btnCloseModal");
        const btnCancel = document.getElementById("btnCancelModal");

        // Fungsi buka modal
        btnOpen.addEventListener("click", function() {
            modal.classList.add("active");
        });

        // Fungsi tutup modal
        function closeModal() {
            modal.classList.remove("active");
        }

        btnClose.addEventListener("click", closeModal);
        btnCancel.addEventListener("click", closeModal);

        // Tutup jika klik di luar area putih
        modal.addEventListener("click", function(e) {
            if (e.target === modal) {
                closeModal();
            }
        });
    });
</script>