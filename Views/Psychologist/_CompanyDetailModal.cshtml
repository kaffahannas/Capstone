@using LightenUp.Web.Models
@{
    var patients = ViewBag.Patients as List<Patient> ?? new List<Patient>();
    var sehat = (int)(ViewBag.SehatCount ?? 0);
    var beresiko = (int)(ViewBag.BeresikoCount ?? 0);
    var bahaya = (int)(ViewBag.BahayaCount ?? 0);
    var company = ViewBag.Company as Company;
}

<div class="modal-container" style="max-width: 600px; padding: 0;">
    <div class="modal-header" style="padding: 24px 24px 10px 24px;">
        <div>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0 0 4px 0; font-weight: 500;">Detail Mitra</p>
            <h2 class="modal-title" style="margin: 0; font-size: 20px; color: var(--text-dark);">@ViewBag.CompanyName</h2>
        </div>
        <button class="close-btn" onclick="closeCompanyDetailModal()">&times;</button>
    </div>

    <div style="padding: 24px; max-height: 70vh; overflow-y: auto;">
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 24px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            <span style="font-size: 24px; font-weight: 800; color: var(--text-dark);">@patients.Count</span>
            <span style="font-size: 15px; color: var(--text-muted);">klien ditangani</span>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
            <div style="background: #F9FAFB; border: 1px solid var(--border-color); border-radius: 12px; padding: 16px; text-align: center;">
                <div style="font-size: 20px;">✅</div>
                <h3 style="margin: 4px 0; font-size: 20px; font-weight: 800; color: #047857;">@sehat</h3>
                <p style="margin: 0; font-size: 12px; color: var(--text-muted);">Sehat</p>
            </div>
            <div style="background: #F9FAFB; border: 1px solid var(--border-color); border-radius: 12px; padding: 16px; text-align: center;">
                <div style="font-size: 20px;">⚠️</div>
                <h3 style="margin: 4px 0; font-size: 20px; font-weight: 800; color: #B45309;">@beresiko</h3>
                <p style="margin: 0; font-size: 12px; color: var(--text-muted);">Beresiko</p>
            </div>
            <div style="background: #F9FAFB; border: 1px solid var(--border-color); border-radius: 12px; padding: 16px; text-align: center;">
                <div style="font-size: 20px;">🔴</div>
                <h3 style="margin: 4px 0; font-size: 20px; font-weight: 800; color: #B91C1C;">@bahaya</h3>
                <p style="margin: 0; font-size: 12px; color: var(--text-muted);">Bahaya</p>
            </div>
        </div>

        @if (bahaya > 0)
        {
            <div style="background: #FEF2F2; border-radius: 12px; border: 1px solid #FCA5A5; padding: 16px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; color: #991B1B;">
                <div>
                    <h3 style="margin: 0 0 4px 0; font-size: 14px; font-weight: 700;">⚠️ @bahaya klien dalam kondisi bahaya</h3>
                    <p style="margin: 0; font-size: 12px; opacity: 0.9;">Pantau perkembangan mereka lebih intensif.</p>
                </div>
            </div>
        }

        <h4 style="font-size: 14px; margin: 0 0 12px 0; font-weight: 600;">Daftar Klien Aktif</h4>
        
        @if (!patients.Any())
        {
            <div style="padding: 24px; text-align: center; color: #9CA3AF; border: 1px dashed var(--border-color); border-radius: 8px; font-size: 13px;">
                Belum ada klien aktif dari perusahaan ini.
            </div>
        }
        else
        {
            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px;">
                @foreach (var p in patients)
                {
                    var badgeColor = p.MentalHealthStatus switch
                    {
                        "Sehat" => "#D1FAE5; color:#047857",
                        "Beresiko" => "#FEF3C7; color:#B45309",
                        "Bahaya" => "#FEE2E2; color:#B91C1C",
                        _ => "#E5E7EB; color:#374151"
                    };
                    <a href="@Url.Action("PatientDetail", "Psychologist", new { id = p.PatientId })"
                       style="background:white; padding:12px 16px; border-radius:8px; border:1px solid var(--border-color); display:flex; justify-content:space-between; align-items:center; text-decoration:none; color:inherit; transition: 0.2s;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <div style="width: 32px; height: 32px; border-radius: 50%; background: #F3E8FF; color: #9333EA; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 12px;">
                                @(p.User?.FullName?.Length > 0 ? p.User.FullName.Substring(0,1).ToUpper() : "?")
                            </div>
                            <div>
                                <div style="font-size: 14px; font-weight: 600; margin-bottom: 2px;">@(p.User?.FullName ?? "—")</div>
                                <div style="font-size: 11px; color: var(--text-muted);">@(p.Department ?? "Divisi belum diatur")</div>
                            </div>
                        </div>
                        <span style="padding:4px 10px; border-radius:999px; font-size:11px; font-weight: 600; background:@badgeColor;">@p.MentalHealthStatus</span>
                    </a>
                }
            </div>
        }
    </div>
    
    <div style="padding: 16px 24px; border-top: 1px solid var(--border-color); background: #F9FAFB; border-radius: 0 0 12px 12px; display: flex; gap: 12px; justify-content: flex-end;">
        <a asp-area="" asp-controller="Psychologist" asp-action="ScheduleHistory" asp-route-company="@ViewBag.CompanyName" class="btn-outline" style="text-align: center; text-decoration: none; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 999px; font-size: 13px; font-weight: 500; padding: 0 24px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px; vertical-align: middle;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            Jadwal
        </a>
        <a asp-area="" asp-controller="Psychologist" asp-action="WorksheetHistory" asp-route-company="@ViewBag.CompanyName" class="btn-outline" style="text-align: center; text-decoration: none; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 999px; font-size: 13px; font-weight: 500; padding: 0 24px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px; vertical-align: middle;"><path d="M14 2H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V8l-6-6z"></path><path d="M14 3v5h5M16 13H8M16 17H8M10 9H8"></path></svg>
            Worksheet
        </a>
    </div>
</div>
