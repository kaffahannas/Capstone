@model LightenUp.Web.Controllers.StatisticsViewModel
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Statistik Keseluruhan";

    var divisions = (ViewBag.Divisions as List<LightenUp.Web.Controllers.PsychologistController.DivisionRow>)
                    ?? new List<LightenUp.Web.Controllers.PsychologistController.DivisionRow>();
    var divLabels = System.Text.Json.JsonSerializer.Serialize(divisions.Select(d => d.Name));
    var divStress = System.Text.Json.JsonSerializer.Serialize(divisions.Select(d => d.StressPct));
}

<div class="dashboard-header">
    <div>
        <h1 class="text-header">Data Keseluruhan Karyawan</h1>
        <p class="text-subtitle">Ringkasan status dan tingkat stres dari seluruh klien aktif.</p>
    </div>
</div>

<div style="display: flex; align-items: center; gap: 8px; margin-bottom: 25px;">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
    </svg>
    <span style="font-size: 26px; font-weight: 700; color: var(--text-dark);">@Model.TotalClients</span>
    <span style="font-size: 18px; color: var(--text-dark);">orang (Client Aktif)</span>
</div>

<div class="stats-summary-grid">
    <div class="stat-box">
        <div class="stat-icon icon-sehat"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
        <div><h3 style="margin: 0; font-size: 24px; font-weight: 700;">@Model.HealthyCount</h3><p style="margin: 0; font-size: 14px; color: var(--text-muted);">Sehat</p></div>
    </div>
    <div class="stat-box">
        <div class="stat-icon icon-beresiko"><div style="width: 16px; height: 16px; background: currentColor; border-radius: 4px;"></div></div>
        <div><h3 style="margin: 0; font-size: 24px; font-weight: 700;">@Model.AtRiskCount</h3><p style="margin: 0; font-size: 14px; color: var(--text-muted);">Beresiko</p></div>
    </div>
    <div class="stat-box">
        <div class="stat-icon icon-bahaya"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg></div>
        <div><h3 style="margin: 0; font-size: 24px; font-weight: 700;">@Model.DangerCount</h3><p style="margin: 0; font-size: 14px; color: var(--text-muted);">Bahaya</p></div>
    </div>
</div>

<div class="charts-grid">
    <div class="chart-card">
        <h3 style="font-size: 16px; font-weight: 700; text-align: center; margin-top: 0; margin-bottom: 20px;">Status Karyawan Keseluruhan</h3>
        @if (Model.TotalClients == 0)
        {
            <div style="text-align:center; color:#9CA3AF; padding:60px 0;">Belum ada client aktif.</div>
        }
        else
        {
            <div style="position: relative; height: 250px; width: 100%;"><canvas id="pieChart"></canvas></div>
        }
    </div>
    <div class="chart-card">
        <h3 style="font-size: 16px; font-weight: 700; text-align: center; margin-top: 0; margin-bottom: 20px;">Tingkat Stress Tiap Divisi</h3>
        @if (!divisions.Any())
        {
            <div style="text-align:center; color:#9CA3AF; padding:60px 0;">Belum ada divisi tercatat.</div>
        }
        else
        {
            <div style="position: relative; height: 250px; width: 100%;"><canvas id="barChart"></canvas></div>
        }
    </div>
</div>

<div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; margin-top: 30px;">
    <div>
        <h3 style="font-size: 20px; font-weight: 700; margin: 0 0 8px 0; color: var(--text-dark);">Ringkasan per Divisi</h3>
        <p style="font-size: 14px; color: var(--primary-purple); margin: 0;">Laporan untuk masing-masing divisi</p>
    </div>
</div>

@if (!divisions.Any())
{
    <div style="padding: 40px; text-align: center; color: #9CA3AF; border: 1px dashed var(--border-color); border-radius: 12px;">
        Belum ada divisi (perusahaan mitra) tercatat untuk klien aktif Anda.
    </div>
}
else
{
    <div class="division-grid">
        @foreach (var d in divisions)
        {
            <a class="division-card" style="cursor: pointer; text-decoration:none; color: white;"
               href="@Url.Action("CompanyDetail", "Psychologist", new { id = d.CompanyId })">
                <span style="font-size: 13px; font-weight: 500; opacity: 0.9;">Detail</span>
                <div style="text-align: center; margin: auto 0; font-weight: 600; font-size: 20px;">@d.Name Report</div>
                <div style="margin-top: auto; background: white; color: var(--text-dark); padding: 16px 20px; border-radius: 8px; text-align: left;">
                    <div style="font-weight: 700; font-size: 15px; margin-bottom: 4px;">@d.Name</div>
                    <div style="font-size: 13px; color: var(--text-muted);">Moods: @d.SehatPct% Sehat · @d.Total orang</div>
                </div>
            </a>
        }
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        @if (Model.TotalClients > 0)
        {
            <text>
            new Chart(document.getElementById('pieChart').getContext('2d'), {
                type: 'pie',
                data: {
                    labels: ['Sehat', 'Beresiko', 'Bahaya'],
                    datasets: [{
                        data: [@Model.HealthyCount, @Model.AtRiskCount, @Model.DangerCount],
                        backgroundColor: ['#10B981', '#F59E0B', '#EF4444'],
                        borderWidth: 2, borderColor: '#ffffff'
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { padding: 20, font: { family: 'Inter', size: 12 } } } } }
            });
            </text>
        }
        @if (divisions.Any())
        {
            <text>
            new Chart(document.getElementById('barChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(divLabels),
                    datasets: [{
                        label: 'Stress Level (%)',
                        data: @Html.Raw(divStress),
                        backgroundColor: '#A7C7FF', borderRadius: 4, barPercentage: 0.5
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, max: 100 }, x: { grid: { display: false } } }
                }
            });
            </text>
        }
    });
</script>
