@model LightenUp.Web.Models.Schedule
@{
    var idCulture = new System.Globalization.CultureInfo("id-ID");
    var startTime = Model.SessionStart.ToString("HH:mm", idCulture);
    var endTime = Model.SessionStart.AddMinutes(Model.DurationMinutes).ToString("HH:mm", idCulture);
    var fullDate = Model.SessionStart.ToString("dddd, d MMMM yyyy", idCulture);
    
    var statusClass = Model.Status switch
    {
        "Completed" => "completed",
        "Cancelled" => "cancelled",
        _ => "scheduled"
    };

    var statusLabel = Model.Status switch
    {
        "Completed" => "Selesai",
        "Cancelled" => "Dibatalkan",
        _ => "Akan Datang"
    };
}

<div class="modal-container" style="max-width: 500px; padding: 0;">
    <div class="modal-header" style="padding: 24px 24px 10px 24px;">
        <h2 class="modal-title" style="margin: 0; font-size: 18px; color: var(--text-dark);">Detail Jadwal Konseling</h2>
        <button class="close-btn" onclick="closeScheduleDetailModal()">&times;</button>
    </div>

    <div style="padding: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px;">
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 48px; height: 48px; border-radius: 50%; background: #F3E8FF; color: #9333EA; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 700;">
                    @(Model.Patient?.User?.FullName?.Length > 0 ? Model.Patient.User.FullName.Substring(0, 1).ToUpper() : "?")
                </div>
                <div>
                    <div style="font-weight: 600; font-size: 16px; color: var(--text-dark);">@(Model.Patient?.User?.FullName ?? "—")</div>
                    <div style="font-size: 13px; color: var(--text-muted); margin-top: 2px;">@(Model.Patient?.Company?.Name ?? "Perusahaan belum diatur")</div>
                </div>
            </div>
            <span class="psy-status-chip psy-status--@statusClass">@statusLabel</span>
        </div>

        <div style="border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); padding: 16px 0; margin-bottom: 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div>
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Tanggal</div>
                <div style="font-size: 14px; font-weight: 600; color: var(--text-dark);">@fullDate</div>
            </div>
            <div>
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Waktu & Durasi</div>
                <div style="font-size: 14px; font-weight: 600; color: var(--text-dark);">@startTime - @endTime WIB (@Model.DurationMinutes mnt)</div>
            </div>
        </div>
        
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div style="margin-bottom: 24px;">
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Catatan Tambahan</div>
                <div style="background: #F9FAFB; padding: 16px; border-radius: 8px; font-size: 14px; color: var(--text-dark); line-height: 1.5; border: 1px solid #E5E7EB;">
                    @Model.Notes
                </div>
            </div>
        }

        <div style="display: flex; gap: 12px; height: 36px; justify-content: flex-end;">
            <button type="button" class="btn-outline" onclick="closeScheduleDetailModal()" style="height: 100%; display: flex; align-items: center; justify-content: center; margin: 0; border: 1px solid var(--border-color); color: var(--text-muted); border-radius: 999px; font-size: 13px; font-weight: 500; padding: 0 24px;">Tutup</button>
            <a href="@Url.Action("PatientScheduleHistory", "Psychologist", new { id = Model.PatientId })" 
               class="btn-fill" style="height: 100%; display: flex; align-items: center; justify-content: center; margin: 0; text-decoration: none; border-radius: 999px; font-size: 13px; font-weight: 500; padding: 0 24px;">
                Lihat Riwayat Lengkap Klien
            </a>
        </div>
    </div>
</div>
