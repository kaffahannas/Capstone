@model LightenUp.Web.Models.ViewModels.PsyWorksheetReviewViewModel
@{
    var statusClass = Model.Status switch
    {
        "Completed" => "completed",
        "InProgress" => "review",
        "Assigned" => "assigned",
        _ => "assigned"
    };

    var statusLabel = Model.Status switch
    {
        "Completed" => "Selesai",
        "InProgress" => "Review",
        "Assigned" => "Belum Dikerjakan",
        _ => "Belum Dikerjakan"
    };
}

<div class="modal-container" style="max-width: 600px; padding: 0;">
    <div class="modal-header" style="padding: 24px 24px 10px 24px;">
        <h2 class="modal-title" style="margin: 0; font-size: 18px; color: var(--text-dark);">Tinjau Worksheet</h2>
        <button class="close-btn" onclick="closeWorksheetDetailModal()">&times;</button>
    </div>

    <div style="padding: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px;">
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 48px; height: 48px; border-radius: 50%; background: #F3E8FF; color: #9333EA; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 700;">
                    @(Model.PatientName?.Length > 0 ? Model.PatientName.Substring(0, 1).ToUpper() : "?")
                </div>
                <div>
                    <div style="font-weight: 600; font-size: 16px; color: var(--text-dark);">@(Model.PatientName ?? "—")</div>
                    <div style="font-size: 13px; color: var(--text-muted); margin-top: 2px;">Pasien Klien</div>
                </div>
            </div>
            <span class="psy-status-chip psy-status--@statusClass">@statusLabel</span>
        </div>

        <div style="border-top: 1px solid var(--border-color); padding-top: 20px; margin-bottom: 24px;">
            <div style="margin-bottom: 16px;">
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Nama Tugas</div>
                <div style="font-size: 15px; font-weight: 600; color: var(--text-dark);">@Model.TaskName</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Deskripsi</div>
                <div style="font-size: 14px; color: var(--text-dark); line-height: 1.5;">@(Model.Description ?? "—")</div>
            </div>
            
            <div style="margin-bottom: 16px;">
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Catatan Pasien</div>
                <div style="background: #F9FAFB; padding: 12px; border-radius: 8px; font-size: 14px; color: var(--text-dark); border: 1px solid #E5E7EB; min-height: 40px;">
                    @(string.IsNullOrEmpty(Model.PatientNote) ? "—" : Model.PatientNote)
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ProofImagePath))
            {
                <div style="margin-bottom: 16px;">
                    <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">Bukti Pengerjaan</div>
                    <img src="@Model.ProofImagePath" style="max-width: 100%; border-radius: 8px; border: 1px solid var(--border-color);" alt="bukti" />
                </div>
            }
        </div>

        <form method="post" action="/Psychologist/ReviewWorksheet" style="background:#fff; border:1px solid #E5E7EB; border-radius:12px; padding:20px; margin-bottom: 24px;">
            <input type="hidden" name="WorksheetId" value="@Model.WorksheetId" />
            <input type="hidden" name="TaskName" value="@Model.TaskName" />
            <input type="hidden" name="PatientName" value="@Model.PatientName" />
            <input type="hidden" name="Status" value="@Model.Status" />
            <div style="font-weight: 600; font-size: 14px; color: var(--text-dark); margin-bottom: 12px;">Umpan Balik Anda</div>
            <textarea name="PsychologistFeedback" rows="3"
                      style="width:100%; padding:10px 12px; border:1px solid #E5E7EB; border-radius:8px; font-family:inherit; font-size:14px; resize:vertical;">@Model.PsychologistFeedback</textarea>
            
            <div style="display:flex; gap:12px; margin-top:16px; height: 36px;">
                <button type="submit" name="action" value="SaveNote"
                        class="btn-outline" style="flex: 1; height: 100%; display: flex; align-items: center; justify-content: center; margin: 0; border-radius: 999px; font-size: 13px; font-weight: 500;">
                    Simpan Catatan
                </button>
                @if (Model.Status == "Completed")
                {
                    <button type="submit" name="action" value="Reopen"
                            class="btn-fill" style="flex: 1; height: 100%; display: flex; align-items: center; justify-content: center; margin: 0; background:#F59E0B; border-radius: 999px; font-size: 13px; font-weight: 500;">
                        Buka Kembali
                    </button>
                }
                else
                {
                    <button type="submit" name="action" value="Complete"
                            class="btn-fill" style="flex: 1; height: 100%; display: flex; align-items: center; justify-content: center; margin: 0; border-radius: 999px; font-size: 13px; font-weight: 500;">
                        Tandai Selesai
                    </button>
                }
            </div>
        </form>

        <div style="display: flex; justify-content: flex-end; height: 36px; gap: 12px;">
            <button type="button" class="btn-outline" onclick="openEditWorksheetModal(@Model.WorksheetId)" style="height: 100%; display: flex; align-items: center; justify-content: center; margin: 0; border-radius: 999px; font-size: 13px; font-weight: 500; padding: 0 20px; border: 1px solid #4338CA; color: #4338CA; background: transparent;">
                Edit Worksheet
            </button>
            <button type="button" class="btn-outline" onclick="closeWorksheetDetailModal()" style="height: 100%; display: flex; align-items: center; justify-content: center; margin: 0; border: 1px solid var(--border-color); color: var(--text-muted); border-radius: 999px; font-size: 13px; font-weight: 500; padding: 0 24px;">Tutup</button>
        </div>
    </div>
</div>
