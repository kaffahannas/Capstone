@model LightenUp.Web.Models.ViewModels.PsyWorksheetEditViewModel

<div class="modal-container" style="max-width: 600px; padding: 0;">
    <div class="modal-header" style="padding: 24px 24px 10px 24px;">
        <h2 class="modal-title" style="margin: 0; font-size: 18px; color: var(--text-dark);">Edit Worksheet</h2>
        <button type="button" class="close-btn" onclick="closeWorksheetDetailModal()">&times;</button>
    </div>

    <div style="padding: 24px;">
        <form asp-action="EditWorksheet" asp-controller="Psychologist" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="WorksheetId" />
            <input type="hidden" asp-for="PatientName" />

            <div style="margin-bottom: 20px;">
                <label style="display:block; margin-bottom: 8px; font-weight: 600; color: #374151; font-size: 14px;">Nama Pasien</label>
                <div style="font-weight: 500; color: #111827; padding: 12px 16px; background: #F9FAFB; border-radius: 12px; border: 1px solid #E5E7EB;">
                    @Model.PatientName
                </div>
            </div>

            <div style="margin-bottom: 20px;">
                <label asp-for="TaskName" style="display:block; margin-bottom: 8px; font-weight: 600; color: #374151; font-size: 14px;">Nama Tugas</label>
                <input asp-for="TaskName" class="form-control" style="width: 100%; padding: 10px 14px; border-radius: 8px; border: 1px solid #D1D5DB; font-size: 14px;" />
            </div>

            <div style="margin-bottom: 20px;">
                <label asp-for="Description" style="display:block; margin-bottom: 8px; font-weight: 600; color: #374151; font-size: 14px;">Deskripsi Tugas</label>
                <textarea asp-for="Description" rows="3" style="width: 100%; padding: 10px 14px; border-radius: 8px; border: 1px solid #D1D5DB; font-size: 14px; font-family: inherit; resize: vertical;"></textarea>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
                <div>
                    <label asp-for="DeadlineDate" style="display:block; margin-bottom: 8px; font-weight: 600; color: #374151; font-size: 14px;">Tanggal Deadline</label>
                    <input asp-for="DeadlineDate" type="date" class="form-control" style="width: 100%; padding: 10px 14px; border-radius: 8px; border: 1px solid #D1D5DB; font-size: 14px;" />
                </div>
                <div>
                    <label asp-for="DeadlineTime" style="display:block; margin-bottom: 8px; font-weight: 600; color: #374151; font-size: 14px;">Waktu Deadline</label>
                    <input asp-for="DeadlineTime" type="time" class="form-control" style="width: 100%; padding: 10px 14px; border-radius: 8px; border: 1px solid #D1D5DB; font-size: 14px;" />
                </div>
            </div>

            <div style="display: flex; gap: 12px; justify-content: flex-end; padding-top: 16px; border-top: 1px solid #E5E7EB;">
                <button type="button" class="btn-outline" onclick="openWorksheetDetailModal(@Model.WorksheetId)" style="height: 38px; padding: 0 24px; border-radius: 999px; font-size: 14px; font-weight: 500; border: 1px solid #D1D5DB; color: #4B5563;">Batal</button>
                <button type="submit" style="height: 38px; padding: 0 24px; border-radius: 999px; font-size: 14px; font-weight: 600; color: white; background: #4338CA; border: none; cursor: pointer; box-shadow: 0 4px 12px rgba(67,56,202,0.2);">Simpan Perubahan</button>
            </div>
        </form>
    </div>
</div>
