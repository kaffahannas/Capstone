@model LightenUp.Web.Models.ViewModels.PsyAddTaskViewModel
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Tambah Tugas";
}

<a href="/Psychologist/Worksheet" class="back-link">← Kembali ke Worksheet</a>

<div class="dashboard-header" style="margin-bottom: 20px;">
    <div>
        <h1 class="text-header">Tambahkan Tugas</h1>
        <p class="text-subtitle">Berikan tugas/aktivitas baru untuk salah satu pasien aktif Anda.</p>
    </div>
</div>

<div style="max-width: 560px; background: white; border: 1px solid var(--border-color); border-radius: 16px; padding: 24px;">
    <form asp-action="AddTask" method="post">
        <div asp-validation-summary="ModelOnly" style="color:#B91C1C; margin-bottom: 12px;"></div>

        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label">Pasien</label>
            <select asp-for="PatientId" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%;">
                <option value="0">-- Pilih Pasien --</option>
                @foreach (var p in Model.AvailablePatients)
                {
                    <option value="@p.PatientId">@p.FullName @(p.CompanyName != null ? "(" + p.CompanyName + ")" : "")</option>
                }
            </select>
            <span asp-validation-for="PatientId" style="color:#B91C1C; font-size:12px;"></span>
        </div>

        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label">Nama Tugas</label>
            <input asp-for="TaskName" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%;" placeholder="Mis. Meditasi 30 Menit" />
            <span asp-validation-for="TaskName" style="color:#B91C1C; font-size:12px;"></span>
        </div>

        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label">Deskripsi (opsional)</label>
            <textarea asp-for="Description" rows="3" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%; font-family:inherit;" placeholder="Jelaskan tugas yang harus dikerjakan..."></textarea>
        </div>

        <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px;">
            <div class="form-group">
                <label class="form-label">Tanggal Deadline</label>
                <input asp-for="DeadlineDate" type="date" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%;" />
            </div>
            <div class="form-group">
                <label class="form-label">Jam Deadline</label>
                <input asp-for="DeadlineTime" type="time" class="form-control" style="padding:10px; border:1px solid #E5E7EB; border-radius:6px; width:100%;" />
            </div>
        </div>

        <div style="display:flex; gap: 12px;">
            <a href="/Psychologist/Worksheet" style="flex:1; padding:12px; text-align:center; border-radius:8px; border:1px solid var(--primary-purple); color:var(--primary-purple); text-decoration:none; font-weight:600;">Batalkan</a>
            <button type="submit" style="flex:1; padding:12px; background:var(--primary-purple); color:white; border:none; border-radius:8px; font-weight:600; cursor:pointer;">Simpan</button>
        </div>
    </form>
</div>
