@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Detail Mitra - " + ViewBag.CompanyName;
}

<div style="padding-top: 10px;">
    <!-- Tombol Kembali Asli Menggunakan href URL -->
    <a href="/Psychologist/Index" style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; background: transparent; border: 1px solid #374151; border-radius: 4px; color: #374151; font-size: 13px; font-weight: 600; cursor: pointer; margin-bottom: 24px; transition: 0.2s; text-decoration: none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Kembali ke Beranda
    </a>

    <div style="margin-bottom: 24px;">
        <p style="font-size: 14px; color: var(--text-dark); margin: 0 0 8px 0; font-weight: 500;">Client aktif dari <span style="font-weight: 700;">@ViewBag.CompanyName</span></p>
        <div style="display: flex; align-items: center; gap: 8px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            <span style="font-size: 24px; font-weight: 800; color: var(--text-dark);">6</span>
            <span style="font-size: 16px; color: var(--text-dark);">orang</span>
        </div>
    </div>

    <!-- 3 Box Status Horizontal Lebar -->
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 24px;">
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 12px; padding: 24px 20px; display: flex; flex-direction: column; align-items: center; text-align: center; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
            <div style="width: 32px; height: 32px; border-radius: 50%; background: #D1FAE5; color: #10B981; display: flex; align-items: center; justify-content: center; margin-bottom: 12px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            <h3 style="margin: 0 0 4px 0; font-size: 24px; font-weight: 800; color: var(--text-dark);">3</h3>
            <p style="margin: 0; font-size: 13px; color: var(--text-muted);">Sehat</p>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 12px; padding: 24px 20px; display: flex; flex-direction: column; align-items: center; text-align: center; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
            <div style="width: 32px; height: 24px; border-radius: 6px; background: #FEF9C3; color: #CA8A04; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; margin-top: 4px;"><div style="width: 8px; height: 8px; background: currentColor; border-radius: 2px;"></div></div>
            <h3 style="margin: 0 0 4px 0; font-size: 24px; font-weight: 800; color: var(--text-dark);">2</h3>
            <p style="margin: 0; font-size: 13px; color: var(--text-muted);">Beresiko</p>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 12px; padding: 24px 20px; display: flex; flex-direction: column; align-items: center; text-align: center; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
            <div style="width: 32px; height: 32px; border-radius: 50%; background: #FFEDD5; color: #EA580C; display: flex; align-items: center; justify-content: center; margin-bottom: 12px;"><span style="font-weight: 800; font-size: 16px;">!</span></div>
            <h3 style="margin: 0 0 4px 0; font-size: 24px; font-weight: 800; color: var(--text-dark);">1</h3>
            <p style="margin: 0; font-size: 13px; color: var(--text-muted);">Bahaya</p>
        </div>
    </div>

    <!-- BANNER PERINGATAN BAHAYA -->
    <div style="background: #EF4444; border-radius: 12px; padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; color: white;">
        <div style="display: flex; align-items: center; gap: 16px;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FBBF24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            <div>
                <h3 style="margin: 0 0 4px 0; font-size: 16px; font-weight: 700;">Ada 1 karyawan dalam kondisi bahaya!</h3>
                <p style="margin: 0; font-size: 13px; opacity: 0.9;">Segera laporkan kepada HR terkait untuk penanganan lebih lanjut.</p>
            </div>
        </div>
        <button onclick="openHrListModal()" style="background: white; color: #EF4444; border: none; padding: 10px 20px; border-radius: 6px; font-weight: 600; font-size: 13px; cursor: pointer; transition: 0.2s;">
            Segera Laporkan Ke HR
        </button>
    </div>

    <!-- Filter Bar -->
    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 16px; margin-bottom: 24px;">
        <div style="display: flex; align-items: center; background: white; border: 1px solid var(--border-color); border-radius: 8px; padding: 10px 16px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" style="margin-right: 10px;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" placeholder="Cari Client...." style="border: none; outline: none; width: 100%; font-size: 13px;" />
        </div>
        <select style="padding: 10px 16px; border: 1px solid var(--border-color); border-radius: 8px; background: white; outline: none; cursor: pointer; color: var(--text-dark); font-size: 13px;"><option>Semua Divisi</option></select>
        <select style="padding: 10px 16px; border: 1px solid var(--border-color); border-radius: 8px; background: white; outline: none; cursor: pointer; color: var(--text-dark); font-size: 13px;"><option>Semua Status</option></select>
    </div>

    <!-- Tombol Navigasi Bawah (Meneruskan Parameter ke Halaman Jadwal) -->
    <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
        <button onclick="window.location.href='/Psychologist/ScheduleHistory?company=@Uri.EscapeDataString(ViewBag.CompanyName)'" style="width: 100%; background: #8B5CF6; color: white; border: none; border-radius: 8px; padding: 14px; font-size: 14px; font-weight: 600; cursor: pointer;">
            Monitor Jadwal Client
        </button>
        <button onclick="window.location.href='/Psychologist/WorksheetHistory?company=@Uri.EscapeDataString(ViewBag.CompanyName)'" style="width: 100%; background: #8B5CF6; color: white; border: none; border-radius: 8px; padding: 14px; font-size: 14px; font-weight: 600; cursor: pointer;">
            Monitor Worksheet Client
        </button>
        <button onclick="openHrListModal()" style="width: 100%; background: #8B5CF6; color: white; border: none; border-radius: 8px; padding: 14px; font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            Kontak HR
        </button>
        <button style="width: 100%; background: #EA580C; color: white; border: none; border-radius: 8px; padding: 14px; font-size: 14px; font-weight: 600; cursor: pointer;">
            Hapus Mitra
        </button>
    </div>
</div>

<!-- ======================================================= -->
<!-- MODAL: DAFTAR HR                                        -->
<!-- ======================================================= -->
<div class="modal-overlay" id="hrListModal">
    <div class="modal-container" style="max-width: 450px; padding: 24px;">
        <div class="modal-header" style="margin-bottom: 20px;">
            <button class="close-btn" onclick="closeHrListModal()" style="position: static; color: var(--text-dark);"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg></button>
            <h2 class="modal-title" style="text-align: center; width: 100%; margin-left: -24px;">Data HR @ViewBag.CompanyName</h2>
        </div>
        <div class="form-group" style="margin-bottom: 20px;"><label class="form-label">Cari HR</label><input type="text" class="form-control" placeholder="Masukkan nama atau divisi" style="border-color: #E5E7EB; border-radius: 4px;" /><span class="form-help" style="color: var(--primary-purple);">Gunakan kolom ini untuk mencari HR.</span></div>
        <h3 style="font-size: 16px; font-weight: 700; margin: 0 0 4px 0; color: var(--text-dark);">Daftar HR</h3>
        <p style="font-size: 12px; color: var(--text-muted); margin: 0 0 16px 0;">Temukan HR menurut kebutuhan anda</p>
        <div style="display: flex; flex-direction: column; gap: 0;">
            <div onclick="openHrDetailModal('Andi Prabowo')" style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border-color); cursor: pointer;">
                <div style="display: flex; align-items: center; gap: 12px;">
                    <div style="width: 32px; height: 32px; background: #E0F2FE; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #0EA5E9;"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" /></svg></div>
                    <span style="font-size: 13px; font-weight: 600; color: var(--text-dark);">Andi Prabowo</span>
                </div>
                <div style="text-align: right; display: flex; align-items: center; gap: 12px;">
                    <div><span style="display: block; font-size: 11px; font-weight: 600; color: var(--text-dark);">Ketersediaan:</span><span style="display: block; font-size: 11px; color: var(--text-muted);">Senin-Jumat,<br />09:00-17:00</span></div>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--text-dark);"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ======================================================= -->
<!-- MODAL: DETAIL PROFIL HR                                 -->
<!-- ======================================================= -->
<div class="modal-overlay" id="hrDetailModal">
    <div class="modal-container" style="max-width: 400px; padding: 24px;">
        <div class="modal-header" style="margin-bottom: 20px;">
            <button class="close-btn" onclick="closeHrDetailModal()" style="position: static; color: var(--text-dark);"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg></button>
        </div>
        <div style="border: 1px solid var(--border-color); border-radius: 8px; overflow: hidden; margin-bottom: 20px;">
            <div style="height: 250px; background: #F3F4F6; display: flex; align-items: center; justify-content: center;"><span style="font-weight: 700; color: var(--text-dark);">Profil HR</span></div>
            <div style="padding: 16px; background: white;">
                <span id="hrDetailName" style="display: block; font-size: 11px; color: var(--text-muted); margin-bottom: 4px;">Andi Prabowo</span>
                <span style="display: block; font-size: 14px; font-weight: 700; color: var(--text-dark);">HR @ViewBag.CompanyName</span>
            </div>
        </div>
        <button style="width: 100%; padding: 12px; background: #F3F4F6; border: none; color: var(--text-dark); border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: 0.2s;" onmouseover="this.style.background='#E5E7EB'" onmouseout="this.style.background='#F3F4F6'" onclick="closeHrDetailModal()">Tutup Profil</button>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const modalHrList = document.getElementById("hrListModal");
        window.openHrListModal = function() { if(modalHrList) modalHrList.classList.add("active"); }
        window.closeHrListModal = function() { if(modalHrList) modalHrList.classList.remove("active"); }
        if (modalHrList) { modalHrList.addEventListener("click", function(e) { if (e.target === modalHrList) closeHrListModal(); }); }

        const modalHrDetail = document.getElementById("hrDetailModal");
        window.openHrDetailModal = function(hrName) {
            const hrDetailName = document.getElementById("hrDetailName");
            if(hrDetailName) hrDetailName.innerText = hrName;
            if(modalHrList) modalHrList.classList.remove("active");
            if(modalHrDetail) modalHrDetail.classList.add("active");
        }
        window.closeHrDetailModal = function() {
            if(modalHrDetail) modalHrDetail.classList.remove("active");
            if(modalHrList) modalHrList.classList.add("active");
        }
        if (modalHrDetail) { modalHrDetail.addEventListener("click", function(e) { if (e.target === modalHrDetail) closeHrDetailModal(); }); }
    });
</script>