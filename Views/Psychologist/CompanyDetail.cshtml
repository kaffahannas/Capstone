@using LightenUp.Web.Models
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Detail Mitra - " + ViewBag.CompanyName;

    var patients = ViewBag.Patients as List<Patient> ?? new List<Patient>();
    var sehat = (int)(ViewBag.SehatCount ?? 0);
    var beresiko = (int)(ViewBag.BeresikoCount ?? 0);
    var bahaya = (int)(ViewBag.BahayaCount ?? 0);
    var company = ViewBag.Company as Company;
}

<div style="padding-top: 10px;">
    <a href="/Psychologist/Index" style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; background: transparent; border: 1px solid #374151; border-radius: 4px; color: #374151; font-size: 13px; font-weight: 600; cursor: pointer; margin-bottom: 24px; text-decoration: none;">
        ← Kembali ke Beranda
    </a>

    <div style="margin-bottom: 24px;">
        <p style="font-size: 14px; color: var(--text-dark); margin: 0 0 8px 0; font-weight: 500;">Client aktif dari <span style="font-weight: 700;">@ViewBag.CompanyName</span></p>
        <div style="display: flex; align-items: center; gap: 8px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            <span style="font-size: 24px; font-weight: 800; color: var(--text-dark);">@patients.Count</span>
            <span style="font-size: 16px; color: var(--text-dark);">orang</span>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 24px;">
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 12px; padding: 24px 20px; text-align: center;">
            <div style="font-size: 24px;">✅</div>
            <h3 style="margin: 4px 0; font-size: 24px; font-weight: 800; color: #047857;">@sehat</h3>
            <p style="margin: 0; font-size: 13px; color: var(--text-muted);">Sehat</p>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 12px; padding: 24px 20px; text-align: center;">
            <div style="font-size: 24px;">⚠️</div>
            <h3 style="margin: 4px 0; font-size: 24px; font-weight: 800; color: #B45309;">@beresiko</h3>
            <p style="margin: 0; font-size: 13px; color: var(--text-muted);">Beresiko</p>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 12px; padding: 24px 20px; text-align: center;">
            <div style="font-size: 24px;">🔴</div>
            <h3 style="margin: 4px 0; font-size: 24px; font-weight: 800; color: #B91C1C;">@bahaya</h3>
            <p style="margin: 0; font-size: 13px; color: var(--text-muted);">Bahaya</p>
        </div>
    </div>

    @if (bahaya > 0)
    {
        <div style="background: #EF4444; border-radius: 12px; padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; color: white;">
            <div>
                <h3 style="margin: 0 0 4px 0; font-size: 16px; font-weight: 700;">⚠️ Ada @bahaya karyawan dalam kondisi bahaya!</h3>
                <p style="margin: 0; font-size: 13px; opacity: 0.9;">Segera laporkan kepada HR terkait untuk penanganan lebih lanjut.</p>
            </div>
            @{
                var firstBahaya = patients.FirstOrDefault(p => p.MentalHealthStatus == "Bahaya");
            }
            @if (firstBahaya != null)
            {
                <a href="@Url.Action("ReportToHr", "Psychologist", new { patientId = firstBahaya.PatientId })"
                   style="background: white; color: #EF4444; border: none; padding: 10px 20px; border-radius: 6px; font-weight: 600; font-size: 13px; text-decoration: none;">
                    Segera Laporkan Ke HR
                </a>
            }
        </div>
    }

    <!-- Patient list -->
    @if (!patients.Any())
    {
        <div style="padding: 40px; text-align: center; color: #9CA3AF; border: 1px dashed var(--border-color); border-radius: 12px;">
            Belum ada pasien dari @ViewBag.CompanyName yang Anda tangani.
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px;">
            @foreach (var p in patients)
            {
                var badgeColor = p.MentalHealthStatus switch
                {
                    "Sehat" => "#D1FAE5; color:#047857",
                    "Beresiko" => "#FEF3C7; color:#B45309",
                    "Bahaya" => "#FEE2E2; color:#B91C1C",
                    _ => "#E5E7EB; color:#374151"
                };
                <a href="@Url.Action("PatientDetail", "Psychologist", new { id = p.PatientId })"
                   style="background:white; padding:14px 18px; border-radius:12px; border:1px solid var(--border-color); display:flex; justify-content:space-between; align-items:center; text-decoration:none; color:inherit;">
                    <div>
                        <strong>@(p.User?.FullName ?? "—")</strong>
                        <div style="font-size: 12px; color: var(--text-muted);">@(p.Department ?? "Divisi belum diatur")</div>
                    </div>
                    <span style="padding:4px 12px; border-radius:999px; font-size:12px; background:@badgeColor;">@p.MentalHealthStatus</span>
                </a>
            }
        </div>
    }

    <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
        <a href="/Psychologist/ScheduleHistory?company=@Uri.EscapeDataString(ViewBag.CompanyName)" style="text-decoration:none; text-align:center; background: #8B5CF6; color: white; border-radius: 8px; padding: 14px; font-size: 14px; font-weight: 600;">
            Monitor Jadwal Client
        </a>
        <a href="/Psychologist/WorksheetHistory?company=@Uri.EscapeDataString(ViewBag.CompanyName)" style="text-decoration:none; text-align:center; background: #8B5CF6; color: white; border-radius: 8px; padding: 14px; font-size: 14px; font-weight: 600;">
            Monitor Worksheet Client
        </a>
        @if (!string.IsNullOrEmpty(company?.ContactEmail))
        {
            <a href="mailto:@company.ContactEmail" style="text-decoration:none; text-align:center; background: #8B5CF6; color: white; border-radius: 8px; padding: 14px; font-size: 14px; font-weight: 600;">
                Kontak HR (@company.ContactEmail)
            </a>
        }
        else
        {
            <button disabled style="background: #E5E7EB; color: #9CA3AF; border: none; border-radius: 8px; padding: 14px; font-size: 14px; font-weight: 600; cursor: not-allowed;">
                Kontak HR (email belum diatur)
            </button>
        }
    </div>
</div>
