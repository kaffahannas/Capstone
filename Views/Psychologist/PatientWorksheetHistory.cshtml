@using LightenUp.Web.Models
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Riwayat Worksheet Pasien";

    var worksheets = ViewBag.Worksheets as List<Worksheet> ?? new List<Worksheet>();
    var patientId = (int)(ViewBag.PatientId ?? 0);
    var idCulture = new System.Globalization.CultureInfo("id-ID");

    (string label, string color) MapStatus(string status) => status switch
    {
        "Assigned" => ("Belum Selesai", "#FCA5A5"),
        "InProgress" => ("On Progress", "#FEF08A"),
        "Completed" => ("Selesai", "#A7F3D0"),
        _ => (status, "#A7F3D0")
    };
}

<a href="javascript:history.back()" class="back-link">← Kembali</a>

<div class="dashboard-header" style="margin-bottom: 20px;">
    <div>
        <h1 class="text-header">Riwayat Worksheet: @ViewBag.PatientName</h1>
        <p class="text-subtitle">Pantau seluruh tugas worksheet pasien ini.</p>
    </div>
</div>

<div class="patient-list-container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <a href="@Url.Action("AddTask", "Psychologist", new { patientId })" style="display: flex; align-items: center; gap: 8px; padding: 12px 20px; background: var(--primary-purple); color: white; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration:none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Tambah Tugas Pasien
        </a>
    </div>

    @if (!worksheets.Any())
    {
        <div style="padding: 40px; text-align: center; color: #9CA3AF; border: 1px dashed var(--border-color); border-radius: 12px;">
            Belum ada worksheet untuk pasien ini.
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 16px;">
            @foreach (var w in worksheets)
            {
                var (label, color) = MapStatus(w.Status);
                <a class="history-card" href="@Url.Action("ReviewWorksheet", "Psychologist", new { id = w.WorksheetId })" style="text-decoration:none; color:inherit;">
                    <div>
                        <h3>@w.TaskName</h3>
                        <p>@w.Deadline.ToString("d MMMM yyyy", idCulture)</p>
                        <p style="margin-top: 8px; font-weight: 500; font-size: 13px; color: @color;">Status : @label</p>
                    </div>
                </a>
            }
        </div>
    }
</div>
