@using LightenUp.Web.Controllers
@{
    ViewData["Title"] = "Pendapatan Saya";
    Layout = "_LayoutDashboard";
    var idCulture = new System.Globalization.CultureInfo("id-ID");
    string Idr(decimal v) => v.ToString("C0", idCulture);

    var assignmentRows = ViewBag.AssignmentRows as List<PayslipAssignmentRow> ?? new();
    int activeCount = (int)(ViewBag.ActivePatientCount ?? 0);
    decimal gross = (decimal)(ViewBag.GrossThisMonth ?? 0m);
    decimal psyShare = (decimal)(ViewBag.PsyShareThisMonth ?? 0m);
    string monthLabel = ViewBag.MonthLabel ?? "";
    bool hasSnapshots = (bool)(ViewBag.HasSnapshots ?? false);
}

<div style="max-width:840px;">

<div class="tasks-hero" style="background:linear-gradient(135deg,#0f4c81 0%,#1565c0 100%); color:white; padding:32px; border-radius:20px; margin-bottom:28px; box-shadow:0 10px 25px rgba(15,76,129,.25); position:relative; overflow:hidden;">
    <div style="position:absolute; right:-20px; top:-40px; opacity:.08; font-size:160px; user-select:none;">💰</div>
    <div style="position:relative; z-index:1;">
        <h1 style="margin:0 0 6px; font-size:26px; font-weight:700;">Ringkasan Pendapatan</h1>
        <p style="margin:0; font-size:14px; opacity:.9;">Berdasarkan pasien aktif × nilai slot langganan · Periode: <strong>@monthLabel</strong></p>
    </div>
</div>

@if (!hasSnapshots && activeCount > 0)
{
    <div style="background:#fffbeb; border:1px solid #fcd34d; border-radius:12px; padding:16px; margin-bottom:24px;">
        ⚠️ Beberapa penugasan belum memiliki snapshot nilai slot. Hubungi Admin jika angka tampak nol.
    </div>
}

<div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(180px,1fr)); gap:16px; margin-bottom:28px;">
    <div style="background:#fff; border-radius:14px; box-shadow:0 2px 10px rgba(0,0,0,.07); padding:20px; text-align:center;">
        <div style="font-size:11px; color:#6b7280; text-transform:uppercase; letter-spacing:.06em; margin-bottom:6px;">Pasien Aktif</div>
        <div style="font-size:32px; font-weight:800; color:#4338ca;">@activeCount</div>
    </div>
    <div style="background:#fff; border-radius:14px; box-shadow:0 2px 10px rgba(0,0,0,.07); padding:20px; text-align:center;">
        <div style="font-size:11px; color:#6b7280; text-transform:uppercase; letter-spacing:.06em; margin-bottom:6px;">Total Slot</div>
        <div style="font-size:22px; font-weight:800; color:#1565c0;">@Idr(gross)</div>
        <div style="font-size:12px; color:#9ca3af;">/ bulan</div>
    </div>
    <div style="background:linear-gradient(135deg,#065f46,#10b981); border-radius:14px; box-shadow:0 2px 10px rgba(0,0,0,.12); padding:20px; text-align:center;">
        <div style="font-size:11px; color:rgba(255,255,255,.8); text-transform:uppercase; letter-spacing:.06em; margin-bottom:6px;">Pendapatan Anda</div>
        <div style="font-size:24px; font-weight:800; color:#fff;">@Idr(psyShare)</div>
        <div style="font-size:12px; color:rgba(255,255,255,.7);">/ bulan</div>
    </div>
</div>

<div style="background:#fff; border-radius:16px; box-shadow:0 2px 10px rgba(0,0,0,.07); padding:24px;">
    <h3 style="font-size:16px; font-weight:700; margin:0 0 16px;">📋 Rincian per Pasien Aktif</h3>
    @if (!assignmentRows.Any())
    {
        <p style="color:#9ca3af; text-align:center; padding:20px 0;">Belum ada pasien aktif dengan penugasan.</p>
    }
    else
    {
        <table style="width:100%; border-collapse:collapse; font-size:13px;">
            <thead>
                <tr style="background:#f9fafb;">
                    <th style="padding:10px 12px; text-align:left;">Pasien</th>
                    <th style="padding:10px 12px; text-align:left;">Tipe</th>
                    <th style="padding:10px 12px; text-align:right;">Nilai Slot</th>
                    <th style="padding:10px 12px; text-align:right;">%</th>
                    <th style="padding:10px 12px; text-align:right;">Pendapatan</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in assignmentRows)
            {
                <tr style="border-bottom:1px solid #f3f4f6;">
                    <td style="padding:10px 12px;">@r.PatientName</td>
                    <td style="padding:10px 12px;">@(r.IsB2B ? "B2B" : "B2C")</td>
                    <td style="padding:10px 12px; text-align:right;">@Idr(r.SlotValue)</td>
                    <td style="padding:10px 12px; text-align:right;">@r.Percentage%</td>
                    <td style="padding:10px 12px; text-align:right; font-weight:600; color:#065f46;">@Idr(r.Earning)</td>
                </tr>
            }
            </tbody>
            <tfoot>
                <tr style="border-top:2px solid #e5e7eb;">
                    <td colspan="4" style="padding:12px; font-weight:700;">Total</td>
                    <td style="padding:12px; text-align:right; font-weight:800; color:#065f46;">@Idr(psyShare)</td>
                </tr>
            </tfoot>
        </table>
    }
</div>

</div>
