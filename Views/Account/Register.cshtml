@model LightenUp.Web.Models.ViewModels.PublicRegisterViewModel

@{
    ViewData["Title"] = "Buat Akun";
    Layout = null;
}

@* #Bagian Daftar# *@

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page register-page">

    <div class="auth-wrapper">
        <div class="auth-container register-card">

            @* #Komponen Header Daftar# *@
            <header class="register-header">
                <a href="/Account/Login" class="back-button register-back" aria-label="Kembali ke masuk">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
                <div class="register-header-text">
                    <h1 class="auth-title register-title">Buat Akun</h1>
                    <p class="auth-subtitle register-subtitle">Lengkapi kolom di bawah untuk melanjutkan.</p>
                </div>
            </header>

            @* #Komponen Form Daftar# *@
            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group">
                    <label asp-for="FullName" class="form-label">Nama Lengkap</label>
                    <input asp-for="FullName" class="form-control-custom" placeholder="John Doe" id="regFullName" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control-custom" placeholder="johndoe@lightenup.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                @* #Komponen Pilih Jenis Akun# *@
                <div class="role-selection-group">
                    <label class="role-selection-label">Pilih Jenis Akun</label>
                    <div class="role-cards register-role-cards">
                        <div class="role-card-wrapper">
                            <input type="radio" asp-for="AccountType" value="Patient" id="rolePatient" class="role-card-input" required />
                            <label class="role-card-label register-role-card" for="rolePatient">Client</label>
                        </div>
                        <div class="role-card-wrapper">
                            <input type="radio" asp-for="AccountType" value="Psychologist" id="rolePsy" class="role-card-input" required />
                            <label class="role-card-label register-role-card" for="rolePsy">Psikolog</label>
                        </div>
                        <div class="role-card-wrapper">
                            <input type="radio" asp-for="AccountType" value="HR" id="roleHr" class="role-card-input" required />
                            <label class="role-card-label register-role-card" for="roleHr">HR</label>
                        </div>
                    </div>
                    <span asp-validation-for="AccountType" class="text-danger"></span>
                    <small class="role-note">
                        Akun Psikolog &amp; HR perlu disetujui tim LightenUp setelah onboarding selesai.
                    </small>
                </div>

                <button type="submit" class="btn-submit">Berikutnya</button>
            </form>

            @* #Komponen Divider Sosial# *@
            <div class="divider"><span>atau daftar dengan</span></div>

            @if (TempData["ExternalError"] != null)
            {
                <div class="text-danger mb-3 text-center">@TempData["ExternalError"]</div>
            }

            @* #Komponen Login Sosial Google# *@
            <div class="social-login-group">
                <form asp-action="ExternalLogin" asp-controller="Account" method="post" id="socialFormGoogle" style="flex:1">
                    <input type="hidden" name="provider" value="Google" />
                    <input type="hidden" name="flow" value="register" />
                    <input type="hidden" name="fullName" id="socialFullName1" value="" />
                    <input type="hidden" name="accountType" id="socialAccountType1" value="" />
                    <button type="submit" class="btn-social" onclick="return copySocialFields(1)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                        </svg> Google
                    </button>
                </form>
            </div>

            @* #Komponen Footer Masuk# *@
            <div class="auth-footer auth-footer--register">
                <span>Sudah memiliki akun?</span>
                <a href="/Account/Login">Masuk</a>
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function copySocialFields(idx) {
            var accountType = document.querySelector('[name="AccountType"]:checked');

            if (!accountType) {
                alert('Silakan pilih Jenis Akun terlebih dahulu.');
                return false;
            }

            // Nama akan diambil otomatis dari Google
            document.getElementById('socialFullName' + idx).value = '';
            document.getElementById('socialAccountType' + idx).value = accountType.value;
            return true;
        }
    </script>
</body>
</html>