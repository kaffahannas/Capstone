@model LightenUp.Web.Models.ViewModels.PublicRegisterViewModel

@{
    ViewData["Title"] = "Buat Akun";
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page register-page">

    <div class="auth-wrapper">
        <div class="auth-container register-card">

            <header class="register-header">
                <a href="/Account/Login" class="back-button register-back" aria-label="Kembali ke masuk">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
                <div class="register-header-text">
                    <h1 class="auth-title register-title">Buat Akun</h1>
                    <p class="auth-subtitle register-subtitle">Lengkapi kolom di bawah untuk melanjutkan.</p>
                </div>
            </header>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group">
                    <label asp-for="FullName" class="form-label">Nama Lengkap</label>
                    <input asp-for="FullName" class="form-control-custom" placeholder="John Doe" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control-custom" placeholder="johndoe@lightenup.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="role-selection-group">
                    <label class="role-selection-label">Pilih Jenis Akun</label>
                    <div class="role-cards register-role-cards">
                        <div class="role-card-wrapper">
                            <input type="radio" asp-for="AccountType" value="Patient" id="rolePatient" class="role-card-input" required />
                            <label class="role-card-label register-role-card" for="rolePatient">Client</label>
                        </div>
                        <div class="role-card-wrapper">
                            <input type="radio" asp-for="AccountType" value="Psychologist" id="rolePsy" class="role-card-input" required />
                            <label class="role-card-label register-role-card" for="rolePsy">Psikolog</label>
                        </div>
                        <div class="role-card-wrapper">
                            <input type="radio" asp-for="AccountType" value="HR" id="roleHr" class="role-card-input" required />
                            <label class="role-card-label register-role-card" for="roleHr">HR</label>
                        </div>
                    </div>
                    <span asp-validation-for="AccountType" class="text-danger"></span>
                    <small class="role-note">
                        Akun Psikolog &amp; HR perlu disetujui tim LightenUp setelah onboarding selesai.
                    </small>
                </div>

                <button type="submit" class="btn-submit">Berikutnya</button>
            </form>

            <div class="auth-footer auth-footer--register">
                <span>Sudah memiliki akun?</span>
                <a href="/Account/Login">Masuk</a>
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>