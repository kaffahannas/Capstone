@model LightenUp.Web.Models.ViewModels.CreatePasswordViewModel

@{
    ViewData["Title"] = "Buat Kata Sandi";
    Layout = null;
}

@* #Bagian Buat Password# *@

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-wrapper">
        <div class="auth-container register-card register-card--password">

            @* #Komponen Header Buat Password# *@
            <header class="password-header">
                <a href="javascript:history.back()" class="back-button password-back" aria-label="Kembali">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
                <div class="password-header-text">
                    <h1 class="auth-title password-title">Buat Kata Sandi</h1>
                    <p class="auth-subtitle password-subtitle">Amankan akun Anda dengan kata sandi yang kuat.</p>
                </div>
            </header>

            @* #Komponen Form Buat Password# *@
            <form asp-action="CreatePassword" method="post">
                <input type="hidden" asp-for="Email" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Kata Sandi Baru</label>
                    <input asp-for="Password" type="password" class="form-control-custom" placeholder="Minimal 6 karakter" id="pwd1" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-label">Konfirmasi Kata Sandi</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control-custom" placeholder="Ulangi kata sandi" id="pwd2" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-submit mt-4">Selesai</button>
            </form>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>