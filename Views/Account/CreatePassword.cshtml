@model LightenUp.Web.Models.ViewModels.CreatePasswordViewModel

@{
    ViewData["Title"] = "Buat Kata Sandi";
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-wrapper">
        <div class="auth-container register-card">

            <a href="javascript:history.back()" class="back-button">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 18L9 12L15 6" stroke="#1f2937" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </a>

            <h1 class="auth-title">Buat Kata Sandi</h1>
            <p class="auth-subtitle">Amankan akun Anda dengan kata sandi yang kuat.</p>

            <form asp-action="CreatePassword" method="post">
                <input type="hidden" asp-for="Email" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Kata Sandi Baru</label>
                    <input asp-for="Password" type="password" class="form-control-custom" placeholder="Minimal 6 karakter" id="pwd1" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-label">Konfirmasi Kata Sandi</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control-custom" placeholder="Ulangi kata sandi" id="pwd2" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-submit mt-4">Selesai</button>
            </form>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>