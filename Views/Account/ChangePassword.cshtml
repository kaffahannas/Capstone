@model LightenUp.Web.Models.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = Model.HasPassword ? "Ubah Password" : "Setel Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page login-page">

    @* #Bagian Ganti Password# *@
    <div class="auth-wrapper">

        <div class="auth-container login-card change-pwd-card">

            @* #Komponen Logo Brand# *@
            <div class="logo-container logo-container--in-card">
                <svg width="72" height="72" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M50 5L90 27V73L50 95L10 73V27L50 5Z" fill="url(#hexGradient)" />
                    <circle cx="50" cy="50" r="18" fill="white" />
                    <line x1="50" y1="14" x2="50" y2="22" stroke="white" stroke-width="3" stroke-linecap="round" />
                    <line x1="50" y1="78" x2="50" y2="86" stroke="white" stroke-width="3" stroke-linecap="round" />
                    <line x1="14" y1="50" x2="22" y2="50" stroke="white" stroke-width="3" stroke-linecap="round" />
                    <line x1="78" y1="50" x2="86" y2="50" stroke="white" stroke-width="3" stroke-linecap="round" />
                    <line x1="25" y1="25" x2="30" y2="30" stroke="white" stroke-width="3" stroke-linecap="round" />
                    <line x1="75" y1="75" x2="70" y2="70" stroke="white" stroke-width="3" stroke-linecap="round" />
                    <line x1="25" y1="75" x2="30" y2="70" stroke="white" stroke-width="3" stroke-linecap="round" />
                    <line x1="75" y1="25" x2="70" y2="30" stroke="white" stroke-width="3" stroke-linecap="round" />
                    <defs>
                        <linearGradient id="hexGradient" x1="10" y1="5" x2="90" y2="95" gradientUnits="userSpaceOnUse">
                            <stop offset="0" stop-color="#C4B5FD" />
                            <stop offset="1" stop-color="#8CE0FF" />
                        </linearGradient>
                    </defs>
                </svg>
                <span class="app-name app-name--in-card">LightenUp</span>
            </div>

            @* #Komponen Header Kembali# *@
            <div class="change-pwd-head">
                <a href="javascript:history.back()" class="change-pwd-back" aria-label="Kembali">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                </a>
                <h1 class="auth-title text-center auth-title--login">@(Model.HasPassword ? "Ubah Password" : "Setel Password")</h1>
            </div>

            <p class="change-pwd-intro">
                @(Model.HasPassword ? "Silakan masukkan password lama Anda untuk keamanan, lalu buat password baru." : "Akun Anda belum memiliki password. Buat password sekarang agar Anda juga bisa login secara manual.")
            </p>

            @* #Komponen Form Ganti Password# *@
            <form asp-action="ChangePassword" method="post">
                <input type="hidden" asp-for="HasPassword" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-center"></div>

                @if (Model.HasPassword)
                {
                    <div class="form-group">
                        <label asp-for="OldPassword" class="form-label"></label>
                        <input asp-for="OldPassword" type="password" class="form-control-custom" placeholder="••••••••" id="oldPasswordInput" autocomplete="current-password" />
                        <span asp-validation-for="OldPassword" class="text-danger"></span>
                    </div>
                }

                <div class="form-group">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" type="password" class="form-control-custom" placeholder="••••••••" id="newPasswordInput" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control-custom" placeholder="••••••••" id="confirmPasswordInput" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="change-pwd-show">
                    <label class="checkbox-group">
                        <input type="checkbox" onclick="togglePasswords()" />
                        <span>Tampilkan Password</span>
                    </label>
                </div>

                <button type="submit" class="btn-submit">Simpan Password</button>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePasswords() {
            var oldPwd = document.getElementById('oldPasswordInput');
            var newPwd = document.getElementById('newPasswordInput');
            var confirmPwd = document.getElementById('confirmPasswordInput');

            if (oldPwd) {
                oldPwd.type = oldPwd.type === "password" ? "text" : "password";
            }
            if (newPwd) {
                newPwd.type = newPwd.type === "password" ? "text" : "password";
            }
            if (confirmPwd) {
                confirmPwd.type = confirmPwd.type === "password" ? "text" : "password";
            }
        }
    </script>
</body>
</html>
