@{
    ViewData["Title"] = "Menunggu Persetujuan";
    Layout = null;
    var roleLabel = (ViewBag.RoleType as string) switch
    {
        "Psychologist" => "Psikolog",
        "HR" => "HR Perusahaan",
        _ => "Akun"
    };
}
@* #Bagian Menunggu Persetujuan# *@
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page">
    @* #Komponen Kartu Pending# *@
    <div class="pending-card">
        <div class="pending-icon">⏳</div>
        <h1 class="pending-title">Hai, @ViewBag.FullName</h1>
        <p class="pending-desc">Akun <strong>@roleLabel</strong> Anda sedang menunggu persetujuan dari tim LightenUp.</p>

        @* #Komponen Langkah Proses# *@
        <div class="pending-steps">
            <strong>Apa yang terjadi sekarang?</strong>
            <ol class="pending-steps-list">
                <li>Tim LightenUp akan meninjau dokumen onboarding Anda.</li>
                <li>Proses biasanya memakan waktu <strong>1–2 hari kerja</strong>.</li>
                <li>Anda akan menerima email saat akun disetujui.</li>
                <li>Setelah disetujui, login kembali untuk mengakses dashboard.</li>
            </ol>
        </div>

        <p class="pending-help">
            Punya pertanyaan? Hubungi <a href="mailto:support@lightenup.com" class="pending-help-link">support@lightenup.com</a>
        </p>

        @* #Komponen Form Keluar# *@
        <form asp-action="Logout" method="post">
            <button type="submit" class="pending-logout-btn">Keluar</button>
        </form>
    </div>
</body>
</html>
