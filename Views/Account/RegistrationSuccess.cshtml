@{
    ViewData["Title"] = "Pendaftaran Berhasil";
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-wrapper">
        <div class="auth-container register-card register-card--success">

            <!-- Ikon Centang Sukses SVG -->
            <svg class="reg-success-icon" width="80" height="80" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="50" cy="50" r="50" fill="#E0E7FF" />
                <circle cx="50" cy="50" r="35" fill="#7C3AED" />
                <path d="M40 50L46.5 56.5L60 43" stroke="white" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>

            <h1 class="auth-title auth-title--reg-success">Pembuatan Akun Selesai!</h1>
            <p class="auth-subtitle auth-subtitle--reg-success">Akun Anda telah berhasil dibuat. Silakan masuk menggunakan email dan kata sandi yang telah Anda daftarkan.</p>

            <a href="/Account/Login" class="btn-submit btn-submit--link">Masuk ke Aplikasi</a>

        </div>
    </div>

</body>
</html>
