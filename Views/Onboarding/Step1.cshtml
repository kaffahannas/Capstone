@model LightenUp.Web.Models.ViewModels.OnboardingStep1ViewModel

@{
    ViewData["Title"] = "Langkah 1";
    Layout = null;
}

@* #Bagian Onboarding Langkah 1# *@

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-wrapper">
        <div class="auth-container register-card">
            
            <a href="/Onboarding/Welcome" class="back-button">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </a>

            <!-- Logo Memanggil File Gambar .ico -->
            <div class="onb-step-logo">
                <img src="~/image/lightenuplogo.ico" alt="LightenUp Logo" class="onb-step-logo-img" onerror="this.classList.add('is-hidden')" />
                <span class="onb-step-logo-text">LightenUp</span>
            </div>

            <h1 class="auth-title auth-title--step1">Langkah 1: Masukkan<br />Foto Diri</h1>
            
            <!-- Indikator Progres -->
            @* #Komponen Progres Langkah 1# *@
            <div class="progress-container mt-3">
                <div class="progress-bar progress-step-1"></div>
            </div>

            <p class="onb-step-note">
                Catatan: Pastikan foto yang dilampirkan adalah foto yang bersifat formal & terlihat profesional, untuk menjaga kredibilitas penyedia layanan psikologi.
            </p>

            @* #Komponen Form Upload Foto# *@
            <form asp-action="Step1" method="post" enctype="multipart/form-data">
                
                @* #Komponen Area Upload# *@
                <label class="upload-area" id="uploadArea">
                    <svg class="upload-icon" id="uploadIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="12" y1="18" x2="12" y2="12"></line>
                        <polyline points="9 15 12 12 15 15"></polyline>
                    </svg>
                    
                    <img id="imagePreview" class="onb-step-preview" alt="" />
                    
                    <div class="upload-text" id="uploadText">
                        Upload file
                    </div>
                    <div class="upload-subtext" id="uploadSubtext">
                        Format JPG/PNG, maksimal 2MB
                    </div>

                    <!-- Input tersembunyi -->
                    <input asp-for="ProfilePhoto" type="file" accept="image/jpeg, image/png" class="file-input-hidden" id="fileInput" />
                </label>
                
                <span asp-validation-for="ProfilePhoto" class="text-danger mb-3 validation-center"></span>

                <button type="submit" class="btn-submit btn-submit--step1">Simpan dan Lanjutnya</button>
            </form>

        </div>
    </div>

    <!-- Script JavaScript untuk Drag & Drop dan Update Teks -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <script>
            const uploadArea = document.getElementById('uploadArea');
            const fileInput = document.getElementById('fileInput');

            // Mematikan efek default browser saat file ditarik ke layar
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                uploadArea.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            // Tambah/Hapus efek highlight saat file diarahkan ke kotak
            ['dragenter', 'dragover'].forEach(eventName => {
                uploadArea.addEventListener(eventName, () => uploadArea.classList.add('dragover'), false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                uploadArea.addEventListener(eventName, () => uploadArea.classList.remove('dragover'), false);
            });

            // Menangkap file saat di-drop
            uploadArea.addEventListener('drop', function(e) {
                let dt = e.dataTransfer;
                let files = dt.files;
            
                if (files.length > 0) {
                    fileInput.files = files; // Memasukkan file yang di-drop ke input form
                    updateUI(files[0]);
                }
            }, false);

            // Menangkap file saat diklik biasa (pilih dari folder)
            fileInput.addEventListener('change', function(e) {
                if (e.target.files.length > 0) {
                    updateUI(e.target.files[0]);
                }
            });

            // Fungsi memperbarui tampilan setelah file dimasukkan
            function updateUI(file) {
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        document.getElementById('imagePreview').src = e.target.result;
                        document.getElementById('imagePreview').classList.add('is-visible');
                        document.getElementById('uploadIcon').classList.add('is-hidden');
                    };
                    reader.readAsDataURL(file);
                }
                
                document.getElementById('uploadText').textContent = file.name;
                document.getElementById('uploadText').classList.add('upload-text--success');
                document.getElementById('uploadSubtext').textContent = 'Foto siap diunggah';
                uploadArea.classList.add('has-file');
            }
    </script>
</body>
</html>
