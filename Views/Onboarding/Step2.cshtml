@model LightenUp.Web.Models.ViewModels.OnboardingStep2ViewModel

@{
    ViewData["Title"] = "Langkah 2";
    Layout = null;
}

@* #Bagian Onboarding Langkah 2# *@

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-wrapper">
        <div class="auth-container register-card">
            
            <a href="/Onboarding/Step1" class="back-button">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 18L9 12L15 6" stroke="#1f2937" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </a>

            @await Html.PartialAsync("_PsyOnboardingBrand")

            <div class="onb-psy-progress-label">Langkah 2 dari 3</div>

            <h1 class="auth-title auth-title--step2">Langkah 2: Status<br />Akademik</h1>
            
            <!-- Indikator Progres (66.66% untuk Step 2) -->
            <div class="progress-container progress-container--step2">
                <div class="progress-bar progress-bar--step2"></div>
            </div>

            <p class="onb-step-note">
                Silakan masukkan informasi akademis Anda.
            </p>

            @* #Komponen Form Akademik# *@
            <form asp-action="Step2" method="post" enctype="multipart/form-data">
                
                <div class="form-group">
                    <label asp-for="LastDegree" class="form-label">Gelar Terakhir</label>
                    <select asp-for="LastDegree" class="form-control-custom form-select-custom">
                        <option value="">Pilih kategori</option>
                        <option value="S1 Psikologi">S1 Psikologi</option>
                        <option value="S2 Magister Profesi Psikologi">S2 Magister Profesi Psikologi</option>
                        <option value="S2 Magister Sains Psikologi">S2 Magister Sains Psikologi</option>
                        <option value="S3 Psikologi">S3 Psikologi</option>
                    </select>
                    <span asp-validation-for="LastDegree" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="University" class="form-label">Universitas Asal</label>
                    <input asp-for="University" class="form-control-custom" placeholder="Contoh: Universitas Indonesia" />
                    <span asp-validation-for="University" class="text-danger"></span>
                </div>
                
                <div class="onb-doc-label-wrap">
                    <label class="form-label">Dokumen pendukung</label>
                </div>

                @* #Komponen Upload Dokumen# *@
                <label class="upload-area upload-area--step2" id="uploadArea">
                    
                    <svg id="uploadIcon" class="upload-icon--step2 upload-icon--default" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
                        <polyline points="13 2 13 9 20 9"></polyline>
                    </svg>
                    
                    <div class="upload-text" id="uploadText">
                        Upload file
                    </div>
                    <div class="upload-subtext" id="uploadSubtext">
                        Format JPG/PDF, maksimal 5 MB
                    </div>

                    <input asp-for="AcademicDocument" type="file" accept="image/jpeg, image/png, application/pdf" class="file-input-hidden" id="fileInput" />
                </label>
                
                <div class="validation-center-wrap">
                    <span asp-validation-for="AcademicDocument" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-submit">Simpan dan Lanjutnya</button>
            </form>

        </div>
    </div>

    <!-- Script JavaScript untuk Fitur Drag and Drop File -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <script>
            const uploadArea = document.getElementById('uploadArea');
            const fileInput = document.getElementById('fileInput');
            const uploadIcon = document.getElementById('uploadIcon');
            const uploadText = document.getElementById('uploadText');
            const uploadSubtext = document.getElementById('uploadSubtext');

            // Mencegah browser membuka file di tab baru saat di-drag
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                uploadArea.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) { e.preventDefault(); e.stopPropagation(); }

            // Efek visual saat file di-drag masuk ke kotak
            ['dragenter', 'dragover'].forEach(eventName => {
                uploadArea.addEventListener(eventName, () => {
                    uploadArea.classList.add('upload-area--drag');
                    uploadIcon.classList.remove('upload-icon--default');
                    uploadIcon.classList.add('upload-icon--purple');
                }, false);
            });

            // Efek visual saat file batal dimasukkan
            ['dragleave', 'drop'].forEach(eventName => {
                uploadArea.addEventListener(eventName, () => {
                    if(!uploadArea.classList.contains('has-file')) {
                        uploadArea.classList.remove('upload-area--drag');
                        uploadIcon.classList.remove('upload-icon--purple');
                        uploadIcon.classList.add('upload-icon--default');
                    }
                }, false);
            });

            // Memproses file yang di-drop
            uploadArea.addEventListener('drop', function(e) {
                let dt = e.dataTransfer;
                let files = dt.files;
                if (files.length > 0) {
                    fileInput.files = files;
                    updateUI(files[0].name);
                }
            }, false);

            // Memproses file yang dipilih melalui klik
            fileInput.addEventListener('change', function(e) {
                if (e.target.files.length > 0) {
                    updateUI(e.target.files[0].name);
                }
            });

            // Merubah tampilan kotak menjadi warna hijau sukses
            function updateUI(fileName) {
                uploadText.textContent = fileName;
                uploadText.classList.add('upload-text--success');
                uploadSubtext.textContent = 'Dokumen siap diunggah';
            
                uploadArea.classList.add('has-file', 'upload-area--has-file');
                uploadArea.classList.remove('upload-area--drag');
                uploadIcon.classList.remove('upload-icon--default', 'upload-icon--purple');
                uploadIcon.classList.add('upload-icon--success');
            }
    </script>
</body>
</html>
