@{
    ViewData["Title"] = "Pendaftaran Berhasil";
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-wrapper">
        <div class="auth-container register-card register-card--onb-success">
            
            <!-- Logo Mini -->
            <div class="onb-success-logo">
                <img src="~/image/lightenuplogo.ico" alt="LightenUp Logo" class="onb-success-logo-img" onerror="this.style.display='none'" />
                <span class="onb-success-logo-text">LightenUp</span>
            </div>

            <h1 class="auth-title auth-title--onb-success">Data berhasil<br />ditambahkan!</h1>
            
            <!-- Indikator Progres Full (Warna Ungu Penuh) -->
            <div class="onb-success-progress"></div>

            <p class="onb-success-desc">
                Anda telah berhasil melengkapi data diri. Namun, fitur lengkap memerlukan persetujuan (Approval) dari Admin terlebih dahulu.
            </p>

            <a href="/Account/PendingApproval" class="btn-submit btn-submit--onb-outline">Lihat Status Akun</a>

        </div>
    </div>

</body>
</html>