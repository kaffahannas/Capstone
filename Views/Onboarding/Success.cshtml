@{
    ViewData["Title"] = "Pendaftaran Berhasil";
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-wrapper">
        <div class="auth-container register-card" style="text-align: center; padding: 50px 30px;">
            
            <!-- Logo Mini -->
            <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 30px;">
                <img src="~/image/lightenuplogo.ico" alt="LightenUp Logo" style="width: 28px; height: auto;" onerror="this.style.display='none'" />
                <span style="font-weight: 700; color: #a476f5; font-size: 20px; letter-spacing: -0.5px;">LightenUp</span>
            </div>

            <h1 class="auth-title" style="font-size: 24px; margin-bottom: 20px;">Data berhasil<br />ditambahkan!</h1>
            
            <!-- Indikator Progres Full (Warna Ungu Penuh) -->
            <div style="width: 100%; height: 8px; background-color: var(--primary-purple); border-radius: 10px; margin-bottom: 30px;"></div>

            <p style="font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 40px;">
                Anda dapat langsung mengakses dashboard LightenUp & mulai menambahkan data pasien. Namun, fitur lengkap mungkin memerlukan persetujuan dari HR.
            </p>

            <a href="/Home/Index" class="btn-submit" style="text-decoration: none; display: inline-block; box-sizing: border-box; background-color: #F3F0FF; color: var(--primary-purple); border: 1px solid var(--primary-purple);">Masuk ke Dashboard</a>

        </div>
    </div>

</body>
</html>