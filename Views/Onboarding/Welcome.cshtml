@{
    ViewData["Title"] = "Selamat Datang";
    Layout = null;
}

@* #Bagian Onboarding Selamat Datang# *@

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-wrapper">

        <div class="auth-container register-card">

            @* #Komponen Logo Brand# *@
            @await Html.PartialAsync("_PsyOnboardingBrand")
            
            @* #Komponen Konten Selamat Datang# *@
            <h1 class="auth-title auth-title--onb-welcome">Selamat datang,<br />@ViewBag.FullName!</h1>
            
            <p class="onb-welcome-intro">
                LightenUp adalah platform pendukung operasional bagi penyedia jasa layanan psikologi, seperti manajemen data pasien, kelola catatan konseling, dan mood tracker.
            </p>

            <p class="onb-welcome-heading">
                Sebagai permulaan, Anda dapat melengkapi data penyedia layanan psikologi seperti:
            </p>

            <ul class="onb-welcome-list">
                <li>Foto diri</li>
                <li>Status akademik, gelar</li>
                <li>Universitas asal gelar</li>
                <li>Nomor SIAP HIMPSI</li>
                <li>Nomor SIPP</li>
                <li>Scan Surat Tanda Registrasi (STR) Psikolog Klinis</li>
                <li>Scan dokumen pendukung lainnya</li>
            </ul>

            @* #Komponen Tombol Mulai# *@
            <a href="/Onboarding/Step1" class="btn-submit btn-submit--onb-start">Lengkapi Data Diri</a>

        </div>
    </div>

</body>
</html>
