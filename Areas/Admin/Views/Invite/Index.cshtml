@model LightenUp.Web.Models.ViewModels.AdminInviteViewModel
@{
    ViewData["Title"] = "Tambah Admin";
    ViewBag.ActiveNav = "Invite";
    var loginUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/AdminAuth/Login";
}

@if (TempData["success"] is string ok)   { <div class="adm-alert success">✅ @ok</div> }
@if (TempData["info"]    is string info) { <div class="adm-alert info">ℹ️ @info</div> }

<div style="max-width:600px;">

    <!-- Explanation card -->
    <div class="adm-card" style="margin-bottom:20px; background:linear-gradient(135deg,#F5F3FF,#EDE9FE); border-color:rgba(124,58,237,0.2);">
        <div style="display:flex; align-items:flex-start; gap:14px;">
            <div style="width:44px; height:44px; background:rgba(124,58,237,0.12); border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;">🛡️</div>
            <div>
                <div style="font-size:14px; font-weight:700; color:var(--adm-primary); margin-bottom:4px;">Undang Administrator Baru</div>
                <p style="font-size:13px; color:var(--adm-text-secondary); margin:0; line-height:1.7;">
                    Akun Admin baru akan langsung dapat login di <a href="@loginUrl" target="_blank" style="color:var(--adm-primary); font-weight:600;">Admin Console</a>
                    menggunakan email dan kata sandi di bawah. Minta mereka mengganti kata sandi setelah login pertama.
                </p>
            </div>
        </div>
    </div>

    <!-- Form card -->
    <form asp-action="Index" method="post" class="adm-card">
        <div class="adm-card-title">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            Informasi Admin Baru
        </div>

        <div asp-validation-summary="ModelOnly" class="adm-alert error" style="display:@(ViewData.ModelState.IsValid ? "none" : "flex");"></div>

        <div class="adm-form-row">
            <label asp-for="FullName">Nama Lengkap</label>
            <input asp-for="FullName" placeholder="Contoh: Budi Santoso" autocomplete="off" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div class="adm-form-row">
            <label asp-for="Email">Alamat Email</label>
            <input asp-for="Email" type="email" placeholder="admin@lightenup.com" autocomplete="off" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="adm-form-row">
            <label asp-for="TempPassword">Kata Sandi Sementara</label>
            <input asp-for="TempPassword" type="text" placeholder="Minimal 8 karakter" autocomplete="new-password" />
            <span asp-validation-for="TempPassword" class="text-danger"></span>
            <div class="adm-form-hint">Admin baru harus mengubah kata sandi ini setelah login pertama kali.</div>
        </div>

        <div class="adm-form-actions">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.69h3a2 2 0 0 1 2 1.72c.13.96.35 1.9.64 2.82a2 2 0 0 1-.45 2.11L7.91 10.1a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.92.29 1.86.51 2.82.64A2 2 0 0 1 22 16.92z"/></svg>
                Buat & Kirim Undangan
            </button>
            <a class="btn btn-secondary" asp-controller="Dashboard" asp-action="Index">Batal</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
