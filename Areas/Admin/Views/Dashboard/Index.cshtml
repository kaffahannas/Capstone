@model LightenUp.Web.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewBag.ActiveNav = "Dashboard";
}

@* #Komponen KartuKPI# *@
@section Head {
    <link rel="stylesheet" href="~/css/admin/dashboard-index.css" asp-append-version="true" />
}


@* #Bagian DashboardAdmin# *@
<div class="adm-stat-grid">
    <div class="adm-stat-card accent-purple">
        <div class="adm-stat-icon">👥</div>
        <div class="adm-stat-label">Total Pengguna</div>
        <div class="adm-stat-value">@Model.TotalUsers</div>
        <div class="adm-stat-sub">Semua role terdaftar</div>
    </div>

    <div class="adm-stat-card accent-green">
        <div class="adm-stat-icon">🧘</div>
        <div class="adm-stat-label">Pasien</div>
        <div class="adm-stat-value">@Model.TotalPatients</div>
        <div class="adm-stat-sub">Pengguna aktif layanan</div>
    </div>

    <div class="adm-stat-card accent-blue">
        <div class="adm-stat-icon">🩺</div>
        <div class="adm-stat-label">Psikolog</div>
        <div class="adm-stat-value">@Model.TotalPsychologists</div>
        @if (Model.PendingPsychologists > 0)
        {
            <div class="adm-stat-sub dash-stat-warning">
                ⏳ @Model.PendingPsychologists menunggu persetujuan
            </div>
        }
        else
        {
            <div class="adm-stat-sub">Semua terverifikasi</div>
        }
    </div>

    <div class="adm-stat-card accent-orange">
        <div class="adm-stat-icon">🏢</div>
        <div class="adm-stat-label">Mitra B2B</div>
        <div class="adm-stat-value">@Model.TotalCompanies <span class="dash-stat-unit">Perusahaan</span></div>
        <div class="adm-stat-sub">
            Mencakup @Model.TotalHrs akun HR Manager
            @if (Model.PendingHrs > 0)
            {
                <br /><span class="dash-stat-pending">⏳ @Model.PendingHrs HR menunggu persetujuan</span>
            }
        </div>
    </div>
</div>

@* #Komponen AlertPenugasan# *@
@if (Model.PendingAssignmentsTotal > 0)
{
    <div class="adm-card dash-alert-assignments">
        <div class="adm-card-inner dash-card-inner-nowrap">
            <div class="dash-alert-content">
                <div class="dash-alert-icon dash-alert-icon--purple">📋</div>
                <div>
                    <div class="dash-alert-title--purple">@Model.PendingAssignmentsTotal Permintaan Penugasan</div>
                    <div class="dash-alert-sub--purple">
                        @Model.PendingAdminAssignments Psy→Pasien &nbsp;·&nbsp;
                        @Model.PendingCancellationByAdmin Pembatalan HR &nbsp;·&nbsp;
                        @Model.PendingPatientAdminRequests Minta Admin
                    </div>
                </div>
            </div>
            <a class="btn btn-primary dash-alert-action" asp-area="Admin" asp-controller="Assignments" asp-action="Index">
                Kelola Penugasan →
            </a>
        </div>
    </div>
}

@* #Komponen AlertPersetujuan# *@
@if (Model.PendingTotal > 0)
{
    <div class="adm-card dash-alert-pending">
        <div class="adm-card-inner dash-card-inner-nowrap">
            <div class="dash-alert-content">
                <div class="dash-alert-icon dash-alert-icon--amber">⚠️</div>
                <div>
                    <div class="dash-alert-title--amber">@Model.PendingTotal Akun Menunggu Persetujuan</div>
                    <div class="dash-alert-sub--amber">
                        @Model.PendingPsychologists Psikolog &nbsp;·&nbsp; @Model.PendingHrs HR Manager
                    </div>
                </div>
            </div>
            <a class="btn btn-primary dash-alert-action" asp-area="Admin" asp-controller="Approvals" asp-action="Index">
                Tinjau Sekarang →
            </a>
        </div>
    </div>
}

@* #Komponen AksiCepat# *@
<div class="adm-card">
    <div class="adm-card-title">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Akses Cepat
    </div>
    <div class="adm-quick-grid">
        <a class="adm-quick-item" asp-area="Admin" asp-controller="Approvals" asp-action="Index">
            <div class="adm-quick-icon dash-quick-icon--amber">📋</div>
            <div class="adm-quick-label">Persetujuan</div>
            <div class="adm-quick-sub">
                @if (Model.PendingTotal > 0)
                { <span class="dash-quick-pending-warning">@Model.PendingTotal menunggu</span> }
                else
                { <text>Semua bersih</text> }
            </div>
        </a>

        <a class="adm-quick-item" asp-area="Admin" asp-controller="Users" asp-action="Index">
            <div class="adm-quick-icon dash-quick-icon--purple">👤</div>
            <div class="adm-quick-label">Pengguna</div>
            <div class="adm-quick-sub">@Model.TotalUsers terdaftar</div>
        </a>

        <a class="adm-quick-item" asp-area="Admin" asp-controller="Companies" asp-action="Index">
            <div class="adm-quick-icon dash-quick-icon--blue">🏢</div>
            <div class="adm-quick-label">Perusahaan</div>
            <div class="adm-quick-sub">@Model.TotalCompanies mitra</div>
        </a>

        <a class="adm-quick-item" asp-area="Admin" asp-controller="Assignments" asp-action="Index">
            <div class="adm-quick-icon dash-quick-icon--purple">📋</div>
            <div class="adm-quick-label">Penugasan</div>
            <div class="adm-quick-sub">
                @if (Model.PendingAssignmentsTotal > 0)
                { <span class="dash-quick-pending-primary">@Model.PendingAssignmentsTotal menunggu</span> }
                else
                { <text>Semua bersih</text> }
            </div>
        </a>

        <a class="adm-quick-item" asp-area="Admin" asp-controller="Payroll" asp-action="Index">
            <div class="adm-quick-icon dash-quick-icon--green">💰</div>
            <div class="adm-quick-label">Payroll</div>
            <div class="adm-quick-sub">Transfer psikolog</div>
        </a>
    </div>
</div>
