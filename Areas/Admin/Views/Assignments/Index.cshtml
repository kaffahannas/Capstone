@using LightenUp.Web.Models
@using LightenUp.Web.Services
@model LightenUp.Web.Models.ViewModels.AdminAssignmentsIndexViewModel
@{
    ViewData["Title"] = "Penugasan Psikolog";
    ViewBag.ActiveNav = "Assignments";
    var idCulture = new System.Globalization.CultureInfo("id-ID");
}

<div class="adm-page-header asg-page-header">
    <h1>Penugasan Psikolog</h1>
    <p class="adm-page-sub">Kelola permintaan pasien yang belum mendapatkan psikolog dan pantau distribusi beban kerja psikolog.</p>
</div>

<div class="adm-tabs">
    <a class="adm-tab @(Model.Tab == "patient" ? "active" : "")"
       asp-action="Index" asp-route-tab="patient">
        Permintaan Pasien @if (Model.PendingPatientRequestCount > 0) { <span class="nav-badge asg-tab-badge">@Model.PendingPatientRequestCount</span> }
    </a>
    <a class="adm-tab @(Model.Tab == "b2b" ? "active" : "")"
       asp-action="Index" asp-route-tab="b2b">
        Kemitraan B2B @if (Model.PendingB2BRequestCount > 0) { <span class="nav-badge asg-tab-badge">@Model.PendingB2BRequestCount</span> }
    </a>
    <a class="adm-tab @(Model.Tab == "workload" ? "active" : "")"
       asp-action="Index" asp-route-tab="workload">
        Beban Kerja Psikolog
    </a>
</div>

@if (TempData["success"] is string ok)
{
    <div class="adm-alert success asg-alert-success">✅ @ok</div>
}
@if (TempData["error"] is string err)
{
    <div class="adm-alert asg-alert-error">⚠️ @err</div>
}

@if (Model.Tab == "patient")
{
    if (!Model.PatientAdminRequests.Any())
    {
        <div class="adm-empty-state-premium">
            <div class="icon">📬</div>
            <h3>Belum ada permintaan dari pasien</h3>
            <p>Pasien yang meminta dicarikan psikolog oleh admin akan muncul di sini.</p>
        </div>
    }
    else
    {
        foreach (var req in Model.PatientAdminRequests)
        {
            <div class="adm-card asg-request-card">
                <div class="asg-request-header">
                    <div>
                        <strong class="asg-patient-name">@(req.Patient?.User?.FullName ?? "—")</strong>
                        <div class="asg-patient-meta">
                            <span class="asg-company-tag">@(req.Patient?.CompanyId != null ? (req.Patient.Company?.Name ?? "B2B") : "Publik (B2C)")</span>
                            @req.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm", idCulture)
                        </div>
                        @if (!string.IsNullOrEmpty(req.Reason))
                        {
                            <div class="asg-reason-box">
                                <strong class="asg-reason-label">Keluhan/Alasan:</strong> @req.Reason
                            </div>
                        }
                        @if (req.PreferredPsychologist != null)
                        {
                            <p class="asg-preference">Preferensi Pasien: <strong>@(req.PreferredPsychologist.User?.FullName)</strong></p>
                        }
                    </div>
                </div>

                <form asp-action="AssignPatient" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@req.Id" />
                    <div class="asg-assign-grid">
                        <div>
                            <label class="asg-field-label">Pilih Psikolog (Berdasarkan Beban Kerja)</label>
                            <select name="psychologistId" required class="asg-select">
                                @foreach (var psy in Model.Psychologists)
                                {
                                    var selected = req.PreferredPsychologistId == psy.PsychologistId;
                                    var wlClass = psy.WorkloadLevel == "low" ? "🟢 Sedikit" : (psy.WorkloadLevel == "high" ? "🔴 Padat" : "🟡 Normal");
                                    <option value="@psy.PsychologistId" selected="@selected">
                                        @wlClass — @psy.FullName (@psy.ActiveCaseload Pasien Aktif)
                                    </option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="asg-btn-assign"
                                onclick="return confirm('Tugaskan psikolog ke pasien ini?')">Tugaskan</button>
                        <button formaction="@Url.Action("DismissPatientRequest")" type="submit" class="asg-btn-dismiss" formnovalidate
                                onclick="return confirm('Tutup permintaan ini tanpa menugaskan?')">Abaikan</button>
                    </div>
                </form>
            </div>
        }
    }
}
else if (Model.Tab == "workload")
{
    <div class="adm-card asg-workload-card">
        <table class="adm-table asg-workload-table">
            <thead class="asg-workload-thead">
                <tr>
                    <th class="asg-workload-th">Psikolog</th>
                    <th class="asg-workload-th asg-workload-th--center">Pasien B2B</th>
                    <th class="asg-workload-th asg-workload-th--center">Pasien Publik</th>
                    <th class="asg-workload-th asg-workload-th--center">Total Pasien Aktif</th>
                    <th class="asg-workload-th asg-workload-th--center">Kapasitas (Load)</th>
                </tr>
            </thead>
            <tbody class="asg-workload-tbody">
            @foreach (var p in Model.Psychologists)
            {
                <tr class="asg-workload-tr">
                    <td class="asg-workload-td">
                        <strong class="asg-psy-name">@p.FullName</strong>
                    </td>
                    <td class="asg-workload-td asg-workload-td--center">@p.B2BCaseload</td>
                    <td class="asg-workload-td asg-workload-td--center">@p.PublicCaseload</td>
                    <td class="asg-workload-td asg-workload-td--center">
                        <span class="asg-caseload-total">@p.ActiveCaseload</span>
                    </td>
                    <td class="asg-workload-td asg-workload-td--center">
                        @if (p.WorkloadLevel == "low")
                        {
                            <span class="asg-badge-low">Sedikit</span>
                        }
                        else if (p.WorkloadLevel == "high")
                        {
                            <span class="asg-badge-high">Padat</span>
                        }
                        else
                        {
                            <span class="asg-badge-normal">Normal</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else if (Model.Tab == "b2b")
{
    if (!Model.B2BRequests.Any())
    {
        <div class="adm-empty-state-premium">
            <div class="icon">🏢</div>
            <h3>Belum ada permintaan kemitraan B2B</h3>
            <p>Perusahaan yang mengajukan kemitraan B2B akan muncul di sini.</p>
        </div>
    }
    else
    {
        foreach (var req in Model.B2BRequests)
        {
            <div class="adm-card asg-request-card">
                <div class="asg-request-header">
                    <div>
                        <strong class="asg-patient-name">@(req.Company?.Name ?? "Perusahaan Tidak Dikenal")</strong>
                        <div class="asg-patient-meta">
                            <span class="asg-company-tag">Pengajuan B2B</span>
                            @req.RequestDate.ToLocalTime().ToString("dd MMM yyyy HH:mm", idCulture)
                        </div>
                        @if (!string.IsNullOrEmpty(req.Notes))
                        {
                            <div class="asg-reason-box">
                                <strong class="asg-reason-label">Catatan HR:</strong> @req.Notes
                            </div>
                        }
                    </div>
                </div>

                <form asp-action="AssignB2BPsychologist" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@req.Id" />
                    <div class="asg-assign-grid">
                        <div>
                            <label class="asg-field-label">Pilih Psikolog untuk Kemitraan B2B ini</label>
                            <select name="psychologistId" required class="asg-select">
                                <option value="">-- Pilih Psikolog --</option>
                                @foreach (var psy in Model.Psychologists)
                                {
                                    var wlClass = psy.WorkloadLevel == "low" ? "🟢 Sedikit" : (psy.WorkloadLevel == "high" ? "🔴 Padat" : "🟡 Normal");
                                    <option value="@psy.PsychologistId">
                                        @wlClass — @psy.FullName (@psy.ActiveCaseload Pasien Aktif)
                                    </option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="asg-btn-assign"
                                onclick="return confirm('Tugaskan psikolog ini untuk menangani B2B perusahaan?')">Tugaskan</button>
                        <button formaction="@Url.Action("DismissB2BRequest")" type="submit" class="asg-btn-dismiss" formnovalidate
                                onclick="return confirm('Tolak permintaan kemitraan ini?')">Abaikan</button>
                    </div>
                </form>
            </div>
        }
    }
}
