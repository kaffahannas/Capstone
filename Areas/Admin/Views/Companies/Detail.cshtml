@model LightenUp.Web.Models.ViewModels.AdminCompanyDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    ViewBag.ActiveNav = "Companies";
    var cid = new System.Globalization.CultureInfo("id-ID");
    int total = Model.TotalPatients;
    int pctSehat   = total > 0 ? (int)Math.Round(Model.SehatCount   * 100.0 / total) : 0;
    int pctBeresiko= total > 0 ? (int)Math.Round(Model.BeresikoCount* 100.0 / total) : 0;
    int pctBahaya  = total > 0 ? (int)Math.Round(Model.BahayaCount  * 100.0 / total) : 0;
}

<a class="back-link" asp-action="Index">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Daftar Perusahaan
</a>

<!-- ── Company header + info ── -->
<div class="adm-card" style="margin-bottom:20px;">
    <div style="display:flex; align-items:center; gap:16px; margin-bottom:22px;">
        <div style="width:56px; height:56px; border-radius:14px; background:linear-gradient(135deg,#7C3AED,#5B21B6); display:flex; align-items:center; justify-content:center; font-size:24px; flex-shrink:0;">🏢</div>
        <div>
            <h2 style="margin:0 0 4px; font-size:22px; font-weight:700; letter-spacing:-0.4px;">@Model.Name</h2>
            <div style="font-size:13px; color:var(--adm-muted);">
                Terdaftar sejak @Model.CreatedAt.ToString("d MMMM yyyy", cid)
            </div>
        </div>
    </div>

    <div class="adm-info-grid">
        <div class="adm-info-row">
            <span class="adm-info-label">Alamat</span>
            <span class="adm-info-value">@(Model.Address ?? "—")</span>
        </div>
        <div class="adm-info-row">
            <span class="adm-info-label">Telepon</span>
            <span class="adm-info-value">@(Model.ContactNumber ?? "—")</span>
        </div>
        <div class="adm-info-row">
            <span class="adm-info-label">Email Kontak</span>
            <span class="adm-info-value">
                @if (!string.IsNullOrEmpty(Model.ContactEmail))
                { <a href="mailto:@Model.ContactEmail" style="color:var(--adm-primary);">@Model.ContactEmail</a> }
                else
                { <text>—</text> }
            </span>
        </div>
        <div class="adm-info-row">
            <span class="adm-info-label">Nomor Registrasi</span>
            <span class="adm-info-value">@(Model.RegistrationNumber ?? "—")</span>
        </div>
        <div class="adm-info-row">
            <span class="adm-info-label">Kode Referral</span>
            <span class="adm-info-value">
                @if (!string.IsNullOrEmpty(Model.ReferralCode))
                { <code>@Model.ReferralCode</code> }
                else
                { <text>—</text> }
            </span>
        </div>
    </div>
</div>

<!-- ── Mental health stats ── -->
<div class="adm-mental-grid" style="margin-bottom:20px;">
    <div class="adm-mental-card" style="border-top:3px solid #7C3AED;">
        <div style="font-size:11px; font-weight:700; color:var(--adm-muted); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:6px;">Total Pasien</div>
        <div class="adm-stat-value" style="color:var(--adm-primary);">@Model.TotalPatients</div>
    </div>
    <div class="adm-mental-card" style="border-top:3px solid #059669;">
        <div style="font-size:11px; font-weight:700; color:var(--adm-muted); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:6px;">✅ Sehat</div>
        <div class="adm-stat-value" style="color:#059669;">@Model.SehatCount</div>
        <div style="font-size:11px; color:var(--adm-muted);">@pctSehat%</div>
    </div>
    <div class="adm-mental-card" style="border-top:3px solid #D97706;">
        <div style="font-size:11px; font-weight:700; color:var(--adm-muted); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:6px;">⚠️ Beresiko</div>
        <div class="adm-stat-value" style="color:#D97706;">@Model.BeresikoCount</div>
        <div style="font-size:11px; color:var(--adm-muted);">@pctBeresiko%</div>
    </div>
    <div class="adm-mental-card" style="border-top:3px solid #DC2626;">
        <div style="font-size:11px; font-weight:700; color:var(--adm-muted); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:6px;">🚨 Bahaya</div>
        <div class="adm-stat-value" style="color:#DC2626;">@Model.BahayaCount</div>
        <div style="font-size:11px; color:var(--adm-muted);">@pctBahaya%</div>
    </div>
</div>

<!-- ── HR table ── -->
<div class="adm-card">
    <div class="adm-card-header">
        <div class="adm-card-title" style="margin-bottom:0;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            HR di Perusahaan Ini
        </div>
        <span class="badge badge-role">@Model.Hrs.Count HR</span>
    </div>

    @if (!Model.Hrs.Any())
    {
        <div class="adm-empty" style="padding:32px;">
            <div class="adm-empty-icon">👤</div>
            <div class="adm-empty-sub">Belum ada HR terdaftar untuk perusahaan ini.</div>
        </div>
    }
    else
    {
        <table class="adm-table" style="border:none;">
            <thead>
                <tr>
                    <th>Nama</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th style="width:80px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hr in Model.Hrs)
                {
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div class="adm-avatar-sm">@string.Join("", hr.FullName.Split(' ').Take(2).Select(w => w[0])).ToUpper()</div>
                                <strong>@hr.FullName</strong>
                            </div>
                        </td>
                        <td style="color:var(--adm-text-secondary);">@hr.Email</td>
                        <td>
                            @if (!hr.IsApprovedByAdmin)
                            { <span class="badge badge-pending">⏳ Pending</span> }
                            else if (hr.IsActive)
                            { <span class="badge badge-active">● Aktif</span> }
                            else
                            { <span class="badge badge-inactive">○ Nonaktif</span> }
                        </td>
                        <td>
                            <a class="btn btn-sm btn-secondary" asp-controller="Users" asp-action="Detail" asp-route-id="@hr.UserId">Detail</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
