@model LightenUp.Web.Models.ViewModels.AdminCompanyDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    ViewBag.ActiveNav = "Companies";
    var cid = new System.Globalization.CultureInfo("id-ID");
    int total = Model.TotalPatients;
    int pctSehat   = total > 0 ? (int)Math.Round(Model.SehatCount   * 100.0 / total) : 0;
    int pctBeresiko= total > 0 ? (int)Math.Round(Model.BeresikoCount* 100.0 / total) : 0;
    int pctBahaya  = total > 0 ? (int)Math.Round(Model.BahayaCount  * 100.0 / total) : 0;
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/companies-detail.css" asp-append-version="true" />
}


@* #Bagian DetailPerusahaan# *@
<a class="back-link" asp-action="Index">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Daftar Perusahaan
</a>

@* #Komponen HeaderPerusahaan# *@
<div class="adm-card cmp-header-card">
    <div class="cmp-header-row">
        <div class="cmp-header-icon">🏢</div>
        <div>
            <h2 class="cmp-header-title">@Model.Name</h2>
            <div class="cmp-header-meta">
                Terdaftar sejak @Model.CreatedAt.ToString("d MMMM yyyy", cid)
            </div>
        </div>
    </div>

    <div class="adm-info-grid">
        <div class="adm-info-row">
            <span class="adm-info-label">Alamat</span>
            <span class="adm-info-value">@(Model.Address ?? "—")</span>
        </div>
        <div class="adm-info-row">
            <span class="adm-info-label">Telepon</span>
            <span class="adm-info-value">@(Model.ContactNumber ?? "—")</span>
        </div>
        <div class="adm-info-row">
            <span class="adm-info-label">Email Kontak</span>
            <span class="adm-info-value">
                @if (!string.IsNullOrEmpty(Model.ContactEmail))
                { <a href="mailto:@Model.ContactEmail" class="cmp-email-link">@Model.ContactEmail</a> }
                else
                { <text>—</text> }
            </span>
        </div>
        <div class="adm-info-row">
            <span class="adm-info-label">Nomor Registrasi</span>
            <span class="adm-info-value">@(Model.RegistrationNumber ?? "—")</span>
        </div>
        <div class="adm-info-row">
            <span class="adm-info-label">Jumlah Divisi</span>
            <span class="adm-info-value">
                <strong>@Model.DivisionCount</strong> divisi
            </span>
        </div>
    </div>
</div>

@* #Komponen StatistikKesehatan# *@
<div class="adm-mental-grid cmp-mental-grid-spaced">
    <div class="adm-mental-card cmp-mental-card--total">
        <div class="cmp-stat-label">Total Pasien</div>
        <div class="adm-stat-value cmp-stat-value--primary">@Model.TotalPatients</div>
    </div>
    <div class="adm-mental-card cmp-mental-card--sehat">
        <div class="cmp-stat-label">✅ Sehat</div>
        <div class="adm-stat-value cmp-stat-value--sehat">@Model.SehatCount</div>
        <div class="cmp-stat-pct">@pctSehat%</div>
    </div>
    <div class="adm-mental-card cmp-mental-card--beresiko">
        <div class="cmp-stat-label">⚠️ Beresiko</div>
        <div class="adm-stat-value cmp-stat-value--beresiko">@Model.BeresikoCount</div>
        <div class="cmp-stat-pct">@pctBeresiko%</div>
    </div>
    <div class="adm-mental-card cmp-mental-card--bahaya">
        <div class="cmp-stat-label">🚨 Bahaya</div>
        <div class="adm-stat-value cmp-stat-value--bahaya">@Model.BahayaCount</div>
        <div class="cmp-stat-pct">@pctBahaya%</div>
    </div>
</div>

@* #Komponen TabelHR# *@
<div class="adm-card">
    <div class="adm-card-header">
        <div class="adm-card-title cmp-card-title-flush">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Manajer HR
        </div>
    </div>

    @if (!Model.Hrs.Any())
    {
        <div class="adm-empty cmp-empty-hr">
            <div class="adm-empty-icon">👤</div>
            <div class="adm-empty-sub">Belum ada HR terdaftar untuk perusahaan ini.</div>
        </div>
    }
    else
    {
        <div class="cmp-hr-table-scroll">
        <table class="adm-table cmp-hr-table">
            <thead>
                <tr>
                    <th>Nama</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th class="cmp-th-action"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hr in Model.Hrs)
                {
                    <tr>
                        <td>
                            <div class="cmp-hr-cell">
                                <div class="adm-avatar-sm">@string.Join("", hr.FullName.Split(' ').Take(2).Select(w => w[0])).ToUpper()</div>
                                <strong>@hr.FullName</strong>
                            </div>
                        </td>
                        <td class="cmp-hr-email">@hr.Email</td>
                        <td>
                            @if (!hr.IsApprovedByAdmin)
                            { <span class="badge badge-pending">⏳ Pending</span> }
                            else if (hr.IsActive)
                            { <span class="badge badge-active">● Aktif</span> }
                            else
                            { <span class="badge badge-inactive">○ Nonaktif</span> }
                        </td>
                        <td>
                            <a class="btn btn-sm btn-secondary" asp-controller="Users" asp-action="Detail" asp-route-id="@hr.UserId">Detail</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>
