@model LightenUp.Web.Models.ViewModels.AdminCompaniesListViewModel
@{
    ViewData["Title"] = "Perusahaan";
    ViewBag.ActiveNav = "Companies";
}

<!-- ── Toolbar ── -->
<form method="get" class="adm-toolbar">
    <div class="adm-toolbar-search">
        <svg class="adm-toolbar-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" name="search" placeholder="Cari nama perusahaan..." value="@Model.Search" />
    </div>
    <button type="submit" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Cari
    </button>
    @if (!string.IsNullOrEmpty(Model.Search))
    {
        <a class="btn btn-ghost" asp-action="Index">✕ Reset</a>
    }
</form>

@if (!Model.Items.Any())
{
    <div class="adm-table-wrap">
        <div class="adm-empty">
            <div class="adm-empty-icon">🏢</div>
            <div class="adm-empty-title">Belum ada perusahaan terdaftar</div>
            <div class="adm-empty-sub">Perusahaan akan muncul di sini setelah HR menyelesaikan onboarding.</div>
        </div>
    </div>
}
else
{
    <div class="adm-count-label" style="margin-bottom:14px;">
        <strong>@Model.Items.Count</strong> perusahaan ditemukan
    </div>

    <div class="adm-table-wrap">
        <table class="adm-table">
            <thead>
                <tr>
                    <th>Perusahaan</th>
                    <th>Kode Referral</th>
                    <th style="text-align:center;">HR</th>
                    <th style="text-align:center;">Pasien Aktif</th>
                    <th>Terdaftar</th>
                    <th style="width:80px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Items)
                {
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:12px;">
                                <div style="width:36px; height:36px; border-radius:10px; background:linear-gradient(135deg,#EDE9FE,#DDD6FE); display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0;">🏢</div>
                                <div>
                                    <div style="font-weight:600; font-size:13.5px;">@c.Name</div>
                                    @if (!string.IsNullOrEmpty(c.Address))
                                    {
                                        <div style="font-size:12px; color:var(--adm-muted);">📍 @c.Address</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.ReferralCode))
                            {
                                <code style="background:var(--adm-bg); padding:3px 9px; border-radius:5px; font-size:12px; color:var(--adm-primary); font-weight:700; letter-spacing:0.5px; border:1px solid var(--adm-border);">@c.ReferralCode</code>
                            }
                            else
                            {
                                <span style="color:var(--adm-muted);">—</span>
                            }
                        </td>
                        <td style="text-align:center;">
                            <span style="font-size:14px; font-weight:600;">@c.HrCount</span>
                        </td>
                        <td style="text-align:center;">
                            <span style="font-size:14px; font-weight:600; color:var(--adm-success);">@c.ActivePatientCount</span>
                            <span style="font-size:12px; color:var(--adm-muted);"> / @c.PatientCount</span>
                        </td>
                        <td style="font-size:12px; color:var(--adm-muted);">
                            @c.CreatedAt.ToString("d MMM yyyy")
                        </td>
                        <td>
                            <a class="btn btn-sm btn-secondary" asp-action="Detail" asp-route-id="@c.CompanyId">Detail</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
