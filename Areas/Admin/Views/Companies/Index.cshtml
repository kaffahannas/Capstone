@model LightenUp.Web.Models.ViewModels.AdminCompaniesListViewModel
@{
    ViewData["Title"] = "Perusahaan";
    ViewBag.ActiveNav = "Companies";
}

@* #Komponen Toolbar# *@
@section Head {
    <link rel="stylesheet" href="~/css/admin/companies-index.css" asp-append-version="true" />
}


@* #Bagian DaftarPerusahaan# *@
<form method="get" class="adm-toolbar">
    <div class="adm-toolbar-search">
        <svg class="adm-toolbar-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" name="search" placeholder="Cari nama perusahaan..." value="@Model.Search" />
    </div>
    <button type="submit" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Cari
    </button>
    @if (!string.IsNullOrEmpty(Model.Search))
    {
        <a class="btn btn-ghost" asp-action="Index">✕ Reset</a>
    }
</form>

@if (!Model.Items.Any())
{
    <div class="adm-table-wrap">
        <div class="adm-empty">
            <div class="adm-empty-icon">🏢</div>
            <div class="adm-empty-title">Belum ada perusahaan terdaftar</div>
            <div class="adm-empty-sub">Perusahaan akan muncul di sini setelah HR menyelesaikan onboarding.</div>
        </div>
    </div>
}
else
{
    <div class="adm-count-label cmp-count-label">
        <strong>@Model.Items.Count</strong> perusahaan ditemukan
    </div>

    <div class="adm-table-wrap">
        <table class="adm-table">
            <thead>
                <tr>
                    <th class="cmp-th-company">Perusahaan</th>
                    <th class="cmp-th-center">Divisi</th>
                    <th class="cmp-th-center">Nama HR</th>
                    <th class="cmp-th-center">Pasien Aktif</th>
                    <th>Terdaftar</th>
                    <th class="cmp-th-action"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="cmp-company-cell">
                                <div class="cmp-company-icon">🏢</div>
                                <div>
                                    <div class="cmp-company-name">@c.Name</div>
                                    @if (!string.IsNullOrEmpty(c.Address))
                                    {
                                        <div class="cmp-company-address">📍 @c.Address</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td class="cmp-th-center">
                            <span class="cmp-stat-value">@c.DivisionCount</span>
                        </td>
                        <td class="cmp-th-center">
                            <span class="cmp-hr-name">@c.HrName</span>
                        </td>
                        <td class="cmp-th-center">
                            <span class="cmp-stat-value cmp-stat-value--success">@c.ActivePatientCount</span>
                            <span class="cmp-stat-muted"> / @c.PatientCount</span>
                        </td>
                        <td class="cmp-td-date">
                            @c.CreatedAt.ToString("d MMM yyyy")
                        </td>
                        <td>
                            <a class="btn btn-sm btn-secondary" asp-action="Detail" asp-route-id="@c.CompanyId">Detail</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
