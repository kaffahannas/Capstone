@model LightenUp.Web.Models.ViewModels.AdminUserDetailViewModel
@{
    ViewData["Title"] = "Detail Pengguna";
    ViewBag.ActiveNav = "Users";

    string RoleBadgeClass(string role) => role switch {
        "Psychologist" => "badge-role-psy",
        "HR"           => "badge-role-hr",
        "Patient"      => "badge-role-pat",
        "Admin"        => "badge-role-adm",
        _              => "badge-role",
    };
    string RoleLabel(string role) => role switch {
        "Psychologist" => "Psikolog",
        "HR"           => "HR Manager",
        "Patient"      => "Pasien",
        "Admin"        => "Admin",
        _              => role,
    };
    string Initials(string name) {
        var parts = (name ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", parts.Take(2).Select(p => p[0])).ToUpper();
    }
}

<a class="back-link" asp-action="Index">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Daftar Pengguna
</a>

@if (TempData["success"] is string ok)  { <div class="adm-alert success">✅ @ok</div> }
@if (TempData["error"]   is string err) { <div class="adm-alert error">⚠️ @err</div> }

<div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; align-items:start;">

    <!-- Left column: profile + info -->
    <div style="display:flex; flex-direction:column; gap:16px;">

        <!-- Profile hero -->
        <div class="adm-card">
            <div class="adm-profile-hero">
                @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                {
                    <img class="adm-profile-avatar" src="@Model.ProfilePicture" alt="Foto @Model.FullName" />
                }
                else
                {
                    <div class="adm-profile-avatar" style="font-size:28px; font-weight:800; display:flex; align-items:center; justify-content:center; background:var(--adm-primary-soft); color:var(--adm-primary);">@Initials(Model.FullName)</div>
                }
                <div style="flex:1;">
                    <h2 class="adm-profile-name">@Model.FullName</h2>
                    <div class="adm-profile-email">@Model.Email</div>
                    <div class="adm-profile-badges">
                        <span class="badge @RoleBadgeClass(Model.Role)">@RoleLabel(Model.Role)</span>
                        @if (!Model.IsApprovedByAdmin)
                        { <span class="badge badge-pending">⏳ Belum Disetujui</span> }
                        else if (Model.IsActive)
                        { <span class="badge badge-active">● Aktif</span> }
                        else
                        { <span class="badge badge-inactive">○ Nonaktif</span> }
                    </div>
                </div>
            </div>

            <!-- Info grid -->
            <div class="adm-info-grid">
                <div class="adm-info-row">
                    <span class="adm-info-label">Telepon</span>
                    <span class="adm-info-value">@(Model.Phone ?? "—")</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.CompanyName))
                {
                    <div class="adm-info-row">
                        <span class="adm-info-label">Perusahaan</span>
                        <span class="adm-info-value">@Model.CompanyName</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Department))
                {
                    <div class="adm-info-row">
                        <span class="adm-info-label">Divisi</span>
                        <span class="adm-info-value">@Model.Department</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.MentalHealthStatus))
                {
                    <div class="adm-info-row">
                        <span class="adm-info-label">Status Mental</span>
                        <span class="adm-info-value">
                            @{
                                var mIcon = Model.MentalHealthStatus switch { "Sehat" => "✅", "Beresiko" => "⚠️", _ => "🚨" };
                            }
                            @mIcon @Model.MentalHealthStatus
                        </span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Specialization))
                {
                    <div class="adm-info-row">
                        <span class="adm-info-label">Spesialisasi</span>
                        <span class="adm-info-value">@Model.Specialization</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.LicenseNumber))
                {
                    <div class="adm-info-row">
                        <span class="adm-info-label">Nomor License</span>
                        <span class="adm-info-value"><code>@Model.LicenseNumber</code></span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right column: actions -->
    <div style="display:flex; flex-direction:column; gap:16px;">

        <!-- Toggle active -->
        <div class="adm-card">
            <div class="adm-card-title">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Status Akun
            </div>
            <p style="font-size:13px; color:var(--adm-text-secondary); margin:0 0 14px; line-height:1.6;">
                @(Model.IsActive ? "Akun ini sedang aktif. Nonaktifkan untuk mencabut akses login." : "Akun ini nonaktif. Aktifkan untuk memulihkan akses login.")
            </p>
            <form asp-action="ToggleActive" method="post">
                <input type="hidden" name="id" value="@Model.UserId" />
                <button type="submit"
                        class="btn @(Model.IsActive ? "btn-danger" : "btn-success") btn-sm"
                        style="width:100%;"
                        onclick="return confirm('@(Model.IsActive ? "Nonaktifkan" : "Aktifkan") akun ini?');">
                    @(Model.IsActive ? "🔒 Nonaktifkan Akun" : "🔓 Aktifkan Akun")
                </button>
            </form>
        </div>

        <!-- Reset password -->
        <div class="adm-card">
            <div class="adm-card-title">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Reset Kata Sandi
            </div>
            <form asp-action="ResetPassword" method="post">
                <input type="hidden" name="id" value="@Model.UserId" />
                <div class="adm-form-row" style="margin-bottom:12px;">
                    <label>Kata sandi baru <small style="color:var(--adm-muted);">(min. 8 karakter)</small></label>
                    <input type="text" name="newPassword" required minlength="8" placeholder="Masukkan kata sandi baru" />
                </div>
                <button type="submit" class="btn btn-primary btn-sm" style="width:100%;"
                        onclick="return confirm('Reset kata sandi pengguna ini?');">
                    🔑 Reset Password
                </button>
            </form>
        </div>

    </div>
</div>
