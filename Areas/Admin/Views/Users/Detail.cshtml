@model LightenUp.Web.Models.ViewModels.AdminUserDetailViewModel
@{
    ViewData["Title"] = "Detail Pengguna";
    ViewBag.ActiveNav = "Users";

    string RoleBadgeClass(string role) => role switch {
        "Psychologist" => "badge-role-psy",
        "HR"           => "badge-role-hr",
        "Patient"      => "badge-role-pat",
        "Admin"        => "badge-role-adm",
        _              => "badge-role",
    };
    string RoleLabel(string role) => role switch {
        "Psychologist" => "Psikolog",
        "HR"           => "HR Manager",
        "Patient"      => "Pasien",
        "Admin"        => "Admin",
        _              => role,
    };
    string Initials(string name) {
        var parts = (name ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", parts.Take(2).Select(p => p[0])).ToUpper();
    }
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/users-detail.css" asp-append-version="true" />
}


@* #Bagian DetailPengguna# *@
@* #Komponen TombolKembali# *@
<a class="back-link" asp-action="Index">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Daftar Pengguna
</a>

@if (TempData["success"] is string ok)  { <div class="adm-alert success">✅ @ok</div> }
@if (TempData["error"]   is string err) { <div class="adm-alert error">⚠️ @err</div> }

<div class="usr-detail-grid">

    <!-- Left column: profile + info -->
    <div class="usr-detail-main">

        <!-- Profile hero -->
        @* #Komponen ProfilPengguna# *@
        <div class="adm-card">
            <div class="adm-profile-hero">
                @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                {
                    <img class="adm-profile-avatar" src="@Model.ProfilePicture" alt="Foto @Model.FullName" />
                }
                else
                {
                    <div class="adm-profile-avatar usr-avatar-fallback">@Initials(Model.FullName)</div>
                }
                <div class="usr-profile-meta">
                    <h2 class="adm-profile-name">@Model.FullName</h2>
                    <div class="adm-profile-email">@Model.Email</div>
                    <div class="adm-profile-badges">
                        <span class="badge @RoleBadgeClass(Model.Role)">@RoleLabel(Model.Role)</span>
                        @if (!Model.IsApprovedByAdmin)
                        { <span class="badge badge-pending">⏳ Belum Disetujui</span> }
                        else if (Model.IsActive)
                        { <span class="badge badge-active">● Aktif</span> }
                        else
                        { <span class="badge badge-inactive">○ Nonaktif</span> }
                    </div>
                </div>
            </div>

            <!-- Info grid -->
            <div class="adm-card-title" style="margin-top:4px; margin-bottom:14px;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
                Informasi Detail
            </div>
            <div class="adm-info-grid">
                <div class="adm-info-row">
                    <span class="adm-info-label">Telepon</span>
                    <span class="adm-info-value">@(Model.Phone ?? "—")</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.CompanyName))
                {
                    <div class="adm-info-row">
                        <span class="adm-info-label">Perusahaan</span>
                        <span class="adm-info-value">@Model.CompanyName</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Department))
                {
                    <div class="adm-info-row">
                        <span class="adm-info-label">Divisi</span>
                        <span class="adm-info-value">@Model.Department</span>
                    </div>
                }

                @if (Model.Role == "Patient")
                {
                    <div class="adm-info-row">
                        <span class="adm-info-label">Tanggal Lahir</span>
                        <span class="adm-info-value">@(Model.DateOfBirth?.ToString("dd MMMM yyyy") ?? "—")</span>
                    </div>
                    <div class="adm-info-row">
                        <span class="adm-info-label">Jenis Kelamin</span>
                        <span class="adm-info-value">@(Model.Gender ?? "—")</span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.CompanyName))
                    {
                        <div class="adm-info-row">
                            <span class="adm-info-label">Perusahaan</span>
                            <span class="adm-info-value">@Model.CompanyName @(string.IsNullOrEmpty(Model.Department) ? "" : $" ({Model.Department})")</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.MentalHealthStatus))
                    {
                        <div class="adm-info-row">
                            <span class="adm-info-label">Status Mental</span>
                            <span class="adm-info-value">@Model.MentalHealthStatus</span>
                        </div>
                    }
                    <div class="adm-info-row">
                        <span class="adm-info-label">Kontak Darurat</span>
                        <span class="adm-info-value">
                            @(Model.EmergencyContactName ?? "—")
                            @if (!string.IsNullOrEmpty(Model.EmergencyContactPhone)) { <br/><small class="usr-emergency-phone">@Model.EmergencyContactPhone</small> }
                        </span>
                    </div>
                }

                @if (Model.Role == "Psychologist")
                {
                    @if (!string.IsNullOrEmpty(Model.Specialization))
                    {
                        <div class="adm-info-row">
                            <span class="adm-info-label">Spesialisasi</span>
                            <span class="adm-info-value">@Model.Specialization</span>
                        </div>
                    }
                    <div class="adm-info-row">
                        <span class="adm-info-label">Pendidikan Terakhir</span>
                        <span class="adm-info-value">@(Model.LastDegree ?? "—") @(string.IsNullOrEmpty(Model.University) ? "" : $" - {Model.University}")</span>
                    </div>
                    <div class="adm-info-row">
                        <span class="adm-info-label">Pengalaman Praktik</span>
                        <span class="adm-info-value">@(Model.ExperienceYears.HasValue ? $"{Model.ExperienceYears} tahun" : "—")</span>
                    </div>
                    <div class="adm-info-row">
                        <span class="adm-info-label">Lokasi Praktik</span>
                        <span class="adm-info-value">@(Model.PracticeLocation ?? "—")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.LicenseNumber))
                    {
                        <div class="adm-info-row">
                            <span class="adm-info-label">SIPP</span>
                            <span class="adm-info-value"><code>@Model.LicenseNumber</code></span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.SiapNumber))
                    {
                        <div class="adm-info-row">
                            <span class="adm-info-label">Nomor SIAP</span>
                            <span class="adm-info-value"><code>@Model.SiapNumber</code></span>
                        </div>
                    }
                }

                @if (Model.Role == "HR")
                {
                    <div class="adm-info-row">
                        <span class="adm-info-label">Perusahaan</span>
                        <span class="adm-info-value">@(Model.CompanyName ?? "—")</span>
                    </div>
                    <div class="adm-info-row">
                        <span class="adm-info-label">Departemen</span>
                        <span class="adm-info-value">@(Model.Department ?? "—")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CompanyRegistrationNumber))
                    {
                        <div class="adm-info-row">
                            <span class="adm-info-label">NIB/SIUP Perusahaan</span>
                            <span class="adm-info-value"><code>@Model.CompanyRegistrationNumber</code></span>
                        </div>
                    }
                    <div class="adm-info-row">
                        <span class="adm-info-label">Pendidikan HR</span>
                        <span class="adm-info-value">@(Model.LastDegree ?? "—") @(string.IsNullOrEmpty(Model.University) ? "" : $" - {Model.University}")</span>
                    </div>
                }
            </div>
        </div>

        @* Dokumen preview card — Psikolog *@
        @if (Model.Role == "Psychologist" && (!string.IsNullOrEmpty(Model.AcademicDocumentUrl) || !string.IsNullOrEmpty(Model.StrDocumentUrl)))
        {
            <div class="adm-card">
                <div class="adm-card-title">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Dokumen Verifikasi
                </div>
                <div class="usr-doc-preview-grid">
                    @if (!string.IsNullOrEmpty(Model.AcademicDocumentUrl))
                    {
                        <div class="usr-doc-preview-item">
                            <div class="usr-doc-preview-label">Ijazah</div>
                            @if (Model.AcademicDocumentUrl.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                            {
                                <a href="@Model.AcademicDocumentUrl" target="_blank" class="usr-doc-preview-pdf">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                                    <span>Buka PDF</span>
                                </a>
                            }
                            else
                            {
                                <a href="@Model.AcademicDocumentUrl" target="_blank" class="usr-doc-preview-img-wrap">
                                    <img src="@Model.AcademicDocumentUrl" alt="Ijazah" class="usr-doc-preview-img" />
                                </a>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.StrDocumentUrl))
                    {
                        <div class="usr-doc-preview-item">
                            <div class="usr-doc-preview-label">STR</div>
                            @if (Model.StrDocumentUrl.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                            {
                                <a href="@Model.StrDocumentUrl" target="_blank" class="usr-doc-preview-pdf">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                                    <span>Buka PDF</span>
                                </a>
                            }
                            else
                            {
                                <a href="@Model.StrDocumentUrl" target="_blank" class="usr-doc-preview-img-wrap">
                                    <img src="@Model.StrDocumentUrl" alt="STR" class="usr-doc-preview-img" />
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @* Dokumen preview card — HR *@
        @if (Model.Role == "HR" && (!string.IsNullOrEmpty(Model.AcademicDocumentUrl) || !string.IsNullOrEmpty(Model.SupportDocumentUrl)))
        {
            <div class="adm-card">
                <div class="adm-card-title">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Dokumen Verifikasi
                </div>
                <div class="usr-doc-preview-grid">
                    @if (!string.IsNullOrEmpty(Model.AcademicDocumentUrl))
                    {
                        <div class="usr-doc-preview-item">
                            <div class="usr-doc-preview-label">Ijazah</div>
                            @if (Model.AcademicDocumentUrl.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                            {
                                <a href="@Model.AcademicDocumentUrl" target="_blank" class="usr-doc-preview-pdf">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                                    <span>Buka PDF</span>
                                </a>
                            }
                            else
                            {
                                <a href="@Model.AcademicDocumentUrl" target="_blank" class="usr-doc-preview-img-wrap">
                                    <img src="@Model.AcademicDocumentUrl" alt="Ijazah" class="usr-doc-preview-img" />
                                </a>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.SupportDocumentUrl))
                    {
                        <div class="usr-doc-preview-item">
                            <div class="usr-doc-preview-label">Dokumen Bukti</div>
                            @if (Model.SupportDocumentUrl.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                            {
                                <a href="@Model.SupportDocumentUrl" target="_blank" class="usr-doc-preview-pdf">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                                    <span>Buka PDF</span>
                                </a>
                            }
                            else
                            {
                                <a href="@Model.SupportDocumentUrl" target="_blank" class="usr-doc-preview-img-wrap">
                                    <img src="@Model.SupportDocumentUrl" alt="Dokumen Bukti" class="usr-doc-preview-img" />
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Right column: actions -->
    <div class="usr-sidebar">

        @* Kartu Langganan — Psikolog *@
        @if (Model.Role == "Psychologist" && Model.PsychologistId.HasValue)
        {
            <div class="adm-card @(Model.IsMitraActive ? "usr-sub-card--active" : "")">
                <div class="adm-card-title">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8a2 2 0 0 0-2 2v2h12V5a2 2 0 0 0-2-2z"/></svg>
                    Langganan Mitra
                </div>
                @if (Model.IsMitraActive)
                {
                    <div class="usr-sub-status usr-sub-status--active">
                        <span class="usr-sub-dot"></span> Aktif
                        @if (Model.MitraEndDate.HasValue)
                        { <span class="usr-sub-exp">s/d @Model.MitraEndDate.Value.ToString("dd MMM yyyy")</span> }
                    </div>
                    <form asp-action="RevokeSubscription" method="post" style="margin-top:12px;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.UserId" />
                        <input type="hidden" name="role" value="Psychologist" />
                        <input type="hidden" name="psychologistId" value="@Model.PsychologistId" />
                        <button type="submit" class="btn btn-sm usr-btn-full usr-btn-revoke"
                                onclick="return confirm('Cabut langganan Mitra psikolog ini?');">
                            Cabut Langganan
                        </button>
                    </form>
                }
                else
                {
                    <p class="usr-card-desc">Belum berlangganan Mitra. Aktifkan atas nama sponsor.</p>
                    <form asp-action="GrantSubscription" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.UserId" />
                        <input type="hidden" name="role" value="Psychologist" />
                        <input type="hidden" name="psychologistId" value="@Model.PsychologistId" />
                        <div class="usr-sub-field">
                            <label class="usr-sub-label">Pilih Paket</label>
                            <select name="planId" class="usr-sub-select">
                                <option value="mitra-10">Mitra 10 Klien (1 bln)</option>
                                <option value="mitra-25" selected>Mitra 25 Klien (1 bln)</option>
                                <option value="mitra-50">Mitra 50 Klien (1 bln)</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm usr-btn-full" style="margin-top:10px;">
                            Aktifkan Mitra
                        </button>
                    </form>
                }
            </div>
        }

        @* Kartu Langganan — HR *@
        @if (Model.Role == "HR" && Model.CompanyId.HasValue)
        {
            <div class="adm-card @(Model.IsCompanySubscriptionActive ? "usr-sub-card--active" : "")">
                <div class="adm-card-title">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8a2 2 0 0 0-2 2v2h12V5a2 2 0 0 0-2-2z"/></svg>
                    Langganan HR
                </div>
                @if (Model.IsCompanySubscriptionActive)
                {
                    <div class="usr-sub-status usr-sub-status--active">
                        <span class="usr-sub-dot"></span> Aktif
                        @if (Model.CompanySubscriptionEndDate.HasValue)
                        { <span class="usr-sub-exp">s/d @Model.CompanySubscriptionEndDate.Value.ToString("dd MMM yyyy")</span> }
                    </div>
                    <form asp-action="RevokeSubscription" method="post" style="margin-top:12px;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.UserId" />
                        <input type="hidden" name="role" value="HR" />
                        <input type="hidden" name="companyId" value="@Model.CompanyId" />
                        <button type="submit" class="btn btn-sm usr-btn-full usr-btn-revoke"
                                onclick="return confirm('Cabut langganan HR perusahaan ini?');">
                            Cabut Langganan
                        </button>
                    </form>
                }
                else
                {
                    <p class="usr-card-desc">Perusahaan belum berlangganan. Aktifkan atas nama sponsor.</p>
                    <form asp-action="GrantSubscription" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.UserId" />
                        <input type="hidden" name="role" value="HR" />
                        <input type="hidden" name="companyId" value="@Model.CompanyId" />
                        <div class="usr-sub-field">
                            <label class="usr-sub-label">Pilih Paket</label>
                            <select name="planId" class="usr-sub-select">
                                <option value="company-10" selected>Perusahaan 10 Karyawan (12 bln)</option>
                                <option value="company-25">Perusahaan 25 Karyawan (12 bln)</option>
                                <option value="company-50">Perusahaan 50 Karyawan (12 bln)</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm usr-btn-full" style="margin-top:10px;">
                            Aktifkan Langganan HR
                        </button>
                    </form>
                }
            </div>
        }

        <!-- Edit Profile -->
        <div class="adm-card">
            <div class="adm-card-title">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                Edit Data Pengguna
            </div>
            <p class="usr-card-desc">
                Ubah informasi profil atau kontak pengguna ini.
            </p>
            <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-primary btn-sm usr-btn-full">
                ✏️ Edit Profil
            </a>
        </div>

        <!-- Toggle active -->
        <div class="adm-card">
            <div class="adm-card-title">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Status Akun
            </div>
            <p class="usr-card-desc">
                @(Model.IsActive ? "Akun ini sedang aktif. Nonaktifkan untuk mencabut akses login." : "Akun ini nonaktif. Aktifkan untuk memulihkan akses login.")
            </p>
            <form asp-action="ToggleActive" method="post">
                <input type="hidden" name="id" value="@Model.UserId" />
                <button type="submit"
                        class="btn @(Model.IsActive ? "btn-warning usr-btn-toggle usr-btn-toggle--active" : "btn-success usr-btn-toggle") btn-sm"
                        onclick="return confirm('@(Model.IsActive ? "Nonaktifkan" : "Aktifkan") akun ini?');">
                    @(Model.IsActive ? "🔒 Nonaktifkan Akun" : "🔓 Aktifkan Akun")
                </button>
            </form>
        </div>
        
        <!-- Delete User -->
        <div class="adm-card usr-delete-card">
            <div class="adm-card-title usr-delete-title">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                Hapus Permanen
            </div>
            <p class="usr-delete-desc">
                Peringatan: Tindakan ini tidak dapat dibatalkan. Semua data terkait pengguna ini akan dihapus.
            </p>
            <form asp-action="Delete" method="post">
                <input type="hidden" name="id" value="@Model.UserId" />
                <button type="submit" class="btn btn-sm usr-btn-delete"
                        onclick="return confirm('APAKAH ANDA YAKIN INGIN MENGHAPUS PENGGUNA INI SECARA PERMANEN?');">
                    🗑️ Hapus Pengguna
                </button>
            </form>
        </div>

    </div>
</div>
