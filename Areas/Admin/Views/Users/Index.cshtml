@model LightenUp.Web.Models.ViewModels.AdminUsersListViewModel
@{
    ViewData["Title"] = "Pengguna";
    ViewBag.ActiveNav = "Users";
    int totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);

    string RoleBadgeClass(string role) => role switch {
        "Psychologist" => "badge-role-psy",
        "HR"           => "badge-role-hr",
        "Patient"      => "badge-role-pat",
        "Admin"        => "badge-role-adm",
        _              => "badge-role",
    };
    string RoleLabel(string role) => role switch {
        "Psychologist" => "Psikolog",
        "HR"           => "HR",
        "Patient"      => "Pasien",
        "Admin"        => "Admin",
        _              => role,
    };
    string Initials(string name) {
        var parts = (name ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", parts.Take(2).Select(p => p[0])).ToUpper();
    }
}

@if (TempData["success"] is string ok)
{
    <div class="adm-alert success">✅ @ok</div>
}

<!-- ── Toolbar ── -->
@section Head {
    <link rel="stylesheet" href="~/css/admin/users-index.css" asp-append-version="true" />
}

<form method="get" class="adm-toolbar">
    <div class="adm-toolbar-search">
        <svg class="adm-toolbar-search-icon usr-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" name="search" placeholder="Cari nama atau email..." value="@Model.Search" class="usr-search-input" />
    </div>
    <select name="role">
        <option value="">Semua Role</option>
        <option value="Patient"       selected="@(Model.Role == "Patient")">Pasien</option>
        <option value="Psychologist"  selected="@(Model.Role == "Psychologist")">Psikolog</option>
        <option value="HR"            selected="@(Model.Role == "HR")">HR</option>
    </select>
    <select name="status">
        <option value="">Semua Status</option>
        <option value="Active"   selected="@(Model.Status == "Active")">Aktif</option>
        <option value="Inactive" selected="@(Model.Status == "Inactive")">Tidak Aktif</option>
        <option value="Pending"  selected="@(Model.Status == "Pending")">Belum Disetujui</option>
    </select>
    <button type="submit" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Filter
    </button>
    @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Role) || !string.IsNullOrEmpty(Model.Status))
    {
        <a class="btn btn-ghost" asp-action="Index">✕ Reset</a>
    }
</form>

<div class="adm-count-label usr-count-label">
    Menampilkan <strong>@Model.Items.Count</strong> dari <strong>@Model.TotalCount</strong> pengguna
</div>

@if (!Model.Items.Any())
{
    <div class="adm-table-wrap">
        <div class="adm-empty">
            <div class="adm-empty-icon">🔍</div>
            <div class="adm-empty-title">Tidak ada pengguna ditemukan</div>
            <div class="adm-empty-sub">Coba ubah filter atau kata kunci pencarian.</div>
        </div>
    </div>
}
else
{
    <div class="usr-cards-container">
        @foreach (var u in Model.Items)
        {
            <div class="usr-card">
                <div class="usr-card-main">
                    <div class="usr-avatar">@Initials(u.FullName)</div>
                    <div class="usr-info">
                        <div class="usr-name-primary">@u.FullName</div>
                        <div class="usr-name-secondary">@u.Email</div>
                    </div>
                </div>
                
                <div class="usr-card-badges">
                    <span class="usr-badge @RoleBadgeClass(u.Role)">@RoleLabel(u.Role)</span>
                    @if (!u.IsApprovedByAdmin)
                    {
                        <span class="usr-badge badge-pending">⏳ Pending</span>
                    }
                    else if (u.IsActive)
                    {
                        <span class="usr-badge badge-active">● Aktif</span>
                    }
                    else
                    {
                        <span class="usr-badge badge-inactive">○ Nonaktif</span>
                    }
                </div>
                
                <div class="usr-card-action">
                    <a class="btn btn-sm btn-secondary" asp-action="Detail" asp-route-id="@u.UserId">Detail</a>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="adm-pagination usr-pagination">
            @if (Model.Page > 1)
            {
                <a class="btn btn-sm btn-secondary"
                   asp-action="Index" asp-route-search="@Model.Search" asp-route-role="@Model.Role"
                   asp-route-status="@Model.Status" asp-route-page="@(Model.Page - 1)">← Prev</a>
            }
            @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(totalPages, Model.Page + 2); p++)
            {
                <a class="btn btn-sm @(p == Model.Page ? "btn-primary" : "btn-secondary")"
                   asp-action="Index" asp-route-search="@Model.Search" asp-route-role="@Model.Role"
                   asp-route-status="@Model.Status" asp-route-page="@p">@p</a>
            }
            @if (Model.Page < totalPages)
            {
                <a class="btn btn-sm btn-secondary"
                   asp-action="Index" asp-route-search="@Model.Search" asp-route-role="@Model.Role"
                   asp-route-status="@Model.Status" asp-route-page="@(Model.Page + 1)">Next →</a>
            }
        </div>
    }
}
