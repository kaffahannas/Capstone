@using Microsoft.AspNetCore.Identity
@using LightenUp.Web.Models
@inject UserManager<ApplicationUser> UserManager
@{
    var user       = await UserManager.GetUserAsync(User);
    var fullName   = user?.FullName ?? "Admin";
    var initials   = string.Join("", (fullName ?? "A").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper();
    var active     = ViewBag.ActiveNav as string ?? "Dashboard";
    var pageTitle  = ViewData["Title"]?.ToString() ?? "Admin";
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle · LightenUp Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css?v=@DateTime.Now.Ticks" />
    <link rel="stylesheet" href="~/css/admin.css?v=@DateTime.Now.Ticks" />
    <link rel="stylesheet" href="~/LightenUp.Web.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <div class="admin-shell app-shell" id="appShell">
        <div class="sidebar-backdrop" id="sidebarBackdrop" aria-hidden="true"></div>

        <!-- ── SIDEBAR ── -->
        <aside class="admin-sidebar app-sidebar" id="appSidebar" aria-label="Navigasi admin">
            <div class="sidebar-header">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="admin-brand">
                    <img src="~/image/lightenuplogo.ico" alt="LightenUp"
                         class="admin-brand-logo"
                         onerror="this.src='';this.classList.add('lay-admin-brand-logo--fallback');this.alt='LU'" />
                    <div>
                        <span class="brand-name">LightenUp</span>
                        <small>Admin Console</small>
                    </div>
                </a>
                <button type="button" class="sidebar-close" id="sidebarClose" aria-label="Tutup menu">&times;</button>
            </div>

            <nav class="admin-nav side-nav" role="navigation">
                <a class="admin-nav-item @(active == "Dashboard" ? "active" : "")"
                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                        <rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>
                    </svg>
                    <span>Dashboard</span>
                </a>

                <a class="admin-nav-item @(active == "Approvals" ? "active" : "")"
                   asp-area="Admin" asp-controller="Approvals" asp-action="Index">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="9 11 12 14 22 4"/>
                        <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                    </svg>
                    <span>Persetujuan</span>
                    @await Component.InvokeAsync("AdminNavBadges", new { type = "Approvals" })
                </a>

                <a class="admin-nav-item @(active == "Users" ? "active" : "")"
                   asp-area="Admin" asp-controller="Users" asp-action="Index">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    <span>Pengguna</span>
                </a>

                <a class="admin-nav-item @(active == "Companies" ? "active" : "")"
                   asp-area="Admin" asp-controller="Companies" asp-action="Index">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/>
                        <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/>
                        <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>
                        <path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>
                    </svg>
                    <span>Perusahaan</span>
                </a>

                <a class="admin-nav-item @(active == "Assignments" ? "active" : "")"
                   asp-area="Admin" asp-controller="Assignments" asp-action="Index">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <polyline points="16 11 18 13 22 9"/>
                    </svg>
                    <span>Penugasan</span>
                    @await Component.InvokeAsync("AdminNavBadges", new { type = "Assignments" })
                </a>

                <a class="admin-nav-item @(active == "Payroll" ? "active" : "")"
                   asp-area="Admin" asp-controller="Payroll" asp-action="Index">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <rect x="2" y="5" width="20" height="14" rx="2"/>
                        <line x1="2" y1="10" x2="22" y2="10"/>
                    </svg>
                    <span>Payroll</span>
                </a>


                <a class="admin-nav-item @(active == "Settings" ? "active" : "")"
                   asp-area="Admin" asp-controller="Settings" asp-action="Index">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                    <span>Pengaturan</span>
                </a>
            </nav>

            <form asp-area="AdminAuth" asp-controller="AdminAuth" asp-action="Logout" method="post" class="admin-logout side-nav-logout">
                <button type="submit" class="admin-logout-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    <span>Keluar</span>
                </button>
            </form>
        </aside>

        <!-- ── MAIN ── -->
        <main class="admin-main app-main">
            <header class="admin-topbar app-topbar">
                <button type="button" class="sidebar-toggle" id="sidebarToggle"
                        aria-label="Buka menu" aria-expanded="false" aria-controls="appSidebar">
                    <span class="hamburger" aria-hidden="true"></span>
                </button>

                <div class="admin-topbar-left">
                    <h2 class="lu-h2">@pageTitle</h2>
                    <span class="admin-topbar-breadcrumb">LightenUp Admin · @pageTitle</span>
                </div>

                <div class="admin-user">
                    <div class="admin-user-info lay-admin-user-info">
                        <strong>@fullName</strong>
                        <span class="role-chip">Admin</span>
                    </div>
                    <div class="admin-user-avatar" aria-hidden="true">@initials</div>
                </div>
            </header>

            <div class="admin-content lu-scroll-host">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
