@{
    var activeTab = ViewBag.ActiveTab as string ?? "Index";
}


@* #Bagian TabPersetujuan# *@
@* #Komponen NavigasiTab# *@
<div class="adm-tabs">
    <a class="adm-tab @(activeTab == "Index" ? "active" : "")"
       asp-action="Index">
        Persetujuan Akun @if (ViewBag.CountAccounts != null && ViewBag.CountAccounts > 0) { <span class="nav-badge apr-tab-badge">@ViewBag.CountAccounts</span> }
    </a>
    <a class="adm-tab @(activeTab == "EmployeeRemovals" ? "active" : "")"
       asp-action="EmployeeRemovals">
        Pemberhentian Karyawan (HR) @if (ViewBag.CountRemovals != null && ViewBag.CountRemovals > 0) { <span class="nav-badge apr-tab-badge">@ViewBag.CountRemovals</span> }
    </a>
<a class="adm-tab @(activeTab == "CancellationRequests" ? "active" : "")"
       asp-action="CancellationRequests">
        Pembatalan (HR) @if (ViewBag.CountCancellations != null && ViewBag.CountCancellations > 0) { <span class="nav-badge apr-tab-badge">@ViewBag.CountCancellations</span> }
    </a>
</div>
