@model LightenUp.Web.Models.ViewModels.AdminApprovalDetailViewModel
@{
    ViewData["Title"] = "Tinjau " + (Model.Role == "Psychologist" ? "Psikolog" : "HR");
    ViewBag.ActiveNav = "Approvals";
    var cid = new System.Globalization.CultureInfo("id-ID");
    string Initials(string name) {
        var parts = (name ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", parts.Take(2).Select(p => p[0])).ToUpper();
    }
    bool hasAcademic = !string.IsNullOrEmpty(Model.AcademicDocumentUrl);
    bool hasStr      = !string.IsNullOrEmpty(Model.StrDocumentUrl);
    bool hasSupport  = !string.IsNullOrEmpty(Model.SupportDocumentUrl);
    bool hasDocs     = hasAcademic || hasStr || hasSupport;
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/approvals-detail.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin/approvals-approvals-tabs.css" asp-append-version="true" />
}

<a class="back-link" asp-action="Index">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Kembali ke Daftar
</a>

<div class="apr-detail-grid">

    <!-- Applicant info -->
    <div class="adm-card">
        <div class="adm-card-title">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Informasi Pengaju
        </div>

        <!-- Avatar + name -->
        <div class="apr-applicant-header">
            @if (!string.IsNullOrEmpty(Model.ProfilePicture))
            {
                <img src="@Model.ProfilePicture" alt="Foto @Model.FullName" class="apr-applicant-avatar" />
            }
            else
            {
                <div class="apr-applicant-avatar-fallback">@Initials(Model.FullName)</div>
            }
            <div>
                <div class="apr-applicant-name">@Model.FullName</div>
                <div class="apr-applicant-email">@Model.Email</div>
                @if (Model.Role == "Psychologist")
                { <span class="badge badge-role-psy">🩺 Psikolog</span> }
                else
                { <span class="badge badge-role-hr">🏢 HR Manager</span> }
            </div>
        </div>

        <!-- Detail rows -->
        <div class="apr-detail-rows">
            @{
                var rows = new List<(string Label, string? Value)>();
                rows.Add(("Telepon", Model.Phone));
                if (Model.Role == "Psychologist") {
                    rows.Add(("Gelar Terakhir", Model.LastDegree));
                    rows.Add(("Universitas", Model.University));
                    rows.Add(("Spesialisasi", Model.Specialization));
                    rows.Add(("Nomor SIPP", Model.LicenseNumber));
                    rows.Add(("Nomor SIAP", Model.SiapNumber));
                    rows.Add(("Lokasi Praktik", Model.PracticeLocation));
                    rows.Add(("Pengalaman", Model.ExperienceYears.HasValue ? Model.ExperienceYears + " tahun" : null));
                } else if (Model.Role == "HR") {
                    rows.Add(("Perusahaan", Model.CompanyName));
                    rows.Add(("Alamat Perusahaan", Model.CompanyAddress));
                    rows.Add(("No. Registrasi", Model.CompanyRegistrationNumber));
                    rows.Add(("Divisi", Model.Department));
                    rows.Add(("Gelar Terakhir", Model.LastDegree));
                    rows.Add(("Universitas", Model.University));
                }
            }
            @foreach (var row in rows.Where(r => !string.IsNullOrWhiteSpace(r.Value)))
            {
                <div class="apr-detail-row">
                    <span class="apr-detail-label">@row.Label</span>
                    <span class="apr-detail-value">@row.Value</span>
                </div>
            }
            <div class="apr-detail-row apr-detail-row--last">
                <span class="apr-detail-label">Diajukan</span>
                <span class="apr-detail-value">@Model.SubmittedAt.ToString("d MMMM yyyy", cid)</span>
            </div>
        </div>
    </div>

    <!-- Documents -->
    <div class="adm-card">
        <div class="adm-card-title">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Dokumen Pendukung
        </div>

        @if (!hasDocs)
        {
            <div class="adm-empty apr-empty-docs">
                <div class="adm-empty-icon apr-empty-docs-icon">📂</div>
                <div class="adm-empty-sub">Tidak ada dokumen yang diunggah oleh pengaju.</div>
            </div>
        }
        else
        {
            @if (hasAcademic)
            {
                <a class="adm-doc-item" href="@Model.AcademicDocumentUrl" target="_blank" rel="noopener">
                    <div class="adm-doc-icon">🎓</div>
                    <div>
                        <div class="apr-doc-title">Dokumen Akademik</div>
                        <div class="apr-doc-subtitle">Ijazah / Transkrip</div>
                    </div>
                    <svg class="apr-doc-link-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
            }
            @if (hasStr)
            {
                <a class="adm-doc-item" href="@Model.StrDocumentUrl" target="_blank" rel="noopener">
                    <div class="adm-doc-icon">📜</div>
                    <div>
                        <div class="apr-doc-title">STR / SIPP</div>
                        <div class="apr-doc-subtitle">Surat Tanda Registrasi</div>
                    </div>
                    <svg class="apr-doc-link-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
            }
            @if (hasSupport)
            {
                <a class="adm-doc-item" href="@Model.SupportDocumentUrl" target="_blank" rel="noopener">
                    <div class="adm-doc-icon">🏢</div>
                    <div>
                        <div class="apr-doc-title">Dokumen Perusahaan</div>
                        <div class="apr-doc-subtitle">SIUP / Akte / Surat Izin</div>
                    </div>
                    <svg class="apr-doc-link-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
            }
        }
    </div>
</div>

<!-- ── Decision ── -->
<div class="adm-card">
    <div class="adm-card-title">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        Keputusan
    </div>

    <form method="post">
        <input type="hidden" name="UserId" value="@Model.UserId" />

        <div class="adm-form-row apr-form-row-narrow">
            <label>Catatan untuk pengaju <small class="apr-label-hint">(opsional, akan dikirim via email)</small></label>
            <textarea name="Note" placeholder="Tuliskan alasan penolakan atau pesan sambutan..."></textarea>
        </div>

        <div class="apr-decision-grid">
            <div class="adm-reject-section">
                <div class="apr-reject-title">🚫 Tolak Permohonan</div>
                <p class="apr-reject-text">
                    Akun akan dinonaktifkan dan pengaju akan mendapat notifikasi email.
                </p>
                <button type="submit"
                        formaction="@Url.Action("Reject")"
                        class="btn btn-danger btn-sm apr-btn-full"
                        onclick="return confirm('Tolak permohonan akun ini?');">
                    Tolak
                </button>
            </div>
            <div class="adm-approve-section">
                <div class="apr-approve-title">✅ Setujui Permohonan</div>
                <p class="apr-approve-text">
                    Akun akan diaktifkan dan pengaju dapat segera login.
                </p>
                <button type="submit"
                        formaction="@Url.Action("Approve")"
                        class="btn btn-success btn-sm apr-btn-full"
                        onclick="return confirm('Setujui permohonan akun ini?');">
                    Setujui
                </button>
            </div>
        </div>
    </form>
</div>
