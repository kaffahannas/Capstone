@model IEnumerable<LightenUp.Web.Models.HrEmployeeRemovalRequest>
@{
    ViewData["Title"] = "Pemberhentian Karyawan";
    ViewBag.ActiveNav = "Approvals";

    int totalAll = Model.Count();
}

@if (TempData["success"] is string ok)
{
    <div class="adm-alert success">✅ @ok</div>
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/approvals-employee-removals.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin/approvals-approvals-tabs.css" asp-append-version="true" />
}


@* #Bagian PemberhentianKaryawan# *@
@* #Komponen HeaderHalaman# *@
<div class="adm-page-header apr-page-header">
    <h1>Manajemen Persetujuan</h1>
    <p class="adm-page-sub">Kelola persetujuan akun pengguna dan permintaan pemberhentian karyawan dari HR.</p>
</div>

<script>
    function submitWithReason(form, promptMsg) {
        var reason = prompt(promptMsg);
        if (reason === null) return false; // Cancelled
        if (!reason.trim()) { alert('Alasan wajib diisi.'); return false; }
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'note';
        input.value = reason;
        form.appendChild(input);
        return true;
    }
</script>

@{
    ViewBag.ActiveTab = "EmployeeRemovals";
}
<partial name="_ApprovalsTabs" />

@if (!Model.Any())
{
    <div class="adm-empty-state-premium apr-empty-premium">
        <div class="icon apr-empty-premium-icon">✅</div>
        <h3>Tidak ada permintaan pemberhentian</h3>
        <p>Permintaan dari HR akan muncul di sini.</p>
    </div>
}
else
{
    <div class="adm-table-wrap">
        <table class="adm-table">
            <thead>
                <tr>
                    <th>Waktu</th>
                    <th>Karyawan</th>
                    <th>Diminta Oleh HR</th>
                    <th>Alasan</th>
                    <th>Status</th>
                    <th class="apr-th-actions">Aksi</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="apr-td-time">
                            @item.CreatedAt.ToString("d MMM yyyy HH:mm")
                        </td>
                        <td>
                            <div class="apr-name-primary">@(item.Patient?.User?.FullName ?? "-")</div>
                            <div class="apr-name-secondary">@(item.Patient?.User?.Email ?? "-")</div>
                        </td>
                        <td>
                            <div class="apr-td-secondary">@(item.RequestedByHr?.FullName ?? "-")</div>
                        </td>
                        <td class="apr-td-reason">
                            @item.Reason
                        </td>
                        <td>
                            @if (item.Status == "Approved")
                            { <span class="badge badge-role-psy apr-badge-approved">Disetujui</span> }
                            else if (item.Status == "Rejected")
                            { <span class="badge badge-role-hr apr-badge-rejected">Ditolak</span> }
                            else
                            { <span class="badge apr-badge-pending">Menunggu</span> }
                        </td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <div class="apr-action-row">
                                    <form asp-action="ApproveEmployeeRemoval" method="post" class="apr-action-form" onsubmit="return submitWithReason(this, 'Berikan alasan atau catatan (opsional namun disarankan):');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm apr-btn-approve">Setujui</button>
                                    </form>
                                    <form asp-action="RejectEmployeeRemoval" method="post" class="apr-action-form" onsubmit="return submitWithReason(this, 'Berikan alasan penolakan (wajib):');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm apr-btn-reject">Tolak</button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <span class="apr-decision-date">@item.DecisionAt?.ToString("d MMM yyyy")</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
