@model IEnumerable<LightenUp.Web.Models.HrEmployeeRemovalRequest>
@{
    ViewData["Title"] = "Pemberhentian Karyawan";
    ViewBag.ActiveNav = "EmployeeRemovals";

    int totalAll = Model.Count();
}

@if (TempData["success"] is string ok)
{
    <div class="adm-alert success">✅ @ok</div>
}

<div class="adm-tabs">
    <a class="adm-tab" asp-action="Index" asp-route-tab="All">
        Persetujuan Akun
    </a>
    <a class="adm-tab active" asp-action="EmployeeRemovals">
        Pemberhentian Karyawan
        @if (totalAll > 0) { <span class="nav-badge" style="position:static; margin-left:2px;">@totalAll</span> }
    </a>
</div>

@if (!Model.Any())
{
    <div class="adm-table-wrap">
        <div class="adm-empty">
            <div class="adm-empty-icon">✅</div>
            <div class="adm-empty-title">Tidak ada permintaan pemberhentian</div>
            <div class="adm-empty-sub">Permintaan dari HR akan muncul di sini.</div>
        </div>
    </div>
}
else
{
    <div class="adm-table-wrap">
        <table class="adm-table">
            <thead>
                <tr>
                    <th>Waktu</th>
                    <th>Karyawan</th>
                    <th>Diminta Oleh HR</th>
                    <th>Alasan</th>
                    <th>Status</th>
                    <th style="width:140px;">Aksi</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-size:12px; color:var(--adm-muted); white-space:nowrap;">
                            @item.CreatedAt.ToString("d MMM yyyy HH:mm")
                        </td>
                        <td>
                            <div style="font-weight:600; font-size:13.5px;">@(item.Patient?.User?.FullName ?? "-")</div>
                            <div style="font-size:12px; color:var(--adm-muted);">@(item.Patient?.User?.Email ?? "-")</div>
                        </td>
                        <td>
                            <div style="font-size:13px; color:var(--adm-text-secondary);">@(item.RequestedByHr?.FullName ?? "-")</div>
                        </td>
                        <td style="font-size:13px; color:var(--adm-text-secondary); max-width:250px;">
                            @item.Reason
                        </td>
                        <td>
                            @if (item.Status == "Approved")
                            { <span class="badge badge-role-psy" style="background:#ECFDF5;color:#065F46">Disetujui</span> }
                            else if (item.Status == "Rejected")
                            { <span class="badge badge-role-hr" style="background:#FEF2F2;color:#991B1B">Ditolak</span> }
                            else
                            { <span class="badge" style="background:#FFFBEB;color:#92400E">Menunggu</span> }
                        </td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <div style="display:flex; gap:6px;">
                                    <form asp-action="ApproveEmployeeRemoval" method="post" style="margin:0;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-primary" style="background:#10B981; border:none;" onclick="return confirm('Yakin setujui pemberhentian karyawan ini?');">Terima</button>
                                    </form>
                                    <form asp-action="RejectEmployeeRemoval" method="post" style="margin:0;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline" style="color:#DC2626; border-color:#DC2626;" onclick="return confirm('Tolak permohonan ini?');">Tolak</button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <span style="font-size:12px; color:var(--adm-muted);">@item.DecisionAt?.ToString("d MMM yyyy")</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
