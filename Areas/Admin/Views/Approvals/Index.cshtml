@model LightenUp.Web.Models.ViewModels.AdminApprovalsViewModel
@{
    ViewData["Title"] = "Persetujuan Akun";
    ViewBag.ActiveNav = "Approvals";

    int totalAll = Model.Items.Count;
    string Initials(string name) {
        var parts = (name ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Join("", parts.Take(2).Select(p => p[0])).ToUpper();
    }
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/approvals-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin/approvals-approvals-tabs.css" asp-append-version="true" />
}


@* #Bagian PersetujuanAkun# *@
@* #Komponen HeaderHalaman# *@
<div class="adm-page-header apr-page-header">
    <h1>Manajemen Persetujuan</h1>
    <p class="adm-page-sub">Kelola persetujuan akun pengguna dan permintaan pemberhentian karyawan dari HR.</p>
</div>

@{
    ViewBag.ActiveTab = "Index";
}
<partial name="_ApprovalsTabs" />

@if (TempData["success"] is string ok)
{
    <div class="adm-alert success">✅ @ok</div>
}



@if (!Model.Items.Any())
{
    <div class="adm-table-wrap">
        <div class="adm-empty">
            <div class="adm-empty-icon">✅</div>
            <div class="adm-empty-title">Tidak ada akun menunggu persetujuan</div>
            <div class="adm-empty-sub">Psikolog baru akan muncul di sini setelah menyelesaikan onboarding.</div>
        </div>
    </div>
}
else
{
    <div class="adm-table-wrap">
        <table class="adm-table">
            <thead>
                <tr>
                    <th>Pengaju</th>
                    <th>Role</th>
                    <th>Info</th>
                    <th>Masuk</th>
                    <th class="apr-th-review"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="adm-user-cell">
                                <div class="adm-avatar-sm">@Initials(item.FullName)</div>
                                <div>
                                    <div class="apr-name-primary">@item.FullName</div>
                                    <div class="apr-name-secondary">@item.Email</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (item.Role == "Psychologist")
                            { <span class="badge badge-role-psy">🩺 Psikolog</span> }
                            else
                            { <span class="badge badge-role-hr">🏢 HR</span> }
                        </td>
                        <td class="apr-td-info">
                            @if (item.Role == "Psychologist")
                            {
                                @if (!string.IsNullOrEmpty(item.LicenseNumber))
                                {
                                    <div class="apr-info-sipp">SIPP: @item.LicenseNumber</div>
                                }
                                @if (!string.IsNullOrEmpty(item.Specialization))
                                {
                                    <div class="apr-info-siap">SIAP: @item.Specialization</div>
                                }
                                @if (string.IsNullOrEmpty(item.LicenseNumber) && string.IsNullOrEmpty(item.Specialization))
                                {
                                    <div>Pendaftaran Baru</div>
                                }
                            }
                            else if (item.Role == "HR")
                            {
                                <div>@(item.CompanyName ?? "Tanpa perusahaan")</div>
                            }
                        </td>
                        <td class="apr-td-date">
                            @(item.SubmittedAt.HasValue ? item.SubmittedAt.Value.ToString("d MMM yyyy") : "—")
                        </td>
                        <td>
                            <a class="adm-btn adm-btn-sm adm-btn-primary apr-btn-review" asp-action="Detail" asp-route-id="@item.UserId">Tinjau</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
