@model IEnumerable<LightenUp.Web.Models.PatientPsychologistAssignment>
@{
    ViewData["Title"] = "Persetujuan Pembatalan HR";
    ViewBag.ActiveNav = "Approvals";
    int totalCount = Model.Count();
}

<div class="adm-page-header apr-page-header">
    <h1>Manajemen Persetujuan</h1>
    <p class="adm-page-sub">Kelola persetujuan akun pengguna dan permintaan pemberhentian karyawan dari HR.</p>
</div>

<script>
    function submitWithReason(form, promptMsg) {
        var reason = prompt(promptMsg);
        if (reason === null) return false; // Cancelled
        if (!reason.trim()) { alert('Alasan wajib diisi.'); return false; }
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'note';
        input.value = reason;
        form.appendChild(input);
        return true;
    }
</script>

@{
    ViewBag.ActiveTab = "CancellationRequests";
}
<partial name="_ApprovalsTabs" />

@if (TempData["success"] is string ok)
{
    <div class="adm-alert success">✅ @ok</div>
}

@if (!Model.Any())
{
    <div class="adm-empty-state-premium apr-empty-premium">
        <div class="icon apr-empty-premium-icon">✨</div>
        <h3>Tidak ada permintaan pembatalan</h3>
        <p>Permintaan pembatalan penugasan dari HR akan muncul di sini.</p>
    </div>
}
else
{
    <div class="adm-card apr-request-card">
        <table class="adm-table apr-request-table">
            <thead class="apr-request-thead">
                <tr>
                    <th class="apr-request-th">Pasien</th>
                    <th class="apr-request-th">Psikolog</th>
                    <th class="apr-request-th">Status</th>
                    <th class="apr-request-th">Pemohon</th>
                    <th class="apr-request-th">Info & Alasan</th>
                    <th class="apr-request-th">Tanggal</th>
                    <th class="apr-request-th apr-request-th--right">Aksi</th>
                </tr>
            </thead>
            <tbody class="apr-request-tbody">
            @foreach (var a in Model)
            {
                <tr class="apr-request-tr">
                    <td class="apr-request-td">
                        <strong class="apr-patient-name">@(a.Patient?.User?.FullName ?? "—")</strong>
                        <span class="apr-patient-tag">@(a.Patient?.CompanyId != null ? (a.Patient.Company?.Name ?? "B2B") : "Publik (B2C)")</span>
                    </td>
                    <td class="apr-request-td apr-psy-name">@(a.Psychologist?.User?.FullName ?? "—")</td>
                    <td class="apr-request-td"><span class="apr-status-hr-cancel">HR minta batalkan</span></td>
                    <td class="apr-request-td">@(a.CancellationRequestedBy?.FullName ?? "—")</td>
                    <td class="apr-request-td">
                        @if (!string.IsNullOrEmpty(a.CancellationReason))
                        {
                            <div class="apr-cancel-reason">@a.CancellationReason</div>
                        }
                        else { <span class="apr-cancel-empty">—</span> }
                    </td>
                    <td class="apr-request-td apr-td-date">@(a.CancellationRequestedAt?.ToString("dd MMM yyyy"))</td>
                    <td class="apr-request-td apr-request-td--right">
                        <div class="apr-action-row">
                            <form asp-action="ApproveAssignment" method="post" class="apr-action-form" onsubmit="return submitWithReason(this, 'Berikan catatan pembatalan (opsional namun disarankan):');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="assignmentId" value="@a.AssignmentId" />
                                <button type="submit" class="btn btn-sm apr-btn-approve">Setujui</button>
                            </form>
                            <form asp-action="RejectAssignment" method="post" class="apr-action-form" onsubmit="return submitWithReason(this, 'Berikan alasan penolakan (wajib):');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="assignmentId" value="@a.AssignmentId" />
                                <button type="submit" class="btn btn-sm apr-btn-reject">Tolak</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
