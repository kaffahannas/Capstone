@using LightenUp.Web.Models
@using LightenUp.Web.Services
@model LightenUp.Web.Models.PsychologistPayrollSetting
@{
    ViewData["Title"] = "Edit Payroll";
    ViewBag.ActiveNav = "Payroll";
    var psyName = ViewBag.PsyName as string ?? "—";
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/payroll-edit.css" asp-append-version="true" />
}

<a class="adm-back-link" asp-action="Index">← Daftar Payroll</a>

<div class="pay-edit-wrap">
    <div class="pay-edit-hero">
        <p class="pay-edit-hero-label">Pengaturan Payroll</p>
        <h2 class="pay-edit-hero-title">@psyName</h2>
        <p class="pay-edit-hero-sub">
            Model Sir Lukas: Bayaran dihitung per sesi selesai, bukan per bulan flat.
        </p>
    </div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PsychologistId" />
        <input type="hidden" asp-for="SessionRate" value="0" />

        <div class="adm-card pay-edit-card">
            <div asp-validation-summary="ModelOnly" class="pay-validation-summary"></div>

            <div class="pay-form-field">
                <label asp-for="PsychologistPercentage" class="pay-form-label">
                    Persentase untuk Psikolog (%) <span class="pay-form-required">*</span>
                </label>
                <input asp-for="PsychologistPercentage" type="number" min="0" max="100" step="1" class="pay-form-input" />
                <span asp-validation-for="PsychologistPercentage" class="pay-form-error"></span>
                <p class="pay-form-hint">
                    Standar platform: 40% psikolog, 60% LightenUp. Contoh: Masukkan 40 untuk 40%.
                </p>
            </div>

            <div class="pay-form-field">
                <label asp-for="AdminReason" class="pay-form-label">
                    Alasan Perubahan Persentase (Wajib Jika Diubah)
                </label>
                <textarea asp-for="AdminReason" rows="3" class="pay-form-input"
                          placeholder="Masukkan alasan mengapa persentase psikolog diubah (cth: tingkat kesulitan rendah)"></textarea>
                <span asp-validation-for="AdminReason" class="pay-form-error"></span>
                <p class="pay-form-hint">
                    Alasan ini akan terlihat oleh psikolog jika ditanyakan.
                </p>
            </div>

            <div class="pay-formula-box">
                <strong>📊 Formula (Sir Lukas):</strong><br />
                <span class="pay-formula-code">
                    Nilai per Sesi = Slot Pasien / Jumlah Sesi per Bulan<br />
                    Bayaran Psikolog = Nilai per Sesi × % Psikolog<br /><br />
                    Contoh: Rp 1.000.000 / 4 sesi = <strong>Rp 250.000/sesi</strong>
                    → Psikolog 40% = <strong>Rp 100.000/sesi</strong>
                </span>
            </div>
        </div>

        <div class="pay-edit-actions">
            <a asp-action="Index" class="pay-btn-cancel">
                Batal
            </a>
            <button type="submit" class="adm-btn adm-btn-primary pay-btn-save">
                💾 Simpan Pengaturan
            </button>
        </div>
    </form>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
