@using LightenUp.Web.Areas.Admin.Controllers
@model List<LightenUp.Web.Areas.Admin.Controllers.AdminPayrollRow>
@{
    ViewData["Title"] = "Payroll Psikolog";
    ViewBag.ActiveNav = "Payroll";
    var idCulture = new System.Globalization.CultureInfo("id-ID");
    string Idr(decimal v) => v.ToString("C0", idCulture);
    var totalPsyShare = Model.Sum(r => r.PsyShareMonthly);
    var totalGross = Model.Sum(r => r.GrossMonthly);
    var monthLabel = DateTime.Now.ToString("MMMM yyyy", idCulture);
}

@if (TempData["success"] is string ok)
{
    <div class="adm-alert success">✅ @ok</div>
}

@section Head {
    <link rel="stylesheet" href="~/css/admin/payroll-index.css" asp-append-version="true" />
}


@* #Bagian PayrollPsikolog# *@
<div class="lu-page pay-page">
<div class="adm-page-header">
    <h1>Payroll Psikolog</h1>
    <p class="adm-page-sub">
        Model per-sesi — Periode: <strong>@monthLabel</strong>.
        Formula: <code>Nilai Sesi = Biaya Langganan ÷ Maks. Sesi/Bulan</code>, lalu × persentase psikolog per sesi selesai.
    </p>
</div>

@* #Komponen KartuKPI# *@
<div class="pay-kpi-grid">
    <div class="pay-kpi-card">
        <p class="pay-kpi-label">Total Psikolog</p>
        <p class="pay-kpi-value">@Model.Count</p>
    </div>
    <div class="pay-kpi-card">
        <p class="pay-kpi-label">Total Slot Bulanan</p>
        <p class="pay-kpi-value pay-kpi-value--medium pay-kpi-value--purple">@Idr(totalGross)</p>
    </div>
    <div class="pay-kpi-card pay-kpi-card--accent">
        <p class="pay-kpi-label">Proyeksi Bayar Psikolog (bulan ini)</p>
        <p class="pay-kpi-value pay-kpi-value--medium pay-kpi-value--white">@Idr(totalPsyShare)</p>
    </div>
</div>

<div class="adm-table-wrap lu-list-scroll">
    <table class="adm-table">
        <thead>
            <tr>
                <th class="pay-th-psy">Psikolog</th>
                <th class="pay-th-center">% Psy</th>
                <th class="pay-th-center">Maks. Sesi</th>
                <th class="pay-th-center">Pasien Aktif</th>
                <th class="pay-th-center">Sesi Selesai (Bulan ini)</th>
                <th class="pay-th-right">Bayaran Psikolog (Bulan ini)</th>
                <th class="pay-th-actions">Aksi</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model)
        {
            var psyPerSesValueFmt = r.ActivePatients > 0 && r.MaxSessionsPerMonth > 0
                ? Idr(r.PerSessionValueTotal)
                : "—";
            <tr>
                <td>
                    <strong>@r.FullName</strong>
                    <br><small class="text-muted">@r.Email</small>
                </td>
                <td class="pay-td-center">
                    <span class="pay-badge-pct">@r.DefaultPsychologistPercentage%</span>
                </td>
                <td class="pay-td-center">
                    <span class="pay-badge-sessions">@r.MaxSessionsPerMonth sesi</span>
                </td>
                <td class="pay-td-count">@r.ActivePatients</td>
                <td class="pay-td-center">
                    @if (r.CompletedSessionsThisMonth > 0)
                    {
                        <span class="pay-badge-completed">@r.CompletedSessionsThisMonth sesi</span>
                    }
                    else
                    {
                        <span class="pay-text-muted">Belum ada</span>
                    }
                </td>
                <td class="pay-td-right">
                    @if (r.PsyShareMonthly > 0)
                    {
                        <strong class="pay-amount-positive">@Idr(r.PsyShareMonthly)</strong>
                    }
                    else
                    {
                        <span class="pay-text-muted">@Idr(0)</span>
                    }
                </td>
                <td class="pay-td-right">
                    <div class="pay-action-row">
                        <button type="button" class="btn btn-sm btn-secondary" onclick="openSettingsModal(@r.PsychologistId, '@r.FullName', @r.DefaultPsychologistPercentage.ToString("G", System.Globalization.CultureInfo.InvariantCulture))">
                            Pengaturan
                        </button>
                        <a asp-action="Transfer" asp-route-id="@r.PsychologistId" class="btn btn-sm btn-primary pay-btn-transfer">
                            Transfer
                        </a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="pay-note">
    <strong>ℹ️ Catatan:</strong>
    Bayaran aktual ditransfer setelah bulan berakhir. Proyeksi di atas berdasarkan sesi yang telah berstatus <em>Completed</em> dalam bulan berjalan.
    Biaya langganan diambil dari subscription aktif pasien/perusahaan dan payment terkait.
</div>
</div>

<dialog id="settingsModal" class="pay-settings-modal" oncancel="closeSettingsModal()">
    <div class="pay-modal-header">
        <h3 class="pay-modal-title">Pengaturan Payroll</h3>
        <button type="button" onclick="closeSettingsModal()" class="pay-modal-close">&times;</button>
    </div>
    <form asp-action="Edit" method="post">
        <div class="pay-modal-form">
            @Html.AntiForgeryToken()
            <input type="hidden" id="modalPsyId" name="PsychologistId" />
            
            <p class="pay-modal-intro">Psikolog: <strong id="modalPsyName"></strong></p>
            
            <div class="pay-modal-field">
                <label class="pay-modal-label">Persentase Bagi Hasil (%)</label>
                <input type="number" id="modalPsyPct" name="PsychologistPercentage" min="0" max="100" step="0.01" required class="form-control pay-modal-input" />
            </div>
            
            <div class="pay-modal-field pay-modal-field--spaced">
                <label class="pay-modal-label">Alasan Perubahan (wajib jika diubah)</label>
                <textarea name="AdminReason" rows="2" class="form-control pay-modal-input" placeholder="Misal: Penyesuaian kontrak baru"></textarea>
            </div>
            
            <div class="pay-modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeSettingsModal()">Batal</button>
                <button type="submit" class="btn btn-primary">Simpan</button>
            </div>
        </div>
    </form>
</dialog>

@section Scripts {
    <script>
        const modal = document.getElementById('settingsModal');
        function openSettingsModal(id, name, pct) {
            document.getElementById('modalPsyId').value = id;
            document.getElementById('modalPsyName').textContent = name;
            document.getElementById('modalPsyPct').value = pct;
            
            // clear the reason field
            document.querySelector('textarea[name="AdminReason"]').value = '';
            
            modal.showModal();
        }
        function closeSettingsModal() {
            modal.close();
        }
    </script>
}
