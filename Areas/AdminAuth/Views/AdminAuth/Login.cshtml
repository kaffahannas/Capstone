@model LightenUp.Web.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Admin Login - LightenUp";
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin-auth.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-card">
        <div class="admin-brand">
            <div class="mark">L</div>
            <h1>LightenUp Admin</h1>
            <small>Internal staff only</small>
        </div>

        <form asp-action="Login" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="err-summary"></div>
            }

            <div class="field">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" placeholder="admin@lightenup.com" autocomplete="email" />
            </div>

            <div class="field">
                <label asp-for="Password">Kata Sandi</label>
                <input asp-for="Password" type="password" autocomplete="current-password" />
            </div>

            <div class="remember-row">
                <input type="checkbox" asp-for="RememberMe" id="rememberMe" />
                <label for="rememberMe" class="remember-label">Ingat saya</label>
            </div>

            <button type="submit" class="btn-submit">Masuk ke Admin Console</button>
        </form>

        <div class="info-strip">
            ⚠️ Akses dibatasi untuk staf LightenUp. Aktivitas login dicatat untuk audit keamanan.
            Jika Anda bukan staf, silakan login di situs utama.
        </div>
    </div>
</body>
</html>
