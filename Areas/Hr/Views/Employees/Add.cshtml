@model LightenUp.Web.Models.ViewModels.HrAddClientViewModel
@{
    ViewData["Title"] = "Tambah Klien";
    ViewBag.ActiveNav = "Klien";
    var referralCode = ViewBag.ReferralCode as string;
}

@* ── Back link ── *@
<a class="pd-back" asp-controller="Employees" asp-action="Index">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Klien Aktif
</a>

<div style="max-width:640px;">
    <h2 style="margin:0 0 4px;font-size:22px;font-weight:800;color:var(--text-dark);">Tambah Klien Baru</h2>
    <p style="margin:0 0 20px;color:var(--text-muted);font-size:14px;">
        Catat karyawan yang akan mendaftar ke LightenUp dengan kode referral perusahaan.
        @if (!string.IsNullOrEmpty(referralCode))
        {
            <br/><strong style="color:var(--primary-purple);">Kode Referral: @referralCode</strong>
        }
    </p>

    <form asp-action="Add" method="post">
        <div class="detail-card">
            <div asp-validation-summary="ModelOnly" style="background:#FEE2E2;color:#B91C1C;padding:10px 14px;border-radius:8px;margin-bottom:16px;font-size:13px;"></div>

            <div class="form-group">
                <label asp-for="Department" class="form-label">Divisi</label>
                <input asp-for="Department" class="form-control" placeholder="Mis. Marketing, Engineering..." />
                <span asp-validation-for="Department" style="color:#DC2626;font-size:12px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="FullName" class="form-label">Nama Karyawan</label>
                <input asp-for="FullName" class="form-control" placeholder="Nama lengkap karyawan" />
                <span asp-validation-for="FullName" style="color:#DC2626;font-size:12px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Kontak</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="nama@perusahaan.com" />
                <span asp-validation-for="Email" style="color:#DC2626;font-size:12px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="EmployeeId" class="form-label">Employee ID <small style="color:var(--text-muted);font-weight:400;">(opsional)</small></label>
                <input asp-for="EmployeeId" class="form-control" placeholder="EMP-2024-..." />
            </div>
        </div>

        <div class="modal-footer" style="padding:0;margin-top:16px;">
            <a asp-action="Index" class="btn-outline">Batalkan</a>
            <button type="submit" class="btn-fill">Simpan Klien</button>
        </div>
    </form>
</div>
