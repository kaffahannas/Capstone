@model LightenUp.Web.Models.ViewModels.HrAddClientViewModel
@{
    ViewData["Title"] = "Tambah Klien";
    ViewBag.ActiveNav = "Klien";
    var referralCode = ViewBag.ReferralCode as string;
}

@* ── Back link ── *@
<a class="pd-back" asp-controller="Employees" asp-action="Index">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Klien Aktif
</a>

<div class="hradd-wrap">
    <h2 class="hradd-title">Tambah Klien Baru</h2>
    <p class="hradd-sub">
        Catat karyawan yang akan mendaftar ke LightenUp dengan kode referral perusahaan.
        @if (!string.IsNullOrEmpty(referralCode))
        {
            <br/><strong class="hradd-referral">Kode Referral: @referralCode</strong>
        }
    </p>

    <form asp-action="Add" method="post">
        <div class="detail-card">
            <div asp-validation-summary="ModelOnly" class="hradd-val-summary"></div>

            <div class="form-group">
                <label asp-for="DivisionId" class="form-label">Divisi</label>
                <select asp-for="DivisionId" class="form-control" asp-items="@(new SelectList(ViewBag.Divisions, "DivisionId", "Name"))">
                    <option value="">Pilih Divisi...</option>
                </select>
                <span asp-validation-for="DivisionId" class="hradd-val-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="FullName" class="form-label">Nama Karyawan</label>
                <input asp-for="FullName" class="form-control" placeholder="Nama lengkap karyawan" />
                <span asp-validation-for="FullName" class="hradd-val-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Kontak</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="nama@perusahaan.com" />
                <span asp-validation-for="Email" class="hradd-val-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="EmployeeId" class="form-label">Employee ID <small class="hradd-label-opt">(opsional)</small></label>
                <input asp-for="EmployeeId" class="form-control" placeholder="EMP-2024-..." />
            </div>
        </div>

        <div class="modal-footer hradd-footer">
            <a asp-action="Index" class="btn-outline">Batalkan</a>
            <button type="submit" class="btn-fill">Simpan Klien</button>
        </div>
    </form>
</div>
