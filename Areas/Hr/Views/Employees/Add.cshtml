@model LightenUp.Web.Models.ViewModels.HrAddClientViewModel
@{
    ViewData["Title"] = "Tambah Client";
    ViewBag.ActiveNav = "Klien";
    var referralCode = ViewBag.ReferralCode as string;
}

<a asp-action="Index" style="text-decoration:none; color:#111;">← Klien Aktif</a>

<div style="max-width: 560px; margin: 16px auto 0;">
    <h2 style="margin-bottom: 8px;">Tambah Client</h2>
    <p style="color:#6B7280; font-size:14px;">
        Catat karyawan yang akan terdaftar. Mereka mendaftar sendiri di situs LightenUp dengan kode referral perusahaan
        @if (!string.IsNullOrEmpty(referralCode))
        {
            <strong style="color:#7C3AED; letter-spacing:1px;">@referralCode</strong>
        }
        . Saat mereka mendaftar, sistem otomatis mengaitkan data ini.
    </p>

    <form asp-action="Add" method="post" class="lu-card" style="margin-top:16px;">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;"></div>

        <div style="margin-bottom:14px;">
            <label asp-for="Department" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Tambahkan Divisi</label>
            <input asp-for="Department" class="onb-input" placeholder="Nama divisi baru" />
            <span asp-validation-for="Department" class="text-danger"></span>
        </div>

        <div style="margin-bottom:14px;">
            <label asp-for="FullName" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Tambahkan Karyawan</label>
            <input asp-for="FullName" class="onb-input" placeholder="Nama karyawan baru" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div style="margin-bottom:14px;">
            <label asp-for="Email" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Tambahkan Kontak</label>
            <input asp-for="Email" type="email" class="onb-input" placeholder="employee@company.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div style="margin-bottom:14px;">
            <label asp-for="EmployeeId" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Employee ID (opsional)</label>
            <input asp-for="EmployeeId" class="onb-input" placeholder="EMP-2024-..." />
        </div>

        <div style="display:flex; gap:12px; margin-top:8px;">
            <a asp-action="Index" class="btn-secondary" style="flex:1; text-align:center;">Batalkan</a>
            <button type="submit" class="btn-primary" style="flex:1;">Simpan Pengaturan</button>
        </div>
    </form>
</div>
