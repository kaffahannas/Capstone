@model LightenUp.Web.Models.ViewModels.HrEmployeesListViewModel
@{
    ViewData["Title"] = "Klien Aktif";
    ViewBag.ActiveNav = "Klien";
    int totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
}

<div style="max-width: 900px;">

    @if (TempData["success"] is string ok)
    {
        <div style="background:#D1FAE5; color:#047857; padding:10px 14px; border-radius:8px; margin-bottom:12px;">@ok</div>
    }

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
        <div>
            <h2 style="margin:0; font-size:20px;">Client aktif</h2>
            <div style="font-size: 22px; font-weight: 600; margin-top:4px;">👥 @Model.TotalCount orang</div>
        </div>
        <a class="btn-primary" asp-action="Add">+ Tambah Client</a>
    </div>

    @* ─── Tab toggle ─── *@
    <div class="task-chips" style="margin-bottom:16px;">
        <a class="task-chip @(Model.Tab == "Semua" ? "selected" : "")"
           asp-action="Index"
           asp-route-tab="Semua"
           asp-route-search="@Model.Search" asp-route-division="@Model.Division" asp-route-status="@Model.Status">Semua</a>
        <a class="task-chip @(Model.Tab == "Sesi" ? "selected" : "")"
           asp-action="Index"
           asp-route-tab="Sesi"
           asp-route-search="@Model.Search" asp-route-division="@Model.Division" asp-route-status="@Model.Status">Sesi Hari Ini</a>
    </div>

    @* ─── Filter form ─── *@
    <form method="get" style="display:grid; grid-template-columns: 2fr 1fr 1fr auto; gap:10px; margin-bottom:20px;">
        <input type="hidden" name="tab" value="@Model.Tab" />
        <input type="search" name="search" placeholder="Cari nama..." value="@Model.Search"
               style="padding:10px 14px; border:1px solid #E5E7EB; border-radius:8px; font-family:inherit;" />
        <select name="division" class="onb-select">
            <option value="">Semua Divisi</option>
            @foreach (var d in Model.Divisions)
            {
                <option value="@d" selected="@(Model.Division == d)">@d</option>
            }
        </select>
        <select name="status" class="onb-select">
            <option value="">Semua Status</option>
            <option value="Sehat" selected="@(Model.Status == "Sehat")">Sehat</option>
            <option value="Beresiko" selected="@(Model.Status == "Beresiko")">Beresiko</option>
            <option value="Bahaya" selected="@(Model.Status == "Bahaya")">Bahaya</option>
        </select>
        <button type="submit" class="btn-pill">Filter</button>
    </form>

    @* ─── Cards ─── *@
    @if (!Model.Items.Any())
    {
        <div class="dash-card-empty">
            <p>Tidak ada client yang cocok.</p>
        </div>
    }
    else
    {
        foreach (var e in Model.Items)
        {
            <a class="task-card" asp-action="Detail" asp-route-id="@e.PatientId" style="grid-template-columns: 60px 1fr auto; align-items:center;">
                <div>
                    <img src="@(string.IsNullOrEmpty(e.ProfilePicture) ? "/lib/bootstrap-icons/icons/person-circle.svg" : e.ProfilePicture)"
                         style="width:48px; height:48px; border-radius:999px; object-fit:cover; background:#EDE9FE;" />
                </div>
                <div>
                    <h4 style="margin:0;">@e.FullName</h4>
                    @if (Model.Tab == "Sesi" && e.TodaySessionStart.HasValue)
                    {
                        <div class="meta">
                            @e.TodaySessionStart.Value.ToString("HH:mm") - @e.TodaySessionStart.Value.AddMinutes(e.TodaySessionDurationMinutes ?? 60).ToString("HH:mm")
                            &nbsp;·&nbsp; @(e.TodaySessionTitle ?? "Sesi")
                        </div>
                    }
                    else
                    {
                        <div class="meta">
                            Aktif Sejak @(e.OnboardingCompletedAt?.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("id-ID")) ?? "—")
                            @if (!string.IsNullOrEmpty(e.Department))
                            {
                                <span>· @e.Department</span>
                            }
                        </div>
                    }
                    <div class="meta">@e.Gender</div>
                </div>
                <span class="status-badge @e.Status.ToLowerInvariant()">@e.Status</span>
            </a>
        }

        @* Pagination *@
        @if (totalPages > 1)
        {
            <div style="display:flex; justify-content:space-between; align-items:center; margin-top:16px;">
                <small style="color:#6B7280;">Menampilkan @((Model.Page - 1) * Model.PageSize + 1)-@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount)) dari @Model.TotalCount entri</small>
                <div style="display:flex; gap:6px;">
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        <a class="task-chip @(p == Model.Page ? "selected" : "")"
                           asp-action="Index"
                           asp-route-tab="@Model.Tab"
                           asp-route-search="@Model.Search" asp-route-division="@Model.Division" asp-route-status="@Model.Status"
                           asp-route-page="@p">@p</a>
                    }
                </div>
            </div>
        }
    }
</div>
