@model LightenUp.Web.Models.ViewModels.HrEmployeeDetailViewModel
@{
    ViewData["Title"] = Model.FullName;
    ViewBag.ActiveNav = "Klien";

    var labelsJson = Json.Serialize(Model.ChartDates.Select(d => d.ToString("dd/MM")));
    var dataJson = Json.Serialize(Model.ChartScores);
}

@section Head {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}

<a asp-action="Index" style="text-decoration:none; color:#111;">← Klien Aktif</a>

<div style="max-width: 720px; margin-top:16px;">

    <!-- Header card -->
    <div class="lu-card" style="display:flex; gap:16px; align-items:center; margin-bottom:16px;">
        <img src="@(string.IsNullOrEmpty(Model.ProfilePicture) ? "/lib/bootstrap-icons/icons/person-circle.svg" : Model.ProfilePicture)"
             style="width:64px; height:64px; border-radius:999px; object-fit:cover; background:#EDE9FE;" />
        <div style="flex:1;">
            <h2 style="margin:0;">@Model.FullName</h2>
            <div style="color:#6B7280; font-size:13px;">
                @Model.Gender · @Model.Age @if (!string.IsNullOrEmpty(Model.Address)) { <span>· @Model.Address</span>} @if (!string.IsNullOrEmpty(Model.Phone)) { <span>· @Model.Phone</span> }
            </div>
        </div>
    </div>

    <!-- Status + Catatan -->
    <div class="lu-card" style="margin-bottom:16px;">
        <h3 class="lu-card-title">Status</h3>
        <span class="status-badge @Model.Status.ToLowerInvariant()">@Model.Status</span>

        <h3 class="lu-card-title" style="margin-top:16px;">Catatan</h3>
        <form asp-action="EditSymptoms" method="post">
            <input type="hidden" name="PatientId" value="@Model.PatientId" />
            <textarea name="Symptoms" rows="3" class="mood-textarea" placeholder="Catatan / gejala...">@Model.Symptoms</textarea>
            <div style="margin-top:8px; display:flex; justify-content:flex-end;">
                <button type="submit" class="btn-pill ghost">Simpan Catatan</button>
            </div>
        </form>
    </div>

    <!-- Today's journal -->
    <div class="lu-card" style="margin-bottom:16px;">
        <h3 class="lu-card-title">Jurnal Hari Ini</h3>
        @if (string.IsNullOrEmpty(Model.TodayJournalSnippet))
        {
            <p style="color:#9CA3AF;">Belum ada jurnal hari ini.</p>
        }
        else
        {
            <p style="background:#FAF5FF; padding:10px 14px; border-radius:8px;">"@Model.TodayJournalSnippet"</p>
        }
    </div>

    <!-- Mood chart -->
    <div class="lu-card" style="margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
            <h3 class="lu-card-title" style="margin:0;">Mood Tracker</h3>
            <div style="display:flex; gap:6px;">
                <a class="task-chip @(Model.ChartWindow == "Week" ? "selected" : "")" asp-action="Detail" asp-route-id="@Model.PatientId" asp-route-window="Week">Week</a>
                <a class="task-chip @(Model.ChartWindow == "Month" ? "selected" : "")" asp-action="Detail" asp-route-id="@Model.PatientId" asp-route-window="Month">Month</a>
            </div>
        </div>
        <canvas id="moodChart" height="100"></canvas>
        <div style="display:flex; justify-content:space-around; margin-top:12px; font-size:13px;">
            <span style="color:#047857;"><strong>@Model.SehatPct%</strong> Sehat</span>
            <span style="color:#B45309;"><strong>@Model.BeresikoPct%</strong> Beresiko</span>
            <span style="color:#B91C1C;"><strong>@Model.BahayaPct%</strong> Bahaya</span>
        </div>
    </div>

    <!-- Report button -->
    <a class="btn-primary" asp-controller="Reports" asp-action="Create" asp-route-patientId="@Model.PatientId"
       style="display:block; text-align:center; padding:14px; margin-bottom:16px;">
        Laporkan ke Psikolog
    </a>

    <!-- Sessions + Worksheets preview -->
    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:12px;">
        <div class="lu-card">
            <h4 style="margin:0 0 8px;">Jadwal</h4>
            @if (Model.NextSessionStart.HasValue)
            {
                <div style="font-size:13px;">
                    @Model.NextSessionStart.Value.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("id-ID"))<br/>
                    <span style="color:#6B7280;">@Model.NextSessionStart.Value.ToString("HH:mm")</span>
                </div>
            }
            else { <span style="color:#9CA3AF;">Belum ada jadwal</span> }
            <a class="btn-pill ghost" asp-controller="Schedules" asp-action="Index" style="margin-top:10px; display:inline-block;">Lihat Riwayat</a>
        </div>
        <div class="lu-card">
            <h4 style="margin:0 0 8px;">Worksheet</h4>
            @if (Model.OpenWorksheetCount > 0)
            {
                <div style="font-size:13px;">Ada <strong>@Model.OpenWorksheetCount worksheet</strong> aktif</div>
            }
            else { <span style="color:#9CA3AF;">Belum ada worksheet aktif</span> }
            <a class="btn-pill ghost" asp-controller="Worksheets" asp-action="Index" style="margin-top:10px; display:inline-block;">Lihat Riwayat</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        new Chart(document.getElementById('moodChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(labelsJson),
                datasets: [{
                    data: @Html.Raw(dataJson),
                    borderColor: '#7C3AED',
                    backgroundColor: 'rgba(124, 58, 237, 0.12)',
                    fill: true,
                    tension: 0.3,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                scales: { y: { min: 0, max: 5, ticks: { stepSize: 1 } } },
                plugins: { legend: { display: false } }
            }
        });
    </script>
}
