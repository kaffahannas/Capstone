@using LightenUp.Web.Models
@{
    Layout = null;
    var patient = ViewBag.Patient as Patient;
    var moods = ViewBag.Moods as List<MoodTracker> ?? new List<MoodTracker>();
    var sessions = ViewBag.Sessions as List<Schedule> ?? new List<Schedule>();
    var worksheets = ViewBag.Worksheets as List<Worksheet> ?? new List<Worksheet>();
    string companyName = ViewBag.CompanyName ?? "";
    DateTime generatedAt = ViewBag.GeneratedAt ?? DateTime.Now;
    var idCulture = new System.Globalization.CultureInfo("id-ID");
    var patientName = patient?.User?.FullName ?? "—";

    string AgeStr(DateTime? dob) {
        if (!dob.HasValue) return "—";
        var today = DateTime.Today;
        int age = today.Year - dob.Value.Year;
        if (dob.Value.Date > today.AddYears(-age)) age--;
        return $"{age} tahun";
    }
    string Gender(string? g) => g == "Male" ? "Laki-laki" : g == "Female" ? "Perempuan" : (g ?? "—");
    string FeelingLabel(string? f) => f switch {
        "Overjoyed" => "Sangat Bahagia", "Happy" => "Bahagia", "Calm" => "Tenang",
        "Neutral" => "Biasa", "Disappointed" => "Kecewa", "Angry" => "Marah", _ => f ?? "—"
    };
    string StatusBadge(string? s) => (s ?? "").ToLowerInvariant();
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <title>Laporan_Karyawan_@patientName.Replace(" ", "_")</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/hr/statistik-print.css" asp-append-version="true" />
</head>
<body class="hr-print-doc">
    <div class="hr-print-sheet">
        <div class="hr-print-header">
            <div>
                <h1 class="hr-print-title">Laporan Karyawan</h1>
                <div class="hr-print-meta">
                    Perusahaan: <strong>@companyName</strong> &nbsp;|&nbsp;
                    Karyawan: <strong>@patientName</strong> &nbsp;|&nbsp;
                    Dibuat: @generatedAt.ToString("dd MMMM yyyy, HH:mm", idCulture)
                </div>
            </div>
            <div class="hr-print-logo">LightenUp<span class="hrst-print-logo-dot">.</span></div>
        </div>

        <h2 class="hr-print-section-title">Profil Karyawan</h2>
        <div class="hr-print-info-grid hr-print-no-break">
            <div>
                <div class="hr-print-info-label">Nama Lengkap</div>
                <div class="hr-print-info-value">@patientName</div>
            </div>
            <div>
                <div class="hr-print-info-label">Email</div>
                <div class="hr-print-info-value">@(patient?.User?.Email ?? "—")</div>
            </div>
            <div>
                <div class="hr-print-info-label">Jenis Kelamin</div>
                <div class="hr-print-info-value">@Gender(patient?.Gender)</div>
            </div>
            <div>
                <div class="hr-print-info-label">Usia</div>
                <div class="hr-print-info-value">@AgeStr(patient?.DateOfBirth)</div>
            </div>
            <div>
                <div class="hr-print-info-label">Divisi</div>
                <div class="hr-print-info-value">@(patient?.DivisionId == null ? "Belum Diatur" : patient?.Division?.Name)</div>
            </div>
            <div>
                <div class="hr-print-info-label">ID Karyawan</div>
                <div class="hr-print-info-value">@(patient?.EmployeeId ?? "—")</div>
            </div>
            <div>
                <div class="hr-print-info-label">Status Mental</div>
                <div class="hr-print-info-value">
                    <span class="hr-print-badge hr-print-badge--@StatusBadge(patient?.MentalHealthStatus)">@(patient?.MentalHealthStatus ?? "—")</span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(patient?.Symptoms))
            {
                <div class="hr-print-info-full">
                    <div class="hr-print-info-label">Gejala / Catatan</div>
                    <div class="hr-print-info-value hr-print-info-value--body">@patient.Symptoms</div>
                </div>
            }
        </div>

        <h2 class="hr-print-section-title hr-print-no-break">Riwayat Mood (30 Hari Terakhir)</h2>
        @if (!moods.Any())
        {
            <p class="hr-print-empty">Belum ada data mood.</p>
        }
        else
        {
            <table class="hr-print-table hr-print-no-break">
                <thead>
                    <tr><th>Tanggal</th><th>Mood</th><th>Catatan</th></tr>
                </thead>
                <tbody>
                @foreach (var m in moods.OrderByDescending(x => x.MoodDate).Take(20))
                {
                    <tr>
                        <td>@m.MoodDate.ToString("dd MMM yyyy", idCulture)</td>
                        <td>@FeelingLabel(m.Feeling)</td>
                        <td>@(m.Note ?? "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <h2 class="hr-print-section-title hr-print-no-break">Riwayat Sesi Konseling</h2>
        @if (!sessions.Any())
        {
            <p class="hr-print-empty">Belum ada sesi konseling.</p>
        }
        else
        {
            <table class="hr-print-table hr-print-no-break">
                <thead>
                    <tr><th>Tanggal &amp; Waktu</th><th>Psikolog</th><th>Status</th><th>Catatan</th></tr>
                </thead>
                <tbody>
                @foreach (var s in sessions)
                {
                    <tr>
                        <td>@s.SessionStart.ToString("dd MMM yyyy, HH:mm", idCulture)</td>
                        <td>@(s.Psychologist?.User?.FullName ?? "—")</td>
                        <td>@s.Status</td>
                        <td>@(s.Notes ?? "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <h2 class="hr-print-section-title hr-print-no-break">Riwayat Worksheet</h2>
        @if (!worksheets.Any())
        {
            <p class="hr-print-empty">Belum ada worksheet.</p>
        }
        else
        {
            <table class="hr-print-table hr-print-no-break">
                <thead>
                    <tr><th>Nama Tugas</th><th>Deadline</th><th>Status</th></tr>
                </thead>
                <tbody>
                @foreach (var w in worksheets)
                {
                    <tr>
                        <td>@w.TaskName</td>
                        <td>@w.Deadline.ToString("dd MMM yyyy", idCulture)</td>
                        <td>@w.Status</td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <div class="hr-print-footer">
            Dokumen ini dibuat secara otomatis oleh sistem HR Console LightenUp pada @generatedAt.ToString("dd/MM/yyyy HH:mm:ss").
            <br>Rahasia &amp; hanya untuk internal perusahaan.
        </div>

        <div class="hr-print-actions no-print">
            <button type="button" class="hr-print-btn" onclick="window.print()">🖨️ Cetak PDF Sekarang</button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            setTimeout(function () { window.print(); }, 500);
        });
    </script>
</body>
</html>
