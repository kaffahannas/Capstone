@model LightenUp.Web.Models.ViewModels.HrPsychologistProfileViewModel
@{
    ViewData["Title"] = Model.FullName;
    ViewBag.ActiveNav = "Klien";
}

@section Head {
    <link rel="stylesheet" href="~/css/hr/psychologists-profile.css" asp-append-version="true" />
}

<a asp-action="Index" class="hrpsy-prof-back">← Direktori Psikolog</a>

@if (TempData["success"] is string ok)
{
    <div class="hrpsy-prof-success">@ok</div>
}

<div class="hrpsy-prof-wrap">

    <div class="lu-card hrpsy-prof-card--center">
        <img src="@(string.IsNullOrEmpty(Model.ProfilePicture) ? "/lib/bootstrap-icons/icons/person-circle.svg" : Model.ProfilePicture)"
             class="hrpsy-prof-avatar" alt="@Model.FullName" />
        <h2 class="hrpsy-prof-name">@Model.FullName</h2>
        <p class="hrpsy-prof-spec">@(Model.Specialization ?? "Psikolog Klinis")</p>
        @if (Model.AlreadyPartnered)
        {
            <span class="status-badge status-badge--partner">Sudah Menjadi Mitra</span>
        }
        else if (Model.HasPendingRequest)
        {
            <span class="status-badge status-badge--pending">Menunggu Persetujuan</span>
        }
    </div>

    <div class="lu-card hrpsy-prof-card--spaced">
        <h3 class="lu-card-title">Riwayat Pengalaman Psikolog</h3>
        <div class="hrpsy-prof-exp">
            @if (!string.IsNullOrEmpty(Model.Bio))
            {
                <p>@Model.Bio</p>
            }
            <ul>
                @if (!string.IsNullOrEmpty(Model.LastDegree)) { <li>Gelar: <strong>@Model.LastDegree</strong></li> }
                @if (!string.IsNullOrEmpty(Model.University)) { <li>Universitas: <strong>@Model.University</strong></li> }
                @if (Model.ExperienceYears.HasValue) { <li>Pengalaman: <strong>@Model.ExperienceYears tahun</strong></li> }
                @if (!string.IsNullOrEmpty(Model.PracticeLocation)) { <li>Lokasi Praktik: <strong>@Model.PracticeLocation</strong></li> }
            </ul>
        </div>
    </div>

    <div class="hrpsy-prof-actions">
        <a class="btn-secondary hrpsy-prof-btn-center" href="mailto:@Model.Email">Kirim Pesan (Email)</a>
        <a class="btn-secondary hrpsy-prof-btn-center" asp-controller="Schedules" asp-action="Request">Permintaan Sesi</a>

        @if (!Model.AlreadyPartnered && !Model.HasPendingRequest)
        {
            <form asp-action="RequestPartnership" asp-route-id="@Model.PsychologistId" method="post">
                <button type="submit" class="btn-primary hrpsy-prof-pick-btn">Ajukan Kemitraan</button>
            </form>
        }
    </div>
</div>
