@model LightenUp.Web.Models.ViewModels.HrPsychologistProfileViewModel
@{
    ViewData["Title"] = Model.FullName;
    ViewBag.ActiveNav = "Klien";
}

<a asp-action="Index" style="text-decoration:none; color:#111;">← Direktori Psikolog</a>

@if (TempData["success"] is string ok)
{
    <div style="background:#D1FAE5; color:#047857; padding:10px 14px; border-radius:8px; margin-top:12px;">@ok</div>
}

<div style="max-width: 560px; margin: 16px auto 0;">

    <div class="lu-card" style="text-align:center;">
        <img src="@(string.IsNullOrEmpty(Model.ProfilePicture) ? "/lib/bootstrap-icons/icons/person-circle.svg" : Model.ProfilePicture)"
             style="width:120px; height:120px; border-radius:999px; object-fit:cover; background:#EDE9FE; margin-bottom:12px;" />
        <h2 style="margin: 0;">@Model.FullName</h2>
        <p style="color:#6B7280; margin: 4px 0 12px;">@(Model.Specialization ?? "Psikolog Klinis")</p>
        @if (Model.AlreadyPartnered)
        {
            <span class="status-badge sehat">Sudah Menjadi Mitra</span>
        }
    </div>

    <div class="lu-card" style="margin-top: 16px;">
        <h3 class="lu-card-title">Riwayat Pengalaman Psikolog</h3>
        <div style="font-size: 13px;">
            @if (!string.IsNullOrEmpty(Model.Bio))
            {
                <p>@Model.Bio</p>
            }
            <ul style="padding-left: 18px; color:#6B7280;">
                @if (!string.IsNullOrEmpty(Model.LastDegree)) { <li>Gelar: <strong style="color:#111;">@Model.LastDegree</strong></li> }
                @if (!string.IsNullOrEmpty(Model.University)) { <li>Universitas: <strong style="color:#111;">@Model.University</strong></li> }
                @if (Model.ExperienceYears.HasValue) { <li>Pengalaman: <strong style="color:#111;">@Model.ExperienceYears tahun</strong></li> }
                @if (!string.IsNullOrEmpty(Model.PracticeLocation)) { <li>Lokasi Praktik: <strong style="color:#111;">@Model.PracticeLocation</strong></li> }
            </ul>
        </div>
    </div>

    <div style="display:grid; gap:10px; margin-top: 20px;">
        <a class="btn-secondary" href="mailto:@Model.Email" style="text-align:center;">Kirim Pesan (Email)</a>
        <a class="btn-secondary" asp-controller="Schedules" asp-action="Request" style="text-align:center;">Permintaan Sesi</a>

        @if (!Model.AlreadyPartnered)
        {
            <form asp-action="Pick" asp-route-id="@Model.PsychologistId" method="post">
                <button type="submit" class="btn-primary" style="width:100%; padding:14px;">Pilih Psikolog</button>
            </form>
        }
    </div>
</div>
