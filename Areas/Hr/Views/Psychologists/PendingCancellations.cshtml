@using LightenUp.Web.Models
@model List<LightenUp.Web.Models.PatientPsychologistAssignment>
@{
    ViewData["Title"] = "Permintaan Pembatalan Kemitraan";
    ViewBag.ActiveNav = "PendingCancellations";
}
@* #Bagian PembatalanKemitraan# *@

@section Head {
    <link rel="stylesheet" href="~/css/hr/psychologists-pending-cancellations.css" asp-append-version="true" />
}

<div class="hr-page-wrap">
    @if (TempData["success"] is string ok)
    {
        <div class="lu-alert-success hpcan-alert-success">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            @ok
        </div>
    }

    <div class="hr-page-header">
        <div class="hr-page-title-group">
            <h1 class="hr-page-title">Permintaan Pembatalan Kemitraan</h1>
            <p class="hr-page-sub">Psikolog meminta mengakhiri kemitraan B2B dengan karyawan Anda. Harap setujui atau tolak permintaan ini secepatnya.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="lu-empty-state hpcan-empty-state">
            <div class="hpcan-empty-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/></svg>
            </div>
            <h3 class="hpcan-empty-title">Tidak Ada Permintaan Baru</h3>
            <p class="hpcan-empty-sub">Semua kemitraan berjalan lancar. Tidak ada pembatalan yang menunggu persetujuan Anda.</p>
            <a asp-controller="Psychologists" asp-action="Index" class="btn-primary hpcan-back-link">
                Kembali ke Daftar Psikolog
            </a>
        </div>
    }
    else
    {
        <div class="lu-card hpcan-card">
            <div class="lu-table-wrap">
                <table class="adm-table">
                    <thead>
                        <tr>
                            <th class="hpcan-th-start">Karyawan (Pasien)</th>
                            <th>Psikolog</th>
                            <th>Alasan Pembatalan</th>
                            <th>Diminta Pada</th>
                            <th class="hpcan-th-end">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td class="hpcan-td-start">
                                    <div class="hpcan-patient-row">
                                        <div class="hpcan-patient-avatar">
                                            @(a.Patient?.User?.FullName?.Substring(0, 1).ToUpper() ?? "?")
                                        </div>
                                        <div class="hpcan-patient-name">
                                            @(a.Patient?.User?.FullName ?? "—")
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="hpcan-psy-row">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                        @(a.Psychologist?.User?.FullName ?? "—")
                                    </div>
                                </td>
                                <td>
                                    <div class="hpcan-reason">
                                        @(a.CancellationReason ?? "—")
                                    </div>
                                </td>
                                <td>
                                    <span class="hpcan-date-badge">
                                        @(a.CancellationRequestedAt?.ToString("dd MMM yyyy") ?? "—")
                                    </span>
                                </td>
                                <td class="hpcan-td-end">
                                    <div class="hpcan-actions">
                                        <form asp-action="ApproveCancellation" method="post" class="hpcan-form-inline">
                                            <input type="hidden" name="assignmentId" value="@a.AssignmentId" />
                                            <button type="submit" class="hpcan-btn-approve" onclick="return confirm('Apakah Anda yakin ingin menyetujui pembatalan kemitraan ini?')">
                                                Setujui
                                            </button>
                                        </form>
                                        <form asp-action="RejectCancellation" method="post" class="hpcan-form-inline">
                                            <input type="hidden" name="assignmentId" value="@a.AssignmentId" />
                                            <button type="submit" class="btn-outline hpcan-btn-reject" onclick="return confirm('Tolak permintaan pembatalan ini?')">
                                                Tolak
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
