@model LightenUp.Web.Models.Schedule
@{
    var idCulture = new System.Globalization.CultureInfo("id-ID");
    var startTime = Model.SessionStart.ToString("HH:mm", idCulture);
    var endTime = Model.SessionStart.AddMinutes(Model.DurationMinutes).ToString("HH:mm", idCulture);
    var fullDate = Model.SessionStart.ToString("dddd, d MMMM yyyy", idCulture);
    
    var statusClass = Model.Status switch
    {
        "Completed" => "completed",
        "Cancelled" => "cancelled",
        _ => "scheduled"
    };

    var statusLabel = Model.Status switch
    {
        "Completed" => "Selesai",
        "Cancelled" => "Dibatalkan",
        _ => "Akan Datang"
    };
}

<div class="modal-container sch-detail-modal">
    <div class="modal-header sch-detail-header">
        <h2 class="modal-title sch-detail-title">Detail Jadwal Konseling</h2>
        <button type="button" class="close-btn" data-sch-detail-close aria-label="Tutup">&times;</button>
    </div>

    <div class="sch-detail-body">
        <div class="sch-detail-top">
            <div class="sch-detail-patient">
                <div class="sch-detail-avatar">
                    @(Model.Patient?.User?.FullName?.Length > 0 ? Model.Patient.User.FullName.Substring(0, 1).ToUpper() : "?")
                </div>
                <div>
                    <div class="sch-detail-name">@(Model.Patient?.User?.FullName ?? "—")</div>
                    <div class="sch-detail-psy">Psikolog: @(Model.Psychologist?.User?.FullName ?? "—")</div>
                </div>
            </div>
            <span class="psy-status-chip psy-status--@statusClass">@statusLabel</span>
        </div>

        <div class="sch-detail-grid">
            <div>
                <div class="sch-detail-label">Tanggal</div>
                <div class="sch-detail-value">@fullDate</div>
            </div>
            <div>
                <div class="sch-detail-label">Waktu & Durasi</div>
                <div class="sch-detail-value">@startTime - @endTime WIB (@Model.DurationMinutes mnt)</div>
            </div>
        </div>
        
        @if (!string.IsNullOrEmpty(Model.MeetingLink))
        {
            <div class="sch-detail-section">
                <div class="sch-detail-label sch-detail-label--gap">Link Meeting</div>
                <a href="@Model.MeetingLink" target="_blank" class="sch-detail-link">
                    Buka Link Sesi Video Call &rarr;
                </a>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="sch-detail-section">
                <div class="sch-detail-label sch-detail-label--gap">Catatan Tambahan</div>
                <div class="sch-detail-notes">
                    @Model.Notes
                </div>
            </div>
        }

        <div class="sch-detail-actions">
            <button type="button" class="btn-outline sch-detail-close-btn" data-sch-detail-close>Tutup</button>
        </div>
    </div>
</div>
