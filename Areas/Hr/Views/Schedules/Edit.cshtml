@model LightenUp.Web.Models.ViewModels.HrScheduleEditViewModel
@{
    ViewData["Title"] = "Edit Jadwal";
    ViewBag.ActiveNav = "Monitoring";
}

<a class="pd-back" asp-action="Index">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Riwayat Jadwal
</a>

<div style="max-width:640px;">
    <h2 style="margin:0 0 4px;font-size:22px;font-weight:800;color:var(--text-dark);">Edit Jadwal Konseling</h2>
    <p style="margin:0 0 20px;color:var(--text-muted);font-size:14px;">
        Pasien: <strong>@Model.PatientName</strong> · Psikolog: <strong>@Model.PsychologistName</strong>
    </p>

    <form asp-action="Edit" method="post">
        <div class="detail-card">
            <input type="hidden" asp-for="ScheduleId" />
            <div asp-validation-summary="ModelOnly" style="background:#FEE2E2;color:#B91C1C;padding:10px 14px;border-radius:8px;margin-bottom:16px;font-size:13px;"></div>

            <div class="form-group">
                <label asp-for="SessionStart" class="form-label">Waktu Mulai</label>
                <input asp-for="SessionStart" type="datetime-local" class="form-control" />
                <span asp-validation-for="SessionStart" style="color:#DC2626;font-size:12px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="DurationMinutes" class="form-label">Durasi (menit)</label>
                <input asp-for="DurationMinutes" type="number" min="15" max="240" class="form-control" />
                <span asp-validation-for="DurationMinutes" style="color:#DC2626;font-size:12px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" class="form-control">
                    <option value="Scheduled">🗓️ Scheduled (Akan Datang)</option>
                    <option value="Completed">✅ Completed (Selesai)</option>
                    <option value="Cancelled">✕ Cancelled (Dibatalkan)</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="form-label">Catatan <small style="color:var(--text-muted);font-weight:400;">(opsional)</small></label>
                <textarea asp-for="Notes" rows="4" class="note-textarea" style="margin-bottom:0;" placeholder="Tambahkan catatan..."></textarea>
            </div>
        </div>

        <div class="modal-footer" style="padding:0;margin-top:16px;">
            <a asp-action="Index" class="btn-outline">Batalkan</a>
            <button type="submit" class="btn-fill">Simpan Perubahan</button>
        </div>
    </form>
</div>
