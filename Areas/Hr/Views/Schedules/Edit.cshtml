@model LightenUp.Web.Models.ViewModels.HrScheduleEditViewModel
@{
    ViewData["Title"] = "Edit Jadwal";
    ViewBag.ActiveNav = "Monitoring";
}

<a asp-action="Index" style="text-decoration:none; color:#111;">← Riwayat Jadwal</a>

<div style="max-width: 560px; margin: 16px auto 0;">
    <h2>Edit Jadwal Konseling</h2>
    <p style="color:#6B7280; font-size:14px;">@Model.PatientName · @Model.PsychologistName</p>

    <form asp-action="Edit" method="post" class="lu-card" style="margin-top:16px;">
        <input type="hidden" asp-for="ScheduleId" />
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;"></div>

        <div style="margin-bottom:14px;">
            <label asp-for="SessionStart" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Waktu Mulai</label>
            <input asp-for="SessionStart" type="datetime-local" class="onb-input" />
            <span asp-validation-for="SessionStart" class="text-danger"></span>
        </div>

        <div style="margin-bottom:14px;">
            <label asp-for="DurationMinutes" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Durasi (menit)</label>
            <input asp-for="DurationMinutes" type="number" min="15" max="240" class="onb-input" />
            <span asp-validation-for="DurationMinutes" class="text-danger"></span>
        </div>

        <div style="margin-bottom:14px;">
            <label asp-for="Status" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Status</label>
            <select asp-for="Status" class="onb-select">
                <option value="Scheduled">Scheduled (Akan Datang / On Going)</option>
                <option value="Completed">Completed (Selesai)</option>
                <option value="Cancelled">Cancelled (Dibatalkan)</option>
            </select>
        </div>

        <div style="margin-bottom:14px;">
            <label asp-for="Notes" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Catatan</label>
            <textarea asp-for="Notes" rows="3" class="mood-textarea"></textarea>
        </div>

        <div style="display:flex; gap:12px;">
            <a asp-action="Index" class="btn-secondary" style="flex:1; text-align:center;">Batal</a>
            <button type="submit" class="btn-primary" style="flex:1;">Simpan</button>
        </div>
    </form>
</div>
