@model LightenUp.Web.Models.ViewModels.HrScheduleListViewModel
@{
    ViewData["Title"] = "Riwayat Jadwal Konseling";
    ViewBag.ActiveNav = "Monitoring";
    var periods = new[] { ("HariIni", "Hari Ini"), ("Mingguan", "Minggu"), ("Bulanan", "Bulan") };
    int totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
}

<div style="max-width: 900px;">
    @if (TempData["success"] is string ok)
    {
        <div style="background:#D1FAE5; color:#047857; padding:10px 14px; border-radius:8px; margin-bottom:12px;">@ok</div>
    }

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
        <h2 style="margin:0;">Cari Riwayat Jadwal Konseling</h2>
        <a class="btn-pill" asp-action="Request">+ Permintaan Sesi</a>
    </div>

    <form method="get">
        <div style="position:relative; margin-bottom:12px;">
            <span style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:#6B7280;">🔍</span>
            <input type="search" name="search" placeholder="Cari nama pasien..." value="@Model.Search"
                   style="width:100%; padding:10px 14px 10px 40px; border:1px solid #E5E7EB; border-radius:999px; font-family:inherit;" />
        </div>

        <p style="margin: 8px 0 4px; font-size:13px; color:#6B7280;">Cari berdasarkan Waktu</p>
        <div class="task-chips" style="margin-bottom: 20px;">
            @foreach (var p in periods)
            {
                <label class="task-chip @(Model.Period == p.Item1 ? "selected" : "")">
                    <input type="radio" name="period" value="@p.Item1" checked="@(Model.Period == p.Item1)" style="display:none" onchange="this.form.submit()" />
                    @p.Item2
                </label>
            }
            @if (Model.Period != null)
            {
                <a class="task-chip" asp-action="Index" asp-route-search="@Model.Search">Clear</a>
            }
        </div>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="dash-card-empty"><p>Tidak ada jadwal yang cocok.</p></div>
    }
    else
    {
        int n = 0;
        foreach (var s in Model.Items)
        {
            n++;
            <a class="task-card" asp-action="Edit" asp-route-id="@s.ScheduleId"
               style="background: linear-gradient(135deg, #7C3AED, #5B21B6); color:#fff; border:0;">
                <div>
                    <h4 style="color:#fff; margin:0 0 6px;">Jadwal Konseling @n - @s.DisplayStatus</h4>
                    <div style="font-size:13px;">
                        @s.SessionStart.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("id-ID"))<br/>
                        @s.SessionStart.ToString("HH.mm") - @s.SessionStart.AddMinutes(s.DurationMinutes).ToString("HH.mm")
                    </div>
                </div>
                <div class="right">
                    <span style="font-size:11px; opacity:0.85; align-self:flex-end;">@s.PsychologistName</span>
                    <span style="width:14px; height:14px; border-radius:999px; background:#fff;"></span>
                </div>
            </a>
        }

        @if (totalPages > 1)
        {
            <div style="text-align:right; margin-top:12px;">
                @for (int p = 1; p <= totalPages; p++)
                {
                    <a class="task-chip @(p == Model.Page ? "selected" : "")"
                       asp-action="Index" asp-route-search="@Model.Search" asp-route-period="@Model.Period" asp-route-page="@p">@p</a>
                }
            </div>
        }
    }
</div>
