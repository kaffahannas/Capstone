@model LightenUp.Web.Models.ViewModels.HrRequestViewModel
@{
    ViewData["Title"] = "Permintaan Sesi";
    ViewBag.ActiveNav = "Monitoring";
}
@* #Bagian PermintaanSesi# *@

@section Head {
    <link rel="stylesheet" href="~/css/hr/schedules-request.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/schedules-schedule-detail-modal.css" asp-append-version="true" />
}

<a class="pd-back" asp-action="Index">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Riwayat Jadwal
</a>

<div class="hrsch-req-wrap">
    <h2 class="hrsch-req-title">Permintaan Jadwal Sesi</h2>
    <p class="hrsch-req-sub">
        Psikolog akan meninjau dan menetapkan jadwal yang sesuai dalam 1–2 hari kerja.
    </p>

    <form asp-action="Request" method="post">
        <div class="detail-card">
            <input type="hidden" asp-for="RequestType" />
            <div asp-validation-summary="ModelOnly" class="hrsch-req-val-summary"></div>

            <div class="form-group">
                <label asp-for="PatientId" class="form-label">Untuk Pasien</label>
                <select asp-for="PatientId" class="form-control">
                    <option value="">Pilih pasien...</option>
                    @foreach (var p in Model.AvailablePatients)
                    {
                        <option value="@p.PatientId">@p.FullName @(p.Department != null ? $"({p.Department})" : "")</option>
                    }
                </select>
                <span asp-validation-for="PatientId" class="hrsch-req-val-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ProposedSessionDate" class="form-label">Usulan Tanggal &amp; Waktu <small class="hrsch-req-label-opt">(opsional)</small></label>
                <input asp-for="ProposedSessionDate" type="datetime-local" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="form-label">Catatan / Alasan <small class="hrsch-req-label-opt">(opsional)</small></label>
                <textarea asp-for="Notes" rows="4" class="note-textarea hrsch-req-textarea" placeholder="Jelaskan alasan permintaan sesi ini..."></textarea>
            </div>
        </div>

        <div class="modal-footer hrsch-req-footer">
            <a asp-action="Index" class="btn-outline">Batalkan</a>
            <button type="submit" class="btn-fill">Kirim Permintaan</button>
        </div>
    </form>
</div>
