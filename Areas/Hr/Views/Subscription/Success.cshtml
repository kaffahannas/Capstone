@{
    ViewData["Title"] = "Pembayaran berhasil";
    ViewBag.ActiveNav = "Langganan";
}
@* #Bagian PembayaranBerhasil# *@
@section Head {
    <link rel="stylesheet" href="~/css/hr/subscription-success.css" asp-append-version="true" />
}

<div class="lu-card hrln-success-card">
    <div class="hrln-success-icon">&#10003;</div>
    <h2>Pembayaran berhasil</h2>
    <p>Paket <strong>@ViewBag.PlanName</strong> perusahaan sudah aktif.</p>
    @if (ViewBag.ReferralCode is string code && !string.IsNullOrEmpty(code))
    {
        <p class="hrln-success-code">Kode referral karyawan: <strong>@code</strong></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary hrln-success-btn">Ke Dashboard HR</a>
</div>
