@{
    ViewData["Title"] = "Pembayaran gagal";
    ViewBag.ActiveNav = "Langganan";
}
@section Head {
    <link rel="stylesheet" href="~/css/hr/subscription-failed.css" asp-append-version="true" />
}

<div class="lu-card hrln-fail-card">
    <div class="hrln-fail-icon">&#10007;</div>
    <h2>Pembayaran gagal atau dibatalkan</h2>
    <p>Silakan coba lagi atau hubungi dukungan jika masalah berlanjut.</p>
    <a asp-action="Index" class="btn btn-primary hrln-fail-btn">Kembali ke langganan</a>
</div>
