@model LightenUp.Web.Models.ViewModels.HrReportCreateViewModel
@{
    var labels     = Json.Serialize(Model.MoodTrendDates.Select(d => d.ToString("dd/MM")));
    var data       = Json.Serialize(Model.MoodTrendScores);
    var statusCss  = (Model.PatientStatus ?? "sehat").ToLower();
    var initial    = string.Join("", (Model.PatientName ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(p => char.ToUpper(p[0])));

    var chartColor = statusCss switch
    {
        "sehat"    => "#10B981",
        "beresiko" => "#F59E0B",
        _          => "#EF4444"
    };
    var chartFill = statusCss switch
    {
        "sehat"    => "rgba(16,185,129,0.12)",
        "beresiko" => "rgba(245,158,11,0.12)",
        _          => "rgba(239,68,68,0.12)"
    };
    
    // Check if we are viewing a sent report. We don't have Status in the ViewModel, but let's check ViewBag or we can just hide it if EmailSentAt has a value?
    // Actually, HrReportCreateViewModel doesn't have Status. I should update ReportsController to pass ViewBag.Status.
}

<div class="hrpf-modal" style="max-width:800px; padding:0; overflow:hidden;">
    @* Header *@
    <div style="background:var(--lu-surface); padding:20px 24px; border-bottom:1px solid var(--lu-border); display:flex; align-items:center; justify-content:space-between;">
        <div style="display:flex; align-items:center; gap:16px;">
            <div class="hrpt-av hrpt-av--@statusCss" style="width:44px; height:44px; font-size:16px; flex-shrink:0;">@initial</div>
            <div>
                <h2 style="margin:0; font-size:18px; font-weight:700; color:var(--lu-text); letter-spacing:-0.3px;">Laporan: @Model.PatientName</h2>
                <div style="display:flex; align-items:center; gap:8px; margin-top:2px; font-size:13px; color:var(--lu-text-muted);">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    @Model.PsychologistName
                </div>
            </div>
        </div>
        <button type="button" class="hrpf-modal-close" onclick="closeEditModal()" style="position:static; width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; border:none; background:var(--lu-surface-hover); color:var(--lu-text-muted); cursor:pointer;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
    </div>

    @* Body *@
    <form method="post" id="editReportForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReportId" />
        <input type="hidden" asp-for="PatientId" />
        <input type="hidden" asp-for="PsychologistId" />
        
        <div style="padding:24px; max-height:60vh; overflow-y:auto; display:flex; flex-direction:column; gap:20px; background:#f9fafb;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
                @* Chart *@
                <div style="background:#fff; border-radius:12px; padding:16px; border:1px solid var(--lu-border); box-shadow:0 1px 2px rgba(0,0,0,0.03);">
                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                        <div style="width:28px; height:28px; border-radius:6px; background:#FEF3C7; color:#D97706; display:flex; align-items:center; justify-content:center;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        </div>
                        <span style="font-weight:600; font-size:14px;">Mood Trend (7 Hari)</span>
                    </div>
                    <div style="height:120px; position:relative;">
                        <canvas id="modalTrendChart"></canvas>
                    </div>
                </div>

                @* Email Preview *@
                <div style="background:#fff; border-radius:12px; padding:16px; border:1px solid var(--lu-border); box-shadow:0 1px 2px rgba(0,0,0,0.03);">
                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                        <div style="width:28px; height:28px; border-radius:6px; background:#DBEAFE; color:#2563EB; display:flex; align-items:center; justify-content:center;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        </div>
                        <span style="font-weight:600; font-size:14px;">Preview Email Subject & Body</span>
                    </div>
                    <div style="font-size:13px; color:var(--lu-text); background:#F3F4F6; padding:10px 12px; border-radius:8px 8px 0 0; font-weight:600; border-bottom:1px solid #E5E7EB;">
                        @Model.PreviewEmailSubject
                    </div>
                    <div style="font-size:13px; color:var(--lu-text); background:#F9FAFB; padding:10px 12px; border-radius:0 0 8px 8px; font-weight:400; white-space:pre-wrap; max-height:120px; overflow-y:auto;">@Model.PreviewEmailBody</div>
                </div>
            </div>

            @* Notes Form *@
            <div style="background:#fff; border-radius:12px; padding:20px; border:1px solid var(--lu-border); box-shadow:0 1px 2px rgba(0,0,0,0.03);">
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
                    <div style="width:28px; height:28px; border-radius:6px; background:#F3E8FF; color:#9333EA; display:flex; align-items:center; justify-content:center;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    </div>
                    <span style="font-weight:600; font-size:14px;">Catatan untuk Psikolog</span>
                </div>
                @if (ViewBag.Status == "Sent")
                {
                    <div style="background:#f9fafb; padding:12px; border-radius:8px; font-size:14px; color:var(--lu-text); min-height:80px;">
                        @(string.IsNullOrEmpty(Model.Notes) ? "—" : Model.Notes)
                    </div>
                }
                else
                {
                    <textarea asp-for="Notes" rows="5" class="hrpf-modal-input" style="resize:vertical;"
                              placeholder="Jelaskan kondisi karyawan, kekhawatiran Anda, atau hal-hal yang perlu diperhatikan psikolog…"></textarea>
                }
            </div>
        </div>

        @* Footer *@
        @if (ViewBag.Status != "Sent")
        {
            <div style="padding:16px 24px; border-top:1px solid var(--lu-border); display:flex; justify-content:flex-end; gap:12px; background:var(--lu-surface);">
                <button type="submit" formaction="@Url.Action("Save")" class="hrpf-modal-cancel" style="background:var(--lu-surface); border:1px solid var(--lu-border); color:var(--lu-text);">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Simpan Draft
                </button>
                <button type="submit" formaction="@Url.Action("Send")" class="hrpf-modal-save" style="background:#7C3AED; border-color:#7C3AED;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    Kirim Laporan
                </button>
            </div>
        }
    </form>
</div>

<script>
    // Initialize Chart
    setTimeout(() => {
        new Chart(document.getElementById('modalTrendChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(labels),
                datasets: [{
                    data: @Html.Raw(data),
                    borderColor: '@Html.Raw(chartColor)',
                    backgroundColor: '@Html.Raw(chartFill)',
                    tension: 0.4,
                    fill: true,
                    pointRadius: 4,
                    pointBackgroundColor: '@Html.Raw(chartColor)',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { min: 0, max: 5, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.05)' } },
                    x: { grid: { display: false } }
                },
                plugins: { legend: { display: false } }
            }
        });
    }, 100);
</script>
