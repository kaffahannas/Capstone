@model LightenUp.Web.Models.ViewModels.HrReportCreateViewModel
@{
    ViewData["Title"] = "Laporkan ke Psikolog";
    ViewBag.ActiveNav = "Klien";

    var labels = Json.Serialize(Model.MoodTrendDates.Select(d => d.ToString("dd/MM")));
    var data = Json.Serialize(Model.MoodTrendScores);

    var trendColor = Model.AssignmentTrend switch
    {
        "Menurun" => "#B45309",
        "Meningkat" => "#047857",
        _ => "#6B7280"
    };
    var stressColor = Model.StressLevel switch
    {
        "Tinggi" => "#B91C1C",
        "Sedang" => "#B45309",
        "Rendah" => "#047857",
        _ => "#6B7280"
    };
}

@section Head {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}

<a asp-controller="Employees" asp-action="Detail" asp-route-id="@Model.PatientId" style="text-decoration:none; color:#111;">← Detail Pasien</a>

<div style="max-width: 560px; margin: 16px auto 0;">
    <h2 style="margin: 0 0 4px;">Laporkan ke Psikolog</h2>
    <p style="color:#6B7280; font-size:14px;">Kirim laporan singkat ke @Model.PsychologistName.</p>

    <div class="lu-card" style="margin-top:16px;">
        <div style="display:flex; gap:12px; align-items:center;">
            <div style="flex:1;">
                <h3 style="margin: 0;">@Model.PatientName</h3>
                <small style="color:#6B7280;">@(Model.PatientDepartment ?? "—")</small>
            </div>
            <span class="status-badge @Model.PatientStatus.ToLowerInvariant()">@Model.PatientStatus</span>
        </div>
    </div>

    <div class="lu-card" style="margin-top:12px;">
        <h3 class="lu-card-title">Mood Trend</h3>
        <small style="color:#6B7280;">Dalam 7 hari terakhir</small>
        <canvas id="trendChart" height="80"></canvas>
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px; margin-top:12px;">
            <div style="background:#FAF5FF; padding:10px; border-radius:8px;">
                <small style="color:#6B7280;">Nilai Penugasan</small>
                <div style="font-weight:700; color:@trendColor;">@Model.AssignmentScore/10</div>
                <small style="color:@trendColor;">@Model.AssignmentTrend</small>
            </div>
            <div style="background:#FAF5FF; padding:10px; border-radius:8px;">
                <small style="color:#6B7280;">Tingkat Stress</small>
                <div style="font-weight:700; color:@stressColor;">@Model.StressLevel</div>
            </div>
        </div>
    </div>

    <form method="post" class="lu-card" style="margin-top:12px;">
        <input type="hidden" asp-for="ReportId" />
        <input type="hidden" asp-for="PatientId" />
        <input type="hidden" asp-for="PsychologistId" />

        <h3 class="lu-card-title">Beri Catatan</h3>
        <textarea asp-for="Notes" rows="4" class="mood-textarea" placeholder="Tambahkan catatan dari Anda untuk psikolog..."></textarea>

        <details style="margin-top:12px;">
            <summary style="cursor:pointer; font-size:13px; color:#6B7280;">Preview email yang akan dikirim</summary>
            <div style="margin-top:8px; padding:10px 12px; background:#F9FAFB; border-radius:8px; font-size:12px;">
                <strong>Subject:</strong> @Model.PreviewEmailSubject<br/><br/>
                <pre style="white-space:pre-wrap; font-family:inherit;">@Model.PreviewEmailBody</pre>
            </div>
        </details>

        <div style="display:flex; gap:10px; margin-top:16px;">
            <a asp-controller="Employees" asp-action="Detail" asp-route-id="@Model.PatientId" class="btn-secondary" style="flex:1; text-align:center;">Batalkan</a>
            <button type="submit" formaction="@Url.Action("Save")" class="btn-secondary" style="flex:1;">Simpan Draft</button>
            <button type="submit" formaction="@Url.Action("Send")" class="btn-primary" style="flex:1;">Kirim Laporan</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        new Chart(document.getElementById('trendChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(labels),
                datasets: [{
                    data: @Html.Raw(data),
                    borderColor: '#F59E0B',
                    backgroundColor: 'rgba(245, 158, 11, 0.12)',
                    tension: 0.3,
                    fill: true,
                    pointRadius: 3
                }]
            },
            options: {
                responsive: true,
                scales: { y: { min: 0, max: 5 } },
                plugins: { legend: { display: false } }
            }
        });
    </script>
}
