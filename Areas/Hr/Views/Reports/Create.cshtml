@model LightenUp.Web.Models.ViewModels.HrReportCreateViewModel
@{
    ViewData["Title"] = "Laporkan ke Psikolog";
    ViewBag.ActiveNav = "Klien";

    var labels     = Json.Serialize(Model.MoodTrendDates.Select(d => d.ToString("dd/MM")));
    var data       = Json.Serialize(Model.MoodTrendScores);
    var statusCss  = (Model.PatientStatus ?? "sehat").ToLower();
    var initial    = string.Join("", (Model.PatientName ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(p => char.ToUpper(p[0])));

    var trendMod = Model.AssignmentTrend switch
    {
        "Meningkat" => "trend-up",
        "Menurun"   => "trend-down",
        _           => "trend-neutral"
    };
    var stressMod = Model.StressLevel switch
    {
        "Tinggi" => "stress-high",
        "Sedang" => "stress-mid",
        "Rendah" => "stress-low",
        _        => "stress-unknown"
    };
    var trendIcon = Model.AssignmentTrend switch
    {
        "Meningkat" => "↑",
        "Menurun"   => "↓",
        _           => "→"
    };

    var chartColor = statusCss switch
    {
        "sehat"    => "#10B981",
        "beresiko" => "#F59E0B",
        _          => "#EF4444"
    };
    var chartFill = statusCss switch
    {
        "sehat"    => "rgba(16,185,129,0.12)",
        "beresiko" => "rgba(245,158,11,0.12)",
        _          => "rgba(239,68,68,0.12)"
    };
}

@section Head {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}

<div class="hrpt-page">

    @* ── Toast ── *@
    @if (TempData["success"] is string ok)
    {
        <div class="hrpt-toast hrpt-toast--ok" id="hrptToast" role="alert">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            @ok
        </div>
    }
    @if (TempData["error"] is string err)
    {
        <div class="hrpt-toast hrpt-toast--err" id="hrptToast" role="alert">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            @err
        </div>
    }

    @* ── Back ── *@
    <a href="@Url.Action("Detail", "Employees", new { area = "Hr", id = Model.PatientId })" class="hrpt-back">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Detail Karyawan
    </a>

    @* ══════ HERO ══════ *@
    <div class="hrpt-hero hrpt-hero--@statusCss">
        <div class="hrpt-hero-bg" aria-hidden="true"></div>
        <div class="hrpt-hero-inner">
            <div class="hrpt-av-wrap">
                <div class="hrpt-av hrpt-av--@statusCss">@initial</div>
            </div>
            <div class="hrpt-hero-info">
                <p class="hrpt-hero-eyebrow">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Laporan ke Psikolog
                </p>
                <h1 class="hrpt-hero-title">@Model.PatientName</h1>
                <div class="hrpt-hero-meta">
                    <span class="hrpt-hero-meta-item">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                        @(Model.PatientDepartment ?? "—")
                    </span>
                    <span class="hrpt-hero-sep">·</span>
                    <span class="hrpt-hero-meta-item">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        @Model.PsychologistName
                    </span>
                </div>
            </div>
            <span class="hrpt-status-badge hrpt-status-badge--@statusCss">
                <span class="hrpt-status-dot" aria-hidden="true"></span>
                @Model.PatientStatus
            </span>
        </div>
    </div>

    @* ══════ METRICS ROW ══════ *@
    <div class="hrpt-metrics">
        <div class="hrpt-metric hrpt-metric--@trendMod">
            <span class="hrpt-metric-label">Nilai Penugasan</span>
            <span class="hrpt-metric-val">@Model.AssignmentScore.ToString("0.0")<span class="hrpt-metric-suffix">/10</span></span>
            <span class="hrpt-metric-sub">@trendIcon @Model.AssignmentTrend</span>
        </div>
        <div class="hrpt-metric hrpt-metric--@stressMod">
            <span class="hrpt-metric-label">Tingkat Stres</span>
            <span class="hrpt-metric-val">@(string.IsNullOrEmpty(Model.StressLevel) ? "—" : Model.StressLevel)</span>
            <span class="hrpt-metric-sub">Kondisi mental</span>
        </div>
        <div class="hrpt-metric">
            <span class="hrpt-metric-label">Mood Trend</span>
            <span class="hrpt-metric-val hrpt-metric-val--sm">@(string.IsNullOrEmpty(Model.MoodTrendLabel) ? "—" : Model.MoodTrendLabel)</span>
            <span class="hrpt-metric-sub">7 hari terakhir</span>
        </div>
    </div>

    @* ══════ BODY GRID ══════ *@
    <div class="hrpt-grid">

        @* ── Left column ── *@
        <div class="hrpt-main">

            @* Mood chart *@
            <div class="hrpf-card">
                <div class="hrpf-card-head">
                    <div class="hrpf-card-icon hrpf-card-icon--amber" aria-hidden="true">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    </div>
                    <h3 class="hrpf-card-title">Mood Trend</h3>
                    <span class="hrpt-card-period">7 hari terakhir</span>
                </div>
                <div class="hrpt-chart-wrap">
                    <canvas id="trendChart"></canvas>
                </div>
            </div>

            @* Notes form *@
            <form method="post">
                <div class="hrpf-card">
                    <div class="hrpf-card-head">
                        <div class="hrpf-card-icon hrpf-card-icon--purple" aria-hidden="true">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                        </div>
                        <h3 class="hrpf-card-title">Catatan untuk Psikolog</h3>
                    </div>
                    <input type="hidden" asp-for="ReportId" />
                    <input type="hidden" asp-for="PatientId" />
                    <input type="hidden" asp-for="PsychologistId" />
                    <textarea asp-for="Notes" rows="7" class="hrpt-textarea"
                              placeholder="Jelaskan kondisi karyawan, kekhawatiran Anda, atau hal-hal yang perlu diperhatikan psikolog…"></textarea>
                    <div class="hrpt-action-row">
                        <a href="@Url.Action("Detail", "Employees", new { area = "Hr", id = Model.PatientId })"
                           class="hrpt-btn-cancel">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            Batalkan
                        </a>
                        <button type="submit" formaction="@Url.Action("Save")" class="hrpt-btn-draft">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Simpan Draft
                        </button>
                        <button type="submit" formaction="@Url.Action("Send")" class="hrpt-btn-send">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                            Kirim ke Psikolog
                        </button>
                    </div>
                </div>
            </form>

        </div>

        @* ── Right sidebar ── *@
        <div class="hrpt-side">

            @* Email preview *@
            <div class="hrpf-card">
                <div class="hrpf-card-head">
                    <div class="hrpf-card-icon hrpf-card-icon--blue" aria-hidden="true">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </div>
                    <h3 class="hrpf-card-title">Preview Email</h3>
                </div>
                <div class="hrpt-email-subj">
                    <span class="hrpt-email-subj-label">Subject</span>
                    <span class="hrpt-email-subj-val">@Model.PreviewEmailSubject</span>
                </div>
                <div class="hrpt-email-body">
                    <pre>@Model.PreviewEmailBody</pre>
                </div>
            </div>

            @* Tip *@
            <div class="hrpt-tip">
                <strong>💡 Catatan:</strong> Email dikirim otomatis ke psikolog saat Anda menekan <em>Kirim ke Psikolog</em>. Draft hanya tersimpan di sistem dan belum dikirim.
            </div>

        </div>
    </div>

</div>

@section Scripts {
<script>
(function () {
    const t = document.getElementById('hrptToast');
    if (t) setTimeout(() => { t.style.transition = 'opacity .4s'; t.style.opacity = '0'; }, 3200);
})();

new Chart(document.getElementById('trendChart'), {
    type: 'line',
    data: {
        labels: @Html.Raw(labels),
        datasets: [{
            data: @Html.Raw(data),
            borderColor: '@Html.Raw(chartColor)',
            backgroundColor: '@Html.Raw(chartFill)',
            tension: 0.4,
            fill: true,
            pointRadius: 5,
            pointBackgroundColor: '@Html.Raw(chartColor)',
            pointBorderColor: '#fff',
            pointBorderWidth: 2
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
            y: { min: 0, max: 5, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.05)' } },
            x: { grid: { display: false } }
        },
        plugins: { legend: { display: false } }
    }
});
</script>
}
