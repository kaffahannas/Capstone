@model LightenUp.Web.Models.ViewModels.HrOnboardingCompanyViewModel
@{
    ViewData["Title"] = "Data Perusahaan";
    var existingDoc = ViewBag.ExistingSupportDocumentUrl as string;
}

<h1 class="onb-title">Langkah 3: Data Perusahaan</h1>
<p class="onb-subtitle">Daftarkan perusahaan Anda. Kode referral untuk karyawan akan dibuat otomatis setelah langganan perusahaan aktif.</p>

<form asp-action="Company" method="post" enctype="multipart/form-data" class="onb-content">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div style="margin-bottom: 14px;">
        <label asp-for="CompanyAddress" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Lokasi Perusahaan</label>
        <textarea asp-for="CompanyAddress" rows="2" class="onb-textarea" placeholder="Jl. Ki Hajar Dewantara, Kota Jababeka, Cikarang Baru, Bekasi"></textarea>
        <span asp-validation-for="CompanyAddress" class="text-danger"></span>
    </div>

    <div style="margin-bottom: 14px;">
        <label asp-for="CompanyName" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Nama Perusahaan</label>
        <input asp-for="CompanyName" class="onb-input" placeholder="PT. ABDI JAYA" />
        <span asp-validation-for="CompanyName" class="text-danger"></span>
    </div>

    <div style="margin-bottom: 14px;">
        <label asp-for="RegistrationNumber" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Nomor Perusahaan</label>
        <input asp-for="RegistrationNumber" class="onb-input" placeholder="20171274-2020-02-1002" />
    </div>

    <div class="onb-upload-block">
        <label style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Scan Dokumen Pendukung</label>
        @if (!string.IsNullOrEmpty(existingDoc))
        {
            <div class="onb-upload-preview" id="existingSupportPreview">
                @if (existingDoc.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                {
                    <a href="@existingDoc" target="_blank" rel="noopener" class="onb-file-link">📄 Dokumen tersimpan (PDF) — lihat</a>
                }
                else
                {
                    <img src="@existingDoc" alt="Dokumen pendukung" class="onb-upload-thumb" />
                }
                <p class="onb-upload-hint">File sudah diunggah. Pilih file baru untuk mengganti.</p>
            </div>
        }
        <label class="onb-upload-zone">
            <input type="file" asp-for="SupportDocument" accept="image/*,.pdf" class="onb-upload-input" data-preview="supportPreview" />
            <div class="onb-upload-placeholder">
                <span class="onb-upload-icon">📄</span>
                <strong>Upload file</strong>
                <small>Format JPG/PDF, maksimal 5 MB</small>
            </div>
            <div id="supportPreview" class="onb-upload-preview onb-upload-preview-new" hidden></div>
        </label>
    </div>

    <div style="margin-top: 16px;">
        <label asp-for="Department" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Divisi yang Anda kelola</label>
        <input asp-for="Department" class="onb-input" placeholder="HR & GA" />
        <span asp-validation-for="Department" class="text-danger"></span>
    </div>

    <div class="onb-footer">
        <a asp-action="Academic" class="onb-btn onb-btn-secondary">Sebelumnya</a>
        <button type="submit" class="onb-btn onb-btn-primary">Simpan dan Lanjutkan</button>
    </div>
</form>
