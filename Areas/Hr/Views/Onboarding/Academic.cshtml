@model LightenUp.Web.Models.ViewModels.HrOnboardingAcademicViewModel
@{
    ViewData["Title"] = "Status Akademik";
    var existingDoc = ViewBag.ExistingDocumentUrl as string;
}

<h1 class="onb-title">Langkah 2: Status Akademik</h1>
<p class="onb-subtitle">Silakan masukkan informasi akademis Anda.</p>

<form asp-action="Academic" method="post" enctype="multipart/form-data" class="onb-content">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div style="margin-bottom: 16px;">
        <label asp-for="LastDegree" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Gelar Terakhir</label>
        <select asp-for="LastDegree" class="onb-select">
            <option value="">Pilih kategori</option>
            <option value="SMA">SMA / Sederajat</option>
            <option value="D3">D3</option>
            <option value="S1">S1</option>
            <option value="S2">S2</option>
            <option value="S3">S3</option>
        </select>
        <span asp-validation-for="LastDegree" class="text-danger"></span>
    </div>

    <div style="margin-bottom: 16px;">
        <label asp-for="University" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Universitas Asal</label>
        <input asp-for="University" class="onb-input" placeholder="Universitas ABCDE" />
        <span asp-validation-for="University" class="text-danger"></span>
    </div>

    <div class="onb-upload-block">
        <label style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Dokumen pendukung</label>
        @if (!string.IsNullOrEmpty(existingDoc))
        {
            <div class="onb-upload-preview" id="existingDocPreview">
                @if (existingDoc.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                {
                    <a href="@existingDoc" target="_blank" rel="noopener" class="onb-file-link">📄 Dokumen tersimpan (PDF) — lihat</a>
                }
                else
                {
                    <img src="@existingDoc" alt="Dokumen akademik" class="onb-upload-thumb" />
                }
                <p class="onb-upload-hint">File sudah diunggah. Pilih file baru untuk mengganti.</p>
            </div>
        }
        <label class="onb-upload-zone">
            <input type="file" asp-for="AcademicDocument" accept="image/*,.pdf" class="onb-upload-input" data-preview="academicPreview" />
            <div class="onb-upload-placeholder">
                <span class="onb-upload-icon">📄</span>
                <strong>Upload file</strong>
                <small>Format JPG/PDF, maksimal 5 MB</small>
            </div>
            <div id="academicPreview" class="onb-upload-preview onb-upload-preview-new" hidden></div>
        </label>
        <span asp-validation-for="AcademicDocument" class="text-danger"></span>
    </div>

    <div class="onb-footer">
        <a asp-action="Photo" class="onb-btn onb-btn-secondary">Sebelumnya</a>
        <button type="submit" class="onb-btn onb-btn-primary">Simpan dan Lanjutkan</button>
    </div>
</form>
