@{
    ViewData["Title"] = "Selamat Datang";
    ViewBag.HideChrome = true;
}
@* #Bagian OnboardingSelamatDatang# *@

<div class="onb-welcome onb-welcome--hr">
    @await Html.PartialAsync("_OnboardingBrand")
    <h1>Selamat datang, @(ViewBag.HrName ?? "HR")!</h1>
    <p>
        LightenUp adalah platform pendukung operasional bagi penyedia jasa layanan psikologi.
        Sebagai permulaan, lengkapi data HR sebuah perusahaan: foto diri, status akademik,
        dan informasi perusahaan.
    </p>
</div>

<form asp-action="Welcome" method="post" class="onb-footer onb-welcome-footer">
    <button type="submit" class="onb-btn onb-btn-primary">Lengkapi data HR</button>
</form>
