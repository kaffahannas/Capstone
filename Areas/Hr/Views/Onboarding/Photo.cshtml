@model LightenUp.Web.Models.ViewModels.HrOnboardingPhotoViewModel
@{
    ViewData["Title"] = "Foto Diri";
    var existingPhoto = ViewBag.ExistingPhotoUrl as string;
}

<h1 class="onb-title">Langkah 1: Masukkan Foto Diri</h1>
<p class="onb-subtitle">Pastikan foto yang dilampirkan adalah foto yang bersifat formal &amp; terlihat professional, untuk menjaga kredibilitas penyedia layanan psikologi.</p>

<form asp-action="Photo" method="post" enctype="multipart/form-data" class="onb-content">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="onb-upload-block">
        @if (!string.IsNullOrEmpty(existingPhoto))
        {
            <div class="onb-upload-preview" id="existingPhotoPreview">
                <img src="@existingPhoto" alt="Foto profil" class="onb-upload-thumb onb-upload-thumb-round" />
                <p class="onb-upload-hint">Foto sudah diunggah. Pilih file baru untuk mengganti.</p>
            </div>
        }
        <label class="onb-upload-zone">
            <input type="file" asp-for="Photo" accept="image/*" class="onb-upload-input" data-preview="photoPreview" />
            <div class="onb-upload-placeholder">
                <span class="onb-upload-icon">📷</span>
                <strong>Upload file</strong>
                <small>Format JPG, maksimal 2MB</small>
            </div>
            <div id="photoPreview" class="onb-upload-preview onb-upload-preview-new" hidden></div>
        </label>
        <span asp-validation-for="Photo" class="text-danger"></span>
    </div>

    <div class="onb-footer">
        <button type="submit" class="onb-btn onb-btn-primary">Simpan dan Lanjutkan</button>
    </div>
</form>
