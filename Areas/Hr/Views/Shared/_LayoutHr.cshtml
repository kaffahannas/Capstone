@using Microsoft.AspNetCore.Identity

@using LightenUp.Web.Models

@using LightenUp.Web.Data

@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager

@inject ApplicationDbContext DbContext

@{

    var user = await UserManager.GetUserAsync(User);

    var fullName = user?.FullName ?? "HR";

    var hr = user == null ? null : await DbContext.HrStaffs

        .Include(h => h.Company)

        .FirstOrDefaultAsync(h => h.UserId == user.Id);

    var companyName = hr?.Company?.Name ?? "";

    var active = ViewBag.ActiveNav as string ?? "Beranda";



    var hour = DateTime.Now.Hour;

    var greeting = hour switch

    {

        >= 4 and < 11 => "Selamat pagi",

        >= 11 and < 15 => "Selamat siang",

        >= 15 and < 19 => "Selamat sore",

        _ => "Selamat malam"

    };

}
@* #Bagian LayoutHR# *@

<!DOCTYPE html>

<html lang="id">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - LightenUp HR</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/hr/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/components-hr-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/components-hr-hero.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/components-hr-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/components-hr-page.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/components-hr-list.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/components-hr-card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/components-hr-toast.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/components-hr-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/components-hr-psy-modal.css" asp-append-version="true" />

    @await RenderSectionAsync("Head", required: false)

</head>

<body class="hr-body">

    <div class="app-shell hr-shell" id="appShell">

        <div class="sidebar-backdrop" id="sidebarBackdrop" aria-hidden="true"></div>



        @* #Komponen Sidebar# *@
        <aside class="sidebar app-sidebar hr-sidebar" id="appSidebar" aria-label="Navigasi HR">

            <div class="sidebar-header">

                <a class="sidebar-brand" asp-controller="Home" asp-action="Index">

                    <img src="~/image/lightenuplogo.ico" alt="LightenUp" onerror="this.classList.add('is-hidden')" />

                    <span class="hr-brand-text">

                        <span class="hr-brand-name">LightenUp</span>

                        <small class="hr-brand-sub">HR Console</small>

                    </span>

                </a>

                <button type="button" class="sidebar-close" id="sidebarClose" aria-label="Tutup menu">&times;</button>

            </div>



            <nav class="nav-menu" aria-label="Menu utama">

                <a class="nav-item @(active == "Beranda" ? "active" : "")" asp-controller="Home" asp-action="Index">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>

                    Beranda

                </a>

                <a class="nav-item @(active == "Klien" ? "active" : "")" asp-controller="Employees" asp-action="Index">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>

                    Klien

                </a>

                <a class="nav-item @(active == "Statistik" ? "active" : "")" asp-controller="Statistik" asp-action="Index">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>

                    Statistik

                </a>

                <a class="nav-item @(active == "Jadwal" ? "active" : "")" asp-controller="Schedules" asp-action="Index">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>

                    Jadwal Sesi

                </a>

                <a class="nav-item @(active == "Monitoring" ? "active" : "")" asp-controller="Worksheets" asp-action="Index">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1" ry="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>

                    Worksheet

                </a>

                <a class="nav-item @(active == "Langganan" ? "active" : "")" asp-controller="Subscription" asp-action="Index">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>

                    Langganan

                </a>

                <a class="nav-item @(active == "Psikolog" ? "active" : "")" asp-controller="Psychologists" asp-action="Index">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>

                    Psikolog

                </a>

                <a class="nav-item @(active == "PendingCancellations" ? "active" : "")" asp-controller="Psychologists" asp-action="PendingCancellations">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>

                    Req. Pembatalan

                </a>

                <a class="nav-item @(active == "Laporan" ? "active" : "")" asp-controller="Reports" asp-action="Index">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>

                    Laporan

                </a>

                <a class="nav-item @(active == "Profil" ? "active" : "")" asp-controller="Profile" asp-action="Index">

                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>

                    Profil

                </a>

            </nav>



            <div class="hr-nav-logout">

                <form asp-controller="Account" asp-action="Logout" asp-area="" method="post">

                    <button type="submit" class="hr-logout-btn">

                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>

                        <span>Keluar</span>

                    </button>

                </form>

            </div>

        </aside>



        <div class="main-content app-main">

            @* #Komponen Topbar# *@
            <header class="app-topbar">

                <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Buka menu navigasi" aria-expanded="false" aria-controls="appSidebar">

                    <span class="hamburger" aria-hidden="true"></span>

                </button>

                <div>

                    <h2 class="greeting">@greeting, @fullName 👋</h2>

                    @if (!string.IsNullOrEmpty(companyName))

                    {

                        <small class="topbar-sub">HR @companyName</small>

                    }

                </div>

            </header>



            <div class="app-content lu-scroll-host">

                @RenderBody()

            </div>

        </div>

    </div>



    @await RenderSectionAsync("Modals", required: false)

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>

