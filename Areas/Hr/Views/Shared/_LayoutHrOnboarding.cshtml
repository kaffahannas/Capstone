@using LightenUp.Web.Models.ViewModels
@{
    var progress = ViewBag.Progress as HrOnboardingProgress;
    var pageTitle = ViewData["Title"] as string ?? "Onboarding HR";
    var hideChrome = ViewBag.HideChrome as bool? ?? false;
}
@* #Bagian LayoutOnboardingHR# *@
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-typography.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-form.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-actions.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-upload.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/onboarding-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/onboarding-welcome.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/onboarding-company.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hr/onboarding-success.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <div class="onb-wrapper">
        @if (!hideChrome)
        {
            @* #Komponen ProgressBar# *@
            <div class="onb-topbar">
                <span>Onboarding HR</span>
                <a class="close-btn" asp-controller="Account" asp-action="Login" asp-area="" title="Keluar">&times;</a>
            </div>

            @if (progress != null)
            {
                <div class="onb-progress-label">Langkah @progress.Current dari @progress.Total</div>
                <div class="onb-progress">
                    <div class="onb-progress-bar" style="--bar-w: @(progress.Percent)%;"></div>
                </div>
            }
        }

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.querySelectorAll('.onb-upload-input').forEach(input => {
            input.addEventListener('change', () => {
                const previewId = input.dataset.preview;
                const preview = previewId ? document.getElementById(previewId) : null;
                const placeholder = input.closest('.onb-upload-zone').querySelector('.onb-upload-placeholder');
                if (!preview || !input.files?.length) {
                    if (placeholder) placeholder.classList.remove('is-hidden');
                    if (preview) preview.hidden = true;
                    return;
                }
                const file = input.files[0];
                preview.hidden = false;
                if (placeholder) placeholder.classList.add('is-hidden');
                if (file.type === 'application/pdf') {
                    preview.innerHTML = `
                        <a href="javascript:void(0)" class="onb-file-link">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                <polyline points="10 9 9 9 8 9"></polyline>
                            </svg>
                            <span class="file-name">${file.name}</span>
                            <span class="file-status">(Siap diunggah)</span>
                        </a>`;
                } else if (file.type.startsWith('image/')) {
                    const img = document.createElement('img');
                    img.className = 'onb-upload-thumb';
                    img.alt = 'Pratinjau';
                    img.src = URL.createObjectURL(file);
                    preview.innerHTML = '';
                    preview.appendChild(img);
                } else {
                    preview.innerHTML = '<p class="onb-upload-hint">' + file.name + '</p>';
                }
            });
        });
    </script>
</body>
</html>
