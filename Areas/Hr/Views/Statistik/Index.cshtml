@model LightenUp.Web.Models.ViewModels.HrStatistikOverviewViewModel
@{
    ViewData["Title"] = "Statistik";
    ViewBag.ActiveNav = "Statistik";
    int total = Math.Max(1, Model.ActiveCount);

    var divLabels = Json.Serialize(Model.Divisions.Select(d => d.Name));
    var divStress = Json.Serialize(Model.Divisions.Select(d => d.StressPct));
}

@section Head {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}

<div style="max-width: 900px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
        <div>
            <h2 style="margin:0;">Data Keseluruhan Karyawan</h2>
            <small style="color:#6B7280;">@Model.CompanyName</small>
        </div>
        <div style="display:flex; gap:8px;">
            <a class="btn-pill ghost" asp-action="ExportCsv">Export CSV</a>
            <a class="btn-pill" asp-action="Print" target="_blank">Export PDF</a>
        </div>
    </div>

    <p style="margin: 0 0 12px;"><strong>Client aktif:</strong> 👥 @Model.ActiveCount orang</p>

    <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap:12px; margin-bottom:24px;">
        <div class="lu-card" style="text-align:center;">
            <div style="font-size:28px;">✅</div>
            <div style="font-size:22px; font-weight:700; color:#047857;">@Model.Sehat</div>
            <div style="font-size:12px; color:#6B7280;">Sehat</div>
        </div>
        <div class="lu-card" style="text-align:center;">
            <div style="font-size:28px;">⚠️</div>
            <div style="font-size:22px; font-weight:700; color:#B45309;">@Model.Beresiko</div>
            <div style="font-size:12px; color:#6B7280;">Beresiko</div>
        </div>
        <div class="lu-card" style="text-align:center;">
            <div style="font-size:28px;">🔴</div>
            <div style="font-size:22px; font-weight:700; color:#B91C1C;">@Model.Bahaya</div>
            <div style="font-size:12px; color:#6B7280;">Bahaya</div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-bottom:24px;">
        <div class="lu-card">
            <h3 class="lu-card-title">Status Karyawan Keseluruhan</h3>
            <canvas id="pieChart" height="220"></canvas>
        </div>
        <div class="lu-card">
            <h3 class="lu-card-title">Tingkat Stress Tiap Divisi (%)</h3>
            @if (!Model.Divisions.Any())
            {
                <p style="color:#9CA3AF;">Belum ada divisi tercatat.</p>
            }
            else
            {
                <canvas id="stressChart" height="220"></canvas>
            }
        </div>
    </div>

    <h3 style="font-size:16px; margin: 24px 0 12px;">Ringkasan per Divisi</h3>
    @if (!Model.Divisions.Any())
    {
        <div class="dash-card-empty">
            <p>Belum ada divisi tercatat untuk perusahaan ini.</p>
        </div>
    }
    else
    {
        <div style="display:flex; gap:12px; overflow-x:auto; padding-bottom:8px;">
            @foreach (var d in Model.Divisions)
            {
                <a asp-action="Division" asp-route-name="@d.Name" style="min-width:180px; text-decoration:none; color:inherit;">
                    <div class="lu-card" style="border-color:#C4B5FD;">
                        <div style="background:#7C3AED; color:#fff; padding:8px 10px; border-radius:8px; text-align:center; margin: -20px -20px 12px;">Detail</div>
                        <div style="text-align:center; padding:24px 8px; background:#EDE9FE; color:#7C3AED; font-weight:600; border-radius:8px;">@d.Name Report</div>
                        <div style="margin-top:10px; font-size:13px;">
                            <strong>@d.Name</strong><br/>
                            <span style="color:#6B7280;">@d.Count orang · Sehat: @d.SehatPct%</span>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        new Chart(document.getElementById('pieChart'), {
            type: 'pie',
            data: {
                labels: ['Sehat', 'Beresiko', 'Bahaya'],
                datasets: [{
                    data: [@Model.Sehat, @Model.Beresiko, @Model.Bahaya],
                    backgroundColor: ['#10B981', '#F59E0B', '#EF4444']
                }]
            },
            options: { responsive: true }
        });

        @if (Model.Divisions.Any())
        {
            <text>
            new Chart(document.getElementById('stressChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(divLabels),
                    datasets: [{
                        label: 'Stress %',
                        data: @Html.Raw(divStress),
                        backgroundColor: '#A78BFA'
                    }]
                },
                options: {
                    responsive: true,
                    scales: { y: { beginAtZero: true, max: 100, ticks: { callback: v => v + '%' } } },
                    plugins: { legend: { display: false } }
                }
            });
            </text>
        }
    </script>
}
