@model LightenUp.Web.Models.ViewModels.HrStatistikOverviewViewModel
@{
    ViewData["Title"] = "Statistik Perusahaan";
    ViewBag.ActiveNav = "Statistik";
    var cid = new System.Globalization.CultureInfo("id-ID");

    var divLabels = Json.Serialize(Model.Divisions.Select(d => d.Name));
    var divStress = Json.Serialize(Model.Divisions.Select(d => d.StressPct));
    var divSehat  = Json.Serialize(Model.Divisions.Select(d => d.SehatPct));

    int total = Math.Max(1, Model.ActiveCount);
    var healthScore = (int)Math.Round((double)Model.Sehat / total * 100);
    var scoreLabel  = healthScore >= 70 ? "Sangat Baik" : healthScore >= 40 ? "Perlu Perhatian" : "Kritis";
    var scoreSuffix = healthScore >= 70 ? "👍" : healthScore >= 40 ? "⚠️" : "🚨";
    var arcOffset   = (int)Math.Round(207.35 * (1 - healthScore / 100.0));
}

@section Head {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}

@* ── Hero (same stat-hero pattern as Psychologist/Statistics) ── *@
<div class="stat-hero">
    <div class="stat-hero-left">
        <p class="stat-hero-eyebrow">HR · Laporan Kesehatan Mental</p>
        <h1 class="stat-hero-title">Statistik @Model.CompanyName</h1>
        <p class="stat-hero-sub">@DateTime.Now.ToString("dddd, d MMMM yyyy", cid) · Ringkasan kesehatan mental seluruh karyawan</p>
        <div class="stat-hero-actions">
            <a class="sch-hero-btn sch-hero-btn--sm" asp-action="ExportCsv">📥 Export CSV</a>
            <a class="sch-hero-btn sch-hero-btn--sm sch-hero-btn--print" asp-action="Print" target="_blank">🖨️ Cetak PDF</a>
        </div>
    </div>
    <div class="stat-hero-score">
        <div class="stat-score-ring">
            <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
                <circle cx="40" cy="40" r="33" fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="7"/>
                <circle cx="40" cy="40" r="33" fill="none" stroke="white" stroke-width="7"
                        stroke-linecap="round"
                        stroke-dasharray="207.35"
                        stroke-dashoffset="@arcOffset"
                        transform="rotate(-90 40 40)"
                        class="stat-score-ring-progress"/>
            </svg>
            <div class="stat-score-inner">
                <span class="stat-score-pct">@healthScore<small>%</small></span>
            </div>
        </div>
        <div class="stat-score-meta">
            <p class="stat-score-name">Wellness Score @scoreSuffix</p>
            <p class="stat-score-label">@scoreLabel · @Model.ActiveCount karyawan aktif</p>
        </div>
    </div>
</div>

@* ── KPI cards (stat-kpi-row) ── *@
<div class="stat-kpi-row">
    <div class="stat-kpi stat-kpi--total">
        <div class="stat-kpi-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="stat-kpi-body">
            <span class="stat-kpi-value">@Model.ActiveCount</span>
            <span class="stat-kpi-label">Total Karyawan</span>
        </div>
        <div class="stat-kpi-bar stat-kpi-bar--total stat-kpi-bar--full"></div>
    </div>

    <div class="stat-kpi stat-kpi--sehat">
        <div class="stat-kpi-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="stat-kpi-body">
            <span class="stat-kpi-value">@Model.Sehat</span>
            <span class="stat-kpi-label">Sehat</span>
        </div>
        @{ var sehatPct = (int)Math.Round((double)Model.Sehat / total * 100); }
        <div class="stat-kpi-bar stat-kpi-bar--sehat" style="--bar-w:@sehatPct%"></div>
    </div>

    <div class="stat-kpi stat-kpi--beresiko">
        <div class="stat-kpi-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div class="stat-kpi-body">
            <span class="stat-kpi-value">@Model.Beresiko</span>
            <span class="stat-kpi-label">Beresiko</span>
        </div>
        @{ var beresikoPct = (int)Math.Round((double)Model.Beresiko / total * 100); }
        <div class="stat-kpi-bar stat-kpi-bar--beresiko" style="--bar-w:@beresikoPct%"></div>
    </div>

    <div class="stat-kpi stat-kpi--bahaya">
        <div class="stat-kpi-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="stat-kpi-body">
            <span class="stat-kpi-value">@Model.Bahaya</span>
            <span class="stat-kpi-label">Bahaya</span>
        </div>
        @{ var bahayaPct = (int)Math.Round((double)Model.Bahaya / total * 100); }
        <div class="stat-kpi-bar stat-kpi-bar--bahaya" style="--bar-w:@bahayaPct%"></div>
    </div>
</div>

@* ── Charts row ── *@
<div class="stat-charts-row">

    <div class="stat-chart-card stat-chart-card--donut">
        <div class="stat-chart-head">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
            <h3 class="stat-chart-title">Distribusi Status Karyawan</h3>
        </div>
        @if (Model.ActiveCount == 0)
        {
            <div class="stat-empty">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                <p>Belum ada karyawan aktif</p>
            </div>
        }
        else
        {
            <div class="stat-donut-wrap">
                <div class="stat-canvas-wrap"><canvas id="pieChart"></canvas></div>
                <ul class="stat-legend">
                    <li class="stat-legend-item">
                        <span class="stat-legend-dot stat-legend-dot--sehat"></span>
                        <span>Sehat</span>
                        <strong>@Model.Sehat</strong>
                    </li>
                    <li class="stat-legend-item">
                        <span class="stat-legend-dot stat-legend-dot--beresiko"></span>
                        <span>Beresiko</span>
                        <strong>@Model.Beresiko</strong>
                    </li>
                    <li class="stat-legend-item">
                        <span class="stat-legend-dot stat-legend-dot--bahaya"></span>
                        <span>Bahaya</span>
                        <strong>@Model.Bahaya</strong>
                    </li>
                </ul>
            </div>
        }
    </div>

    <div class="stat-chart-card stat-chart-card--bar">
        <div class="stat-chart-head">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            <h3 class="stat-chart-title">Tingkat Stress per Divisi</h3>
        </div>
        @if (!Model.Divisions.Any())
        {
            <div class="stat-empty">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                <p>Belum ada data divisi</p>
            </div>
        }
        else
        {
            <div class="stat-canvas-wrap"><canvas id="barChart"></canvas></div>
        }
    </div>

</div>

@* ── Division cards ── *@
@if (Model.Divisions.Any())
{
    <div class="stat-section-head">
        <div class="stat-section-title-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            <h2 class="stat-section-title">Ringkasan per Divisi</h2>
            <span class="stat-section-chip">@Model.Divisions.Count() divisi</span>
        </div>
    </div>

    <div class="stat-division-grid">
        @foreach (var d in Model.Divisions)
        {
            var statusCss = d.StressPct >= 50 ? "bahaya" : d.StressPct >= 25 ? "beresiko" : "sehat";
            var statusLabel = d.StressPct >= 50 ? "Tinggi" : d.StressPct >= 25 ? "Sedang" : "Rendah";
            var initial = string.IsNullOrEmpty(d.Name) ? "?" : d.Name.Substring(0, 1).ToUpper();
            <div class="stat-div-card" onclick="openDivModal('@d.Name', @d.Count, @d.StressPct, @d.SehatPct, @d.SehatCount, @d.BeresikoCount, @d.BahayaCount)">
                <div class="stat-div-header">
                    <div class="stat-div-logo">@initial</div>
                    <div class="stat-div-meta">
                        <span class="stat-div-name">@d.Name</span>
                        <span class="stat-div-count">@d.Count karyawan</span>
                    </div>
                    <span class="stat-div-chip stat-div-chip--@statusCss">@statusLabel</span>
                </div>
                <div class="stat-div-bars">
                    <div class="stat-div-bar-row">
                        <span class="stat-div-bar-label">Sehat</span>
                        <div class="stat-div-bar-track"><div class="stat-div-bar-fill stat-div-bar-fill--sehat" style="--bar-w:@d.SehatPct%"></div></div>
                        <span class="stat-div-bar-pct">@d.SehatPct%</span>
                    </div>
                    <div class="stat-div-bar-row">
                        <span class="stat-div-bar-label">Stress</span>
                        <div class="stat-div-bar-track"><div class="stat-div-bar-fill stat-div-bar-fill--stress" style="--bar-w:@d.StressPct%"></div></div>
                        <span class="stat-div-bar-pct">@d.StressPct%</span>
                    </div>
                </div>
                <div class="stat-div-footer stat-div-footer--hr">
                    Lihat detail <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="stat-no-div">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        <p>Tambahkan karyawan dengan divisi untuk melihat statistik per divisi.</p>
    </div>
}

<!-- Division Modal -->
<div class="psy-modal-overlay" id="divDetailModal" onclick="closeDivModal(event)">
    <div class="psy-modal-content" onclick="event.stopPropagation()">
        <button class="psy-modal-close" onclick="closeDivModal(event)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        
        <div class="psy-modal-header psy-modal-header--blue">
            <h2 id="dName" class="psy-modal-title"></h2>
            <div class="psy-modal-subtitle">
                <span id="dCount"></span> Karyawan Aktif
            </div>
        </div>
        
        <div class="psy-modal-body">
            <h3 class="psy-modal-section-title">Distribusi Kesehatan Mental</h3>
            
            <div class="psy-modal-distro-grid">
                <div class="psy-modal-stat-grid">
                    <div class="psy-modal-stat-box--sehat">
                        <div class="psy-modal-stat-val--sehat" id="dSehatCount">0</div>
                        <div class="psy-modal-stat-lbl--sehat">Sehat</div>
                    </div>
                    <div class="psy-modal-stat-box--beresiko">
                        <div class="psy-modal-stat-val--beresiko" id="dBeresikoCount">0</div>
                        <div class="psy-modal-stat-lbl--beresiko">Beresiko</div>
                    </div>
                    <div class="psy-modal-stat-box--bahaya">
                        <div class="psy-modal-stat-val--bahaya" id="dBahayaCount">0</div>
                        <div class="psy-modal-stat-lbl--bahaya">Bahaya</div>
                    </div>
                </div>
                <div class="psy-modal-chart-wrap--sm">
                    <canvas id="dDoughnutChart"></canvas>
                </div>
            </div>
            
            <div class="stat-div-bars psy-modal-bars">
                <div class="stat-div-bar-row psy-modal-bar-row--spaced">
                    <span class="stat-div-bar-label psy-modal-bar-label">Sehat</span>
                    <div class="stat-div-bar-track"><div class="stat-div-bar-fill stat-div-bar-fill--sehat psy-modal-bar-fill-init" id="dSehatBar"></div></div>
                    <span class="stat-div-bar-pct" id="dSehatPct">0%</span>
                </div>
                <div class="stat-div-bar-row">
                    <span class="stat-div-bar-label psy-modal-bar-label">Stress</span>
                    <div class="stat-div-bar-track"><div class="stat-div-bar-fill stat-div-bar-fill--stress psy-modal-bar-fill-init" id="dStressBar"></div></div>
                    <span class="stat-div-bar-pct" id="dStressPct">0%</span>
                </div>
            </div>
            
            <h3 class="psy-modal-section-title psy-modal-section-title--chart">Perubahan Mood (30 Hari)</h3>
            <div class="psy-modal-chart-wrap--lg">
                <canvas id="dChart"></canvas>
            </div>
        </div>
        
        <div class="psy-modal-footer">
            <a href="#" id="dLink" class="btn-mitra btn-mitra--blue" target="_blank">Download Laporan (PDF)</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    document.addEventListener("DOMContentLoaded", function () {

        @if (Model.ActiveCount > 0)
        {
            <text>
        var ctx = document.getElementById('pieChart');
        if (ctx) {
            new Chart(ctx.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['Sehat', 'Beresiko', 'Bahaya'],
                    datasets: [{ data: [@Model.Sehat, @Model.Beresiko, @Model.Bahaya], backgroundColor: ['#10B981','#F59E0B','#EF4444'], borderWidth: 3, borderColor: '#fff', hoverOffset: 6 }]
                },
                options: { responsive: true, maintainAspectRatio: false, cutout: '68%', plugins: { legend: { display: false } } }
            });
        }
            </text>
        }

        @if (Model.Divisions.Any())
        {
            <text>
        var barCtx = document.getElementById('barChart');
        if (barCtx) {
            new Chart(barCtx.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(divLabels),
                    datasets: [
                        { label: 'Sehat (%)', data: @Html.Raw(divSehat), backgroundColor: '#10B981', borderRadius: 6, barPercentage: 0.55 },
                        { label: 'Stress (%)', data: @Html.Raw(divStress), backgroundColor: '#F59E0B', borderRadius: 6, barPercentage: 0.55 }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'top', labels: { padding: 16, usePointStyle: true } } },
                    scales: {
                        y: { beginAtZero: true, max: 100, ticks: { callback: v => v + '%' }, grid: { color: '#F3F4F6' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }
            </text>
        }

    });
    var modalChartInstance = null;
    var modalDoughnutInstance = null;

    function openDivModal(name, count, stressPct, sehatPct, sehatCount, beresikoCount, bahayaCount) {
        document.getElementById('dName').textContent = name;
        document.getElementById('dCount').textContent = count;
        
        document.getElementById('dSehatCount').textContent = sehatCount;
        document.getElementById('dBeresikoCount').textContent = beresikoCount;
        document.getElementById('dBahayaCount').textContent = bahayaCount;
        
        document.getElementById('dSehatBar').style.width = sehatPct + '%';
        document.getElementById('dSehatPct').textContent = sehatPct + '%';
        
        document.getElementById('dStressBar').style.width = stressPct + '%';
        document.getElementById('dStressPct').textContent = stressPct + '%';
        
        // Append print=true to trigger auto-print when downloading
        document.getElementById('dLink').href = '/Hr/Statistik/Division?name=' + encodeURIComponent(name) + '&print=true';
        
        var modal = document.getElementById('divDetailModal');
        modal.style.display = 'flex';
        setTimeout(() => {
            modal.classList.add('is-active');
            document.body.style.overflow = 'hidden';
        }, 10);
        
        // Initialize Doughnut Chart
        if (modalDoughnutInstance) {
            modalDoughnutInstance.destroy();
        }
        var dCtx = document.getElementById('dDoughnutChart').getContext('2d');
        modalDoughnutInstance = new Chart(dCtx, {
            type: 'doughnut',
            data: {
                labels: ['Sehat', 'Beresiko', 'Bahaya'],
                datasets: [{
                    data: [sehatCount, beresikoCount, bahayaCount],
                    backgroundColor: ['#10B981', '#F59E0B', '#EF4444'],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '65%',
                plugins: { legend: { display: false } }
            }
        });
        
        // Fetch Line Chart Data
        fetch('/Hr/Statistik/DivisionChartData?name=' + encodeURIComponent(name))
            .then(res => res.json())
            .then(data => {
                if (modalChartInstance) {
                    modalChartInstance.destroy();
                }
                var ctx = document.getElementById('dChart').getContext('2d');
                modalChartInstance = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            data: data.data,
                            borderColor: '#3B82F6',
                            backgroundColor: 'rgba(59, 130, 246, 0.12)',
                            fill: true, tension: 0.4,
                            pointRadius: 4, pointBackgroundColor: '#3B82F6'
                        }]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        scales: {
                            y: { min: 0, max: 5, ticks: { stepSize: 1 }, grid: { color: '#F3F4F6' } },
                            x: { grid: { display: false } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });
            });
    }
    
    function closeDivModal(e) {
        if(e) e.preventDefault();
        var modal = document.getElementById('divDetailModal');
        modal.classList.remove('is-active');
        setTimeout(() => {
            modal.style.display = 'none';
            document.body.style.overflow = '';
        }, 300);
    }
    </script>
}
