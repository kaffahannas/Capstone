@model LightenUp.Web.Models.ViewModels.HrRequestViewModel
@{
    ViewData["Title"] = "Permintaan Worksheet";
    ViewBag.ActiveNav = "Monitoring";
}

<a class="pd-back" asp-action="Index">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Riwayat Worksheet
</a>

<div style="max-width:640px;">
    <h2 style="margin:0 0 4px;font-size:22px;font-weight:800;color:var(--text-dark);">Permintaan Worksheet</h2>
    <p style="margin:0 0 20px;color:var(--text-muted);font-size:14px;">
        Psikolog akan meninjau dan menetapkan worksheet yang sesuai dalam 1–2 hari kerja.
    </p>

    <form asp-action="Request" method="post">
        <div class="detail-card">
            <input type="hidden" asp-for="RequestType" />
            <div asp-validation-summary="ModelOnly" style="background:#FEE2E2;color:#B91C1C;padding:10px 14px;border-radius:8px;margin-bottom:16px;font-size:13px;"></div>

            <div class="form-group">
                <label asp-for="PatientId" class="form-label">Untuk Pasien</label>
                <select asp-for="PatientId" class="form-control">
                    <option value="">Pilih pasien...</option>
                    @foreach (var p in Model.AvailablePatients)
                    {
                        <option value="@p.PatientId">@p.FullName @(p.Department != null ? $"({p.Department})" : "")</option>
                    }
                </select>
                <span asp-validation-for="PatientId" style="color:#DC2626;font-size:12px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="ProposedTaskName" class="form-label">Nama Worksheet yang Diusulkan <small style="color:var(--text-muted);font-weight:400;">(opsional)</small></label>
                <input asp-for="ProposedTaskName" class="form-control" placeholder="Mis. Latihan pernapasan 10 menit..." />
            </div>

            <div class="form-group">
                <label asp-for="ProposedDeadline" class="form-label">Usulan Deadline <small style="color:var(--text-muted);font-weight:400;">(opsional)</small></label>
                <input asp-for="ProposedDeadline" type="date" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="form-label">Catatan / Alasan <small style="color:var(--text-muted);font-weight:400;">(opsional)</small></label>
                <textarea asp-for="Notes" rows="4" class="note-textarea" style="margin-bottom:0;" placeholder="Jelaskan alasan permintaan worksheet ini..."></textarea>
            </div>
        </div>

        <div class="modal-footer" style="padding:0;margin-top:16px;">
            <a asp-action="Index" class="btn-outline">Batalkan</a>
            <button type="submit" class="btn-fill">Kirim Permintaan</button>
        </div>
    </form>
</div>
