@model LightenUp.Web.Models.ViewModels.HrRequestViewModel
@{
    ViewData["Title"] = "Permintaan Worksheet";
    ViewBag.ActiveNav = "Monitoring";
}

<a asp-action="Index" style="text-decoration:none; color:#111;">← Riwayat Worksheet</a>

<div style="max-width: 560px; margin: 16px auto 0;">
    <h2>Minta Psikolog untuk Memberi Worksheet</h2>
    <p style="color:#6B7280; font-size:14px;">Sampaikan ringkasan kepada psikolog yang menangani pasien. Psikolog akan meninjau dan menetapkan worksheet jika setuju.</p>

    <form asp-action="Request" method="post" class="lu-card" style="margin-top:16px;">
        <input type="hidden" asp-for="RequestType" />
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;"></div>

        <div style="margin-bottom:14px;">
            <label asp-for="PatientId" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Untuk Pasien</label>
            <select asp-for="PatientId" class="onb-select">
                <option value="">Pilih pasien</option>
                @foreach (var p in Model.AvailablePatients)
                {
                    <option value="@p.PatientId">@p.FullName @(p.Department != null ? "(" + p.Department + ")" : "")</option>
                }
            </select>
            <span asp-validation-for="PatientId" class="text-danger"></span>
        </div>

        <div style="margin-bottom:14px;">
            <label asp-for="ProposedTaskName" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Usulan Nama Worksheet</label>
            <input asp-for="ProposedTaskName" class="onb-input" placeholder="Mis. Latihan pernapasan 10 menit" />
        </div>

        <div style="margin-bottom:14px;">
            <label asp-for="ProposedDeadline" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Usulan Deadline</label>
            <input asp-for="ProposedDeadline" type="date" class="onb-input" />
        </div>

        <div style="margin-bottom:14px;">
            <label asp-for="Notes" style="display:block; font-size:13px; color:#6B7280; margin-bottom:6px;">Catatan</label>
            <textarea asp-for="Notes" rows="4" class="mood-textarea" placeholder="Alasan / konteks tambahan..."></textarea>
        </div>

        <div style="display:flex; gap:12px;">
            <a asp-action="Index" class="btn-secondary" style="flex:1; text-align:center;">Batalkan</a>
            <button type="submit" class="btn-primary" style="flex:1;">Kirim Permintaan</button>
        </div>
    </form>
</div>
