@model List<LightenUp.Web.Models.ViewModels.PatientListItem>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Daftar Klien";
    var cid = new System.Globalization.CultureInfo("id-ID");
}

<div class="psy-dashboard-grid" style="grid-template-columns: 1fr; align-content: start;">
    @{
        ViewData["ActiveTab"] = "Semua";
        ViewData["SemuaUrl"] = Url.Action("Index", "Client", new { area = "Psychologist" });
        ViewData["MitraUrl"] = Url.Action("Index", "Monitoring", new { area = "Psychologist" });
    }
    <partial name="_MitraTabs" />
    <section class="psy-card psy-client-card">
        <header class="psy-card-head">
            <div class="psy-card-title-wrap">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <h2 class="psy-card-title">Daftar Klien Aktif</h2>
                <span class="psy-count-chip">@Model.Count</span>
            </div>
            <div class="psy-card-tools">
                <div class="psy-search-wrap">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" id="clientSearch" placeholder="Cari klien..." class="psy-search" oninput="filterClientSearch()" />
                </div>
            </div>
        </header>

        <div class="psy-client-list" id="clientListView">
            @if (!Model.Any())
            {
                <div class="psy-empty">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    <p>Belum ada klien yang ditangani</p>
                </div>
            }
            else
            {
                @foreach (var patient in Model)
                {
                    var statusCss = patient.Status?.ToLower() switch {
                        "bahaya" => "bahaya",
                        "beresiko" => "beresiko",
                        _ => "sehat"
                    };
                    var initials = patient.FullName.Length > 0 ? patient.FullName.Substring(0, 1).ToUpper() : "?";
                    <div class="psy-client-row client-searchable" data-name="@patient.FullName.ToLower()">
                        <div class="psy-client-avatar psy-avatar--@statusCss">@initials</div>
                        <div class="psy-client-info">
                            <span class="psy-client-name">@patient.FullName</span>
                            <span class="psy-client-meta">@patient.Gender &middot; Sejak @patient.JoinedDate.ToString("d MMM yyyy", cid)</span>
                            <span class="psy-client-meta" style="display:block; margin-top: 4px; color: #6B7280; font-size: 12px;">@patient.CompanyName</span>
                        </div>
                        @if (patient.IsSubscriptionExpired)
                        {
                            <span class="psy-sub-expired-badge">
                                @(patient.CompanyId != null ? "Menunggu HR" : "Langganan Habis")
                            </span>
                        }
                        <span class="psy-status-chip psy-status--@statusCss">@patient.Status</span>
                        <a href="/Psychologist/Client/PatientDetail/@patient.PatientId" class="psy-btn psy-btn--ghost psy-btn--sm">Detail &rarr;</a>
                    </div>
                }
            }
        </div>
    </section>
</div>

@section Scripts {
<script>
    function filterClientSearch() {
        var q = document.getElementById("clientSearch").value.toLowerCase();
        document.querySelectorAll(".client-searchable").forEach(function(row) {
            row.style.display = row.dataset.name.includes(q) ? "" : "none";
        });
    }
</script>
}
