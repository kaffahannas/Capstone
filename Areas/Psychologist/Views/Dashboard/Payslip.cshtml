@model LightenUp.Web.Models.ViewModels.PayslipViewModel
@using LightenUp.Web.Models
@using LightenUp.Web.Models.ViewModels
@using LightenUp.Web.Controllers
@{
    ViewData["Title"] = "Pendapatan Saya";
    Layout = "_LayoutDashboard";
    var idCulture = new System.Globalization.CultureInfo("id-ID");
    string Idr(decimal v) => v.ToString("C0", idCulture);

    var assignmentRows = Model.Assignments;
    int activeCount = Model.Assignments.Count;
    int totalSlots = Model.Assignments.Sum(a => Math.Min(a.CompletedSessions, a.MaxSessions));
    decimal psyShare = Model.TotalPsyShare;
    string monthLabel = Model.MonthName;
    bool hasSnapshots = assignmentRows.Any(a => a.SubscriptionValue > 0);
}

@section Head {
    <link rel="stylesheet" href="~/css/psychologist/dashboard-payslip.css" asp-append-version="true" />
}

<div class="psy-payslip-page">

<div class="tasks-hero pay-hero">
    <div class="pay-hero-deco">💸</div>
    <div class="pay-hero-inner">
        <p class="pay-hero-eyebrow">PSIKOLOG · KEUANGAN</p>
        <h1 class="pay-hero-title">Ringkasan Pendapatan</h1>
        <p class="pay-hero-sub">Berdasarkan sesi selesai × nilai per sesi dari langganan pasien · Periode: <strong>@monthLabel</strong></p>
    </div>
</div>

@if (ViewBag.PayrollSetting != null)
{
    var setting = ViewBag.PayrollSetting as PsychologistPayrollSetting;
    if (setting != null && !string.IsNullOrWhiteSpace(setting.AdminReason))
    {
        <div class="pay-info-box">
            <h3 class="pay-info-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                Informasi Persentase
            </h3>
            <p class="pay-info-text">
                Admin telah menetapkan persentase bagi hasil Anda menjadi <strong>@setting.PsychologistPercentage%</strong>.<br/>
                <strong class="pay-info-label">Catatan Admin:</strong><br/>
                <span class="pay-info-quote">"@setting.AdminReason"</span>
            </p>
        </div>
    }
}

@if (!hasSnapshots && activeCount > 0)
{
    <div class="pay-warn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span>Beberapa penugasan belum memiliki snapshot nilai slot. Hubungi Admin jika angka tampak nol.</span>
    </div>
}

<div class="pay-kpi-grid">
    <div class="pay-kpi">
        <div class="pay-kpi-label">Pasien Aktif</div>
        <div class="pay-kpi-value">@activeCount</div>
    </div>
    <div class="pay-kpi">
        <div class="pay-kpi-label">Total Sesi</div>
        <div class="pay-kpi-value pay-kpi-value--md">@totalSlots</div>
    </div>
    <div class="pay-kpi pay-kpi--income">
        <div class="pay-kpi-label pay-kpi-label--light">Pendapatan Anda</div>
        <div class="pay-kpi-value pay-kpi-value--lg">@Idr(psyShare)</div>
        <div class="pay-kpi-suffix pay-kpi-suffix--light">/ bulan</div>
    </div>
</div>

<div class="pay-panel">
    <h3 class="pay-panel-title">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        Rincian per Pasien Aktif
    </h3>
    @if (!assignmentRows.Any())
    {
        <div class="pay-empty">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
            <p>Belum ada pasien aktif dengan penugasan.</p>
        </div>
    }
    else
    {
        <div class="pay-table-wrap">
        <table class="pay-table">
            <thead>
                <tr>
                    <th class="pay-th pay-th--left">Pasien</th>
                    <th class="pay-th pay-th--left">Tipe</th>
                    <th class="pay-th pay-th--right">Biaya Langganan</th>
                    <th class="pay-th pay-th--center">Sesi Bulan Ini</th>
                    <th class="pay-th pay-th--right">Nilai / Sesi</th>
                    <th class="pay-th pay-th--right">%</th>
                    <th class="pay-th pay-th--right">Pendapatan</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in assignmentRows)
            {
                <tr>
                    <td class="pay-td pay-td--name">@r.PatientName</td>
                    <td class="pay-td pay-td--muted"><span class="pay-type-badge pay-type-badge--@(r.PatientType.ToLower())">@r.PatientType</span></td>
                    <td class="pay-td pay-td--right">
                        @Idr(r.SubscriptionValue)
                        @if (r.PatientType == "B2B" && r.B2BPlanAmount.GetValueOrDefault() > 0 && r.B2BEmployeeCount.GetValueOrDefault() > 0)
                        {
                            <div class="pay-formula-detail">@Idr(r.B2BPlanAmount!.Value) &divide; @r.B2BEmployeeCount karyawan</div>
                        }
                    </td>
                    <td class="pay-td pay-td--center">
                        <span class="pay-sessions-badge">@r.CompletedSessions</span>
                        <span class="pay-sessions-muted">/ @r.MaxSessions</span>
                    </td>
                    <td class="pay-td pay-td--right">
                        @Idr(r.PerSessionValue)
                        @if (r.PatientType == "B2B" && r.SubscriptionValue > 0 && r.MaxSessions > 0)
                        {
                            <div class="pay-formula-detail">@Idr(r.SubscriptionValue) &divide; @r.MaxSessions sesi</div>
                        }
                    </td>
                    <td class="pay-td pay-td--right">@r.FeePercentage.ToString("0.##", idCulture)%</td>
                    <td class="pay-td pay-td--income">
                        @Idr(r.PsyShare)
                        @if (r.CompletedSessions > 0)
                        {
                            <div class="pay-earning-detail">(@r.FeePercentage.ToString("0.##", idCulture)% × @r.CompletedSessions sesi)</div>
                        }
                    </td>
                </tr>
            }
            </tbody>
            <tfoot class="pay-tfoot">
                <tr>
                    <td colspan="6">Total Pendapatan</td>
                    <td class="pay-td pay-td--total">@Idr(psyShare)</td>
                </tr>
            </tfoot>
        </table>
        </div>
    }
</div>

<div class="pay-panel pay-panel--spaced">
    <h3 class="pay-panel-title">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        Riwayat Transfer Bulanan
    </h3>
    @{
        var payouts = ViewBag.Payouts as List<LightenUp.Web.Models.MonthlyPayout>;
        var currentSetting = ViewBag.PayrollSetting as LightenUp.Web.Models.PsychologistPayrollSetting;
    }
    
    @if (currentSetting == null || string.IsNullOrEmpty(currentSetting.BankDetailsPdfPath))
    {
        <div class="pay-bank-alert">
            <h4 class="pay-bank-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Dokumen Rekening Belum Dilengkapi
            </h4>
            <p class="pay-bank-text">
                Riwayat transfer dan penerimaan gaji belum dapat diproses. Anda wajib mengunggah dokumen rekening (Buku Tabungan / M-Banking) terlebih dahulu agar Admin Keuangan dapat melakukan transfer bulanan ke rekening Anda.
            </p>
            <a asp-area="Psychologist" asp-controller="Profile" asp-action="Profile" class="pay-bank-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Unggah Dokumen di Profil
            </a>
        </div>
    }
    else if (payouts != null && payouts.Any())
    {
        <div class="pay-table-wrap">
        <table class="pay-table">
            <thead>
                <tr>
                    <th class="pay-th pay-th--left">Periode</th>
                    <th class="pay-th pay-th--right">Nominal Transfer</th>
                    <th class="pay-th pay-th--center">Bukti Transfer</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in payouts)
            {
                <tr>
                    <td>
                        <strong class="pay-period-name">@System.Globalization.CultureInfo.GetCultureInfo("id-ID").DateTimeFormat.GetMonthName(p.Month) @p.Year</strong><br/>
                        <span class="pay-period-date">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            @p.PaidAt?.ToString("dd MMM yyyy")
                        </span>
                    </td>
                    <td class="pay-td pay-td--income">@Idr(p.TotalAmount)</td>
                    <td class="pay-td pay-td--center">
                        @if (!string.IsNullOrEmpty(p.ProofOfTransferFilePath))
                        {
                            <a href="@p.ProofOfTransferFilePath" target="_blank" class="pay-proof-link">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                                Lihat File
                            </a>
                        }
                        else
                        {
                            <span class="pay-proof-pending">Menunggu</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }
    else
    {
        <div class="pay-empty">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
            <p>Belum ada riwayat transfer dari Admin.</p>
        </div>
    }
</div>

</div>
