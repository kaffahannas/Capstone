@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Statistik Klien Klinik";
    ViewData["ActiveTab"] = "Mitra";
    ViewData["SemuaUrl"] = Url.Action("Statistics", "Dashboard", new { area = "Psychologist" });
    ViewData["MitraUrl"] = Url.Action("Statistik", "Monitoring", new { area = "Psychologist" });

    var cid      = new System.Globalization.CultureInfo("id-ID");
    int total    = ViewBag.TotalClients ?? 0;
    int sehat    = ViewBag.SehatCount ?? 0;
    int beresiko = ViewBag.BeresikoCount ?? 0;
    int bahaya   = ViewBag.BahayaCount ?? 0;

    var healthScore = total > 0 ? (int)Math.Round((double)sehat / total * 100) : 0;
    var scoreLabel  = healthScore >= 70 ? "Sangat Baik" : healthScore >= 40 ? "Perlu Perhatian" : "Kritis";
    var scoreSuffix = healthScore >= 70 ? "&#x1F44D;" : healthScore >= 40 ? "&#x26A0;&#xFE0F;" : "&#x1F6A8;";
    var arcOffset   = (int)Math.Round(207.35 * (1 - healthScore / 100.0));
}

@section Head {
    <link rel="stylesheet" href="~/css/shared/components-stat-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shared/components-schedule-dashboard.css" asp-append-version="true" />
}

<partial name="_MitraTabs" />

    @* ── Hero banner ── *@
    <div class="sch-hero" style="margin-bottom: 20px;">
        <div class="sch-hero-left">
            <p class="sch-hero-eyebrow">Laporan Kesehatan Mental</p>
            <h1 class="sch-hero-title">Statistik Klien Klinik</h1>
            <p class="sch-hero-sub">@DateTime.Now.ToString("dddd, d MMMM yyyy", cid) · Ringkasan klien klinik Anda</p>
        </div>
        <div class="stat-hero-score">
            <div class="stat-score-ring">
                <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
                    <circle cx="40" cy="40" r="33" fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="7"/>
                    <circle cx="40" cy="40" r="33" fill="none" stroke="white" stroke-width="7"
                            stroke-linecap="round"
                            stroke-dasharray="207.35"
                            stroke-dashoffset="@arcOffset"
                            transform="rotate(-90 40 40)"
                            class="stat-score-ring-progress"/>
                </svg>
                <div class="stat-score-inner">
                    <span class="stat-score-pct">@healthScore<small>%</small></span>
                </div>
            </div>
            <div class="stat-score-meta">
                <p class="stat-score-name">Wellness Score</p>
                <p class="stat-score-label">@scoreLabel · @total klien aktif</p>
            </div>
        </div>
    </div>

    @* ── KPI cards ── *@
    <div class="stat-kpi-row">
        <div class="stat-kpi stat-kpi--total">
            <div class="stat-kpi-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="stat-kpi-body">
                <span class="stat-kpi-value">@total</span>
                <span class="stat-kpi-label">Total Klien</span>
            </div>
            <div class="stat-kpi-bar stat-kpi-bar--total stat-kpi-bar--full"></div>
        </div>

        <div class="stat-kpi stat-kpi--sehat">
            <div class="stat-kpi-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div class="stat-kpi-body">
                <span class="stat-kpi-value">@sehat</span>
                <span class="stat-kpi-label">Sehat</span>
            </div>
            @if (total > 0)
            {
                var pct = (int)Math.Round((double)sehat / total * 100);
                <div class="stat-kpi-bar stat-kpi-bar--sehat" style="--bar-w:@pct%"></div>
            }
        </div>

        <div class="stat-kpi stat-kpi--beresiko">
            <div class="stat-kpi-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <div class="stat-kpi-body">
                <span class="stat-kpi-value">@beresiko</span>
                <span class="stat-kpi-label">Beresiko</span>
            </div>
            @if (total > 0)
            {
                var pct = (int)Math.Round((double)beresiko / total * 100);
                <div class="stat-kpi-bar stat-kpi-bar--beresiko" style="--bar-w:@pct%"></div>
            }
        </div>

        <div class="stat-kpi stat-kpi--bahaya">
            <div class="stat-kpi-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div class="stat-kpi-body">
                <span class="stat-kpi-value">@bahaya</span>
                <span class="stat-kpi-label">Bahaya</span>
            </div>
            @if (total > 0)
            {
                var pct = (int)Math.Round((double)bahaya / total * 100);
                <div class="stat-kpi-bar stat-kpi-bar--bahaya" style="--bar-w:@pct%"></div>
            }
        </div>
    </div>

    @* ── Distribution bar ── *@
    @if (total > 0)
    {
        int sehatPct    = (int)Math.Round((double)sehat    / total * 100);
        int beresikoPct = (int)Math.Round((double)beresiko / total * 100);
        int bahayaPct   = (int)Math.Round((double)bahaya   / total * 100);
        <div class="stat-dist-card">
            <p class="stat-dist-title">Distribusi Status Mental</p>
            <div class="stat-dist-bar">
                @if (sehatPct > 0)    { <div class="stat-dist-seg stat-dist-seg--sehat"    style="width:@(sehatPct)%"></div> }
                @if (beresikoPct > 0) { <div class="stat-dist-seg stat-dist-seg--beresiko" style="width:@(beresikoPct)%"></div> }
                @if (bahayaPct > 0)   { <div class="stat-dist-seg stat-dist-seg--bahaya"   style="width:@(bahayaPct)%"></div> }
            </div>
            <div class="stat-dist-legend">
                <span class="stat-dist-item"><span class="stat-dist-dot stat-dist-dot--sehat"></span> Sehat @sehatPct%</span>
                <span class="stat-dist-item"><span class="stat-dist-dot stat-dist-dot--beresiko"></span> Beresiko @beresikoPct%</span>
                <span class="stat-dist-item"><span class="stat-dist-dot stat-dist-dot--bahaya"></span> Bahaya @bahayaPct%</span>
            </div>
        </div>
    }
    else
    {
        <div class="stat-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <p class="stat-empty-title">Belum ada data</p>
            <p class="stat-empty-sub">Statistik akan muncul setelah klien klinik bergabung melalui kode referal Anda.</p>
        </div>
    }
