@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Statistik Klien Klinik";
    int total = ViewBag.TotalClients ?? 0;
    int sehat = ViewBag.SehatCount ?? 0;
    int beresiko = ViewBag.BeresikoCount ?? 0;
    int bahaya = ViewBag.BahayaCount ?? 0;
}

<div style="max-width:700px; margin:0 auto; padding:24px 16px;">
    @{
        ViewData["ActiveTab"] = "Mitra";
        ViewData["SemuaUrl"] = Url.Action("Statistics", "Dashboard", new { area = "Psychologist" });
        ViewData["MitraUrl"] = Url.Action("Statistik", "Monitoring", new { area = "Psychologist" });
    }
    <partial name="_MitraTabs" />
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
        <h2 style="font-size:16px; font-weight:700;">Statistik Klien Klinik</h2>
        <div style="display:flex; gap:8px;">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Daftar Klien</a>
        </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:12px; margin-bottom:24px;">
        <div class="stat-card">
            <div class="stat-label">Total Klien</div>
            <div class="stat-value">@total</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Sehat</div>
            <div class="stat-value" style="color:#15803d;">@sehat</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Berisiko</div>
            <div class="stat-value" style="color:#b45309;">@beresiko</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Bahaya</div>
            <div class="stat-value" style="color:#b91c1c;">@bahaya</div>
        </div>
    </div>

    @if (total > 0)
    {
        <div class="psy-card" style="padding:20px;">
            <div style="font-size:13px; font-weight:600; margin-bottom:12px;">Distribusi Status Mental</div>
            @{
                int sehatPct = (int)Math.Round((double)sehat / total * 100);
                int beresikoPct = (int)Math.Round((double)beresiko / total * 100);
                int bahayaPct = (int)Math.Round((double)bahaya / total * 100);
            }
            <div style="height:20px; border-radius:10px; overflow:hidden; display:flex; margin-bottom:8px;">
                @if (sehatPct > 0) { <div style="width:@sehatPct%; background:#22c55e;"></div> }
                @if (beresikoPct > 0) { <div style="width:@beresikoPct%; background:#f59e0b;"></div> }
                @if (bahayaPct > 0) { <div style="width:@bahayaPct%; background:#ef4444;"></div> }
            </div>
            <div style="display:flex; gap:16px; font-size:12px;">
                <span style="color:#15803d;">■ Sehat @sehatPct%</span>
                <span style="color:#b45309;">■ Berisiko @beresikoPct%</span>
                <span style="color:#b91c1c;">■ Bahaya @bahayaPct%</span>
            </div>
        </div>
    }
    else
    {
        <div style="text-align:center; padding:40px; color:var(--color-text-secondary);">
            Belum ada data klien klinik.
        </div>
    }
</div>
