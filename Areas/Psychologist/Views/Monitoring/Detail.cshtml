@model LightenUp.Web.Models.Patient

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = $"Detail — {Model.User?.FullName}";
    var idCulture      = new System.Globalization.CultureInfo("id-ID");
    var hasMoodData    = (bool)(ViewBag.HasMoodData ?? false);
    var todaySession   = ViewBag.TodaySession as LightenUp.Web.Models.Schedule;
    var openWs         = (int)(ViewBag.OpenWorksheetCount ?? 0);
    var sehatPct       = (int)(ViewBag.SehatPct   ?? 0);
    var beresikoPct    = (int)(ViewBag.BeresikoPct ?? 0);
    var bahayaPct      = (int)(ViewBag.BahayaPct   ?? 0);
    var ageStr         = ViewBag.AgeStr as string ?? "—";

    var initial     = Model.User?.FullName?.Length > 0 ? Model.User.FullName.Substring(0, 1).ToUpper() : "?";
    var statusLower = (Model.MentalHealthStatus ?? "sehat").ToLower();
    var heroAccent  = statusLower switch {
        "bahaya"   => "pd-hero--bahaya",
        "beresiko" => "pd-hero--beresiko",
        _          => ""
    };
    var genderLabel = Model.Gender == "Male" ? "Laki-laki" : Model.Gender == "Female" ? "Perempuan" : "—";
}

@section Head {
    <link rel="stylesheet" href="~/css/psychologist/client-patient-detail.css" asp-append-version="true" />
}

<a href="/Psychologist/Monitoring" class="pd-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Kembali ke Klien Klinik
</a>

<div class="pd-page">

<div class="pd-hero @heroAccent">
    <div class="pd-hero-inner">

        <div class="pd-hero-av">@initial</div>

        <div class="pd-hero-id">
            <p class="pd-hero-eyebrow">Klien Klinik · Mitra</p>
            <h1 class="pd-hero-name">@(Model.User?.FullName ?? "—")</h1>
            <div class="pd-hero-meta">
                <span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    @genderLabel
                </span>
                <span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    @ageStr
                </span>
            </div>
        </div>

        <div class="pd-hero-status-wrap">
            <span class="pd-status-badge pd-status--@statusLower">
                <span class="pd-status-dot" aria-hidden="true"></span>
                @(Model.MentalHealthStatus ?? "Sehat")
            </span>
            <span class="pd-hero-status-label">Status Mental</span>
        </div>

        <div class="pd-hero-stats">
            <div class="pd-hero-stat">
                <span class="pd-hero-stat-val">@openWs</span>
                <span class="pd-hero-stat-lbl">Worksheet Aktif</span>
            </div>
            <div class="pd-hero-stat pd-hero-stat--mood">
                <span class="pd-hero-stat-val">@sehatPct%</span>
                <span class="pd-hero-stat-lbl">Hari Sehat (7 hari)</span>
            </div>
        </div>

    </div>
</div>

<div class="pd-grid">

    <div class="pd-sidebar">

        <div class="pd-card pd-card--blue">
            <div class="pd-card-accent"></div>
            <div class="pd-card-head">
                <div class="pd-card-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <h3 class="pd-card-title">Info Pasien</h3>
            </div>
            <div class="pd-card-body">
                <div class="pd-field">
                    <span class="pd-field-label">Telepon</span>
                    <span class="pd-field-val">@(string.IsNullOrEmpty(Model.User?.PhoneNumber) ? "Belum diatur" : Model.User.PhoneNumber)</span>
                </div>
                <div class="pd-field">
                    <span class="pd-field-label">Bergabung</span>
                    <span class="pd-field-val">@(Model.OnboardingCompletedAt?.ToString("d MMMM yyyy", idCulture) ?? "—")</span>
                </div>
                <div class="pd-field">
                    <span class="pd-field-label">Tipe</span>
                    <span class="pd-field-val">Klien Klinik</span>
                </div>
            </div>
        </div>

        <div class="pd-card pd-card--plain">
            <div class="pd-card-head">
                <div class="pd-card-icon pd-card-icon--schedule">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <h3 class="pd-card-title">Jadwal Hari Ini</h3>
            </div>
            <div class="pd-card-body">
                @if (todaySession != null)
                {
                    <div class="pd-session-row">
                        <div class="pd-session-time">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            @todaySession.SessionStart.ToString("HH:mm") WIB
                        </div>
                        @if (!string.IsNullOrEmpty(todaySession.Notes))
                        {
                            <p class="pd-session-note">@todaySession.Notes</p>
                        }
                    </div>
                }
                else
                {
                    <p class="pd-field-val pd-field-val--muted">Tidak ada sesi hari ini.</p>
                }
            </div>
        </div>

        <div class="pd-card pd-card--plain">
            <div class="pd-card-head">
                <div class="pd-card-icon pd-card-icon--ws">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg>
                </div>
                <h3 class="pd-card-title">Worksheet</h3>
            </div>
            <div class="pd-card-body">
                @if (openWs > 0)
                {
                    <div class="pd-ws-count">
                        <span class="pd-ws-num">@openWs</span>
                        <span class="pd-ws-label">worksheet aktif</span>
                    </div>
                }
                else
                {
                    <p class="pd-field-val pd-field-val--muted">Belum ada worksheet aktif.</p>
                }
            </div>
        </div>

        <div class="pd-card pd-card--plain">
            <div class="pd-card-head">
                <div class="pd-card-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                </div>
                <h3 class="pd-card-title">Aksi Cepat</h3>
            </div>
            <div class="pd-card-body pd-card-body--actions">
                <a href="/Psychologist/Schedule/PatientScheduleHistory?id=@Model.PatientId" class="pd-action-link pd-action-link--purple">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Riwayat Konseling
                </a>
                <a href="/Psychologist/Worksheet/PatientWorksheetHistory?id=@Model.PatientId" class="pd-action-link pd-action-link--blue">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Riwayat Worksheet
                </a>
            </div>
        </div>

    </div>

    <div class="pd-main">

        <div class="pd-card pd-card--plain pd-mood-card">
            <div class="pd-card-head">
                <div class="pd-card-icon pd-card-icon--mood">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <h3 class="pd-card-title">Mood Tracker</h3>
                <div class="pd-period-btns" id="moodPeriodBtns">
                    <button class="pd-period-btn active" data-days="7">7H</button>
                    <button class="pd-period-btn" data-days="30">30H</button>
                    <button class="pd-period-btn" data-days="90">90H</button>
                </div>
            </div>
            <div class="pd-card-body">
                <div class="pd-chart-wrap @(hasMoodData ? "" : "pd-is-hidden")" id="moodChartWrap">
                    <canvas id="moodChart"></canvas>
                </div>
                <div class="pd-mood-legend @(hasMoodData ? "" : "pd-is-hidden")" id="moodLegend">
                    <div class="pd-mood-leg-item pd-mood-leg--sehat">
                        <span class="pd-mood-leg-val" id="legSehat">@sehatPct%</span>
                        <span class="pd-mood-leg-lbl">Sehat</span>
                    </div>
                    <div class="pd-mood-leg-divider"></div>
                    <div class="pd-mood-leg-item pd-mood-leg--beresiko">
                        <span class="pd-mood-leg-val" id="legBeresiko">@beresikoPct%</span>
                        <span class="pd-mood-leg-lbl">Beresiko</span>
                    </div>
                    <div class="pd-mood-leg-divider"></div>
                    <div class="pd-mood-leg-item pd-mood-leg--bahaya">
                        <span class="pd-mood-leg-val" id="legBahaya">@bahayaPct%</span>
                        <span class="pd-mood-leg-lbl">Bahaya</span>
                    </div>
                </div>
                <div class="pd-empty-mood @(hasMoodData ? "pd-is-hidden" : "")" id="moodEmpty">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    <p>Belum ada data mood pada periode ini.</p>
                </div>
            </div>
        </div>

    </div>

</div>

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function () {
    const patientId  = @Model.PatientId;
    const initLabels = @Html.Raw(ViewBag.MoodLabels ?? "[]");
    const initScores = @Html.Raw(ViewBag.MoodScores ?? "[]");

    const MOOD_EMOJI = { 0: '', 1: '😢', 2: '😔', 3: '😐', 4: '😊', 5: '😄' };

    const ctx = document.getElementById('moodChart').getContext('2d');
    const moodChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: initLabels,
            datasets: [{
                data: initScores,
                borderColor: '#7C3AED',
                backgroundColor: 'rgba(124,58,237,0.08)',
                borderWidth: 2.5,
                pointBackgroundColor: '#7C3AED',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 5,
                fill: true,
                tension: 0.4,
                spanGaps: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(c) {
                            const v = c.parsed.y;
                            if (v == null) return 'Tidak ada data';
                            const emoji = MOOD_EMOJI[Math.round(v)] || '';
                            const label = v >= 4.5 ? 'Overjoyed' : v >= 3.5 ? 'Happy/Calm' :
                                          v >= 2.5 ? 'Neutral'   : v >= 1.5 ? 'Disappointed' : 'Angry';
                            return emoji + ' ' + label;
                        }
                    }
                }
            },
            scales: {
                y: {
                    min: 0, max: 5,
                    ticks: {
                        stepSize: 1,
                        callback: function(value) { return MOOD_EMOJI[value] !== undefined ? MOOD_EMOJI[value] : ''; },
                        font: { size: 16 }
                    },
                    grid: { color: '#F3F4F6' }
                },
                x: { grid: { display: false } }
            }
        }
    });

    document.querySelectorAll('.pd-period-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
            document.querySelectorAll('.pd-period-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            const wrap  = document.getElementById('moodChartWrap');
            const lgnd  = document.getElementById('moodLegend');
            const empty = document.getElementById('moodEmpty');
            wrap.classList.add('is-loading');
            try {
                const days = this.dataset.days;
                const res  = await fetch('/Psychologist/GetMoodData?patientId=' + patientId + '&days=' + days);
                const d    = await res.json();
                moodChart.data.labels           = d.labels;
                moodChart.data.datasets[0].data = d.scores;
                moodChart.update();
                if (d.hasData) {
                    wrap.classList.remove('pd-is-hidden');
                    lgnd.classList.remove('pd-is-hidden');
                    empty.classList.add('pd-is-hidden');
                    document.getElementById('legSehat').textContent    = d.sehatPct    + '%';
                    document.getElementById('legBeresiko').textContent = d.beresikoPct + '%';
                    document.getElementById('legBahaya').textContent   = d.bahayaPct   + '%';
                } else {
                    wrap.classList.add('pd-is-hidden');
                    lgnd.classList.add('pd-is-hidden');
                    empty.classList.remove('pd-is-hidden');
                }
            } catch(e) { console.error('Mood fetch failed', e); }
            finally { wrap.classList.remove('is-loading'); }
        });
    });
})();
</script>
}
