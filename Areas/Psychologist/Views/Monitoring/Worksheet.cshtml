@model List<LightenUp.Web.Models.Worksheet>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Worksheet Klien Klinik";
    ViewData["ActiveTab"] = "Mitra";
    ViewData["SemuaUrl"] = Url.Action("Worksheet", "Worksheet", new { area = "Psychologist" });
    ViewData["MitraUrl"] = Url.Action("Worksheet", "Monitoring", new { area = "Psychologist" });

    var countBelum   = (int)(ViewBag.CountBelum   ?? 0);
    var countReview  = (int)(ViewBag.CountReview  ?? 0);
    var countSelesai = (int)(ViewBag.CountSelesai ?? 0);
}

@section Head {
    <link rel="stylesheet" href="~/css/shared/components-worksheet-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/worksheet-worksheet-detail-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/worksheet-edit-worksheet-modal.css" asp-append-version="true" />
}

<div class="psy-dashboard-grid" style="grid-template-columns: 1fr; align-content: start;">
    <partial name="_MitraTabs" />

    @* ── Hero banner ── *@
    <div class="ws-hero">
        <div class="ws-hero-bg"></div>
        <div class="ws-hero-inner">
        <div class="ws-hero-left">
            <p class="ws-hero-eyebrow">Psikolog · Klien Klinik</p>
            <h1 class="ws-hero-title">Worksheet Klien Klinik</h1>
            <p class="ws-hero-sub">Kelola dan pantau aktivitas tugas harian klien klinik Anda</p>
            <button type="button" class="ws-hero-btn" onclick="openAddTaskModal()">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Tambah Tugas Baru
            </button>
        </div>
        <div class="ws-hero-stats">
            <div class="ws-stat-bubble">
                <span class="ws-stat-value">@Model.Count</span>
                <span class="ws-stat-label">Total Tugas</span>
            </div>
            <div class="ws-stat-bubble ws-stat-bubble--belum">
                <span class="ws-stat-value">@countBelum</span>
                <span class="ws-stat-label">Belum Dikerjakan</span>
            </div>
            <div class="ws-stat-bubble ws-stat-bubble--review">
                <span class="ws-stat-value">@countReview</span>
                <span class="ws-stat-label">Review</span>
            </div>
            <div class="ws-stat-bubble ws-stat-bubble--done">
                <span class="ws-stat-value">@countSelesai</span>
                <span class="ws-stat-label">Selesai</span>
            </div>
        </div>
        </div>
    </div>

    @* ── Toolbar ── *@
    <div class="ws-toolbar">
        <div class="ws-search-wrap">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="wsSearch" placeholder="Cari tugas atau nama klien..." class="ws-search-input" oninput="wsFilter()" />
        </div>
        <div class="ws-filter-tabs" id="wsFilterTabs">
            <button class="ws-filter-tab ws-filter-tab--active" data-filter="all"     onclick="wsSetFilter(this,'all')">Semua</button>
            <button class="ws-filter-tab ws-tab--belum"         data-filter="belum"   onclick="wsSetFilter(this,'belum')">Belum Dikerjakan</button>
            <button class="ws-filter-tab ws-tab--review"        data-filter="review"  onclick="wsSetFilter(this,'review')">Review</button>
            <button class="ws-filter-tab ws-tab--done"          data-filter="selesai" onclick="wsSetFilter(this,'selesai')">Selesai</button>
        </div>
        <button type="button" class="ws-add-btn" onclick="openAddTaskModal()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Tambah Tugas
        </button>
    </div>

    @* ── Task list ── *@
    @if (!Model.Any())
    {
        <div class="ws-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <p class="ws-empty-title">Belum ada tugas yang dibuat</p>
            <p class="ws-empty-sub">Buat tugas pertama untuk klien klinik Anda.</p>
            <button type="button" class="ws-empty-btn" onclick="openAddTaskModal()">Tambah Tugas Baru</button>
        </div>
    }
    else
    {
        <div class="ws-task-list" id="wsTaskList">
            <div class="ws-no-results" id="wsNoResults" style="display:none;">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <p>Tidak ada hasil yang cocok</p>
            </div>
            @foreach (var w in Model)
            {
                var statusClass = w.Status == "Completed" ? "selesai"
                    : w.Status == "InReview" ? "review" : "belum";
                var statusLabel = w.Status == "Completed" ? "Selesai"
                    : w.Status == "InReview" ? "Review"
                    : "Belum Dikerjakan";

                var patientName = w.Patient?.User?.FullName ?? "—";
                var initial = patientName.Length > 0 ? patientName.Substring(0,1).ToUpper() : "?";
                <div class="ws-task-card ws-task-data" data-status="@statusClass" data-name="@patientName.ToLower() @w.TaskName.ToLower()" data-task="@w.TaskName.ToLower()">
                    <div class="ws-task-avatar ws-avatar--@statusClass">@initial</div>
                    <div class="ws-task-info">
                        <span class="ws-task-patient">@patientName</span>
                        <span class="ws-task-name">@w.TaskName</span>
                        <div class="ws-task-meta">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            <span>Tenggat: @w.Deadline.ToString("d MMM yyyy")</span>
                        </div>
                    </div>
                    <div class="ws-task-right">
                        <span class="ws-status-badge ws-status--@statusClass">@statusLabel</span>
                        <button type="button" onclick="openWorksheetDetailModal(@w.WorksheetId)" class="ws-view-btn">
                            Lihat Tugas
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@await Html.PartialAsync("~/Areas/Psychologist/Views/Worksheet/_AddTaskModal.cshtml", ViewBag.AddTaskForm as LightenUp.Web.Models.ViewModels.PsyAddTaskViewModel ?? new LightenUp.Web.Models.ViewModels.PsyAddTaskViewModel())

<div class="modal-overlay" id="worksheetDetailModal"></div>

@section Scripts {
<script>
    window.openWorksheetDetailModal = async function(id) {
        try {
            const res = await fetch(`/Psychologist/Worksheet/WorksheetDetailModal/${id}`);
            if (!res.ok) throw new Error('Failed');
            const html = await res.text();
            document.getElementById('worksheetDetailModal').innerHTML = html;
            document.getElementById('worksheetDetailModal').classList.add('active');
        } catch (err) { alert("Gagal memuat detail worksheet."); }
    }
    window.openEditWorksheetModal = async function(id) {
        try {
            const res = await fetch(`/Psychologist/Worksheet/EditWorksheetModal/${id}`);
            if (!res.ok) throw new Error('Failed');
            const html = await res.text();
            document.getElementById('worksheetDetailModal').innerHTML = html;
        } catch (err) { alert("Gagal memuat form edit worksheet."); }
    }
    window.closeWorksheetDetailModal = function() {
        document.getElementById('worksheetDetailModal').classList.remove('active');
    }
    window.submitWorksheetDetailForm = function(e) {
        e.preventDefault();
        var form = document.getElementById('worksheetDetailForm') || e.target.closest('form');
        if (!form) return;
        var data = new FormData(form);
        if (e.submitter && e.submitter.name) data.append(e.submitter.name, e.submitter.value);
        fetch(form.action, { method: 'POST', body: data, headers: { 'X-Requested-With': 'fetch' } })
            .then(function(res) {
                if (res.redirected) { window.location.reload(); return; }
                var ct = res.headers.get('content-type') || '';
                if (ct.includes('application/json')) {
                    return res.json().then(function(json) {
                        if (json.reload) window.location.reload();
                    });
                }
                return res.text().then(function(html) {
                    document.getElementById('worksheetDetailModal').innerHTML = html;
                });
            })
            .catch(function() { alert('Gagal menyimpan.'); });
    }
    var wsActiveFilter = 'all';
    function wsFilter() {
        var q = document.getElementById('wsSearch').value.toLowerCase();
        var cards = document.querySelectorAll('.ws-task-data');
        var shown = 0;
        cards.forEach(function(c) {
            var nameMatch = (c.dataset.name || '').includes(q);
            var taskMatch = (c.dataset.task || '').includes(q);
            var statusMatch = wsActiveFilter === 'all' || c.dataset.status === wsActiveFilter;
            var visible = (nameMatch || taskMatch) && statusMatch;
            c.style.display = visible ? '' : 'none';
            if (visible) shown++;
        });
        var noRes = document.getElementById('wsNoResults');
        if (noRes) noRes.style.display = shown === 0 && cards.length > 0 ? 'flex' : 'none';
    }
    function wsSetFilter(btn, f) {
        wsActiveFilter = f;
        document.querySelectorAll('#wsFilterTabs .ws-filter-tab').forEach(b => b.classList.remove('ws-filter-tab--active'));
        btn.classList.add('ws-filter-tab--active');
        wsFilter();
    }
</script>
}
