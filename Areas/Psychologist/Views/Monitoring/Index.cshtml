@model List<LightenUp.Web.Models.Patient>

@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Monitoring Klien Klinik";
    ViewData["ActiveTab"] = "Mitra";
    ViewData["SemuaUrl"] = Url.Action("Index", "Client", new { area = "Psychologist" });
    ViewData["MitraUrl"] = Url.Action("Index", "Monitoring", new { area = "Psychologist" });
    var cid = new System.Globalization.CultureInfo("id-ID");
}

<div class="psy-dashboard-grid" style="grid-template-columns: 1fr; align-content: start;">
    <partial name="_MitraTabs" />

    <section class="psy-card psy-client-card">
        <header class="psy-card-head">
            <div class="psy-card-title-wrap">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <h2 class="psy-card-title">Klien Klinik</h2>
                <span class="psy-count-chip">@Model.Count</span>
            </div>
            <div class="psy-card-tools">
                <div class="psy-search-wrap">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" id="mitraSearch" placeholder="Cari klien..." class="psy-search" oninput="filterMitraSearch()" />
                </div>
            </div>
        </header>

        <div class="psy-client-list" id="mitraListView">
            @if (!Model.Any())
            {
                <div class="psy-empty">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    <p>Belum ada klien klinik</p>
                </div>
            }
            else
            {
                @foreach (var p in Model)
                {
                    var initials = string.IsNullOrWhiteSpace(p.User?.FullName) ? "?" : p.User.FullName.Substring(0, 1).ToUpper();
                    var statusKey = p.MentalHealthStatus?.ToLower() switch {
                        "bahaya"   => "bahaya",
                        "beresiko" => "beresiko",
                        _          => "sehat"
                    };
                    var genderLabel = p.Gender == "Male" ? "Laki-laki" : p.Gender == "Female" ? "Perempuan" : "—";
                    var assignment = p.Assignments.FirstOrDefault(a => a.Status == "Active");
                    var joinDate = assignment?.AssignedAt ?? DateTime.UtcNow;

                    <div class="psy-client-row client-mitra-searchable" data-name="@(p.User?.FullName?.ToLower())">
                        <div class="psy-client-avatar psy-avatar--@statusKey">@initials</div>
                        <div class="psy-client-info">
                            <span class="psy-client-name">@(p.User?.FullName ?? "—")</span>
                            <span class="psy-client-meta">@genderLabel &middot; Sejak @joinDate.ToString("d MMM yyyy", cid)</span>
                            <span class="psy-client-meta" style="display:block; margin-top:4px; color:#6B7280; font-size:12px;">Klien Klinik</span>
                        </div>
                        <span class="psy-status-chip psy-status--@statusKey">@(p.MentalHealthStatus ?? "Sehat")</span>
                        <a href="/Psychologist/Monitoring/Detail/@p.PatientId" class="psy-btn psy-btn--ghost psy-btn--sm">Detail &rarr;</a>
                    </div>
                }
            }
        </div>
    </section>
</div>

@section Scripts {
<script>
    function filterMitraSearch() {
        var q = document.getElementById("mitraSearch").value.toLowerCase();
        document.querySelectorAll(".client-mitra-searchable").forEach(function(row) {
            row.style.display = row.dataset.name && row.dataset.name.includes(q) ? "" : "none";
        });
    }
</script>
}
