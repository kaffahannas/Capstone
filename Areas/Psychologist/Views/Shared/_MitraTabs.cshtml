@using Microsoft.AspNetCore.Identity
@using LightenUp.Web.Data
@using LightenUp.Web.Models
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext

@{
    var user = await UserManager.GetUserAsync(User);
    bool isMitra = false;
    if (user != null)
    {
        var psy = DbContext.Psychologists.FirstOrDefault(p => p.UserId == user.Id);
        // Aktif jika flag menyala ATAU ada langganan Mitra yang masih berlaku
        isMitra = psy != null && (psy.IsMitraActive
            || DbContext.PsychologistSubscriptions.Any(s => s.PsychologistId == psy.PsychologistId
                && s.Status == "Active" && s.EndDate >= DateTime.Today));
    }

    var activeTab = ViewData["ActiveTab"]?.ToString() ?? "Semua";
    var semuaUrl = ViewData["SemuaUrl"]?.ToString() ?? "#";
    var mitraUrl = ViewData["MitraUrl"]?.ToString() ?? "#";
}

<div class="psy-tabs-container" style="margin-bottom: 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e5e7eb;">
    <div style="display: flex; gap: 24px;">
        <a href="@semuaUrl" class="psy-tab" style="padding: 12px 4px; text-decoration: none; position: relative; @(activeTab == "Semua" ? "color: #4f46e5; font-weight: 600;" : "color: #6b7280;")">
            Semua
            @if (activeTab == "Semua")
            {
                <div style="position: absolute; bottom: -1px; left: 0; right: 0; height: 2px; background: #4f46e5;"></div>
            }
        </a>

        @if (isMitra)
        {
            <a href="@mitraUrl" class="psy-tab" style="padding: 12px 4px; text-decoration: none; position: relative; @(activeTab == "Mitra" ? "color: #4f46e5; font-weight: 600;" : "color: #6b7280;")">
                Mitra
                @if (activeTab == "Mitra")
                {
                    <div style="position: absolute; bottom: -1px; left: 0; right: 0; height: 2px; background: #4f46e5;"></div>
                }
            </a>
        }
        else
        {
            <a href="/Psychologist/Mitra" class="psy-tab" style="padding: 6px 12px; margin-top: 6px; margin-bottom: 6px; color: #9ca3af; text-decoration: none; border: 1px dashed #d1d5db; border-radius: 6px; font-size: 0.9rem; display: flex; align-items: center; gap: 4px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Mitra
            </a>
        }
    </div>

    @if (isMitra && activeTab == "Mitra")
    {
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm" style="display: flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 6px; background: white; border: 1px solid #d1d5db; cursor: pointer;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            Cetak Laporan
        </button>
    }
</div>
