@using LightenUp.Web.Controllers
@model LightenUp.Web.Models.ViewModels.PsyScheduleEditViewModel
@{
    ViewData["Title"] = "Edit Jadwal";
    Layout = "_LayoutDashboard";
}

@section Head {
    <link rel="stylesheet" href="~/css/psychologist/schedule-edit-schedule.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/psychologist/schedule-edit-schedule-modal.css" asp-append-version="true" />
}

<a class="es-back" asp-action="Scheduling">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Kembali ke Daftar Jadwal
</a>

<div class="tasks-hero es-hero">
    <div class="es-hero-inner">
        <h1 class="es-hero-title">Edit Jadwal Konseling</h1>
        <p class="es-hero-sub">Pasien: <strong>@Model.PatientName</strong></p>
    </div>
    <svg class="es-hero-deco" viewBox="0 0 100 100" preserveAspectRatio="none"><polygon fill="currentColor" points="0,100 100,0 100,100"/></svg>
</div>

<div class="es-wrap">
    <form asp-action="EditSchedule" method="post">
        <div class="detail-card es-card">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ScheduleId" />
            <input type="hidden" asp-for="PatientName" />
            
            <div asp-validation-summary="ModelOnly" class="es-validation"></div>

            <div class="es-datetime-grid">
                <div class="form-group">
                    <label asp-for="SessionStart" class="form-label es-label">Waktu Mulai</label>
                    <input asp-for="SessionStart" type="datetime-local" class="form-control es-input" />
                    <span asp-validation-for="SessionStart" class="es-field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DurationMinutes" class="form-label es-label">Durasi (menit)</label>
                    <input asp-for="DurationMinutes" type="number" min="15" max="240" class="form-control es-input" />
                    <span asp-validation-for="DurationMinutes" class="es-field-error"></span>
                </div>
            </div>

            <div class="form-group es-field">
                <label asp-for="Status" class="form-label es-label">Status Sesi</label>
                <select asp-for="Status" class="form-control es-input es-input--select">
                    <option value="Scheduled">Akan Datang (Scheduled)</option>
                    <option value="Completed">Selesai (Completed)</option>
                    <option value="Cancelled">Dibatalkan (Cancelled)</option>
                </select>
            </div>

            <div class="form-group es-field">
                <label asp-for="MeetingLink" class="form-label es-label">Link Google Meet <small class="es-label-hint">(Opsional)</small></label>
                <input asp-for="MeetingLink" type="url" class="form-control es-input" placeholder="https://meet.google.com/..." />
                <span asp-validation-for="MeetingLink" class="es-field-error"></span>
            </div>

            <div class="form-group es-field">
                <label asp-for="Notes" class="form-label es-label">Catatan Tambahan <small class="es-label-hint">(Opsional)</small></label>
                <textarea asp-for="Notes" rows="4" class="es-input es-input--textarea" placeholder="Tambahkan catatan sesi..."></textarea>
                <span asp-validation-for="Notes" class="es-field-error"></span>
            </div>
        </div>

        <div class="es-actions">
            <a asp-action="Scheduling" class="es-btn-cancel">Batalkan</a>
            <button type="submit" class="es-btn-submit">Simpan Perubahan</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
