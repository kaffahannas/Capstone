@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Mitra LightenUp";
    var psy = ViewBag.Psy as LightenUp.Web.Models.Psychologist;
    var activeSub = ViewBag.ActiveSub as LightenUp.Web.Models.PsychologistSubscription;
    bool isMitraActive = ViewBag.IsMitraActive == true;
    int clientCount = ViewBag.ClientCount ?? 0;
    var idCulture = new System.Globalization.CultureInfo("id-ID");

    int daysLeft = 0;
    if (isMitraActive && activeSub != null)
        daysLeft = Math.Max(0, (activeSub.EndDate.Date - DateTime.Today).Days);
    bool expiringSoon = daysLeft > 0 && daysLeft <= 30;
    int quotaPct = activeSub != null && activeSub.PatientLimit > 0
        ? Math.Min(100, (int)Math.Round(clientCount * 100.0 / activeSub.PatientLimit))
        : 0;
}

@section Head {
    <link rel="stylesheet" href="~/css/psychologist/mitra-index.css" asp-append-version="true" />
}

<div class="psymi-page">

    @* ══ HERO ══ *@
    <div class="psymi-hero">
        <div class="psymi-hero-bg" aria-hidden="true"></div>
        <div class="psymi-hero-inner">
            <div class="psymi-hero-text">
                <p class="psymi-hero-eyebrow">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><circle cx="12" cy="12" r="2"/></svg>
                    Psikolog · Add-on Mitra
                </p>
                <h1 class="psymi-hero-title">Mitra LightenUp</h1>
                <p class="psymi-hero-sub">Kelola pasien klinik Anda dengan kode referal, monitoring, dan laporan terpadu.</p>
            </div>
            @if (isMitraActive)
            {
                <div class="psymi-hero-status @(expiringSoon ? "psymi-hero-status--warn" : "")">
                    <div class="psymi-hero-status-icon" aria-hidden="true">
                        @if (expiringSoon)
                        {
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        }
                        else
                        {
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        }
                    </div>
                    <div>
                        <div class="psymi-hero-status-plan">@(activeSub?.PlanName ?? "Mitra Aktif")</div>
                        <div class="psymi-hero-status-days">@daysLeft hari tersisa</div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* ══ ALERTS ══ *@
    @if (TempData["success"] is string ok)
    {
        <div class="psymi-alert psymi-alert--green">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            @ok
        </div>
    }
    @if (TempData["info"] is string info)
    {
        <div class="psymi-alert psymi-alert--blue">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @info
        </div>
    }

    @* ══ BODY ══ *@
    <div class="psymi-body">

        @if (isMitraActive)
        {
            @* ── Status aktif ── *@
            <div class="psymi-active-card @(expiringSoon ? "psymi-active-card--warn" : "")">
                <div class="psymi-active-icon" aria-hidden="true">
                    @if (expiringSoon)
                    {
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    }
                    else
                    {
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    }
                </div>
                <div class="psymi-active-info">
                    <div>
                        @if (expiringSoon)
                        {
                            <span class="psymi-active-status-badge psymi-active-status-badge--warn">Segera Habis</span>
                        }
                        else
                        {
                            <span class="psymi-active-status-badge">Mitra Aktif</span>
                        }
                    </div>
                    <div class="psymi-active-plan-name">@(activeSub?.PlanName ?? "Add-on Mitra")</div>
                    <div class="psymi-active-expiry">Berlaku hingga @activeSub?.EndDate.ToString("d MMMM yyyy", idCulture)</div>
                </div>
                <div class="psymi-active-days-ring @(expiringSoon ? "psymi-active-days-ring--warn" : "")">
                    <span class="psymi-active-days-num">@daysLeft</span>
                    <span class="psymi-active-days-lbl">hari</span>
                </div>
            </div>

            @if (activeSub != null && activeSub.PatientLimit > 0)
            {
                <div class="psymi-active-card psymi-active-card--quota">
                    <div class="psymi-active-info">
                        <div class="psymi-active-plan-name">Kuota Klien Klinik</div>
                        <div class="psymi-active-expiry">@clientCount / @activeSub.PatientLimit klien terdaftar</div>
                        <div class="psymi-quota-bar-track">
                            <div class="psymi-quota-bar-fill @(quotaPct >= 90 ? "psymi-quota-bar-fill--warn" : "")" style="--bar-w:@(quotaPct)%"></div>
                        </div>
                    </div>
                </div>
            }

            @* ── Kode Referal ── *@
            <div class="psymi-section">
                <div class="psymi-section-head">
                    <div class="psymi-section-icon psymi-section-icon--teal" aria-hidden="true">
                        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    </div>
                    <div>
                        <h2 class="psymi-section-title">Kode Referal Anda</h2>
                        <p class="psymi-section-sub">Bagikan kode ini ke pasien klinik Anda agar mereka terhubung ke akun Anda saat onboarding.</p>
                    </div>
                </div>
                <div class="psymi-ref-body">
                    @if (!string.IsNullOrEmpty(psy?.MitraReferralCode))
                    {
                        <div class="psymi-ref-card">
                            <span class="psymi-ref-code" id="mitraRefCode">@psy.MitraReferralCode</span>
                            <button type="button" class="psymi-ref-copy" id="copyRefBtn" data-code="@psy.MitraReferralCode" aria-label="Salin kode referal">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                Salin
                            </button>
                        </div>
                        <p class="psymi-ref-hint">Pasien klinik memasukkan kode ini saat onboarding atau melalui halaman profil mereka.</p>
                    }
                    else
                    {
                        <p class="psymi-ref-hint" style="margin-bottom:12px;">Belum ada kode referal. Generate sekarang untuk mulai menerima pasien klinik.</p>
                    }
                    <form method="post" asp-action="GenerateReferralCode">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="psymi-ref-generate-btn">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.34"/></svg>
                            @(string.IsNullOrEmpty(psy?.MitraReferralCode) ? "Generate Kode Referal" : "Generate Ulang Kode")
                        </button>
                    </form>
                </div>
                <div class="psymi-actions">
                    <a asp-area="Psychologist" asp-controller="Monitoring" asp-action="Index" class="psymi-action-btn psymi-action-btn--primary">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Monitoring Klien
                    </a>
                    <a asp-area="Psychologist" asp-controller="Monitoring" asp-action="Statistik" class="psymi-action-btn psymi-action-btn--outline">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        Statistik Klien
                    </a>
                    <a asp-area="Psychologist" asp-controller="Monitoring" asp-action="Worksheet" class="psymi-action-btn psymi-action-btn--outline">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        Worksheet
                    </a>
                    <a asp-area="Psychologist" asp-controller="Monitoring" asp-action="Jadwal" class="psymi-action-btn psymi-action-btn--outline">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Jadwal
                    </a>
                </div>
            </div>
        }
        else
        {
            @* ══ UPSELL: belum aktif — pricing cards ══ *@
            var plans = ViewBag.Plans as List<LightenUp.Web.Models.ViewModels.MitraPlanViewModel> ?? new List<LightenUp.Web.Models.ViewModels.MitraPlanViewModel>();
            var idC = new System.Globalization.CultureInfo("id-ID");
            <div class="psymi-plans-wrap">
                <div class="psymi-plans-header">
                    <h2 class="psymi-plans-title">Pilih Paket Mitra</h2>
                    <p class="psymi-plans-sub">Aktifkan add-on Mitra untuk kode referal, monitoring pasien klinik, dan laporan terpadu.</p>
                </div>

                <div class="psymi-plans-grid">
                    @foreach (var plan in plans.Where(p => p.PlanId != "mitra-test"))
                    {
                        var isPopular = plan.PlanId == "mitra-25";
                        <div class="psymi-plan @(isPopular ? "psymi-plan--popular" : "")">
                            @if (isPopular)
                            {
                                <div class="psymi-plan-popular-badge">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                    Paling Populer
                                </div>
                            }

                            <div class="psymi-plan-icon psymi-plan-icon--@(isPopular ? "yellow" : "teal")" aria-hidden="true">
                                @if (isPopular)
                                {
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                }
                                else
                                {
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                }
                            </div>

                            <h3 class="psymi-plan-name">@plan.Name</h3>

                            <div class="psymi-plan-pricing">
                                <span class="psymi-plan-currency">Rp</span>
                                <span class="psymi-plan-price">@plan.Price.ToString("N0", idC)</span>
                            </div>
                            <div class="psymi-plan-duration">per @plan.DurationMonths bulan</div>

                            @if (isPopular)
                            {
                                <div class="psymi-plan-save">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                    Rekomendasi terbaik
                                </div>
                            }

                            <p class="psymi-plan-desc">@plan.Description</p>

                            <ul class="psymi-plan-features">
                                <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Hingga @plan.PatientLimit pasien klinik</li>
                                <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Kode referal unik</li>
                                <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Dashboard monitoring klien</li>
                                <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Laporan yang bisa dicetak</li>
                                @if (isPopular)
                                {
                                    <li><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Prioritas dukungan</li>
                                }
                            </ul>

                            <form asp-action="Checkout" method="post" class="psymi-plan-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="planId" value="@plan.PlanId" />
                                <button type="submit" class="psymi-plan-btn @(isPopular ? "psymi-plan-btn--popular" : "")">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                    Bayar Sekarang
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
<script>
(function () {
    var btn = document.getElementById('copyRefBtn');
    if (!btn) return;
    var defaultHtml = btn.innerHTML;
    var doneHtml = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Tersalin!';
    btn.addEventListener('click', function () {
        var code = this.dataset.code;
        if (!code) return;
        navigator.clipboard.writeText(code).then(() => {
            btn.innerHTML = doneHtml;
            btn.classList.add('is-copied');
            setTimeout(function () {
                btn.innerHTML = defaultHtml;
                btn.classList.remove('is-copied');
            }, 2000);
        });
    });
})();
</script>
}
