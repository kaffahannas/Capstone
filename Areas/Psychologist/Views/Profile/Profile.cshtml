@model LightenUp.Web.Models.ViewModels.PsyProfileExtViewModel
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Profil Saya";
    var displayName = Model.FullName.Replace("Dr. ", "").Replace("dr. ", "").Trim();
    var initial     = displayName.Length > 0 ? displayName.Substring(0, 1).ToUpper() : "?";
    var location    = !string.IsNullOrEmpty(Model.OfficeAddress)    ? Model.OfficeAddress
                    : !string.IsNullOrEmpty(Model.PracticeLocation) ? Model.PracticeLocation
                    : null;
}

@if (TempData["success"] is string ok)
{
    <div class="lu-alert-success" role="status">@ok</div>
}

@section Head {
    <link rel="stylesheet" href="~/css/psychologist/profile-profile.css" asp-append-version="true" />
}


@* #Bagian ProfilPsikolog# *@
<div class="prf-page">

@* #Komponen HeroProfil# *@
<div class="prf-hero">
    <div class="prf-hero-inner">

        @* #Komponen Avatar# *@
        <div class="prf-hero-av-wrap">
            <div class="prf-hero-av-ring" aria-hidden="true"></div>
            @if (!string.IsNullOrEmpty(Model.ProfilePicture))
            {
                <img src="@Model.ProfilePicture" alt="Foto profil" class="prf-hero-av-img" />
            }
            else
            {
                <div class="prf-hero-av-fallback">@initial</div>
            }
            <button type="button" class="prf-av-edit-btn" onclick="openEditModal()" title="Edit foto">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </button>
        </div>

        @* #Komponen Identitas# *@
        <div class="prf-hero-id">
            <p class="prf-hero-eyebrow">Psikolog · LightenUp</p>
            <h1 class="prf-hero-name">Dr. @displayName</h1>
            @if (!string.IsNullOrEmpty(Model.Specialization))
            {
                <p class="prf-hero-spec">@Model.Specialization</p>
            }
            <span class="prf-hero-status @(Model.IsActive ? "prf-hero-status--active" : "prf-hero-status--inactive")">
                <span class="prf-hero-status-dot" aria-hidden="true"></span>
                @(Model.IsActive ? "Aktif" : "Tidak Aktif")
            </span>
            <div class="prf-hero-btns">
                <button type="button" class="prf-hero-btn prf-hero-btn--white" onclick="openEditModal()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit Profil
                </button>
                <a asp-area="" asp-controller="PsyRequests" asp-action="Index" class="prf-hero-btn prf-hero-btn--ghost">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    Permintaan
                </a>
            </div>
        </div>

        @* Right: stat bubbles *@
        <div class="prf-hero-stats">
            <div class="prf-hero-stat">
                <span class="prf-hero-stat-val">@Model.Employees</span>
                <span class="prf-hero-stat-lbl">Pasien</span>
            </div>
            <div class="prf-hero-stat prf-hero-stat--cases">
                <span class="prf-hero-stat-val">@Model.ActiveCases</span>
                <span class="prf-hero-stat-lbl">Kasus Aktif</span>
            </div>
            @if (Model.ExperienceYears.HasValue)
            {
                <div class="prf-hero-stat prf-hero-stat--exp">
                    <span class="prf-hero-stat-val">@Model.ExperienceYears</span>
                    <span class="prf-hero-stat-lbl">Thn Pengalaman</span>
                </div>
            }
        </div>

    </div>
</div>

<div class="prf-main-grid">
    @* #Komponen KolomProfesional# *@
    <div class="prf-col">
        
        @* Tentang Saya *@
        <div class="prf-card prf-card--blue prf-card--auto">
            <div class="prf-card-accent" aria-hidden="true"></div>
            <div class="prf-card-head">
                <div class="prf-card-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                </div>
                <h3 class="prf-card-title">Tentang Saya</h3>
            </div>
            <div class="prf-card-body prf-card-body--prose">
                @if (!string.IsNullOrWhiteSpace(Model.Bio))
                {
                    <p class="prf-bio-text">@Model.Bio</p>
                }
                else
                {
                    <div class="prf-bio-empty">
                        <p>Belum ada informasi tentang Anda.</p>
                        <button type="button" onclick="openEditModal()" class="prf-bio-add-btn">Tambahkan sekarang</button>
                    </div>
                }
            </div>
        </div>

        @* Pendidikan & Kualifikasi *@
        <div class="prf-card prf-card--purple">
            <div class="prf-card-accent" aria-hidden="true"></div>
            <div class="prf-card-head">
                <div class="prf-card-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                </div>
                <h3 class="prf-card-title">Pendidikan & Kualifikasi</h3>
            </div>
            <div class="prf-card-body">
                <div class="prf-field">
                    <span class="prf-field-label">Pendidikan Terakhir</span>
                    <span class="prf-field-val">
                        @(string.IsNullOrEmpty(Model.LastDegree) && string.IsNullOrEmpty(Model.University) ? "Belum diatur" : $"{Model.LastDegree}{(string.IsNullOrEmpty(Model.University) ? "" : " · " + Model.University)}")
                    </span>
                </div>
                <div class="prf-field">
                    <span class="prf-field-label">Spesialisasi</span>
                    @if (!string.IsNullOrEmpty(Model.Specialization))
                    {
                        <span class="prf-spec-chip">@Model.Specialization</span>
                    }
                    else
                    {
                        <span class="prf-field-val prf-field-val--muted">Belum diatur</span>
                    }
                </div>
                <div class="prf-field">
                    <span class="prf-field-label">No. SIPP</span>
                    <span class="prf-field-val prf-field-val--license">@(Model.SippNumber ?? "Belum diatur")</span>
                </div>
                <div class="prf-field">
                    <span class="prf-field-label">Pengalaman Praktik</span>
                    <span class="prf-field-val">@(Model.ExperienceYears.HasValue ? $"{Model.ExperienceYears} tahun" : "Belum diatur")</span>
                </div>
            </div>
        </div>
    </div>

    @* #Komponen KolomKontak# *@
    <div class="prf-col">
        
        @* Kontak & Praktik *@
        <div class="prf-card prf-card--sky">
            <div class="prf-card-accent" aria-hidden="true"></div>
            <div class="prf-card-head">
                <div class="prf-card-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <h3 class="prf-card-title">Kontak & Praktik</h3>
            </div>
            <div class="prf-card-body">
                <div class="prf-field">
                    <span class="prf-field-label">Email</span>
                    <span class="prf-field-val">@Model.Email</span>
                </div>
                <div class="prf-field">
                    <span class="prf-field-label">Telepon</span>
                    <span class="prf-field-val @(string.IsNullOrEmpty(Model.Phone) ? "prf-field-val--muted" : "")">
                        @(string.IsNullOrEmpty(Model.Phone) ? "Belum diatur" : Model.Phone)
                    </span>
                </div>
                <div class="prf-field">
                    <span class="prf-field-label">Lokasi Praktik</span>
                    <span class="prf-field-val @(location == null ? "prf-field-val--muted" : "")">
                        @(location ?? "Belum diatur")
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(Model.OfficeAddress))
                {
                    <div class="prf-field">
                        <span class="prf-field-label">Alamat Kantor</span>
                        <span class="prf-field-val prf-address">@Model.OfficeAddress</span>
                    </div>
                }
            </div>
        </div>

        @* Pengaturan Kerjasama B2B *@
        <form method="post" asp-action="Settings" class="prf-card prf-card--green prf-card--auto">
            @Html.AntiForgeryToken()
            <div class="prf-card-accent" aria-hidden="true"></div>
            <div class="prf-card-head">
                <div class="prf-card-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
                </div>
                <h3 class="prf-card-title">Terima Kerjasama B2B</h3>
            </div>
            <div class="prf-card-body">
                <p class="prf-card-desc">Saat aktif, profil Anda dapat ditemukan HR perusahaan di Direktori Psikolog.</p>
                <div class="prf-field prf-field--b2b-toggle">
                    <span class="prf-field-label prf-field-label--plain">Status Kerjasama</span>
                    <label class="prf-toggle prf-toggle--inline" title="@(Model.AcceptsB2B ? "Aktif — klik untuk nonaktifkan" : "Tidak aktif — klik untuk aktifkan")">
                        <input type="checkbox" name="AcceptsB2B" id="b2bToggle" value="true" @(Model.AcceptsB2B ? "checked" : "") onchange="this.form.submit()" />
                        <span class="prf-toggle-track"><span class="prf-toggle-thumb"></span></span>
                        <span class="prf-toggle-label" id="b2bLabel">@(Model.AcceptsB2B ? "Aktif" : "Nonaktif")</span>
                    </label>
                </div>
            </div>
        </form>

        @* Pengaturan Keamanan *@
        <div class="prf-card prf-card--auto" style="border: 1px solid #e2e8f0; background: #f8fafc; cursor: pointer; transition: all 0.2s; text-decoration: none;" onclick="window.location.href='/Account/ChangePassword'">
            <div class="prf-card-accent" aria-hidden="true" style="background: #94a3b8;"></div>
            <div class="prf-card-head" style="margin-bottom: 0;">
                <div class="prf-card-icon" style="background: #e2e8f0; color: #475569;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                </div>
                <div>
                    <h3 class="prf-card-title" style="margin-bottom: 4px; color: #1e293b;">Pengaturan Keamanan</h3>
                    <p style="margin: 0; font-size: 13px; color: #64748b;">Atur atau ubah password akun Anda</p>
                </div>
            </div>
        </div>
        
    </div>
</div>

</div>@* /prf-page *@

@* #Bagian ModalEditProfil# *@
<div class="prf-modal-overlay" id="prfModalOverlay" role="dialog" aria-modal="true" aria-labelledby="prfModalTitle">
    <form method="post" asp-action="EditProfile" enctype="multipart/form-data" autocomplete="off" class="prf-modal prf-edit-form">
        <div class="prf-modal-header">
            <h2 id="prfModalTitle">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="prf-modal-title-icon" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit Profil
            </h2>
            <button type="button" class="prf-modal-close" onclick="closeEditModal()" aria-label="Tutup">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        @Html.AntiForgeryToken()
        <div class="prf-modal-body">

                @* ─ Identitas ─ *@
                <div class="prf-form-section-label">Identitas</div>
                <div class="prf-form-row">
                    <div class="prf-form-group">
                        <label>Nama Lengkap *</label>
                        <input type="text" name="FullName" value="@Model.FullName" placeholder="Nama lengkap" required />
                    </div>
                    <div class="prf-form-group">
                        <label>No. Telepon</label>
                        <input type="tel" name="Phone" value="@Model.Phone" placeholder="+62 8xx-xxxx-xxxx" />
                    </div>
                </div>

                @* ─ Tentang Saya ─ *@
                <div class="prf-form-section-label">Tentang Saya</div>
                <div class="prf-form-group">
                    <label>Deskripsi Profil</label>
                    <textarea name="Bio" rows="4" placeholder="Ceritakan singkat tentang pendekatan terapi, keahlian, dan nilai profesional Anda..." class="prf-bio-textarea">@Model.Bio</textarea>
                </div>

                @* ─ Profesional ─ *@
                <div class="prf-form-section-label">Profesional</div>
                <div class="prf-form-row">
                    <div class="prf-form-group">
                        <label>Spesialisasi</label>
                        <input type="text" name="Specialization" value="@Model.Specialization" placeholder="cth. Klinis, Industri" />
                    </div>
                    <div class="prf-form-group">
                        <label>No. SIPP</label>
                        <input type="text" name="SippNumber" value="@Model.SippNumber" placeholder="cth. SIPP-12345" />
                    </div>
                </div>
                <div class="prf-form-row">
                    <div class="prf-form-group">
                        <label>Gelar / Pendidikan Terakhir</label>
                        <input type="text" name="LastDegree" value="@Model.LastDegree" placeholder="cth. M.Psi., S.Psi." />
                    </div>
                    <div class="prf-form-group">
                        <label>Universitas</label>
                        <input type="text" name="University" value="@Model.University" placeholder="cth. Universitas Indonesia" />
                    </div>
                </div>
                <div class="prf-form-row">
                    <div class="prf-form-group">
                        <label>Tahun Pengalaman</label>
                        <input type="number" name="ExperienceYears" value="@Model.ExperienceYears" placeholder="cth. 5" min="0" max="60" />
                    </div>
                    <div class="prf-form-group">
                        <label>Lokasi Praktik</label>
                        <input type="text" name="PracticeLocation" value="@Model.PracticeLocation" placeholder="cth. Jakarta Selatan" />
                    </div>
                </div>

                @* ─ Lainnya ─ *@
                <div class="prf-form-section-label">Lainnya</div>
                <div class="prf-form-group">
                    <label>Alamat Kantor</label>
                    <input type="text" name="OfficeAddress" value="@Model.OfficeAddress" placeholder="Alamat lengkap kantor / klinik" />
                </div>

                @* ─ Dokumen Rekening (Payroll) ─ *@
                <div class="prf-form-section-label">Dokumen Rekening (Payroll)</div>
                <div class="prf-form-group">
                    <label>Upload Bukti Rekening Bank (Buku Tabungan / M-Banking)</label>
                    <input type="file" name="BankDocumentFile" accept=".pdf,image/*" class="prf-file-input" />
                    @if (!string.IsNullOrEmpty(Model.BankDetailsPdfPath))
                    {
                        <div class="prf-bank-ok">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            Dokumen rekening sudah diunggah <a href="@Model.BankDetailsPdfPath" target="_blank" class="prf-bank-link">Lihat Dokumen</a>
                        </div>
                    }
                    else
                    {
                        <div class="prf-bank-missing">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            Anda belum mengunggah dokumen rekening. Gaji tidak dapat ditransfer.
                        </div>
                    }
                </div>

                @* ─ Photo upload drop zone (compact horizontal) ─ *@
                <div class="prf-form-group">
                    <label>Foto Profil</label>
                    <div class="prf-dropzone" id="prfDropzone">
                        @* Left: avatar preview *@
                        <div class="prf-dz-av">
                            @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                            {
                                <img src="@Model.ProfilePicture" id="prfPreviewImg" class="prf-dz-av-img" alt="Foto profil" />
                            }
                            else
                            {
                                <img src="" id="prfPreviewImg" class="prf-dz-av-img prf-preview-hidden" alt="" />
                                <svg id="prfDzIcon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                            }
                        </div>
                        @* Middle: text *@
                        <div class="prf-dz-text">
                            <span id="prfDropzoneHint" class="prf-dz-title">
                                @(string.IsNullOrEmpty(Model.ProfilePicture) ? "Belum ada foto" : "Foto profil saat ini")
                            </span>
                            <small class="prf-dz-sub" id="prfDropzoneSub">JPG, PNG, atau WEBP · maks. 5 MB</small>
                        </div>
                        @* Right: pick button *@
                        <button type="button" class="prf-dz-btn" onclick="document.getElementById('prfFileInput').click()">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                            Pilih Foto
                        </button>
                        <input type="file" name="ProfilePictureFile" id="prfFileInput"
                               accept=".jpg,.jpeg,.png,.webp" class="prf-preview-hidden"
                               onchange="prfHandleFile(this.files[0])" />
                    </div>
                </div>

            </div>
            <div class="prf-modal-footer">
                <button type="button" class="prf-modal-btn prf-modal-btn--cancel" onclick="closeEditModal()">Batal</button>
                <button type="submit" class="prf-modal-btn prf-modal-btn--save">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="prf-save-icon" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    Simpan Perubahan
                </button>
            </div>
    </form>
</div>

@section Scripts {
<script>
/* ── Modal open/close ── */
function openEditModal() {
    var overlay = document.getElementById('prfModalOverlay');
    overlay.classList.add('prf-modal--open');
    document.body.classList.add('lu-scroll-lock');
    var first = overlay.querySelector('input:not([type=file])');
    if (first) setTimeout(function() { first.focus(); }, 60);
}
function closeEditModal() {
    document.getElementById('prfModalOverlay').classList.remove('prf-modal--open');
    document.body.classList.remove('lu-scroll-lock');
}
document.getElementById('prfModalOverlay').addEventListener('click', function(e) {
    if (e.target === this) closeEditModal();
});
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeEditModal();
});

/* ── Photo drop zone ── */
function prfHandleFile(file) {
    if (!file) return;
    var allowed = ['image/jpeg','image/png','image/webp'];
    if (!allowed.includes(file.type)) {
        alert('Format tidak didukung. Gunakan JPG, PNG, atau WEBP.');
        return;
    }
    if (file.size > 5 * 1024 * 1024) {
        alert('Ukuran file terlalu besar. Maksimal 5 MB.');
        return;
    }
    var reader = new FileReader();
    reader.onload = function(e) {
        var img    = document.getElementById('prfPreviewImg');
        var title  = document.getElementById('prfDropzoneHint');
        var sub    = document.getElementById('prfDropzoneSub');
        var icon   = document.getElementById('prfDzIcon');
        img.src = e.target.result;
        img.classList.remove('prf-preview-hidden');
        if (icon) icon.classList.add('is-hidden');
        if (title) title.textContent = file.name;
        if (sub)   sub.textContent   = (file.size / 1024).toFixed(0) + ' KB · Siap diunggah';
        document.getElementById('prfDropzone').classList.add('prf-dropzone--has-file');
    };
    reader.readAsDataURL(file);
}

// Drag & drop events
(function() {
    var dz = document.getElementById('prfDropzone');
    if (!dz) return;
    dz.addEventListener('dragover', function(e) {
        e.preventDefault();
        dz.classList.add('prf-dropzone--drag');
    });
    dz.addEventListener('dragleave', function(e) {
        if (!dz.contains(e.relatedTarget)) dz.classList.remove('prf-dropzone--drag');
    });
    dz.addEventListener('drop', function(e) {
        e.preventDefault();
        dz.classList.remove('prf-dropzone--drag');
        var file = e.dataTransfer.files[0];
        if (file) {
            // Assign to the real input so the form submits it
            var dt = new DataTransfer();
            dt.items.add(file);
            document.getElementById('prfFileInput').files = dt.files;
            prfHandleFile(file);
        }
    });
})();

/* ── B2B toggle: auto-submit on change ── */
(function() {
    var cb  = document.getElementById('b2bToggle');
    var lbl = document.getElementById('b2bLabel');
    if (!cb || !lbl) return;
    cb.addEventListener('change', function() {
        lbl.textContent = 'Menyimpan…';
        // Do NOT disable cb — disabled inputs are excluded from POST data
        cb.closest('form').submit();
    });
})();
</script>
}
