@using LightenUp.Web.Models.ViewModels
@{
    var progress = ViewBag.Progress as OnboardingProgress;
    var pageTitle = ViewData["Title"] as string ?? "Data Pribadi";
    var hideChrome = ViewBag.HideChrome as bool? ?? false;  // Welcome screen sets this
}
@* #Bagian Layout Onboarding Pasien# *@
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-typography.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-form.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-actions.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-upload.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/onboarding/components-onboarding-responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/onboarding-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/onboarding-welcome.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/onboarding-terms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/onboarding-medication.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/onboarding-counseling.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <div class="onb-wrapper">
        @if (!hideChrome)
        {
            @* #Komponen Topbar Onboarding# *@
            <div class="onb-topbar">
                <span>Data Pribadi</span>
                <a class="close-btn" asp-controller="Account" asp-action="Login" asp-area="" title="Keluar">&times;</a>
            </div>

            @if (progress != null)
            {
                <div class="onb-progress-label">Pertanyaan @progress.Current dari @progress.Total</div>
                <div class="onb-progress">
                    <div class="onb-progress-bar" style="--bar-w: @(progress.Percent)%;"></div>
                </div>
            }
        }

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
