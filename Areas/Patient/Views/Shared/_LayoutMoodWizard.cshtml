@{
    var step = ViewBag.Step as string ?? "";
    int current = 0, total = 6; // check-in always has 6 questions
    if (!string.IsNullOrEmpty(step) && step.Contains('/'))
    {
        var parts = step.Split('/');
        int.TryParse(parts[0], out current);
        int.TryParse(parts[1], out total);
    }
    var pct = (total > 0 && current > 0) ? (int)((double)current / total * 100) : 0;
    bool isCheckIn = ViewBag.IsCheckIn == true;
    var wizardTitle = isCheckIn ? "Daily Check-In" : "Mood Tracker";
    var wizardEmoji = isCheckIn ? "📔" : "😊";
}
@* #Bagian Layout Wizard Mood# *@
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/patient/components-patient-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/mood-wizard-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/mood-feeling.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/mood-note.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/mood-question.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/mood-summary.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/mood-triggers.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/journal-checkin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/journal-checkin-saved.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/journal-question.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="mood-wizard-body">

    @* #Komponen Header Wizard# *@
    <div class="mood-wizard-header">
        <strong class="mood-wizard-title">
            <span aria-hidden="true">@wizardEmoji</span> @wizardTitle
        </strong>
        <a asp-area="Patient" asp-controller="Dashboard" asp-action="Index"
           class="mood-wizard-close" aria-label="Tutup">×</a>
    </div>

    @* #Komponen Progress Wizard# *@
    @if (current > 0 && total > 0)
    {
        <div class="mood-wizard-progress">
            <div class="mood-wizard-progress-meta">
                <span class="mood-wizard-progress-step">
                    Langkah @current dari @total
                </span>
                <span class="mood-wizard-progress-pct">@pct%</span>
            </div>
            <div class="mood-wizard-progress-track">
                <div class="mood-wizard-progress-fill" style="--bar-w:@pct%;"></div>
            </div>
        </div>
    }

    @* #Komponen Konten Wizard# *@
    <div class="mood-shell">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        if (window.self !== window.top) {
            document.documentElement.classList.add('is-popup');
            document.body.classList.add('is-popup');
        }

        function notifyMoodWizardHeight() {
            if (window.self === window.top) return;
            var root = document.querySelector('.mood-wizard-body');
            if (!root) return;
            var height = Math.ceil(root.scrollHeight);
            window.parent.postMessage({ type: 'moodWizardResize', height: height }, window.location.origin);
        }

        window.addEventListener('load', notifyMoodWizardHeight);
        window.addEventListener('resize', notifyMoodWizardHeight);
        if (window.ResizeObserver) {
            new ResizeObserver(notifyMoodWizardHeight).observe(document.body);
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
