@using Microsoft.AspNetCore.Identity
@using LightenUp.Web.Models
@inject UserManager<ApplicationUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName ?? "Sahabat";
    var active = ViewBag.ActiveNav as string ?? "Beranda";
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LightenUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/components-patient-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/components-patient-ui.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/components-patient-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/components-patient-modal.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="patient-body">
    <div class="app-shell" id="appShell">
        <div class="sidebar-backdrop" id="sidebarBackdrop" aria-hidden="true"></div>

        <aside class="app-sidebar" id="appSidebar" aria-label="Navigasi utama">
            <div class="sidebar-header">
                <a class="brand" asp-controller="Dashboard" asp-action="Index">
                    <img src="~/image/lightenuplogo.ico" alt="LightenUp" class="brand-logo" onerror="this.classList.add('is-hidden')" />
                    <span class="brand-name">LightenUp</span>
                </a>
                <button type="button" class="sidebar-close" id="sidebarClose" aria-label="Tutup menu">&times;</button>
            </div>

            <nav class="side-nav">
                <a class="side-nav-item @(active == "Beranda" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    <span>Beranda</span>
                </a>
                <a class="side-nav-item @(active == "Statistik" ? "active" : "")"
                   asp-controller="Statistik" asp-action="Index">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    <span>Statistik</span>
                </a>
                <a class="side-nav-item @(active == "Jadwal" ? "active" : "")"
                   asp-controller="Jadwal" asp-action="Index">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span>Jadwal Konseling</span>
                </a>
                <a class="side-nav-item @(active == "Tugas" ? "active" : "")"
                   asp-controller="Tasks" asp-action="Index">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    <span>Tugas</span>
                </a>
                <a class="side-nav-item @(active == "Langganan" ? "active" : "")"
                   asp-controller="Subscription" asp-action="Index">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                    <span>Langganan</span>
                </a>
                <a class="side-nav-item @(active == "Psikolog" ? "active" : "")"
                   asp-controller="Psychologists" asp-action="Index">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <span>Pilih Psikolog</span>
                </a>
                <a class="side-nav-item @(active == "Profil" ? "active" : "")"
                   asp-controller="Profile" asp-action="Index">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <span>Profil</span>
                </a>
            </nav>

            <form asp-controller="Account" asp-action="Logout" asp-area="" method="post" class="side-nav-logout">
                <button type="submit" class="logout-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    <span>Keluar</span>
                </button>
            </form>
        </aside>

        <div class="app-main">
            <header class="app-topbar">
                <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Buka menu navigasi" aria-expanded="false" aria-controls="appSidebar">
                    <span class="hamburger" aria-hidden="true"></span>
                </button>
                <h2 class="greeting">Hai, @fullName</h2>
            </header>

            <div class="app-content lu-scroll-host">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
