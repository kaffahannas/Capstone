@model LightenUp.Web.Models.ViewModels.OnboardingReferralViewModel
@{
    ViewData["Title"] = "Kode Referral";
}
@* #Bagian Onboarding - Kode Referral# *@

@* #Komponen Form Kode Referral# *@
<div class="onb-step">
<h1 class="onb-title">Punya kode referral?</h1>
<p class="onb-subtitle">Opsional. Bisa kamu isi nanti dari halaman profil.</p>

<form asp-action="ReferralCode" method="post" class="onb-content">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="ReferralCode" class="onb-input" placeholder="Masukkan kode referral (opsional)" />
    <span asp-validation-for="ReferralCode" class="text-danger"></span>

    <div class="onb-info">
        Kode referral bisa berasal dari dua sumber:<br />
        <strong>Perusahaan (B2B)</strong> — karyawan yang terdaftar di perusahaan mitra dapat memakai kode divisi HR selama langganan perusahaan masih aktif.<br />
        <strong>Psikolog Mitra</strong> — pasien klinik dapat memakai kode referal dari psikolog Anda agar terhubung langsung ke dashboard monitoring psikolog tersebut.
    </div>

    <div class="onb-footer">
        <a asp-action="AppGoals" class="onb-btn onb-btn-secondary">Sebelumnya</a>
        <button type="submit" class="onb-btn onb-btn-primary">Berikutnya</button>
    </div>
</form>
</div>
