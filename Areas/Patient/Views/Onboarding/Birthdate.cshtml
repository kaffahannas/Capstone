@model LightenUp.Web.Models.ViewModels.OnboardingBirthdateViewModel
@{
    ViewData["Title"] = "Tanggal Lahir";
    var months = new[] { "Januari","Februari","Maret","April","Mei","Juni","Juli","Agustus","September","Oktober","November","Desember" };
    var currentYear = DateTime.Now.Year;
}

<h1 class="onb-title">Tanggal Lahir</h1>

<form asp-action="Birthdate" method="post" class="onb-content">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="onb-date-grid">
        <select asp-for="Day" class="onb-select">
            <option value="">Tanggal</option>
            @for (int d = 1; d <= 31; d++)
            {
                <option value="@d">@d</option>
            }
        </select>
        <select asp-for="Month" class="onb-select">
            <option value="">Bulan</option>
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m">@months[m - 1]</option>
            }
        </select>
        <select asp-for="Year" class="onb-select">
            <option value="">Tahun</option>
            @for (int y = currentYear - 13; y >= currentYear - 100; y--)
            {
                <option value="@y">@y</option>
            }
        </select>
    </div>
    <span asp-validation-for="Day" class="text-danger"></span>
    <span asp-validation-for="Month" class="text-danger"></span>
    <span asp-validation-for="Year" class="text-danger"></span>

    <div class="onb-info">
        Informasi usia hanya akan digunakan untuk kebutuhan konseling.
    </div>

    <div class="onb-footer">
        <a asp-action="Gender" class="onb-btn onb-btn-secondary">Sebelumnya</a>
        <button type="submit" class="onb-btn onb-btn-primary">Berikutnya</button>
    </div>
</form>
