@model LightenUp.Web.Models.ViewModels.MoodTrackerSessionViewModel
@{
    ViewData["Title"] = "Catatan";
    ViewBag.Step = "3/8";
    var triggerCsv = string.Join(",", Model.Triggers);
}
@* #Bagian Lacak Mood - Catatan# *@

@* #Komponen Form Catatan Mood# *@
<h2 class="mood-question">
    <a asp-action="Triggers" asp-route-feeling="@Model.Feeling" asp-route-triggers="@triggerCsv" asp-route-note="@Model.Note"
       class="mood-back-link">←</a>
    Ada yang ingin kamu tambahkan?
</h2>
<p class="mood-helper">Opsional &mdash; tulis singkat apa yang ada di pikiranmu hari ini.</p>

<form asp-action="Note" method="post">
    <input type="hidden" asp-for="Feeling" />
    @foreach (var t in Model.Triggers)
    {
        <input type="hidden" name="Triggers" value="@t" />
    }

    <textarea asp-for="Note" class="mood-textarea" placeholder="Ceritakan disini..."></textarea>
    <span asp-validation-for="Note" class="text-danger"></span>

    <div class="mood-footer">
        <button type="submit" class="btn-primary">Berikutnya</button>
    </div>
</form>
