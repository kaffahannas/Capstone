@model LightenUp.Web.Models.ViewModels.MoodTrackerSessionViewModel
@using LightenUp.Web.Models.ViewModels
@{
    var q = MoodQuestions.For(Model.QuestionStep);
    var overallStep = 3 + Model.QuestionStep;
    ViewBag.Step = $"{overallStep}/8";
    ViewData["Title"] = $"Kuesioner {Model.QuestionStep}";
    var currentScore = Model.CurrentQuestionScore();
}

<h2 class="mood-question mq-title">@q.Question</h2>
<p class="mood-helper mq-helper">@q.Hint</p>

<form asp-action="Question" method="post">
    <input type="hidden" asp-for="Feeling" />
    <input type="hidden" name="triggers" value="@string.Join(",", Model.Triggers)" />
    <input type="hidden" asp-for="Note" />
    <input type="hidden" asp-for="QuestionStep" />
    <input type="hidden" asp-for="FocusScore" />
    <input type="hidden" asp-for="AnxietyScore" />
    <input type="hidden" asp-for="SleepScore" />
    <input type="hidden" asp-for="MindLoadScore" />
    <input type="hidden" asp-for="EmotionScore" />

    <span asp-validation-summary="ModelOnly" class="text-danger mq-validation"></span>

    <div class="mq-scale-labels">
        <span>😞 Sangat Buruk</span>
        <span>😁 Sangat Baik</span>
    </div>

    <div class="mq-scale-row" id="scaleRow">
        @for (int n = 1; n <= 5; n++)
        {
            var isSelected = currentScore == n;
            var emoji = n switch { 1 => "😞", 2 => "🙁", 3 => "😐", 4 => "🙂", _ => "😁" };
            <button type="button"
                    class="mq-btn @(isSelected ? "mq-btn--selected" : "")"
                    data-value="@n">
                <span class="mq-emoji">@emoji</span>
                <span class="mq-num">@n</span>
            </button>
        }
    </div>

    <div class="mood-footer">
        @if (Model.QuestionStep > 1)
        {
            <a asp-action="Question"
               asp-route-feeling="@Model.Feeling"
               asp-route-triggers="@string.Join(",", Model.Triggers)"
               asp-route-note="@Model.Note"
               asp-route-questionStep="@(Model.QuestionStep - 1)"
               asp-route-focusScore="@Model.FocusScore"
               asp-route-anxietyScore="@Model.AnxietyScore"
               asp-route-sleepScore="@Model.SleepScore"
               asp-route-mindLoadScore="@Model.MindLoadScore"
               asp-route-emotionScore="@Model.EmotionScore"
               class="btn-secondary">← Sebelumnya</a>
        }
        else
        {
            <a asp-action="Note"
               asp-route-feeling="@Model.Feeling"
               asp-route-triggers="@string.Join(",", Model.Triggers)"
               asp-route-note="@Model.Note"
               class="btn-secondary">← Catatan</a>
        }
        <button type="submit" class="btn-primary" id="submitBtn">
            @(Model.QuestionStep < 5 ? "Berikutnya →" : "Lihat Ringkasan →")
        </button>
    </div>
</form>

@section Scripts {
    <script>
        const fieldByStep = {
            1: "FocusScore", 2: "AnxietyScore", 3: "SleepScore",
            4: "MindLoadScore", 5: "EmotionScore"
        };
        const step = @Model.QuestionStep;
        const fieldName = fieldByStep[step];

        document.querySelectorAll('.mq-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.mq-btn').forEach(b => b.classList.remove('mq-btn--selected'));
                btn.classList.add('mq-btn--selected');
                document.querySelector('input[name="' + fieldName + '"]').value = btn.dataset.value;
            });
        });
    </script>
}
