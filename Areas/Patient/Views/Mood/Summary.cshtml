@model LightenUp.Web.Models.ViewModels.MoodTrackerSessionViewModel
@using LightenUp.Web.Models.ViewModels
@{
    ViewData["Title"] = "Simpan Mood";
    ViewBag.Step = "4/4";
    var triggerCsv = string.Join(",", Model.Triggers);
    var feelingClass = Model.Feeling.ToLowerInvariant();
    var indoToday = DateTime.Today.ToString("dddd, d MMMM yyyy", new System.Globalization.CultureInfo("id-ID"));
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
    <a asp-action="Question"
       asp-route-feeling="@Model.Feeling"
       asp-route-triggers="@triggerCsv"
       asp-route-note="@Model.Note"
       asp-route-questionStep="5"
       asp-route-focusScore="@Model.FocusScore"
       asp-route-anxietyScore="@Model.AnxietyScore"
       asp-route-sleepScore="@Model.SleepScore"
       asp-route-mindLoadScore="@Model.MindLoadScore"
       asp-route-emotionScore="@Model.EmotionScore"
       style="text-decoration:none; color:#111;">← Sebelumnya</a>
    <span style="font-size:13px; color:#6B7280;">@indoToday</span>
</div>

<h2 class="mood-question" style="text-align:center;">Hari ini kamu merasa</h2>

<div class="mood-summary @feelingClass">
    <span class="big-emoji">@MoodPalette.Emoji(Model.Feeling)</span>
    <div class="feeling-label">@MoodPalette.Label(Model.Feeling)</div>
    @if (Model.Triggers.Any())
    {
        <div class="triggers-label">
            Kegiatan/Aktivitas:
            @string.Join(", ", Model.Triggers.Select(t => MoodOptions.TriggerLabel(t)))
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Note))
    {
        <div style="margin-top:12px; font-size:13px; max-width:320px; margin-left:auto; margin-right:auto;">
            <em>"@Model.Note"</em>
        </div>
    }
</div>

<form asp-action="Summary" method="post">
    <input type="hidden" asp-for="Feeling" />
    @foreach (var t in Model.Triggers)
    {
        <input type="hidden" name="Triggers" value="@t" />
    }
    <input type="hidden" asp-for="Note" />
    <input type="hidden" asp-for="FocusScore" />
    <input type="hidden" asp-for="AnxietyScore" />
    <input type="hidden" asp-for="SleepScore" />
    <input type="hidden" asp-for="MindLoadScore" />
    <input type="hidden" asp-for="EmotionScore" />
    <button type="submit" class="btn-primary" style="width:100%; padding:16px; background:#1F2937;">Simpan Mood</button>
</form>
