@model LightenUp.Web.Models.ViewModels.TaskListViewModel
@using LightenUp.Web.Models.ViewModels
@{
    ViewData["Title"] = "Tugas Kamu";
    ViewBag.ActiveNav = "Tugas";

    var statusChips = new[]
    {
        ("Assigned",   "Belum Dikerjakan"),
        ("InProgress", "Sedang Dikerjakan"),
        ("Completed",  "Selesai")
    };
    var periodChips = new[]
    {
        ("HariIni",  "Hari Ini"),
        ("Mingguan", "Mingguan"),
        ("Bulanan",  "Bulanan"),
        ("Tahunan",  "Tahunan")
    };
}
@* #Bagian Daftar Tugas# *@

@section Head {
    <link rel="stylesheet" href="~/css/patient/tasks-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/tasks-detail-modal.css" asp-append-version="true" />
}

<div class="tasks-page">

@{
    var hasActivePsy = (bool)(ViewBag.HasActivePsychologist ?? false);
    var psyName = ViewBag.PsychologistName as string;
    var subEndDate = ViewBag.SubscriptionEndDate as DateTime?;
    var isSubExpired = (bool)(ViewBag.IsSubscriptionExpired ?? false);
    var tasksIsB2B = (bool)(ViewBag.IsB2B ?? false);
}
@* #Komponen Hero Tugas# *@
<div class="tasks-hero">
    <div class="tasks-hero-deco">📝</div>
    <div class="tasks-hero-inner">
        <h1 class="tasks-hero-title">
            <span class="tasks-hero-icon">✏️</span>
            Tugas Kamu
        </h1>
        @if (hasActivePsy)
        {
            <div class="tasks-psy-info-row">
                <span class="tasks-psy-info-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    @psyName
                </span>
                @if (subEndDate.HasValue && !isSubExpired)
                {
                    <span class="tasks-psy-info-divider">·</span>
                    <span class="tasks-psy-info-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Aktif s/d @subEndDate.Value.ToString("dd MMM yyyy")
                    </span>
                }
            </div>
            @if (isSubExpired)
            {
                <div class="tasks-expired-banner">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @if (tasksIsB2B)
                    {
                        <span>Akses tidak aktif. Hubungi HR perusahaan untuk memperbarui langganan. Kamu masih bisa melihat tugas yang sudah ada.</span>
                    }
                    else
                    {
                        <span>Masa aktif langganan habis. Kamu masih bisa melihat tugas yang sudah ada.</span>
                        <a asp-action="Index" asp-controller="Psychologists" asp-area="Patient" class="tasks-expired-btn">Pilih Psikolog Lagi →</a>
                    }
                </div>
            }
        }
        else
        {
            <p class="tasks-hero-sub">Tugas dari psikolog akan muncul di sini setelah kamu memilih psikolog.</p>
            <a asp-action="Index" asp-controller="Psychologists" asp-area="Patient" class="tasks-hero-btn">
                Beli Psikolog Dulu
            </a>
        }
    </div>
</div>

<div class="tasks-container">
    @if (TempData["success"] is string s)
    {
        <div class="tasks-success">
            ✔️ @s
        </div>
    }

    <form method="get" id="filterForm" class="tasks-filter-form">
        @* #Komponen Filter Tugas# *@
        <div class="tasks-toolbar">
            <label class="task-search tasks-search-label">
                <span class="icon">🔍</span>
                <input type="search" name="search" placeholder="Cari Tugas..." value="@Model.Search" class="tasks-search-input" />
            </label>
        </div>

        <div class="tasks-filter-row">
            <div>
                <p class="tasks-filter-group-label">Status Tugas</p>
                <div class="task-chips tasks-chips--flat">
                    @foreach (var c in statusChips)
                    {
                        var selected = Model.Statuses.Contains(c.Item1);
                        <label class="task-chip @(selected ? "selected" : "")">
                            <input type="checkbox" name="status" value="@c.Item1" checked="@selected" onchange="document.getElementById('filterForm').submit()" />
                            @c.Item2
                        </label>
                    }
                </div>
            </div>
            
            <div>
                <p class="tasks-filter-group-label">Tenggat Waktu</p>
                <div class="task-chips tasks-chips--flat">
                    @foreach (var c in periodChips)
                    {
                        var selected = Model.Periods.Contains(c.Item1);
                        <label class="task-chip @(selected ? "selected" : "")">
                            <input type="checkbox" name="period" value="@c.Item1" checked="@selected" onchange="document.getElementById('filterForm').submit()" />
                            @c.Item2
                        </label>
                    }
                </div>
            </div>
        </div>
    </form>

@if (!Model.Items.Any())
{
    <div class="dash-card-empty">
        <p>Tidak ada tugas yang cocok.</p>
    </div>
}
else
{
    @* #Komponen Daftar Kartu Tugas# *@
    <div class="custom-scroll tasks-list-scroll">
        @foreach (var t in Model.Items)
        {
            <a href="javascript:void(0)" class="task-card @WorksheetStatus.CssClass(t.Status)" onclick="openTaskModal(@t.WorksheetId)">
                <div>
                    <h4>@t.TaskName</h4>
                    <p class="desc">@t.Description</p>
                    <div class="meta">
                        <span>Status: <strong>@t.StatusLabel</strong></span>
                        <span class="tasks-meta-sep">• @t.PsychologistName</span>
                    </div>
                </div>
                <div class="right">
                    <span class="date-tag">@t.DateLabel</span>
                    <span class="badge-arrow">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </span>
                </div>
            </a>
        }
    </div>

    @if (Model.HasMore)
    {
        <div class="tasks-load-more">
            <a class="btn-pill ghost"
               asp-action="Index"
               asp-route-search="@Model.Search"
               asp-route-page="@(Model.Page + 1)"
               asp-route-status="@string.Join(",", Model.Statuses)"
               asp-route-period="@string.Join(",", Model.Periods)">
                Lihat Tugas Lainnya ›
            </a>
        </div>
    }
    }
</div>
</div>

@section Overlays {
@* #Komponen Modal Tugas# *@
<div class="hrpf-modal-overlay" id="taskModalOverlay">
    <div class="hrpf-modal tasks-modal" id="taskModalContainer">
        <!-- Modal content loaded via AJAX -->
    </div>
</div>
}

@section Scripts {
    <script>
        async function openTaskModal(id) {
            try {
                const res = await fetch(`/Patient/Tasks/DetailModal/${id}`);
                if (!res.ok) throw new Error('Network error');
                const html = await res.text();
                document.getElementById('taskModalContainer').innerHTML = html;
                const overlay = document.getElementById('taskModalOverlay');
                overlay.classList.add('is-open');
                document.body.classList.add('lu-scroll-lock');
                
                const scripts = document.getElementById('taskModalContainer').getElementsByTagName('script');
                for (let i = 0; i < scripts.length; i++) {
                    eval(scripts[i].innerText);
                }
            } catch (err) {
                console.error(err);
                alert("Gagal memuat detail tugas.");
            }
        }
        function closeTaskModal() {
            document.getElementById('taskModalOverlay').classList.remove('is-open');
            document.body.classList.remove('lu-scroll-lock');
        }
    </script>
}
