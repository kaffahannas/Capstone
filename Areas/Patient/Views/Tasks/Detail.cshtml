@model LightenUp.Web.Models.ViewModels.TaskDetailViewModel
@using LightenUp.Web.Models.ViewModels
@{
    ViewData["Title"] = Model.TaskName;
    ViewBag.ActiveNav = "Tugas";
    var indoDeadline = Model.Deadline.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("id-ID"));
}

<a asp-action="Index" class="tasks-back">← Tugas Kamu</a>

@if (TempData["error"] is string err)
{
    <div class="tasks-error">@err</div>
}

<div class="task-summary-card">
    <h2 class="task-summary-title">@Model.TaskName</h2>
    <p class="task-summary-desc">@Model.Description</p>
    <div class="task-summary-meta">
        Status: <strong class="@WorksheetStatus.CssClass(Model.Status)">@Model.StatusLabel</strong>
        &middot; Deadline: <strong>@indoDeadline</strong>
        &middot; Oleh: <strong>@Model.PsychologistName</strong>
    </div>
</div>

@if (Model.IsLocked)
{
    <div class="lu-card">
        <h3 class="lu-card-title">Foto Kegiatan</h3>
        @if (!string.IsNullOrEmpty(Model.ProofImagePath))
        {
            <img src="@Model.ProofImagePath" alt="Bukti" class="task-proof-img" />
        }
        else
        {
            <p class="task-empty-note">Tidak ada foto.</p>
        }

        <h3 class="lu-card-title task-section-title">Catatan Kamu</h3>
        <p>@(Model.Note ?? "—")</p>

        @if (!string.IsNullOrEmpty(Model.PsychologistFeedback))
        {
            <h3 class="lu-card-title task-section-title">Umpan Balik Psikolog</h3>
            <p>@Model.PsychologistFeedback</p>
        }
    </div>
}
else
{
    <form asp-action="Submit" method="post" enctype="multipart/form-data" class="task-submit-panel">
        <input type="hidden" name="WorksheetId" value="@Model.WorksheetId" />

        <h3>Upload Foto Kegiatanmu Disini!</h3>
        <label class="upload-dropzone" id="dropzone">
            <input type="file" name="Photo" accept="image/*" id="photoInput" />
            @if (!string.IsNullOrEmpty(Model.ProofImagePath))
            {
                <img src="@Model.ProofImagePath" alt="Foto" id="preview" />
                <p class="task-upload-hint">Klik untuk mengganti foto.</p>
            }
            else
            {
                <div class="placeholder" id="placeholder">
                    <div class="task-upload-icon">📷</div>
                    <p>Klik untuk memilih foto<br/><small>JPG, PNG, WEBP, GIF — max 20MB</small></p>
                </div>
                <img id="preview" class="task-preview-hidden" alt="Foto" />
            }
        </label>

        <h3 class="task-note-heading">Deskripsikan Perasaanmu</h3>
        <textarea name="Note" class="mood-textarea" placeholder="Ceritakan bagaimana perasaanmu setelah mengerjakan tugas ini...">@Model.Note</textarea>

        <div class="task-submit-actions">
            <button type="submit" class="btn-primary task-submit-btn">Simpan</button>
        </div>
    </form>
}

@section Scripts {
    <script>
        const input = document.getElementById('photoInput');
        const preview = document.getElementById('preview');
        const placeholder = document.getElementById('placeholder');
        if (input) {
            input.addEventListener('change', () => {
                const file = input.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    preview.classList.remove('task-preview-hidden');
                    if (placeholder) placeholder.style.display = 'none';
                };
                reader.readAsDataURL(file);
            });
        }
    </script>
}
