@{
    ViewData["Title"] = "Minta Jadwal Sesi";
    ViewBag.ActiveNav = "Jadwal";
    var psyName = ViewBag.PsychologistName as string ?? "Psikolog";
}
@* #Bagian Minta Jadwal Sesi# *@

@section Head {
    <link rel="stylesheet" href="~/css/patient/jadwal-request-session.css" asp-append-version="true" />
}

@* #Komponen Form Minta Jadwal# *@
<div class="jdw-req-wrap">
<div class="tasks-hero jdw-req-hero">
    <h1>
        <span class="jdw-req-hero-ico">📅</span>
        Minta Jadwal Sesi
    </h1>
    <p>Psikolog Anda: <strong>@psyName</strong></p>
</div>

<div class="jdw-req-card">
    <form asp-action="RequestSession" method="post">

        <div class="jdw-req-field">
            <label class="jdw-req-label">
                Usulan Tanggal &amp; Waktu Sesi <span class="jdw-req-required">*</span>
            </label>
            <input type="datetime-local" name="proposedDate"
                   min="@DateTime.Now.AddHours(2).ToString("yyyy-MM-ddTHH:mm")"
                   class="jdw-req-input"
                   required />
        </div>

        <div class="jdw-req-field jdw-req-field--notes">
            <label class="jdw-req-label">
                Catatan <small class="jdw-req-optional">(opsional)</small>
            </label>
            <textarea name="notes" rows="3"
                      class="jdw-req-textarea"
                      placeholder="Sampaikan topik yang ingin didiskusikan..."></textarea>
        </div>

        <div class="jdw-req-actions">
            <a asp-action="Index" class="jdw-req-cancel">
                Batal
            </a>
            <button type="submit" class="jdw-req-submit">
                Kirim Permintaan
            </button>
        </div>
    </form>
</div>
</div>
