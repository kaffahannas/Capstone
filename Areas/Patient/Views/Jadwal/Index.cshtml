@model LightenUp.Web.Models.ViewModels.JadwalViewModel
@{
    ViewData["Title"] = "Jadwal Konseling";
    ViewBag.ActiveNav = "Jadwal";
}
@* #Bagian Jadwal Konseling# *@

@section Head {
    <link rel="stylesheet" href="~/css/patient/jadwal-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/jadwal-request-session-modal.css" asp-append-version="true" />
}

<div class="jdw-page">

@* #Komponen Hero Jadwal# *@
<div class="jdw-hero">
    <div class="jdw-hero-deco">🗓️</div>
    <div class="jdw-hero-inner">
        <h1 class="jdw-hero-title">
            <span class="jdw-hero-icon">📅</span>
            Jadwal Konseling
        </h1>
        <p class="jdw-hero-sub">Lihat dan kelola jadwal sesi konselingmu dengan Psikolog.</p>
        @if (Model.HasActivePsychologist)
        {
            <button type="button" class="jdw-hero-btn" onclick="openRequestSessionModal()">
                + Minta Jadwal Sesi ke Psikolog
            </button>
        }
        else
        {
            <a asp-action="Index" asp-controller="Psychologists" asp-area="Patient" class="jdw-hero-btn jdw-hero-btn--muted">
                Cari Psikolog Dulu
            </a>
        }
    </div>
</div>

<div class="jdw-container">
    
    @* #Komponen Sesi Mendatang# *@
    <h3 class="jdw-section-title">
        <span class="jdw-section-ico">✨</span> Sesi Mendatang
    </h3>

    @if (!Model.UpcomingSessions.Any())
    {
        <div class="dash-card-empty jdw-empty jdw-empty--upcoming">
            <p class="jdw-empty-text">Belum ada jadwal sesi mendatang.</p>
        </div>
    }
    else
    {
        <div class="custom-scroll jdw-scroll--upcoming">
            @foreach (var s in Model.UpcomingSessions)
            {
                <div class="jdw-session-card">
                    <div class="jdw-session-left">
                        <div class="jdw-date-box">
                            <span class="jdw-date-month">@s.SessionStart.ToString("MMM")</span>
                            <span class="jdw-date-day">@s.SessionStart.ToString("dd")</span>
                        </div>
                        <div>
                            <h4 class="jdw-session-title">Sesi Konseling - @s.PsychologistName</h4>
                            <div class="jdw-session-meta">
                                <span class="jdw-meta-item">⏰ @s.SessionStart.ToString("HH:mm") WIB (@s.DurationMinutes menit)</span>
                                <span class="jdw-meta-item jdw-meta-status">🟢 @s.Status</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        @if (!string.IsNullOrEmpty(s.MeetingLink))
                        {
                            <a href="@s.MeetingLink" target="_blank" class="jdw-join-btn">Join Meeting</a>
                        }
                        else
                        {
                            <button disabled class="jdw-join-btn--disabled">Link Belum Tersedia</button>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @* #Komponen Riwayat Sesi# *@
    <h3 class="jdw-section-title jdw-section-title--past">
        Riwayat Sesi
    </h3>

    @if (!Model.PastSessions.Any())
    {
        <div class="dash-card-empty jdw-empty">
            <p class="jdw-empty-text">Belum ada riwayat sesi.</p>
        </div>
    }
    else
    {
        <div class="custom-scroll jdw-scroll--past">
            @foreach (var s in Model.PastSessions)
            {
                <div class="jdw-past-card">
                    <div>
                        <h4 class="jdw-past-title">Sesi Konseling - @s.PsychologistName</h4>
                        <p class="jdw-past-date">@s.SessionStart.ToString("dd MMM yyyy, HH:mm") WIB</p>
                    </div>
                    <span class="jdw-past-status">@s.Status</span>
                </div>
            }
        </div>
    }

</div>
</div>

@if (TempData["success"] is string okMsg)
{
    <div class="jdw-toast jdw-toast--success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        @okMsg
    </div>
}

@if (TempData["info"] is string infoMsg)
{
    <div class="jdw-toast jdw-toast--info">
        ℹ️ @infoMsg
    </div>
}

@if (Model.HasActivePsychologist)
{
    @await Html.PartialAsync("_RequestSessionModal")
}
