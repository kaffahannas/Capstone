@model LightenUp.Web.Models.ViewModels.JadwalViewModel
@{
    ViewData["Title"] = "Jadwal Konseling";
    ViewBag.ActiveNav = "Jadwal";
}
@* #Bagian Jadwal Konseling# *@

@section Head {
    <link rel="stylesheet" href="~/css/patient/jadwal-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient/jadwal-request-session-modal.css" asp-append-version="true" />
}

<div class="jdw-page">

@* #Komponen Hero Jadwal# *@
<div class="jdw-hero">
    <div class="jdw-hero-deco">🗓️</div>
    <div class="jdw-hero-inner">
        <h1 class="jdw-hero-title">
            <span class="jdw-hero-icon">📅</span>
            Jadwal Konseling
        </h1>

        @if (Model.HasActivePsychologist && Model.IsSubscriptionExpired)
        {
            <div class="jdw-psy-info-row">
                <span class="jdw-psy-info-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    @Model.PsychologistName
                </span>
            </div>
            <div class="jdw-expired-banner">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                @if (Model.IsB2B)
                {
                    <span>Akses tidak aktif. Hubungi HR perusahaan Anda untuk memperbarui langganan.</span>
                }
                else
                {
                    <span>Masa aktif langganan habis.</span>
                    <a asp-action="Index" asp-controller="Psychologists" asp-area="Patient" class="jdw-expired-btn">Pilih Psikolog Lagi →</a>
                }
            </div>
        }
        else if (Model.HasActivePsychologist)
        {
            <div class="jdw-psy-info-row">
                <span class="jdw-psy-info-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    @Model.PsychologistName
                </span>
                <span class="jdw-psy-info-divider">·</span>
                <span class="jdw-psy-info-item jdw-psy-info-item--quota @(Model.SessionsUsedThisMonth >= Model.MaxSessionsPerMonth ? "jdw-quota--full" : "")">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    @Model.SessionsUsedThisMonth/@Model.MaxSessionsPerMonth sesi bulan ini
                </span>
                @if (Model.SubscriptionEndDate.HasValue)
                {
                    <span class="jdw-psy-info-divider">·</span>
                    <span class="jdw-psy-info-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Aktif s/d @Model.SubscriptionEndDate.Value.ToString("dd MMM yyyy")
                    </span>
                }
            </div>
            @if (Model.SessionsUsedThisMonth >= Model.MaxSessionsPerMonth)
            {
                <div class="jdw-expired-banner jdw-expired-banner--token">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <span>Token sesi bulan ini sudah habis (@Model.SessionsUsedThisMonth/@Model.MaxSessionsPerMonth). Tersedia lagi bulan depan.</span>
                </div>
            }
            else
            {
                <button type="button" class="jdw-hero-btn" onclick="openRequestSessionModal()">
                    + Request Sesi Konseling
                </button>
            }
        }
        else
        {
            <p class="jdw-hero-sub">Anda belum memilih psikolog. Pilih psikolog untuk bisa request sesi konseling.</p>
            <a asp-action="Index" asp-controller="Psychologists" asp-area="Patient" class="jdw-hero-btn jdw-hero-btn--cta">
                Beli Psikolog Dulu
            </a>
        }
    </div>
</div>

<div class="jdw-container">
    
    @* #Komponen Sesi Mendatang# *@
    <h3 class="jdw-section-title">
        <span class="jdw-section-ico">✨</span> Sesi Mendatang
    </h3>

    @if (!Model.UpcomingSessions.Any())
    {
        <div class="dash-card-empty jdw-empty jdw-empty--upcoming">
            <p class="jdw-empty-text">Belum ada jadwal sesi mendatang.</p>
        </div>
    }
    else
    {
        <div class="custom-scroll jdw-scroll--upcoming">
            @foreach (var s in Model.UpcomingSessions)
            {
                <div class="jdw-session-card">
                    <div class="jdw-session-left">
                        <div class="jdw-date-box">
                            <span class="jdw-date-month">@s.SessionStart.ToString("MMM")</span>
                            <span class="jdw-date-day">@s.SessionStart.ToString("dd")</span>
                        </div>
                        <div>
                            <h4 class="jdw-session-title">Sesi Konseling - @s.PsychologistName</h4>
                            <div class="jdw-session-meta">
                                <span class="jdw-meta-item">⏰ @s.SessionStart.ToString("HH:mm") WIB (@s.DurationMinutes menit)</span>
                                <span class="jdw-meta-item jdw-meta-status">🟢 @s.Status</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        @if (!string.IsNullOrEmpty(s.MeetingLink))
                        {
                            <a href="@s.MeetingLink" target="_blank" class="jdw-join-btn">Join Meeting</a>
                        }
                        else
                        {
                            <button disabled class="jdw-join-btn--disabled">Link Belum Tersedia</button>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @* #Komponen Riwayat Sesi# *@
    <h3 class="jdw-section-title jdw-section-title--past">
        Riwayat Sesi
    </h3>

    @if (!Model.PastSessions.Any())
    {
        <div class="dash-card-empty jdw-empty">
            <p class="jdw-empty-text">Belum ada riwayat sesi.</p>
        </div>
    }
    else
    {
        <div class="custom-scroll jdw-scroll--past">
            @foreach (var s in Model.PastSessions)
            {
                <div class="jdw-past-card">
                    <div>
                        <h4 class="jdw-past-title">Sesi Konseling - @s.PsychologistName</h4>
                        <p class="jdw-past-date">@s.SessionStart.ToString("dd MMM yyyy, HH:mm") WIB</p>
                    </div>
                    <span class="jdw-past-status">@s.Status</span>
                </div>
            }
        </div>
    }

</div>
</div>

@if (TempData["success"] is string okMsg)
{
    <div class="jdw-toast jdw-toast--success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        @okMsg
    </div>
}

@if (TempData["info"] is string infoMsg)
{
    <div class="jdw-toast jdw-toast--info">
        ℹ️ @infoMsg
    </div>
}

@section Overlays {
@if (Model.HasActivePsychologist)
{
    @await Html.PartialAsync("_RequestSessionModal")
}
}
