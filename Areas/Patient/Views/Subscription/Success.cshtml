@{
    ViewData["Title"] = "Pembayaran berhasil";
    ViewBag.ActiveNav = "Langganan";
}
@* #Bagian Langganan - Berhasil# *@

@section Head {
    <link rel="stylesheet" href="~/css/patient/subscription-result.css" asp-append-version="true" />
}

<div class="lu-card sub-result-card">
    <div class="sub-result-icon">&#10003;</div>
    <h2>Pembayaran berhasil</h2>
    <p>Paket <strong>@ViewBag.PlanName</strong> Anda sudah aktif.</p>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary sub-result-action">Ke Beranda</a>
</div>
