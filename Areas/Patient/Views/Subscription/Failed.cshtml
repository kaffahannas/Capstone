@{
    ViewData["Title"] = "Pembayaran gagal";
    ViewBag.ActiveNav = "Langganan";
}

@section Head {
    <link rel="stylesheet" href="~/css/patient/subscription-result.css" asp-append-version="true" />
}

<div class="lu-card sub-result-card">
    <h2>Pembayaran belum selesai</h2>
    <p>Transaksi @ViewBag.OrderId tidak berhasil atau masih menunggu konfirmasi.</p>
    <a asp-action="Index" class="btn btn-primary sub-result-action">Coba lagi</a>
</div>
