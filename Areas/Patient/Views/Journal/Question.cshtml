@model LightenUp.Web.Models.ViewModels.JournalCheckInSessionViewModel
@using LightenUp.Web.Models.ViewModels
@{
    var q = CheckInQuestions.For(Model.Step);
    ViewData["Title"] = $"Pertanyaan {Model.Step}";
    ViewBag.Step = "";
    var current = Model.CurrentScore();
    var pct = (int)((double)Model.Step / 6 * 100);
}

<div style="font-size:13px; color:#6B7280; margin-bottom:6px;">Pertanyaan @Model.Step dari 6</div>
<div class="onb-progress" style="margin-bottom:16px;">
    <div class="onb-progress-bar" style="width:@(pct)%;"></div>
</div>

<div style="text-align:center; margin-bottom:24px;">
    <div style="font-size: 60px;">🧘</div>
</div>

<h2 class="mood-question" style="text-align:center;">@q.Question</h2>
<p class="mood-helper" style="text-align:center;">Pilihlah skala 1 hingga 5 yang paling menggambarkan kondisimu.</p>

<form asp-action="Question" method="post">
    @* Persist accumulated scores *@
    <input type="hidden" asp-for="Step" />
    <input type="hidden" asp-for="FocusScore" />
    <input type="hidden" asp-for="AnxietyScore" />
    <input type="hidden" asp-for="SleepScore" />
    <input type="hidden" asp-for="MindLoadScore" />
    <input type="hidden" asp-for="EmotionScore" />
    <input type="hidden" asp-for="OverallScore" />

    <div style="display:flex; justify-content:space-between; font-size:12px; color:#6B7280; margin-bottom:8px;">
        <span>Sangat Buruk</span>
        <span>Sangat Baik</span>
    </div>
    <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:8px; margin-bottom:24px;" id="scaleRow">
        @for (int n = 1; n <= 5; n++)
        {
            <button type="button" class="scale-btn @(current == n ? "selected" : "")" data-value="@n"
                    style="aspect-ratio:1; border:1.5px solid #E5E7EB; border-radius:10px; background:#fff; font-size:18px; cursor:pointer;">@n</button>
        }
    </div>
    <span asp-validation-summary="ModelOnly" class="text-danger"></span>

    <div class="mood-footer">
        @if (Model.Step > 1)
        {
            <button type="submit" class="btn-secondary" name="goBack" value="true" formaction="@Url.Action("Question", new {
                step = Model.Step - 1,
                FocusScore = Model.FocusScore,
                AnxietyScore = Model.AnxietyScore,
                SleepScore = Model.SleepScore,
                MindLoadScore = Model.MindLoadScore,
                EmotionScore = Model.EmotionScore,
                OverallScore = Model.OverallScore
            })" formmethod="get">Sebelumnya</button>
        }
        <button type="submit" class="btn-primary">Selanjutnya</button>
    </div>
</form>

@section Scripts {
    <script>
        // Map step number → field name on the hidden inputs
        const fieldByStep = {
            1: "FocusScore", 2: "AnxietyScore", 3: "SleepScore",
            4: "MindLoadScore", 5: "EmotionScore", 6: "OverallScore"
        };
        const step = @Model.Step;
        const fieldName = fieldByStep[step];

        document.querySelectorAll('.scale-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.scale-btn').forEach(b => {
                    b.classList.remove('selected');
                    b.style.background = '#fff';
                    b.style.color = '#111';
                    b.style.borderColor = '#E5E7EB';
                });
                btn.classList.add('selected');
                btn.style.background = '#7C3AED';
                btn.style.color = '#fff';
                btn.style.borderColor = '#7C3AED';
                document.querySelector('input[name="' + fieldName + '"]').value = btn.dataset.value;
            });
            // Initialize style for selected
            if (btn.classList.contains('selected')) {
                btn.style.background = '#7C3AED';
                btn.style.color = '#fff';
                btn.style.borderColor = '#7C3AED';
            }
        });
    </script>
}
