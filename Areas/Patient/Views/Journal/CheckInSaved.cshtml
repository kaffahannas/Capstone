@{
    ViewData["Title"] = "Tersimpan";
    ViewBag.Step = "";
}

<div style="text-align:center; padding: 40px 0;">
    <div style="width:80px; height:80px; margin:0 auto 24px; background:#7C3AED; border-radius:999px; display:grid; place-items:center; color:#fff; font-size:36px;">✓</div>
    <h2 class="mood-question">Data Berhasil Disimpan!</h2>
    <p class="mood-helper">Terima kasih telah mengisi.</p>
</div>

<div style="margin: 40px 0; padding: 32px; text-align:center; background:#FAF5FF; border-radius:16px;">
    <div style="font-size:48px; margin-bottom:12px;">📝</div>
    <h3 style="margin: 0 0 8px;">Lanjutkan ke sesi journaling?</h3>
    <p class="mood-helper">Tuliskan perasaanmu hari ini!</p>
</div>

<div class="mood-footer">
    <a href="/Patient/Dashboard" class="btn-secondary">Kembali</a>
    <a asp-action="Write" class="btn-primary">Selanjutnya</a>
</div>
