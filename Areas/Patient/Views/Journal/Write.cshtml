@model LightenUp.Web.Models.ViewModels.JournalWriteViewModel
@{
    ViewData["Title"] = "Tulis Jurnal";
    ViewBag.ActiveNav = "Beranda";
    Layout = "_LayoutPatient";
}
@* #Bagian Tulis Jurnal# *@

@section Head {
    <link rel="stylesheet" href="~/css/patient/journal-write.css" asp-append-version="true" />
}

@* #Komponen Form Tulis Jurnal# *@
<div class="lu-card jnl-write-card">
    <h2>@(Model.JournalId == null ? "Tulis Jurnal" : "Edit Jurnal")</h2>

    <form asp-action="Write" method="post">
        <input type="hidden" asp-for="JournalId" />
        <div asp-validation-summary="ModelOnly" class="text-danger jnl-write-validation"></div>

        <div class="jnl-write-field">
            <label asp-for="Title" class="jnl-write-label">Judul (opsional)</label>
            <input asp-for="Title" placeholder="Hari yang Penuh Produktivitas..."
                   class="jnl-write-input" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="jnl-write-field jnl-write-field--content">
            <label asp-for="Content" class="jnl-write-label">Tuliskan perasaanmu</label>
            <textarea asp-for="Content" rows="12" class="mood-textarea" placeholder="Mulai menulis..."></textarea>
            <span asp-validation-for="Content" class="text-danger"></span>
        </div>

        <div class="jnl-write-actions">
            <a href="/Patient/Dashboard" class="btn-secondary">Batal</a>
            <button type="submit" class="btn-primary">Simpan Jurnal</button>
        </div>
    </form>
</div>
