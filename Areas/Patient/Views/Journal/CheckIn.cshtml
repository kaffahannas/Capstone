@{
    ViewData["Title"] = "Daily Check-In";
    ViewBag.Step = "";
    ViewBag.IsCheckIn = true;
}
@* #Bagian Daily Check-In - Mulai# *@

@* #Komponen Intro Check-In# *@
<div class="jnl-ci-intro">
    <div class="jnl-ci-emoji">📷</div>
    <h2 class="mood-question">Yuk Cek Kondisi Harian Kamu Terlebih Dahulu!</h2>
    <p class="mood-helper">
        6 pertanyaan singkat untuk melacak fokus, kecemasan, tidur, beban pikiran, emosi, dan perasaan kamu hari ini.
    </p>
</div>

<form asp-action="CheckIn" method="post">
    <button type="submit" class="btn-primary jnl-ci-submit">Lanjutkan</button>
</form>
<a href="/Patient/Dashboard" class="btn-secondary jnl-ci-back">Kembali</a>
