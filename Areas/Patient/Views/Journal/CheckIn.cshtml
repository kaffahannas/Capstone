@{
    ViewData["Title"] = "Daily Check-In";
    ViewBag.Step = "";
}

<div style="text-align:center; padding: 24px 0;">
    <div style="font-size: 80px; margin-bottom: 16px;">📷</div>
    <h2 class="mood-question">Yuk Cek Kondisi Harian Kamu Terlebih Dahulu!</h2>
    <p class="mood-helper">
        6 pertanyaan singkat untuk melacak fokus, kecemasan, tidur, beban pikiran, emosi, dan perasaan kamu hari ini.
    </p>
</div>

<form asp-action="CheckIn" method="post">
    <button type="submit" class="btn-primary" style="width:100%; padding:14px; margin-bottom:10px;">Lanjutkan</button>
</form>
<a href="/Patient/Dashboard" class="btn-secondary" style="display:block; text-align:center; padding:14px;">Kembali</a>
