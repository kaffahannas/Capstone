@model LightenUp.Web.Models.ViewModels.PatientProfileEditViewModel
@{
    ViewData["Title"] = "Edit Profil";
    ViewBag.ActiveNav = "Profil";
    var photoSrc = string.IsNullOrEmpty(Model.CurrentProfilePicture)
        ? "/lib/bootstrap-icons/icons/person-circle.svg"
        : Model.CurrentProfilePicture;
}

@section Head {
    <link rel="stylesheet" href="~/css/patient/profile-edit.css" asp-append-version="true" />
}

<div class="pf-edit-page">
    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="pf-edit-form">

        <div class="pf-edit-header">
            <div class="pf-edit-header-left">
                <a asp-action="Index" class="pf-edit-back-btn">←</a>
                <div>
                    <h1 class="pf-edit-page-title">Edit Profil</h1>
                    <p class="pf-edit-page-sub">Perbarui informasi pribadi dan kontak darurat</p>
                </div>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="pf-edit-errors"></div>

        <div class="pf-edit-grid">

            <div class="pf-edit-sidebar">

                <div class="lu-card pf-edit-photo-card">
                    <div class="pf-edit-photo-preview-wrap pf-edit-photo-wrap-centered">
                        <img id="pfPhotoPreview" class="pf-edit-photo-preview" src="@photoSrc" alt="Foto profil" />
                        <label class="pf-edit-photo-change" title="Ganti foto">
                            📷
                            <input asp-for="ProfilePicture" type="file" accept="image/*" id="pfPhotoInput" class="pf-edit-upload-input" />
                        </label>
                    </div>
                    <p class="pf-edit-photo-hint">Klik ikon 📷 untuk mengganti foto profil</p>
                    <p class="pf-edit-photo-limit">Max 10 MB · JPG, PNG, WEBP</p>
                </div>

                @if (Model.IsAlreadyB2B)
                {
                    <div class="lu-card pf-edit-side-card">
                        <p class="pf-edit-side-label">Status Akun</p>
                        <div class="pf-edit-b2b-box">
                            <span class="pf-edit-b2b-ico">🏢</span>
                            <div>
                                <div class="pf-edit-b2b-sub">Terhubung ke</div>
                                <div class="pf-edit-b2b-name">@Model.CurrentCompanyName</div>
                            </div>
                        </div>
                        <p class="pf-edit-b2b-note">Divisi ditetapkan melalui kode referral dan tidak dapat diubah manual.</p>
                    </div>
                }
                else
                {
                    <div class="lu-card pf-edit-side-card">
                        <p class="pf-edit-side-label">Bergabung ke Perusahaan</p>
                        <div class="pf-field pf-edit-referral-field">
                            <label asp-for="ReferralCode" class="pf-label">Kode Referral <span class="pf-label-opt">(opsional)</span></label>
                            <input asp-for="ReferralCode" class="pf-input" placeholder="Kode dari HR perusahaan" />
                            <span asp-validation-for="ReferralCode" class="pf-field-error"></span>
                        </div>
                        <p class="pf-edit-referral-note">Masukkan kode dari HRD untuk mengaktifkan akun karyawan.</p>
                    </div>
                }

                <div class="lu-card pf-edit-tips-card">
                    <p class="pf-edit-tips-title">💡 Tips Profil Lengkap</p>
                    <ul class="pf-edit-tips-list">
                        <li>Isi kontak darurat agar tim bisa membantu saat dibutuhkan</li>
                        <li>Tanggal lahir membantu personalisasi program</li>
                        <li>Nomor telepon aktif untuk notifikasi jadwal</li>
                    </ul>
                </div>

            </div>

            <div class="pf-edit-main">

                <section class="lu-card pf-edit-panel pf-edit-panel--personal">
                    <header class="pf-edit-panel-head">
                        <span class="pf-edit-panel-ico" aria-hidden="true">👤</span>
                        <h2 class="pf-edit-panel-title">Data Diri &amp; Pekerjaan</h2>
                    </header>
                    <div class="pf-edit-panel-body">
                        <div class="pf-field pf-edit-field-mb">
                            <label asp-for="FullName" class="pf-label">Nama Lengkap</label>
                            <input asp-for="FullName" class="pf-input" placeholder="Nama lengkap sesuai identitas" />
                            <span asp-validation-for="FullName" class="pf-field-error"></span>
                        </div>
                        <div class="pf-edit-row-2">
                            <div class="pf-field pf-edit-field-none">
                                <label asp-for="Phone" class="pf-label">Nomor Telepon</label>
                                <input asp-for="Phone" class="pf-input" placeholder="+62 8xx xxxx xxxx" />
                            </div>
                            <div class="pf-field pf-edit-field-none">
                                <label asp-for="DateOfBirth" class="pf-label">Tanggal Lahir</label>
                                <input asp-for="DateOfBirth" type="date" class="pf-input" />
                            </div>
                        </div>
                        @if (Model.IsAlreadyB2B)
                        {
                            <div class="pf-edit-row-2 pf-edit-row-2--last">
                                <div class="pf-field pf-edit-field-none">
                                    <label asp-for="Gender" class="pf-label">Jenis Kelamin</label>
                                    <select asp-for="Gender" class="pf-select">
                                        <option value="">Pilih</option>
                                        <option value="Male">Laki-Laki</option>
                                        <option value="Female">Perempuan</option>
                                    </select>
                                </div>
                                <div class="pf-field pf-edit-field-none">
                                    <label asp-for="EmployeeId" class="pf-label">ID Karyawan</label>
                                    <input asp-for="EmployeeId" class="pf-input" placeholder="Nomor karyawan" />
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="pf-field pf-edit-field-none">
                                <label asp-for="Gender" class="pf-label">Jenis Kelamin</label>
                                <select asp-for="Gender" class="pf-select">
                                    <option value="">Pilih</option>
                                    <option value="Male">Laki-Laki</option>
                                    <option value="Female">Perempuan</option>
                                </select>
                            </div>
                        }
                        <p class="pf-edit-panel-note pf-edit-panel-note--info pf-edit-note-mt">
                            Data ini digunakan untuk personalisasi layanan dan program kesehatan mental Anda.
                        </p>
                    </div>
                </section>

                <section class="lu-card pf-edit-panel pf-edit-panel--emergency">
                    <header class="pf-edit-panel-head">
                        <span class="pf-edit-panel-ico" aria-hidden="true">🆘</span>
                        <h2 class="pf-edit-panel-title">Kontak Darurat</h2>
                    </header>
                    <div class="pf-edit-panel-body">
                        <div class="pf-edit-row-2">
                            <div class="pf-field pf-edit-field-none">
                                <label asp-for="EmergencyContactName" class="pf-label">Nama Kontak</label>
                                <input asp-for="EmergencyContactName" class="pf-input" placeholder="Nama lengkap" />
                            </div>
                            <div class="pf-field pf-edit-field-none">
                                <label asp-for="EmergencyContactRelation" class="pf-label">Hubungan</label>
                                <input asp-for="EmergencyContactRelation" class="pf-input" placeholder="Pasangan, Saudara, Ortu…" />
                            </div>
                        </div>
                        <div class="pf-edit-row-2 pf-edit-row-2--last">
                            <div class="pf-field pf-edit-field-none">
                                <label asp-for="EmergencyContactPhone" class="pf-label">Nomor Telepon</label>
                                <input asp-for="EmergencyContactPhone" class="pf-input" placeholder="+62 8xx xxxx xxxx" />
                            </div>
                            <div class="pf-field pf-edit-field-none">
                                <label asp-for="EmergencyContactEmail" class="pf-label">Email</label>
                                <input asp-for="EmergencyContactEmail" type="email" class="pf-input" placeholder="email@contoh.com" />
                                <span asp-validation-for="EmergencyContactEmail" class="pf-field-error"></span>
                            </div>
                        </div>
                        <p class="pf-edit-panel-note pf-edit-note-mt">
                            Orang yang dapat dihubungi saat Anda membutuhkan bantuan mendesak.
                        </p>
                    </div>
                </section>

                <div class="pf-edit-actions">
                    <a asp-action="Index" class="pf-btn pf-btn--outline">Batal</a>
                    <button type="submit" class="pf-btn pf-btn--primary">💾 Simpan Perubahan</button>
                </div>

            </div>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var input = document.getElementById('pfPhotoInput');
            var preview = document.getElementById('pfPhotoPreview');
            if (!input || !preview) return;
            input.addEventListener('change', function () {
                var file = input.files && input.files[0];
                if (!file) return;
                preview.src = URL.createObjectURL(file);
            });
        })();
    </script>
}
