@model LightenUp.Web.Models.ViewModels.PatientProfileViewModel
@{
    ViewData["Title"] = "Profil Saya";
    ViewBag.ActiveNav = "Profil";

    string mailto(string? email) => string.IsNullOrEmpty(email) ? "#" : $"mailto:{email}";
    string tel(string? phone)    => string.IsNullOrEmpty(phone)  ? "#" : $"tel:{phone}";
    string dash(string? v) => string.IsNullOrWhiteSpace(v) ? "—" : v!;
    var cid = new System.Globalization.CultureInfo("id-ID");

    var statusCss  = Model.MentalHealthStatus switch { "Sehat" => "sehat", "Beresiko" => "beresiko", _ => "bahaya" };
    var statusIcon = Model.MentalHealthStatus switch { "Sehat" => "✅", "Beresiko" => "⚠️", _ => "🚨" };
    var moodPct    = Model.TotalMoodPercent ?? 0;
    var genderLabel = Model.Gender switch { "Male" => "Laki-Laki", "Female" => "Perempuan", _ => dash(Model.Gender) };
    var dobLabel = Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("d MMMM yyyy", cid) : "—";
    var ageLabel = Model.DateOfBirth.HasValue
        ? $"{(int)((DateTime.Today - Model.DateOfBirth.Value.Date).TotalDays / 365.25)} tahun"
        : null;
    var profileItems = new (string Label, bool Done)[] {
        ("Nomor Telepon",  !string.IsNullOrEmpty(Model.Phone)),
        ("Kontak Darurat", !string.IsNullOrEmpty(Model.EmergencyContactName)),
        ("Tanggal Lahir",  Model.DateOfBirth.HasValue),
        ("Jenis Kelamin",  !string.IsNullOrEmpty(Model.Gender)),
    };
    var doneCount = profileItems.Count(x => x.Done);
    var pct = (int)Math.Round(doneCount * 100.0 / profileItems.Length);
    var tipIcon = Model.MentalHealthStatus switch { "Sehat" => "🌟", "Beresiko" => "💛", _ => "🆘" };
    var tipMsg = Model.MentalHealthStatus switch {
        "Sehat"    => "Mood kamu terjaga dengan baik. Lanjutkan kebiasaan positifmu!",
        "Beresiko" => "Skor mood perlu diperhatikan. Coba journaling atau meditasi singkat.",
        _          => "Kondisi mentalmu butuh perhatian segera. Hubungi psikolog kamu."
    };
}

@section Head {
    <link rel="stylesheet" href="~/css/patient/profile-index.css" asp-append-version="true" />
}

<div class="pf-page">

    @if (TempData["success"] is string ok)
    {
        <div class="lu-alert-success pf-alert" role="status">@ok</div>
    }

    <div class="pf-layout">

        <aside class="pf-aside" aria-label="Profil pengguna">

            <div class="pf-profile-card">
                <div class="pf-profile-card-inner">
                    <div class="pf-avatar-wrap">
                        @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                        {
                            <img class="pf-avatar" src="@Model.ProfilePicture" alt="Foto profil @Model.FullName" />
                        }
                        else
                        {
                            <div class="pf-avatar-placeholder">
                                @(Model.FullName?.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "?")
                            </div>
                        }
                    </div>
                    <h1 class="pf-name">@Model.FullName</h1>
                    <span class="pf-status pf-status--@statusCss">@statusIcon @Model.MentalHealthStatus</span>
                    @if (!string.IsNullOrEmpty(Model.CompanyName))
                    {
                        <span class="pf-company-tag">🏢 @Model.CompanyName</span>
                    }
                </div>
            </div>

            <div class="lu-card pf-complete-card">
                <p class="pf-complete-head">
                    <span>📋 Kelengkapan Profil</span>
                    <span class="pf-complete-pct">@pct%</span>
                </p>
                <div class="pf-complete-track">
                    <div class="pf-complete-fill" style="--bar-w:@pct%;"></div>
                </div>
                <div class="pf-complete-list">
                    @foreach (var item in profileItems)
                    {
                        <div class="pf-complete-item @(item.Done ? "is-done" : "")">
                            <span class="pf-complete-dot">
                                @if (item.Done) { <span class="pf-complete-check">✓</span> }
                            </span>
                            @item.Label
                        </div>
                    }
                </div>
                @if (pct < 100)
                {
                    <a asp-action="Edit" class="pf-complete-link">✏️ Lengkapi Sekarang →</a>
                }
            </div>

            <section class="pf-help lu-card" aria-label="Bantuan darurat">
                <p class="pf-help-title">🆘 Butuh Bantuan?</p>
                <div class="pf-help-links">
                    <a class="pf-help-link pf-help-link--purple @(string.IsNullOrEmpty(Model.EmergencyContactEmail) && string.IsNullOrEmpty(Model.EmergencyContactPhone) ? "is-disabled" : "")"
                       href="@(!string.IsNullOrEmpty(Model.EmergencyContactEmail) ? mailto(Model.EmergencyContactEmail) : tel(Model.EmergencyContactPhone))">
                        <span aria-hidden="true">🤝</span>
                        <span>
                            @if (!string.IsNullOrEmpty(Model.EmergencyContactName))
                            { @Model.EmergencyContactName }
                            else
                            { <text>Orang Terdekat</text> }
                        </span>
                    </a>
                    @if (!string.IsNullOrEmpty(Model.CompanyHrEmail))
                    {
                        <a class="pf-help-link pf-help-link--blue" href="@mailto(Model.CompanyHrEmail)">
                            <span aria-hidden="true">🏢</span> <span>Kontak HRD</span>
                        </a>
                    }
                    <a class="pf-help-link pf-help-link--green @(string.IsNullOrEmpty(Model.PsychologistEmail) ? "is-disabled" : "")"
                       href="@mailto(Model.PsychologistEmail)">
                        <span aria-hidden="true">💼</span>
                        <span>
                            @if (!string.IsNullOrEmpty(Model.PsychologistName))
                            { @Model.PsychologistName }
                            else
                            { <text>Psikolog</text> }
                        </span>
                    </a>
                </div>
            </section>
        </aside>

        <div class="pf-profile-main">

            <div class="pf-kpi-grid">
                <div class="lu-card pf-kpi-card">
                    <div class="pf-kpi-value pf-kpi-value--primary">
                        @(Model.TotalMoodPercent.HasValue ? $"{Model.TotalMoodPercent}%" : "—")
                    </div>
                    <div class="pf-kpi-label">Skor Mood</div>
                    <div class="pf-mood-track">
                        <div class="pf-mood-fill pf-mood-fill--@statusCss" style="--bar-w:@moodPct%;"></div>
                    </div>
                </div>
                <div class="lu-card pf-kpi-card">
                    <div class="pf-kpi-value pf-kpi-value--amber">@Model.MoodStreakDays 🔥</div>
                    <div class="pf-kpi-label">Hari Beruntun</div>
                    <div class="pf-kpi-sub">check-in mood</div>
                </div>
                <div class="lu-card pf-kpi-card">
                    <div class="pf-kpi-value pf-kpi-value--purple">@Model.TotalSessionsDone</div>
                    <div class="pf-kpi-label">Sesi Selesai</div>
                    @if (Model.NextSessionAt.HasValue)
                    {
                        <div class="pf-kpi-sub pf-kpi-sub--purple">
                            Berikutnya: @Model.NextSessionAt.Value.ToString("d MMM · HH:mm", cid)
                        </div>
                    }
                    else
                    {
                        <div class="pf-kpi-sub">konseling</div>
                    }
                </div>
                <div class="lu-card pf-kpi-card">
                    <div class="pf-kpi-value pf-kpi-value--green">@Model.TotalTasksDone</div>
                    <div class="pf-kpi-label">Tugas Selesai</div>
                    <div class="pf-kpi-sub">dari psikolog</div>
                </div>
            </div>

            <div class="pf-row2-grid">
                <div class="lu-card pf-mental-card">
                    <div class="pf-mental-ico">🧠</div>
                    <div class="pf-mental-body">
                        <div class="pf-mental-label">Status Kesehatan Mental</div>
                        <div class="pf-mental-value pf-mental-value--@statusCss">
                            @statusIcon @Model.MentalHealthStatus
                        </div>
                        <div class="pf-mental-checkin">Check-in terakhir: <strong>@Model.LastCheckLabel</strong></div>
                        @if (Model.NextSessionAt.HasValue)
                        {
                            <div class="pf-session-badge">
                                🗓 Konseling @Model.NextSessionAt.Value.ToString("d MMM yyyy · HH:mm", cid)
                            </div>
                        }
                        else if (Model.LastSessionAt.HasValue)
                        {
                            <div class="pf-last-session">
                                Sesi terakhir: @Model.LastSessionAt.Value.ToString("d MMM yyyy", cid)
                            </div>
                        }
                    </div>
                </div>
                <div class="pf-tip-card pf-tip-card--@statusCss pf-tip-row">
                    <div class="pf-tip-ico-lg">@tipIcon</div>
                    <div>
                        <p class="pf-tip-title">
                            @(Model.MentalHealthStatus switch { "Sehat" => "Pertahankan!", "Beresiko" => "Butuh perhatian lebih", _ => "Segera cari dukungan" })
                        </p>
                        <p class="pf-tip-msg">@tipMsg</p>
                        @if (Model.MentalHealthStatus != "Sehat")
                        {
                            <a asp-controller="Jadwal" asp-action="Index" class="pf-tip-link">
                                📅 Lihat Jadwal Konseling →
                            </a>
                        }
                    </div>
                </div>
            </div>

            <section class="lu-card pf-detail-card" aria-label="Informasi profil">
                <header class="pf-detail-head">
                    <div class="pf-detail-title-wrap">
                        <span class="pf-detail-ico" aria-hidden="true">📋</span>
                        <h2 class="pf-detail-title">Informasi Profil</h2>
                    </div>
                    <a asp-action="Edit" class="pf-detail-edit">Ubah Semua</a>
                </header>

                <div class="pf-detail-split">
                    <div class="pf-detail-section">
                        <h3 class="pf-detail-subtitle"><span aria-hidden="true">👤</span> Data Diri &amp; Pekerjaan</h3>
                        <dl class="pf-info-grid pf-info-grid--dense">
                            <div class="pf-info-item">
                                <dt>Email</dt>
                                <dd><a href="mailto:@Model.Email" class="pf-info-link">@dash(Model.Email)</a></dd>
                            </div>
                            <div class="pf-info-item">
                                <dt>Telepon</dt>
                                <dd>
                                    @if (!string.IsNullOrEmpty(Model.Phone))
                                    { <a href="tel:@Model.Phone" class="pf-info-link">@Model.Phone</a> }
                                    else
                                    { <span class="pf-muted-dash">—</span> }
                                </dd>
                            </div>
                            <div class="pf-info-item">
                                <dt>Tanggal Lahir</dt>
                                <dd>
                                    @dobLabel
                                    @if (ageLabel != null)
                                    { <span class="pf-info-sub">(@ageLabel)</span> }
                                </dd>
                            </div>
                            <div class="pf-info-item">
                                <dt>Jenis Kelamin</dt>
                                <dd>@genderLabel</dd>
                            </div>
                            @if (Model.IsB2B)
                            {
                                <div class="pf-info-item pf-info-item--full">
                                    <dt>Perusahaan</dt>
                                    <dd><span class="pf-info-badge">🏢 @dash(Model.CompanyName)</span></dd>
                                </div>
                                <div class="pf-info-item">
                                    <dt>Divisi</dt>
                                    <dd>@dash(Model.Department)</dd>
                                </div>
                                <div class="pf-info-item">
                                    <dt>ID Karyawan</dt>
                                    <dd>@dash(Model.EmployeeId)</dd>
                                </div>
                            }
                            else
                            {
                                <div class="pf-info-item pf-info-item--full">
                                    <dt>Tipe Akun</dt>
                                    <dd><span class="pf-info-badge pf-info-badge--muted">🌐 Pengguna Publik</span></dd>
                                </div>
                            }
                        </dl>
                    </div>

                    <div class="pf-detail-section pf-detail-section--emergency">
                        <h3 class="pf-detail-subtitle"><span aria-hidden="true">🆘</span> Kontak Darurat</h3>
                        <dl class="pf-info-grid pf-info-grid--dense">
                            <div class="pf-info-item">
                                <dt>Nama</dt>
                                <dd>@dash(Model.EmergencyContactName)</dd>
                            </div>
                            <div class="pf-info-item">
                                <dt>Hubungan</dt>
                                <dd>@dash(Model.EmergencyContactRelation)</dd>
                            </div>
                            <div class="pf-info-item">
                                <dt>Telepon</dt>
                                <dd>
                                    @if (!string.IsNullOrEmpty(Model.EmergencyContactPhone))
                                    { <a href="tel:@Model.EmergencyContactPhone" class="pf-info-link">@Model.EmergencyContactPhone</a> }
                                    else
                                    { <text>—</text> }
                                </dd>
                            </div>
                            <div class="pf-info-item">
                                <dt>Email</dt>
                                <dd>
                                    @if (!string.IsNullOrEmpty(Model.EmergencyContactEmail))
                                    { <a href="mailto:@Model.EmergencyContactEmail" class="pf-info-link">@Model.EmergencyContactEmail</a> }
                                    else
                                    { <text>—</text> }
                                </dd>
                            </div>
                        </dl>
                        @if (!string.IsNullOrEmpty(Model.PsychologistName) || !string.IsNullOrEmpty(Model.PsychologistEmail))
                        {
                            <div class="pf-psy-box">
                                <div class="pf-psy-box-label">Psikolog Anda</div>
                                <div class="pf-psy-box-name">@dash(Model.PsychologistName)</div>
                                @if (!string.IsNullOrEmpty(Model.PsychologistEmail))
                                {
                                    <a href="mailto:@Model.PsychologistEmail" class="pf-info-link pf-psy-box-email">@Model.PsychologistEmail</a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </section>

            <section class="lu-card pf-quick-section" aria-label="Akses cepat">
                <h3 class="pf-quick-title">⚡ Akses Cepat</h3>
                <div class="pf-quick-grid">

                    <button type="button" class="pf-quick-card pf-quick-card--mood" onclick="openMoodModal()">
                        <span class="pf-quick-ico">😊</span>
                        <div class="pf-quick-label">Lacak Mood & Check-In</div>
                        <div class="pf-quick-sub">Catat perasaan harianmu</div>
                    </button>

                    <a asp-controller="Jadwal" asp-action="Index" class="pf-quick-card pf-quick-card--jadwal">
                        <span class="pf-quick-ico">📅</span>
                        <div class="pf-quick-label">Jadwal Konseling</div>
                        <div class="pf-quick-sub">Lihat sesi mendatang</div>
                    </a>

                    <a asp-action="Edit" class="pf-quick-card pf-quick-card--edit">
                        <span class="pf-quick-ico">✏️</span>
                        <div class="pf-quick-label">Edit Profil</div>
                        <div class="pf-quick-sub">Perbarui data & kontak</div>
                    </a>

                    <a href="/Account/ChangePassword" class="pf-quick-card pf-quick-card--security">
                        <span class="pf-quick-ico">🔒</span>
                        <div class="pf-quick-label">Pengaturan Keamanan</div>
                        <div class="pf-quick-sub">Atur atau ubah password</div>
                    </a>
                </div>
            </section>

        </div>

    </div>
</div>

<!-- Mood Tracker Modal (same as Beranda) -->
<div class="hrpf-modal-overlay" id="moodModal" role="dialog" aria-modal="true" aria-labelledby="moodModalTitle">
    <div class="hrpf-modal db-modal--mood">
        <div class="hrpf-modal-head">
            <div class="hrpf-modal-head-icon">😊</div>
            <h2 class="hrpf-modal-title" id="moodModalTitle">Lacak Mood</h2>
            <button type="button" class="hrpf-modal-close" onclick="closeMoodModal()" aria-label="Tutup">&times;</button>
        </div>
        <div class="hrpf-modal-body db-modal-body--iframe">
            <iframe id="moodIframe" src="" class="db-mood-iframe" title="Lacak Mood"></iframe>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/shared/animate-bars.js" asp-append-version="true"></script>
    <script src="~/js/patient/mood-modal.js" asp-append-version="true"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        animateBarFills('.pf-complete-fill, .pf-mood-fill');
    });
    </script>
}
