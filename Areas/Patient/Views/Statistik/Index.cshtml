@model LightenUp.Web.Models.ViewModels.PatientStatistikViewModel
@{
    ViewData["Title"] = "Statistik";
    ViewBag.ActiveNav = "Statistik";

    var trendLabels   = string.Join(",", Model.MoodTrend.Select(p => $"\"{p.Date:dd/MM}\""));
    var trendData     = string.Join(",", Model.MoodTrend.Select(p => p.Score.ToString(System.Globalization.CultureInfo.InvariantCulture)));
    var triggerLabels = string.Join(",", Model.TopTriggers.Select(t => $"\"{System.Web.HttpUtility.JavaScriptStringEncode(t.Label)}\""));
    var triggerData   = string.Join(",", Model.TopTriggers.Select(t => t.Count));
}

@section Head {
    <link rel="stylesheet" href="~/css/patient/statistik-index.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}

<!-- st-layout fills the exact remaining viewport height; charts flex to fill it -->
<div class="st-layout">

<!-- ─── Top bar: KPI chips + period selector ─── -->
<div class="st-topbar">
    <div class="st-kpi-strip">
        <div class="st-chip st-chip--fire">
            <span>🔥</span>
            <div><strong>@Model.Engagement.CurrentStreak</strong><small>streak</small></div>
        </div>
        <div class="st-chip st-chip--purple">
            <span>📅</span>
            <div><strong>@Model.Engagement.TotalDaysTracked</strong><small>hari</small></div>
        </div>
        <div class="st-chip st-chip--gold">
            <span>🏆</span>
            <div><strong>@Model.Engagement.LongestStreak</strong><small>terpanjang</small></div>
        </div>
    </div>
    <div class="st-period-tabs">
        @foreach (var w in new[] { 7, 30, 90 })
        {
            <a class="st-tab @(Model.Window == w ? "st-tab--active" : "")"
               asp-action="Index" asp-route-window="@w">@w hari</a>
        }
    </div>
</div>

<!-- ─── Mood trend (full width) ─── -->
<div class="lu-card st-card st-card--trend">
    <div class="st-card-head">
        <span class="st-card-title">📈 Tren Mood</span>
        <span class="st-badge">@Model.Window hari terakhir</span>
    </div>
    @if (!Model.MoodTrend.Any())
    {
        <div class="st-empty">
            <span>📊</span>
            <p>Belum ada data mood. Mulai melacak untuk melihat tren.</p>
            <a class="btn-pill" asp-area="Patient" asp-controller="Mood" asp-action="Feeling">+ Lacak Mood</a>
        </div>
    }
    else
    {
        <div class="st-canvas-wrap st-canvas--trend"><canvas id="moodTrendChart"></canvas></div>
    }
</div>

<!-- ─── Radar + Triggers side-by-side ─── -->
<div class="st-row2">
    <div class="lu-card st-card">
        <div class="st-card-head">
            <span class="st-card-title">🕸️ Check-In Radar</span>
        </div>
        @if (!Model.HasRadarData)
        {
            <div class="st-empty">
                <span>🕸️</span>
                <p>Belum ada check-in dalam @Model.Window hari terakhir.</p>
                <a class="btn-pill" asp-area="Patient" asp-controller="Mood" asp-action="Feeling">+ Daily Check</a>
            </div>
        }
        else
        {
            <div class="st-canvas-wrap st-canvas--square"><canvas id="radarChart"></canvas></div>
        }
    </div>

    <div class="lu-card st-card">
        <div class="st-card-head">
            <span class="st-card-title">🎯 Pemicu Teratas</span>
            @if (Model.TopTriggers.Any())
            {
                <span class="st-badge">@Model.MoodEntriesWithTriggers dari @Model.MoodEntryCount entri mood</span>
            }
        </div>
        @if (!Model.TopTriggers.Any())
        {
            <div class="st-empty">
                <span>🎯</span>
                <p>Belum ada pemicu tercatat dalam @Model.Window hari terakhir.</p>
            </div>
        }
        else
        {
            <p class="st-trigger-hint">Menghitung pemicu utama per sesi (total @Model.MoodEntriesWithTriggers dari @Model.MoodEntryCount lacak mood).</p>
            <div class="st-canvas-wrap st-canvas--square"><canvas id="triggersChart"></canvas></div>
        }
    </div>
</div><!-- st-row2 -->

</div><!-- st-layout -->

@section Scripts {
<script>
    const C_PURPLE = '#7C3AED';
    const C_SOFT   = 'rgba(124,58,237,0.12)';
    const C_GRID   = 'rgba(0,0,0,0.06)';

    Chart.defaults.font.family = "'Inter',sans-serif";
    Chart.defaults.font.size   = 11;
    Chart.defaults.color       = '#6B7280';

    @if (Model.MoodTrend.Any())
    {
        <text>
    new Chart(document.getElementById('moodTrendChart'), {
        type: 'line',
        data: {
            labels: [@Html.Raw(trendLabels)],
            datasets: [{
                data: [@Html.Raw(trendData)],
                borderColor: C_PURPLE, backgroundColor: C_SOFT,
                fill: true, tension: 0.4,
                pointRadius: 4, pointBackgroundColor: '#fff',
                pointBorderColor: C_PURPLE, pointBorderWidth: 2, borderWidth: 2.5
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { callbacks: {
                label: ctx => [,'😠 Marah','😔 Kecewa','😐 Netral','😊 Senang','🤩 Gembira'][ctx.parsed.y] || ctx.parsed.y
            }}},
            scales: {
                x: { grid: { color: C_GRID }, ticks: { maxTicksLimit: 12 } },
                y: { min: 0, max: 5, ticks: { stepSize: 1,
                    callback: v => [,'😠','😔','😐','😊','🤩'][v] || '' },
                    grid: { color: C_GRID } }
            }
        }
    });
        </text>
    }

    @if (Model.HasRadarData)
    {
        <text>
    new Chart(document.getElementById('radarChart'), {
        type: 'radar',
        data: {
            labels: ['Fokus','Cemas','Tidur','Beban','Emosi','Overall'],
            datasets: [{
                data: [
                    @Model.Radar.Focus.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    @Model.Radar.Anxiety.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    @Model.Radar.Sleep.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    @Model.Radar.MindLoad.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    @Model.Radar.Emotion.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    @Model.Radar.Overall.ToString(System.Globalization.CultureInfo.InvariantCulture)
                ],
                backgroundColor: C_SOFT, borderColor: C_PURPLE,
                pointBackgroundColor: C_PURPLE, pointRadius: 3, borderWidth: 2
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { r: { min: 0, max: 5,
                ticks: { stepSize: 1, backdropColor: 'transparent', font: { size: 9 } },
                grid: { color: C_GRID },
                pointLabels: { font: { size: 10 } }
            }}
        }
    });
        </text>
    }

    @if (Model.TopTriggers.Any())
    {
        <text>
    new Chart(document.getElementById('triggersChart'), {
        type: 'bar',
        data: {
            labels: [@Html.Raw(triggerLabels)],
            datasets: [{ data: [@Html.Raw(triggerData)],
                backgroundColor: C_PURPLE, borderRadius: 5, borderSkipped: false }]
        },
        options: {
            indexAxis: 'y', responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: {
                    beginAtZero: true,
                    max: @(Math.Max(Model.MoodEntriesWithTriggers, 1)),
                    ticks: { stepSize: 1, precision: 0 },
                    grid: { color: C_GRID }
                },
                y: { grid: { display: false }, ticks: { font: { size: 10 } } }
            }
        }
    });
        </text>
    }
</script>
}
